---
import "../styles/globals.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { WORKER_URL } from "../data/site-config";

interface Props {
  title?: string;
  description?: string;
  /** Add subtle PHDc-green tint to body (used by home page) */
  tint?: boolean;
}

const {
  title = "AsPEN — Asian Pharmacoepidemiology Network",
  description = "A Special Interest Group of ISPE advancing multi-national database research in pharmacoepidemiology across the Asia/Pacific region.",
  tint = false,
} = Astro.props;

const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" sizes="100x100" href={`${base}images/AsPenLogo-100.png`} />
    <link rel="icon" type="image/png" href={`${base}images/AsPenLogo.png`} />
    <title>{title}</title>
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${base}images/AsPenLogo.png`} />
    <meta property="og:type" content="website" />
    <script is:inline define:vars={{ WORKER_URL }}>
      // Expose the auth worker URL globally so the Header (and any other
      // page-level script) can call /api/me to detect a member session.
      window.__ASPEN_WORKER_URL__ = WORKER_URL || "";
    </script>
  </head>
  <body class:list={["text-slate-800 antialiased", tint ? "home-tint" : "bg-white"]}>
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 bg-brand-600 text-white px-3 py-2 rounded">Skip to content</a>
    <Header />
    <main id="main" class="min-h-[60vh]">
      <slot />
    </main>
    <Footer pageTitle={title} />
  </body>
</html>
