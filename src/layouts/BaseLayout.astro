---
import "../styles/globals.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { WORKER_URL } from "../data/site-config";

interface Props {
  title?: string;
  description?: string;
  /** Add subtle PHDc-green tint to body (used by home page) */
  tint?: boolean;
}

const {
  title = "AsPEN; Asian Pharmacoepidemiology Network",
  description = "A Special Interest Group of ISPE advancing multi-national database research in pharmacoepidemiology across the Asia/Pacific region.",
  tint = false,
} = Astro.props;

// Normalise base so `${base}/path` always produces a single slash regardless
// of whether BASE_URL ends with one (apex build → '/', GH Pages → '/AsPEN').
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// Canonical URL always points at the primary public domain, so the GitHub
// Pages mirror (phd-center.github.io/AsPEN) defers to aspensig.asia instead
// of competing with it for ranking. Strip the /AsPEN base from the path.
const PRIMARY_ORIGIN = "https://www.aspensig.asia";
const canonicalPath = Astro.url.pathname.replace(/^\/AsPEN(?=\/|$)/, "") || "/";
const canonical = `${PRIMARY_ORIGIN}${canonicalPath}`;
const ogImage = `${PRIMARY_ORIGIN}/images/AsPenLogo.png`;

// JSON-LD Organization markup helps search engines recognise AsPEN as an
// entity (knowledge-panel eligible) and link its official profiles.
const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Asian Pharmacoepidemiology Network",
  alternateName: "AsPEN",
  url: PRIMARY_ORIGIN,
  logo: ogImage,
  description:
    "A Special Interest Group of ISPE advancing multi-national database research in pharmacoepidemiology across the Asia/Pacific region.",
  sameAs: ["https://www.pharmacoepi.org/communities/sigs/aspen/"],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" sizes="100x100" href={`${base}/images/AsPenLogo-100.png`} />
    <link rel="icon" type="image/png" href={`${base}/images/AsPenLogo.png`} />
    <title>{title}</title>
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Asian Pharmacoepidemiology Network" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} is:inline />
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />
    <script is:inline define:vars={{ WORKER_URL }}>
      // Expose the auth worker URL globally so the Header (and any other
      // page-level script) can call /api/me to detect a member session.
      window.__ASPEN_WORKER_URL__ = WORKER_URL || "";

      // ── Bearer-token fallback for browsers that block 3p cookies ──
      // The worker sets a SameSite=None+Secure cookie, which iOS Safari
      // and other 3p-cookie-blocking browsers refuse to send back. To
      // keep mobile login working without putting the worker on the
      // same registrable domain, the worker ALSO returns the JWT in
      // two places:
      //   1. magic-link verify   → 302 Location: /members/#t=<jwt>
      //   2. password login JSON → { ok: true, token: <jwt> }
      // The site grabs whichever it sees, stashes it in localStorage,
      // and sends it as `Authorization: Bearer <jwt>` on every call
      // to the worker.
      (function () {
        var KEY = "aspen.session.token";
        var WORKER = WORKER_URL || "";

        // (1) On every page load, if the URL fragment carries #t=<jwt>
        //     left by the magic-link verify redirect, peel it off, save
        //     it in localStorage, and strip the fragment without
        //     adding a history entry.
        try {
          var h = window.location.hash || "";
          if (h.indexOf("#t=") === 0) {
            var t = decodeURIComponent(h.slice(3));
            if (t) {
              try { localStorage.setItem(KEY, t); } catch (e) {}
              try {
                history.replaceState(null, "",
                  window.location.pathname + window.location.search);
              } catch (e) {}
            }
          }
        } catch (e) {}

        // (2) Monkey-patch fetch so any call to the worker carries
        //     Authorization: Bearer <jwt> (if we have one) in addition
        //     to credentials:include. Both paths validate the same
        //     server-side, so whichever the browser allows wins.
        if (WORKER && typeof window.fetch === "function") {
          var nativeFetch = window.fetch.bind(window);
          window.fetch = function (input, init) {
            var url = typeof input === "string"
              ? input
              : (input && input.url) || "";
            if (url.indexOf(WORKER) === 0) {
              var token = "";
              try { token = localStorage.getItem(KEY) || ""; } catch (e) {}
              if (token) {
                init = init || {};
                var hdrs = new Headers(init.headers || {});
                if (!hdrs.has("Authorization")) {
                  hdrs.set("Authorization", "Bearer " + token);
                }
                init.headers = hdrs;
              }
            }
            return nativeFetch(input, init);
          };
        }

        // Expose a tiny helper so login.astro and logout handlers can
        // sync localStorage with the cookie/JSON token flow.
        window.__aspenAuth = {
          setToken: function (t) {
            try { if (t) localStorage.setItem(KEY, t); } catch (e) {}
          },
          clearToken: function () {
            try { localStorage.removeItem(KEY); } catch (e) {}
          },
        };
      })();
    </script>
  </head>
  <body class:list={["text-slate-800 antialiased", tint ? "home-tint" : "bg-white"]}>
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 bg-brand-600 text-white px-3 py-2 rounded">Skip to content</a>
    <Header />
    <main id="main" class="min-h-[60vh]">
      <slot />
    </main>
    <Footer pageTitle={title} />
  </body>
</html>
