---
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const nav = [
  { href: `${base}/`, label: "Home" },
  { href: `${base}/about/`, label: "About" },
  { href: `${base}/databases/`, label: "Databases" },
  { href: `${base}/activities/`, label: "Activities" },
  { href: `${base}/publications/`, label: "Publications" },
  { href: `${base}/history/`, label: "History" },
  { href: `${base}/members/`, label: "Members" },
  { href: `${base}/contact/`, label: "Contact" },
];
const path = Astro.url.pathname.replace(/\/$/, "");
---

<header class="sticky top-0 z-30 bg-white/90 backdrop-blur border-b border-slate-200">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16">
    <a href={`${base}/`} class="flex items-center gap-2 font-bold text-brand-700 text-lg">
      <span class="inline-block w-8 h-8 rounded-full bg-brand-600 text-white grid place-items-center text-sm">As</span>
      <span>AsPEN</span>
    </a>
    <nav aria-label="Primary" class="hidden md:flex items-center gap-1">
      {nav.map((item) => {
        const target = item.href.replace(/\/$/, "");
        const active = path === target || (target !== base && path.startsWith(target));
        return (
          <a
            href={item.href}
            class={`px-3 py-2 text-sm rounded hover:bg-slate-100 transition-colors ${active ? "text-brand-700 font-semibold" : "text-slate-700"}`}
          >
            {item.label}
          </a>
        );
      })}
    </nav>
    <details class="md:hidden relative">
      <summary class="list-none cursor-pointer p-2 rounded hover:bg-slate-100" aria-label="Open menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </summary>
      <div class="absolute right-0 mt-2 w-48 bg-white border border-slate-200 rounded shadow-lg py-2">
        {nav.map((item) => (
          <a href={item.href} class="block px-4 py-2 text-sm text-slate-700 hover:bg-slate-100">{item.label}</a>
        ))}
      </div>
    </details>
  </div>
</header>
