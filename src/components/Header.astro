---
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const nav = [
  { href: `${base}/`, label: "Home" },
  { href: `${base}/about/`, label: "About" },
  { href: `${base}/databases/`, label: "Databases" },
  { href: `${base}/activities/`, label: "Activities" },
  { href: `${base}/publications/`, label: "Publications" },
  { href: `${base}/contact/`, label: "Contact" },
];
// Open-source friendship links — shown as a thin strip above the main nav.
// Drop in a logo image at the listed `image` path (under public/images/) to
// replace the text-only fallback; update `href` to the real upstream URL.
const oss = [
  { label: "Ocean",  href: "https://ocean-dev.phdcenter.org.tw", image: "open-source/ocean.svg"  },
  { label: "GitHub", href: "https://github.com/",                image: "open-source/github.svg" },
];
const path = Astro.url.pathname.replace(/\/$/, "");
const membersHref = `${base}/members/`;
const isOnMembers = path.startsWith(`${base}/members`.replace(/\/$/, ""));
---

<div class="bg-slate-50/80 border-b border-slate-200">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-2 flex items-center justify-end gap-5">
    <span class="hidden sm:inline text-[10px] uppercase tracking-[0.18em] text-slate-500 font-bold">Open source · friendship links</span>
    {oss.map((s) => (
      <a href={s.href} target="_blank" rel="noopener noreferrer" aria-label={s.label}
         class="inline-flex items-center gap-2 text-slate-600 hover:text-brand-700 transition">
        <img src={`${base}/images/${s.image}`} alt={s.label} class="h-7 w-auto" onerror="this.style.display='none'; this.nextElementSibling.style.display='inline';" />
        <span class="hidden text-sm font-semibold">{s.label}</span>
      </a>
    ))}
  </div>
</div>

<header class="sticky top-0 z-30 bg-white/90 backdrop-blur border-b border-slate-200">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16">
    <a href={`${base}/`} class="flex items-center gap-3" aria-label="AsPEN — Asian Pharmacoepidemiology Network">
      <img src={`${base}/images/AsPenLogo.png`} alt="" class="h-10 w-auto shrink-0" width="36" height="40" />
      <span class="hidden lg:inline text-sm font-bold text-brand-700 leading-tight whitespace-nowrap">
        Asian Pharmacoepidemiology Network
      </span>
    </a>
    <nav aria-label="Primary" class="hidden md:flex items-center gap-1">
      {nav.map((item) => {
        const target = item.href.replace(/\/$/, "");
        const active = path === target || (target !== base && path.startsWith(target));
        return (
          <a
            href={item.href}
            class={`px-3 py-2 text-sm rounded hover:bg-slate-100 transition-colors ${active ? "text-brand-700 font-semibold" : "text-slate-700"}`}
          >
            {item.label}
          </a>
        );
      })}
      <!-- ── Sign in / Members CTA (always-visible, right-aligned) ── -->
      <a
        href={membersHref}
        data-members-cta
        class:list={[
          "ml-2 px-3 py-1.5 text-sm rounded-lg border transition-colors font-semibold",
          isOnMembers
            ? "border-brand-700 bg-brand-700 text-white"
            : "border-brand-600 text-brand-700 hover:bg-brand-50",
        ]}
      >
        <span data-cta-label>Sign in</span>
      </a>
    </nav>
    <details class="md:hidden relative">
      <summary class="list-none cursor-pointer p-2 rounded hover:bg-slate-100" aria-label="Open menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </summary>
      <div class="absolute right-0 mt-2 w-48 bg-white border border-slate-200 rounded shadow-lg py-2">
        {nav.map((item) => (
          <a href={item.href} class="block px-4 py-2 text-sm text-slate-700 hover:bg-slate-100">{item.label}</a>
        ))}
        <a href={membersHref} data-members-cta class="block px-4 py-2 text-sm font-semibold text-brand-700 border-t border-slate-200 mt-1 pt-2 hover:bg-brand-50">
          <span data-cta-label>Sign in</span>
        </a>
      </div>
    </details>
  </div>
</header>

<!-- Swap "Sign in" → "Members" once the session cookie is present. -->
<script is:inline>
  (() => {
    // Use the WORKER_URL from site-config — fetch it client-side via a tiny
    // module-style import via window.__WORKER_URL set by a global script? No.
    // Simpler: read it from a meta tag injected by BaseLayout, OR just hardcode
    // the check pattern. For now, do a fetch to /api/me — if the worker URL
    // hasn't been wired the call quietly fails and we stay on "Sign in".
    const url = (window.__ASPEN_WORKER_URL__ || "").replace(/\/$/, "");
    if (!url) return;
    fetch(url + "/api/me", { credentials: "include" })
      .then((r) => r.ok ? r.json() : null)
      .then((data) => {
        if (data && data.ok && data.member) {
          document.querySelectorAll("[data-cta-label]").forEach((el) => {
            el.textContent = "Members";
          });
        }
      })
      .catch(() => { /* offline / cors / no session — ignore */ });
  })();
</script>
