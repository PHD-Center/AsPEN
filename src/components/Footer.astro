---
interface Props {
  /** Forwarded from BaseLayout. Used to build a page-specific citation. */
  pageTitle?: string;
}
const { pageTitle = "Asian Pharmacoepidemiology Network (AsPEN) website" } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const year = new Date().getFullYear();

// ── Page-aware citation. Generates a RIS pointing at THIS page.
const isoDate = new Date().toISOString().slice(0, 10);

// Strip the "; AsPEN" / " - AsPEN" suffix many page titles carry, since
// the citation TI shouldn't be redundant with the corporate author.
const cleanTitle = pageTitle.replace(/\s*[-\-]\s*AsPEN\s*$/, "").trim() || "AsPEN website";

// Current page URL; Astro.url.pathname already includes the BASE_URL prefix
// (e.g. "/AsPEN/databases/") for static builds. Ensure a trailing slash so
// the root path comes out as "/AsPEN/" rather than "/AsPEN".
const path = (Astro.url.pathname || "/").replace(/\/?$/, "/");
const pageUrl = `https://phd-center.github.io${path}`;

// Bibkey is a slug derived from the page path (e.g. /AsPEN/databases/ →
// "aspen-databases"). Falls back to "aspen-home" for the root.
const slug = path
  .replace(/^\/AsPEN\/?/, "")
  .replace(/\/$/, "")
  .replace(/[^a-z0-9]+/gi, "-")
  .toLowerCase() || "home";
const bibkey = `aspen-${slug}`;

const ris = `TY  - ELEC
AU  - Asian Pharmacoepidemiology Network (AsPEN)
TI  - ${cleanTitle}
PY  - ${year}
PB  - PHDc, NCKU
ED  - Tsai DH-T
ED  - Lai EC-C
N1  - Maintained by PHDc, NCKU; Tsai DH-T, Lai EC-C
UR  - ${pageUrl}
Y2  - ${isoDate.replace(/-/g, "/")}
ER  - `;

const formats = [
  { id: "ris", label: "RIS", ext: "ris", mime: "application/x-research-info-systems", text: ris },
];
---

<footer class="mt-24 border-t border-slate-200 bg-slate-50">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-10 grid gap-8 md:grid-cols-4 text-sm">
    <div>
      <p class="font-semibold text-slate-800">AsPEN</p>
      <p class="text-slate-600 mt-1">Beyond a SIG of ISPE</p>
    </div>
    <div>
      <p class="font-semibold text-slate-800">Websites of interest</p>
      <ul class="mt-2 space-y-1">
        <li><a class="hover:text-brand-600" href="https://www.pharmacoepi.org/communities/sigs/aspen/" target="_blank" rel="noopener">ISPE AsPEN SIG</a></li>
        <li><a class="hover:text-brand-600" href="https://neurogen.hku.hk/" target="_blank" rel="noopener">NeuroGEN</a></li>
        <li><a class="hover:text-brand-600" href="https://www.phdcenter.org.tw/" target="_blank" rel="noopener">Population Health Data Center, NCKU</a></li>
        <li><a class="hover:text-brand-600" href="https://www.darwin-eu.org/" target="_blank" rel="noopener">DARWIN EU</a></li>
      </ul>
    </div>
    <div>
      <p class="font-semibold text-slate-800">Get involved</p>
      <ul class="mt-2 space-y-1">
        <li><a class="hover:text-brand-600" href={`${base}/membership/`}>Become a member</a></li>
        <li><a class="hover:text-brand-600" href={`${base}/about/#how-to-join`}>Join the ISPE SIG</a></li>
        <li><a class="hover:text-brand-600" href={`${base}/contact/`}>Contact</a></li>
      </ul>
    </div>
    <div data-cite-col>
      <p class="font-semibold text-slate-800">Cite this site</p>
      <ul class="mt-2 space-y-1">
        {formats.map((f) => (
          <li>
            <button
              type="button"
              data-cite-format={f.id}
              data-cite-text={f.text}
              data-cite-ext={f.ext}
              data-cite-mime={f.mime}
              class="hover:text-brand-600 text-left underline-offset-2 hover:underline"
            >{f.label}</button>
          </li>
        ))}
      </ul>
      <p data-cite-status class="mt-2 text-xs text-brand-700 h-3" aria-live="polite"></p>
    </div>
  </div>
  <div class="border-t border-slate-200 py-4 text-center text-xs text-slate-500">
    © {year} AsPEN. All rights reserved.
  </div>
</footer>

<script is:inline define:vars={{ bibkey }}>
  (() => {
    const col = document.querySelector("[data-cite-col]");
    if (!col) return;
    const status = col.querySelector("[data-cite-status]");
    const flash = (msg) => {
      if (!status) return;
      status.textContent = msg;
      clearTimeout(flash._t);
      flash._t = setTimeout(() => { status.textContent = ""; }, 1800);
    };
    col.querySelectorAll("[data-cite-format]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const fmt  = btn.dataset.citeFormat;
        const text = btn.dataset.citeText || "";
        const ext  = btn.dataset.citeExt  || "txt";
        const mime = btn.dataset.citeMime || "text/plain";
        // Plain-text formats get a -format suffix so they don't collide.
        const filename = ext === "txt" ? `${bibkey}-${fmt}.${ext}` : `${bibkey}.${ext}`;
        const blob = new Blob([text], { type: `${mime};charset=utf-8` });
        const href = URL.createObjectURL(blob);
        const a = document.createElement("a");
        a.href = href;
        a.download = filename;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        setTimeout(() => URL.revokeObjectURL(href), 1000);
        flash(`Downloaded ${filename}`);
      });
    });
  })();
</script>
