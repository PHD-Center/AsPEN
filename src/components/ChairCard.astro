---
interface Props {
  name: string;
  affiliation: string;
  bio?: string;
  photo?: string;
}
const { name, affiliation, bio, photo } = Astro.props;
---

<aside class="bg-white border border-slate-200 rounded-lg p-6 shadow-sm flex gap-5 items-start">
  <div class="shrink-0 w-20 h-20 rounded-full bg-brand-100 grid place-items-center text-brand-700 font-bold text-2xl overflow-hidden">
    {photo ? <img src={photo} alt={name} class="w-full h-full object-cover" /> : <span>{name.split(" ").map(p => p[0]).slice(0, 2).join("")}</span>}
  </div>
  <div>
    <p class="text-xs uppercase tracking-widest text-slate-500">Current Chair</p>
    <p class="text-xl font-semibold text-slate-900 mt-1">{name}</p>
    <p class="text-sm text-slate-600">{affiliation}</p>
    {bio && <p class="text-sm text-slate-700 mt-3 leading-relaxed">{bio}</p>}
  </div>
</aside>
