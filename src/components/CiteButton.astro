---
// "Cite this resource" widget. Five formats — Lancet (Vancouver-style),
// JAMA (AMA 11th ed.), NEJM (modified Vancouver), BibTeX, RIS — each with
// copy-to-clipboard and download-as-file buttons.
//
// Attribution model: AsPEN is the corporate author; maintainers credited
// in a "Maintained by" note. Mirrors the on-screen byline.
//
// Props:
//   title   — the resource title, e.g. "Databases" or "Publications"
//   url     — canonical URL to cite
//   bibkey  — short BibTeX/RIS identifier and download filename stem
interface Props {
  title: string;
  url: string;
  bibkey: string;
}
const { title, url, bibkey } = Astro.props;

const today = new Date();
const year = today.getFullYear();
const isoDate = today.toISOString().slice(0, 10);
const longDate = today.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });

// Lancet (Vancouver-style) — corporate author, title, maintainers in note,
// year. URL (accessed Month Day, Year).
const lancet = `Asian Pharmacoepidemiology Network (AsPEN). ${title}. Maintained by PHDc, NCKU; Tsai DH-T, Lai EC-C. ${year}. ${url} (accessed ${longDate}).`;

// JAMA (AMA 11th edition) — separate "Published" and "Accessed" sentences;
// URL at the very end, no trailing punctuation.
const jama = `Asian Pharmacoepidemiology Network (AsPEN). ${title}. PHDc, NCKU. Maintained by Tsai DH-T, Lai EC-C. Published ${year}. Accessed ${longDate}. ${url}`;

// NEJM — modified Vancouver. URL embedded as a sentence, then "Accessed".
const nejm = `Asian Pharmacoepidemiology Network. ${title}. Maintained by PHDc, NCKU; Tsai DH-T, Lai EC-C. ${url}. Accessed ${longDate}.`;

const bibtex = `@misc{${bibkey},
  author       = {{Asian Pharmacoepidemiology Network (AsPEN)}},
  title        = {${title}},
  year         = {${year}},
  howpublished = {\\url{${url}}},
  note         = {Maintained by PHDc, NCKU; Tsai DH-T, Lai EC-C. Accessed: ${isoDate}}
}`;

const ris = `TY  - ELEC
AU  - Asian Pharmacoepidemiology Network (AsPEN)
TI  - ${title}
PY  - ${year}
PB  - PHDc, NCKU
ED  - Tsai DH-T
ED  - Lai EC-C
N1  - Maintained by PHDc, NCKU; Tsai DH-T, Lai EC-C
UR  - ${url}
Y2  - ${isoDate.replace(/-/g, "/")}
ER  - `;

const widgetId = `cite-${bibkey}`;
---

<details class="mt-10 border border-slate-200 rounded-lg bg-white" id={widgetId}>
  <summary class="cursor-pointer select-none px-5 py-3 flex items-center gap-2 hover:bg-slate-50 rounded-lg">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand-700">
      <path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V20c0 1 0 1 1 1z"></path>
      <path d="M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V20c0 1 0 1 1 1z"></path>
    </svg>
    <span class="text-sm font-semibold text-slate-800">Cite this resource</span>
    <span class="ml-auto text-xs text-slate-400">Lancet · JAMA · NEJM · BibTeX · RIS</span>
  </summary>
  <div class="border-t border-slate-200 p-5">
    <div class="flex flex-wrap gap-1 mb-3" role="tablist">
      <button type="button" data-cite-tab="lancet" class="cite-tab px-3 py-1.5 text-xs font-semibold rounded border border-slate-300 hover:bg-slate-50 aria-selected:bg-brand-700 aria-selected:text-white aria-selected:border-brand-700" aria-selected="true">Lancet</button>
      <button type="button" data-cite-tab="jama" class="cite-tab px-3 py-1.5 text-xs font-semibold rounded border border-slate-300 hover:bg-slate-50 aria-selected:bg-brand-700 aria-selected:text-white aria-selected:border-brand-700">JAMA</button>
      <button type="button" data-cite-tab="nejm" class="cite-tab px-3 py-1.5 text-xs font-semibold rounded border border-slate-300 hover:bg-slate-50 aria-selected:bg-brand-700 aria-selected:text-white aria-selected:border-brand-700">NEJM</button>
      <button type="button" data-cite-tab="bibtex" class="cite-tab px-3 py-1.5 text-xs font-semibold rounded border border-slate-300 hover:bg-slate-50 aria-selected:bg-brand-700 aria-selected:text-white aria-selected:border-brand-700">BibTeX</button>
      <button type="button" data-cite-tab="ris" class="cite-tab px-3 py-1.5 text-xs font-semibold rounded border border-slate-300 hover:bg-slate-50 aria-selected:bg-brand-700 aria-selected:text-white aria-selected:border-brand-700">RIS</button>
    </div>

    <div class="relative">
      <pre data-cite-pane="lancet" class="cite-pane block bg-slate-50 border border-slate-200 rounded p-4 pr-28 text-xs text-slate-700 whitespace-pre-wrap font-mono">{lancet}</pre>
      <pre data-cite-pane="jama" class="cite-pane hidden bg-slate-50 border border-slate-200 rounded p-4 pr-28 text-xs text-slate-700 whitespace-pre-wrap font-mono">{jama}</pre>
      <pre data-cite-pane="nejm" class="cite-pane hidden bg-slate-50 border border-slate-200 rounded p-4 pr-28 text-xs text-slate-700 whitespace-pre-wrap font-mono">{nejm}</pre>
      <pre data-cite-pane="bibtex" class="cite-pane hidden bg-slate-50 border border-slate-200 rounded p-4 pr-28 text-xs text-slate-700 whitespace-pre-wrap font-mono">{bibtex}</pre>
      <pre data-cite-pane="ris" class="cite-pane hidden bg-slate-50 border border-slate-200 rounded p-4 pr-28 text-xs text-slate-700 whitespace-pre-wrap font-mono">{ris}</pre>
      <div class="absolute top-2 right-2 flex gap-1">
        <button
          type="button"
          data-cite-copy
          class="bg-white border border-slate-300 hover:bg-brand-50 hover:border-brand-300 text-xs font-semibold text-slate-700 px-2.5 py-1 rounded shadow-sm transition"
        >Copy</button>
        <button
          type="button"
          data-cite-download
          class="bg-white border border-slate-300 hover:bg-brand-50 hover:border-brand-300 text-xs font-semibold text-slate-700 px-2.5 py-1 rounded shadow-sm transition inline-flex items-center gap-1"
          aria-label="Download citation"
        >
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Download
        </button>
      </div>
    </div>
  </div>
</details>

<script is:inline define:vars={{ widgetId, bibkey }}>
  (() => {
    const root = document.getElementById(widgetId);
    if (!root) return;
    const tabs = root.querySelectorAll("[data-cite-tab]");
    const panes = root.querySelectorAll("[data-cite-pane]");
    const copyBtn = root.querySelector("[data-cite-copy]");
    const dlBtn = root.querySelector("[data-cite-download]");

    let active = "lancet";

    const show = (key) => {
      active = key;
      tabs.forEach((t) => t.setAttribute("aria-selected", t.dataset.citeTab === key ? "true" : "false"));
      panes.forEach((p) => p.classList.toggle("hidden", p.dataset.citePane !== key));
    };
    tabs.forEach((t) => t.addEventListener("click", () => show(t.dataset.citeTab)));

    const activeText = () => {
      const pane = root.querySelector(`[data-cite-pane="${active}"]`);
      return pane ? pane.textContent || "" : "";
    };

    const flash = (btn, msg) => {
      const orig = btn.textContent;
      btn.textContent = msg;
      btn.classList.add("text-brand-700", "border-brand-400");
      setTimeout(() => {
        btn.textContent = orig;
        btn.classList.remove("text-brand-700", "border-brand-400");
      }, 1400);
    };

    copyBtn.addEventListener("click", async () => {
      const text = activeText();
      try {
        await navigator.clipboard.writeText(text);
        flash(copyBtn, "Copied ✓");
      } catch {
        const ta = document.createElement("textarea");
        ta.value = text;
        document.body.appendChild(ta);
        ta.select();
        try { document.execCommand("copy"); flash(copyBtn, "Copied ✓"); } catch {}
        document.body.removeChild(ta);
      }
    });

    dlBtn.addEventListener("click", () => {
      const ext = active === "bibtex" ? "bib" : active === "ris" ? "ris" : "txt";
      const mime = active === "bibtex"
        ? "application/x-bibtex"
        : active === "ris"
        ? "application/x-research-info-systems"
        : "text/plain";
      // For the plain-text formats include the format name so downloads don't
      // collide: aspen-databases-lancet.txt vs -jama.txt vs -nejm.txt.
      const filename = ext === "txt" ? `${bibkey}-${active}.${ext}` : `${bibkey}.${ext}`;
      const text = activeText();
      const blob = new Blob([text], { type: `${mime};charset=utf-8` });
      const href = URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.href = href;
      a.download = filename;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      setTimeout(() => URL.revokeObjectURL(href), 1000);
      // Rebuild label with download icon
      const orig = dlBtn.innerHTML;
      dlBtn.textContent = "Downloaded ✓";
      dlBtn.classList.add("text-brand-700", "border-brand-400");
      setTimeout(() => {
        dlBtn.innerHTML = orig;
        dlBtn.classList.remove("text-brand-700", "border-brand-400");
      }, 1400);
    });
  })();
</script>
