---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
}
const { eyebrow, title, description } = Astro.props;
---

<header class="bg-slate-50 border-b border-slate-200">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-14">
    {eyebrow && <p class="uppercase tracking-widest text-xs text-brand-600 font-semibold mb-2">{eyebrow}</p>}
    <h1 class="text-4xl md:text-5xl font-bold text-slate-900">{title}</h1>
    {description && <p class="mt-4 text-lg text-slate-600 max-w-3xl">{description}</p>}
  </div>
</header>
