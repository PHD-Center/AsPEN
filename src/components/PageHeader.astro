---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
}
const { eyebrow, title, description } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<header class="relative bg-gradient-to-br from-brand-50 via-white to-brand-100/40 border-b border-slate-200 overflow-hidden">
  <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-14 flex items-center gap-6">
    <img
      src={`${base}/images/AsPenLogo.png`}
      alt=""
      class="hidden sm:block shrink-0 w-20 h-20 object-contain"
      aria-hidden="true"
    />
    <div>
      {eyebrow && <p class="uppercase tracking-widest text-xs text-brand-600 font-semibold mb-2">{eyebrow}</p>}
      <h1 class="text-4xl md:text-5xl font-bold text-slate-900">{title}</h1>
      {description && <p class="mt-4 text-lg text-slate-600 max-w-3xl">{description}</p>}
    </div>
  </div>
</header>
