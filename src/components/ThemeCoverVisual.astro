---
// Abstract editorial illustrations used on the magazine-cover spreads when
// no real image is supplied. Each variant is a small inline SVG drawn with
// the brand-green ink. Kept restrained on purpose — geometric, not figurative.
interface Props {
  variant: "network" | "wave" | "rings" | "dots" | "bars" | "target" | "cluster";
  /** Optional override colour; defaults to brand ink. */
  ink?: string;
  class?: string;
}
const { variant, ink = "#21443e", class: className = "" } = Astro.props;

// Pre-compute dot positions (avoids 60 inline arrays). Dense grid representing
// the 3.6M paired records ethos — a "field of subjects".
const dotPositions: { cx: number; cy: number }[] = [];
const cols = 13;
const rows = 9;
for (let r = 0; r < rows; r++) {
  for (let c = 0; c < cols; c++) {
    dotPositions.push({ cx: 8 + c * 7, cy: 8 + r * 9 });
  }
}
---

<div class:list={["w-full h-full flex items-center justify-center", className]}>
  {variant === "network" && (
    <svg viewBox="0 0 100 80" class="w-full h-full" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
      <g stroke={ink} stroke-width="0.5" stroke-opacity="0.55" fill="none">
        <line x1="22" y1="22" x2="48" y2="38" />
        <line x1="48" y1="38" x2="74" y2="22" />
        <line x1="48" y1="38" x2="60" y2="62" />
        <line x1="74" y1="22" x2="86" y2="48" />
        <line x1="60" y1="62" x2="80" y2="62" />
        <line x1="22" y1="22" x2="28" y2="56" />
        <line x1="28" y1="56" x2="60" y2="62" />
        <line x1="60" y1="62" x2="86" y2="48" />
        <line x1="48" y1="38" x2="86" y2="48" />
        <line x1="22" y1="22" x2="48" y2="38" />
        <line x1="28" y1="56" x2="48" y2="38" />
      </g>
      <g fill={ink}>
        <circle cx="22" cy="22" r="3" />
        <circle cx="48" cy="38" r="5" />
        <circle cx="74" cy="22" r="3" />
        <circle cx="86" cy="48" r="2.5" />
        <circle cx="28" cy="56" r="2.5" />
        <circle cx="60" cy="62" r="4" />
        <circle cx="80" cy="62" r="2.8" />
      </g>
    </svg>
  )}

  {variant === "wave" && (
    <svg viewBox="0 0 100 60" class="w-full h-full" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
      <g stroke={ink} fill="none">
        <path d="M 0 30 Q 8 8, 16 30 T 32 30 T 48 30 T 64 30 T 80 30 T 100 30" stroke-width="1.8" />
        <path d="M 0 42 Q 10 28, 20 42 T 40 42 T 60 42 T 80 42 T 100 42" stroke-width="0.7" stroke-opacity="0.4" />
        <path d="M 0 18 Q 12 4, 24 18 T 48 18 T 72 18 T 96 18 T 100 18" stroke-width="0.7" stroke-opacity="0.4" />
      </g>
    </svg>
  )}

  {variant === "rings" && (
    <svg viewBox="0 0 100 100" class="w-full h-full" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
      <g stroke={ink} fill="none">
        <circle cx="50" cy="50" r="44" stroke-width="0.5" stroke-opacity="0.35" />
        <circle cx="50" cy="50" r="34" stroke-width="0.6" stroke-opacity="0.55" />
        <circle cx="50" cy="50" r="24" stroke-width="0.8" stroke-opacity="0.7" />
        <circle cx="50" cy="50" r="14" stroke-width="1" />
        <circle cx="50" cy="50" r="5" fill={ink} stroke-width="0" />
      </g>
    </svg>
  )}

  {variant === "dots" && (
    <svg viewBox="0 0 100 90" class="w-full h-full" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
      <g fill={ink}>
        {dotPositions.map((p) => <circle cx={p.cx} cy={p.cy} r="1.4" />)}
      </g>
    </svg>
  )}

  {variant === "bars" && (
    <svg viewBox="0 0 100 70" class="w-full h-full" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
      <g fill={ink}>
        <rect x="6"  y="40" width="8" height="22" />
        <rect x="18" y="18" width="8" height="44" />
        <rect x="30" y="28" width="8" height="34" />
        <rect x="42" y="6"  width="8" height="56" />
        <rect x="54" y="22" width="8" height="40" />
        <rect x="66" y="12" width="8" height="50" />
        <rect x="78" y="34" width="8" height="28" />
        <rect x="90" y="48" width="6" height="14" />
      </g>
    </svg>
  )}

  {variant === "target" && (
    <svg viewBox="0 0 100 100" class="w-full h-full" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
      <g stroke={ink} fill="none">
        <circle cx="50" cy="50" r="42" stroke-width="0.6" stroke-opacity="0.3" />
        <circle cx="50" cy="50" r="30" stroke-width="0.6" stroke-opacity="0.55" />
        <circle cx="50" cy="50" r="18" stroke-width="0.6" stroke-opacity="0.8" />
        <circle cx="50" cy="50" r="6" fill={ink} stroke-width="0" />
        <line x1="0" y1="50" x2="100" y2="50" stroke-width="0.3" stroke-dasharray="2 2" stroke-opacity="0.35" />
        <line x1="50" y1="0" x2="50" y2="100" stroke-width="0.3" stroke-dasharray="2 2" stroke-opacity="0.35" />
      </g>
    </svg>
  )}

  {variant === "cluster" && (
    <svg viewBox="0 0 100 70" class="w-full h-full" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
      <g stroke={ink} stroke-width="0.6" fill="none">
        <ellipse cx="30" cy="22" rx="14" ry="7" transform="rotate(22 30 22)" />
        <ellipse cx="56" cy="18" rx="16" ry="6" transform="rotate(-18 56 18)" />
        <ellipse cx="72" cy="35" rx="13" ry="7" transform="rotate(35 72 35)" />
        <ellipse cx="42" cy="40" rx="15" ry="7" transform="rotate(50 42 40)" />
        <ellipse cx="64" cy="52" rx="14" ry="6" transform="rotate(8 64 52)" />
        <ellipse cx="26" cy="50" rx="11" ry="6" transform="rotate(-30 26 50)" />
      </g>
    </svg>
  )}
</div>
