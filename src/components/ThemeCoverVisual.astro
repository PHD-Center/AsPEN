---
// Editorial illustrations for theme covers. Each variant is bound to a theme
// so the imagery actually evokes the subject rather than reading as generic
// decoration. All inline SVG, monochrome brand-green ink on cream paper.
interface Props {
  variant:
    | "network"   // methods — connected database cylinders
    | "wave"      // neuropsychiatric — EEG-style trace with a pandemic dip
    | "rings"     // diabetes — continuous-glucose-monitor curve over target band
    | "dots"      // pregnancy — grid of paired large+small dots
    | "bars"      // pain & opioids — pill silhouette with dose bars above
    | "target"    // oncology — cluster of cells, one dividing
    | "cluster";  // older adults — pile of pill silhouettes
  /** Optional override colour; defaults to brand ink. */
  ink?: string;
  class?: string;
}
const { variant, ink = "#21443e", class: className = "" } = Astro.props;

// Pair grid for the pregnancy visual: each pair is one big + one small dot.
const pairs: { x: number; y: number }[] = [];
for (let r = 0; r < 4; r++) {
  for (let c = 0; c < 5; c++) {
    pairs.push({ x: 10 + c * 18, y: 12 + r * 18 });
  }
}
---

<div class:list={["w-full h-full flex items-center justify-center", className]}>
  {variant === "network" && (
    <!-- Methods: connected database cylinders across continents -->
    <svg viewBox="0 0 100 80" class="w-full h-full" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
      <g stroke={ink} stroke-width="0.4" stroke-opacity="0.45" fill="none">
        <line x1="20" y1="25" x2="50" y2="20" />
        <line x1="50" y1="20" x2="80" y2="30" />
        <line x1="20" y1="25" x2="35" y2="55" />
        <line x1="35" y1="55" x2="65" y2="60" />
        <line x1="65" y1="60" x2="80" y2="30" />
        <line x1="50" y1="20" x2="65" y2="60" />
      </g>
      <!-- Five database cylinders: top ellipse + body + bottom curve -->
      {[
        { cx: 20, cy: 25, rx: 6,  ry: 2 },
        { cx: 50, cy: 20, rx: 7,  ry: 2.2 },
        { cx: 80, cy: 30, rx: 6,  ry: 2 },
        { cx: 35, cy: 55, rx: 5.5,ry: 1.8 },
        { cx: 65, cy: 60, rx: 6.5,ry: 2 },
      ].map((d) => (
        <g fill={ink}>
          <ellipse cx={d.cx} cy={d.cy - 4} rx={d.rx} ry={d.ry} />
          <rect x={d.cx - d.rx} y={d.cy - 4} width={d.rx * 2} height="8" />
          <path d={`M ${d.cx - d.rx} ${d.cy + 4} A ${d.rx} ${d.ry} 0 0 0 ${d.cx + d.rx} ${d.cy + 4} L ${d.cx + d.rx} ${d.cy - 4} L ${d.cx - d.rx} ${d.cy - 4} Z`} />
        </g>
      ))}
    </svg>
  )}

  {variant === "wave" && (
    <!-- Neuropsychiatric: EEG-style trace with a pandemic dip in the middle -->
    <svg viewBox="0 0 100 50" class="w-full h-full" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
      <g stroke={ink} fill="none" stroke-linecap="round">
        <path d="M 0 25 L 5 25 L 8 18 L 12 32 L 16 22 L 20 25 L 25 25 L 28 14 L 32 36 L 36 24 L 40 26 L 45 26
                 L 48 26 L 52 26 L 56 26 L 60 26
                 L 65 25 L 68 12 L 72 38 L 76 22 L 80 28 L 85 25 L 88 16 L 92 34 L 96 24 L 100 26"
              stroke-width="1.4" />
      </g>
      <!-- Subtle annotation -->
      <g stroke={ink} stroke-width="0.2" stroke-opacity="0.4" stroke-dasharray="1 1.5" fill="none">
        <rect x="42" y="20" width="18" height="12" />
      </g>
    </svg>
  )}

  {variant === "rings" && (
    <!-- Diabetes: continuous glucose curve oscillating over a target band -->
    <svg viewBox="0 0 100 60" class="w-full h-full" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
      <!-- Target band -->
      <rect x="0" y="26" width="100" height="10" fill={ink} fill-opacity="0.08" />
      <line x1="0" y1="26" x2="100" y2="26" stroke={ink} stroke-width="0.2" stroke-opacity="0.4" stroke-dasharray="2 2" />
      <line x1="0" y1="36" x2="100" y2="36" stroke={ink} stroke-width="0.2" stroke-opacity="0.4" stroke-dasharray="2 2" />
      <!-- Glucose curve -->
      <path d="M 0 32 Q 8 14, 18 30 T 36 32 Q 46 50, 56 30 T 78 18 Q 88 42, 100 28"
            stroke={ink} stroke-width="1.4" fill="none" stroke-linecap="round" />
      <!-- Sample points -->
      {[10, 27, 46, 67, 88].map((cx, i) => {
        const y = [22, 31, 42, 25, 36][i];
        return <circle cx={cx} cy={y} r="1.2" fill={ink} />;
      })}
    </svg>
  )}

  {variant === "dots" && (
    <!-- Pregnancy: 5×4 grid of mother–child pairs (large dot + small dot, linked) -->
    <svg viewBox="0 0 100 80" class="w-full h-full" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
      {pairs.map((p) => (
        <g fill={ink}>
          <circle cx={p.x} cy={p.y} r="3" />
          <circle cx={p.x + 6} cy={p.y + 2} r="1.5" />
          <path d={`M ${p.x + 3} ${p.y} Q ${p.x + 4.5} ${p.y - 1.5} ${p.x + 4.8} ${p.y + 1.8}`} stroke={ink} stroke-width="0.4" fill="none" />
        </g>
      ))}
    </svg>
  )}

  {variant === "bars" && (
    <!-- Pain & opioids: pill silhouette with country-dose bars above -->
    <svg viewBox="0 0 100 70" class="w-full h-full" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
      <!-- Bars (dose per country) -->
      <g fill={ink}>
        <rect x="14"  y="22" width="6" height="20" />
        <rect x="24"  y="10" width="6" height="32" />
        <rect x="34"  y="18" width="6" height="24" />
        <rect x="44"  y="6"  width="6" height="36" />
        <rect x="54"  y="14" width="6" height="28" />
        <rect x="64"  y="20" width="6" height="22" />
        <rect x="74"  y="12" width="6" height="30" />
        <rect x="84"  y="26" width="6" height="16" />
      </g>
      <!-- Pill silhouette below the bars (oblong tablet, scored in the middle) -->
      <g fill={ink}>
        <rect x="20" y="52" width="60" height="12" rx="6" />
      </g>
      <line x1="50" y1="52" x2="50" y2="64" stroke="#f3eee3" stroke-width="1.2" />
    </svg>
  )}

  {variant === "target" && (
    <!-- Oncology: cluster of cells, one dividing in the centre -->
    <svg viewBox="0 0 100 70" class="w-full h-full" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
      <g stroke={ink} stroke-width="0.6" fill="none">
        <!-- Surrounding cells -->
        <ellipse cx="22" cy="22" rx="9" ry="7" />
        <circle cx="22" cy="22" r="2" fill={ink} stroke-width="0" />

        <ellipse cx="78" cy="20" rx="8" ry="6.5" />
        <circle cx="78" cy="20" r="2" fill={ink} stroke-width="0" />

        <ellipse cx="20" cy="52" rx="8.5" ry="6.5" />
        <circle cx="20" cy="52" r="1.8" fill={ink} stroke-width="0" />

        <ellipse cx="80" cy="54" rx="9" ry="7" />
        <circle cx="80" cy="54" r="2.2" fill={ink} stroke-width="0" />

        <!-- Centre cell, dividing (peanut shape via two overlapping ellipses) -->
        <ellipse cx="44" cy="38" rx="8" ry="6.5" />
        <ellipse cx="56" cy="38" rx="8" ry="6.5" />
        <circle cx="44" cy="38" r="2.2" fill={ink} stroke-width="0" />
        <circle cx="56" cy="38" r="2.2" fill={ink} stroke-width="0" />
      </g>
    </svg>
  )}

  {variant === "cluster" && (
    <!-- Older adults: varied pill silhouettes (round, oblong, capsule) clustered -->
    <svg viewBox="0 0 100 70" class="w-full h-full" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
      <g fill={ink}>
        <!-- Capsule (rotated) -->
        <g transform="rotate(-25 30 22)">
          <rect x="14" y="18" width="32" height="9" rx="4.5" />
          <rect x="14" y="18" width="16" height="9" fill={ink} fill-opacity="0.55" />
        </g>
        <!-- Oblong tablet (rotated) -->
        <g transform="rotate(20 65 18)">
          <rect x="48" y="14" width="34" height="10" rx="5" />
          <line x1="65" y1="14" x2="65" y2="24" stroke="#f3eee3" stroke-width="1.1" />
        </g>
        <!-- Round tablet -->
        <circle cx="32" cy="44" r="9" />
        <line x1="23" y1="44" x2="41" y2="44" stroke="#f3eee3" stroke-width="1.1" />
        <!-- Oval pill -->
        <g transform="rotate(40 55 50)">
          <ellipse cx="55" cy="50" rx="13" ry="6" />
        </g>
        <!-- Small capsule -->
        <g transform="rotate(-10 82 50)">
          <rect x="70" y="46" width="22" height="7" rx="3.5" />
          <rect x="70" y="46" width="11" height="7" fill={ink} fill-opacity="0.55" />
        </g>
      </g>
    </svg>
  )}
</div>
