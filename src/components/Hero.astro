---
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<section class="relative overflow-hidden bg-white border-b border-slate-200">
  <!-- decorative accents -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute -top-32 -right-24 w-[420px] h-[420px] rounded-full bg-gradient-to-br from-accent-500/15 via-brand-500/10 to-transparent blur-3xl"></div>
    <div class="absolute -bottom-40 -left-20 w-[360px] h-[360px] rounded-full bg-gradient-to-tr from-brand-500/10 to-transparent blur-3xl"></div>
  </div>

  <!-- top accent bar -->
  <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-accent-500 via-brand-500 to-brand-700"></div>

  <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-20 md:py-28 grid lg:grid-cols-[1fr_auto] gap-10 items-center">
    <div>
      <p class="inline-flex items-center gap-2 uppercase tracking-widest text-xs text-brand-600 font-semibold mb-4">
        <span class="inline-block w-6 h-px bg-brand-500"></span>
        Asian Pharmacoepidemiology Network
      </p>
      <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold leading-[1.05] text-slate-900 tracking-tight">
        Multi-national studies for <span class="text-brand-600">Asia</span>
      </h1>
      <p class="mt-6 max-w-2xl text-lg text-slate-600 leading-relaxed">
        AsPEN advances pharmacoepidemiology research in Asia-Pacific to support medication safety, effectiveness evaluation, and regional education, collaboration, and knowledge exchange.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href={`${base}/about/`} class="inline-flex items-center bg-brand-600 text-white font-semibold px-5 py-2.5 rounded-lg shadow-sm hover:bg-brand-700 hover:shadow-md transition">About AsPEN</a>
        <a href={`${base}/about/#how-to-join`} class="inline-flex items-center bg-white text-slate-800 border border-slate-300 font-semibold px-5 py-2.5 rounded-lg hover:border-brand-500 hover:text-brand-700 transition">How to join</a>
      </div>
    </div>
    <div class="hidden lg:flex items-center justify-center">
      <div class="relative">
        <div class="absolute inset-0 -m-4 bg-gradient-to-br from-accent-500/10 to-brand-500/10 rounded-3xl blur-xl"></div>
        <img src={`${base}/images/AsPenLogo.png`} alt="AsPEN logo" class="relative w-60 h-60 object-contain" />
      </div>
    </div>
  </div>
</section>
