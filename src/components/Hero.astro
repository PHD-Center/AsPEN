---
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<section class="relative overflow-hidden bg-gradient-to-br from-brand-700 via-brand-600 to-brand-500 text-white">
  <div class="absolute inset-0 opacity-20" aria-hidden="true">
    <svg viewBox="0 0 800 400" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice" class="w-full h-full">
      <defs>
        <pattern id="dots" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
          <circle cx="2" cy="2" r="1" fill="white" />
        </pattern>
      </defs>
      <rect width="800" height="400" fill="url(#dots)" />
    </svg>
  </div>
  <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-20 md:py-28">
    <p class="uppercase tracking-widest text-xs text-brand-100 mb-3">Asian Pharmacoepidemiology Network</p>
    <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight max-w-3xl">
      Multi-national database research, built for Asia/Pacific.
    </h1>
    <p class="mt-6 max-w-2xl text-lg text-brand-50">
      AsPEN is a Special Interest Group of the International Society for Pharmacoepidemiology (ISPE), supporting collaborative pharmacoepidemiologic research and rapid identification of emerging safety signals across the region.
    </p>
    <div class="mt-8 flex flex-wrap gap-3">
      <a href={`${base}/about/`} class="inline-flex items-center bg-white text-brand-700 font-semibold px-5 py-2.5 rounded shadow hover:bg-brand-50 transition">About AsPEN</a>
      <a href={`${base}/about/#how-to-join`} class="inline-flex items-center bg-brand-900/30 border border-white/40 text-white font-semibold px-5 py-2.5 rounded hover:bg-brand-900/50 transition">How to join</a>
    </div>
  </div>
</section>
