---
// AsPEN Governance org chart.
// Top: Chair. Bottom: two groups under the Chair.

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

interface Member {
  name: string;
  role: string;
  inst: string;
  photo?: string;
}

const chair: Member & { affiliation: string } = {
  name: "Ju-Young Shin",
  role: "Chair",
  inst: "SKKU · SNU",
  affiliation: "SKKU · SNU",
  photo: "Judy.png",
};

const academic = {
  title: "Academic & Education",
  members: [
    { name: "Edward Lai",  role: "Education Lead",      inst: "NCKU", photo: "Edward.jpg" },
    { name: "Daniel Tsai", role: "Education Secretary", inst: "NCKU", photo: "Daniel.png" },
  ] as Member[],
};

const operations = {
  title: "Operations & Coordination",
  members: [{ name: "Ju-Young Shin", role: "Lead", inst: "SKKU", photo: "Judy.png" }] as Member[],
  blurb: "Led by Ju-Young Shin with the SKKU team; handles operational coordination, ISPE liaison, and multi-country study governance.",
};

const initials = (n: string) => n.split(" ").map((p) => p[0]).slice(0, 2).join("");
---

<div class="not-prose my-6">
  <!-- Chair card centered (with photo) -->
  <div class="flex justify-center">
    <div class="relative bg-gradient-to-br from-brand-600 to-brand-700 text-white px-6 py-4 rounded-xl shadow-lg flex items-center gap-4 min-w-[300px]">
      <div class="shrink-0 w-16 h-16 rounded-full bg-white/95 overflow-hidden border-2 border-white shadow-sm">
        {chair.photo ? (
          <img src={`${base}/images/${chair.photo}`} alt={chair.name} class="block w-full h-full object-cover" />
        ) : (
          <div class="w-full h-full grid place-items-center text-brand-700 font-bold text-lg">{initials(chair.name)}</div>
        )}
      </div>
      <div class="text-left">
        <p class="text-[10px] uppercase tracking-[0.2em] text-brand-100 font-semibold">{chair.role}</p>
        <p class="font-bold text-lg mt-0.5 leading-tight">{chair.name}</p>
        <p class="text-xs text-brand-50 mt-0.5">{chair.affiliation}</p>
      </div>
    </div>
  </div>

  <!-- Vertical line down from chair -->
  <div class="flex justify-center"><div class="w-px h-8 bg-slate-300"></div></div>

  <!-- Horizontal connector + two branches -->
  <div class="relative grid grid-cols-1 md:grid-cols-2 gap-6">
    <div class="hidden md:block absolute top-0 left-1/4 right-1/4 h-px bg-slate-300"></div>

    {[academic, operations].map((group) => (
      <div class="flex flex-col items-center">
        <div class="hidden md:block w-px h-8 bg-slate-300"></div>
        <div class="md:hidden w-px h-4 bg-slate-300"></div>
        <div class="w-full bg-white border-2 border-brand-200 rounded-xl p-5 shadow-sm">
          <p class="text-[10px] uppercase tracking-[0.2em] text-brand-700 font-bold">{group.title}</p>
          <ul class="mt-3 space-y-3">
            {group.members.map((m) => (
              <li class="flex items-center gap-3">
                <div class="shrink-0 w-12 h-12 rounded-full overflow-hidden bg-brand-50 border border-brand-100">
                  {m.photo ? (
                    <img src={`${base}/images/${m.photo}`} alt={m.name} class="block w-full h-full object-cover" />
                  ) : (
                    <div class="w-full h-full grid place-items-center text-brand-700 text-xs font-bold">{initials(m.name)}</div>
                  )}
                </div>
                <div class="leading-tight">
                  <p class="font-semibold text-slate-900 text-sm">{m.name}</p>
                  <p class="text-xs text-slate-600">{m.role}<span class="text-slate-400"> · {m.inst}</span></p>
                </div>
              </li>
            ))}
          </ul>
          {group.blurb && <p class="text-xs text-slate-500 mt-3 leading-relaxed">{group.blurb}</p>}
        </div>
      </div>
    ))}
  </div>
</div>
