---
// AsPEN Governance — team-style layout (Chair hero + Education Co-Leads + Ops note)

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

interface Member {
  name: string;
  role: string;
  inst: string;
  photo?: string;
}

const chair: Member = {
  name: "Ju-Young Shin",
  role: "Chair",
  inst: "SKKU · SNU",
  photo: "Judy.png",
};

const educationLeads: Member[] = [
  { name: "Edward Lai",  role: "Education Co-Lead", inst: "NCKU", photo: "Edward.jpg" },
  { name: "Daniel Tsai", role: "Education Co-Lead", inst: "NCKU", photo: "Daniel.png" },
];

const initials = (n: string) => n.split(" ").map((p) => p[0]).slice(0, 2).join("");
---

<div class="not-prose my-8 space-y-10">
  <!-- Chair hero -->
  <div>
    <p class="text-[10px] uppercase tracking-[0.25em] text-brand-600 font-bold mb-3">Chair</p>
    <article class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-brand-700 via-brand-600 to-accent-500 text-white shadow-lg">
      <div class="absolute -top-12 -right-12 w-48 h-48 rounded-full bg-white/10 blur-3xl pointer-events-none"></div>
      <div class="absolute -bottom-16 -left-8 w-40 h-40 rounded-full bg-accent-500/30 blur-2xl pointer-events-none"></div>
      <div class="relative flex flex-col sm:flex-row items-center sm:items-stretch gap-5 sm:gap-6 p-5 sm:p-7">
        <div class="shrink-0 w-32 h-32 sm:w-40 sm:h-40 rounded-xl overflow-hidden bg-white/95 border-4 border-white shadow-md">
          {chair.photo ? (
            <img src={`${base}/images/${chair.photo}`} alt={chair.name} class="block w-full h-full object-cover object-top" />
          ) : (
            <div class="w-full h-full grid place-items-center text-brand-700 font-bold text-3xl">{initials(chair.name)}</div>
          )}
        </div>
        <div class="flex-1 flex flex-col justify-center text-center sm:text-left">
          <p class="text-2xl sm:text-3xl font-bold leading-tight">{chair.name}</p>
          <p class="text-sm sm:text-base text-brand-50 mt-1">{chair.inst}</p>
          <p class="text-sm text-brand-50/90 mt-3 leading-relaxed max-w-2xl">
            Coordinates AsPEN's programme strategy, ISPE liaison, and multi-country study governance.
          </p>
        </div>
      </div>
    </article>
  </div>

  <!-- Education Co-Leads -->
  <div>
    <div class="flex items-baseline justify-between mb-4">
      <p class="text-[10px] uppercase tracking-[0.25em] text-brand-600 font-bold">Academic & Education</p>
      <span class="text-xs text-slate-500">Co-Leads</span>
    </div>
    <div class="grid gap-4 sm:grid-cols-2">
      {educationLeads.map((m) => (
        <article class="group flex items-center gap-4 p-4 rounded-xl bg-white border border-slate-200 hover:border-brand-400 hover:shadow-md transition">
          <div class="shrink-0 w-20 h-20 rounded-full overflow-hidden bg-brand-50 border border-brand-100 group-hover:border-brand-300 transition">
            {m.photo ? (
              <img src={`${base}/images/${m.photo}`} alt={m.name} class="block w-full h-full object-cover object-top" />
            ) : (
              <div class="w-full h-full grid place-items-center text-brand-700 text-sm font-bold">{initials(m.name)}</div>
            )}
          </div>
          <div class="leading-tight">
            <p class="font-bold text-slate-900 text-base">{m.name}</p>
            <p class="text-sm text-brand-700 font-medium mt-0.5">{m.role}</p>
            <p class="text-xs text-slate-500 mt-0.5">{m.inst}</p>
          </div>
        </article>
      ))}
    </div>
  </div>

  <!-- Operations note -->
  <div class="border-l-4 border-brand-300 pl-5 py-1">
    <p class="text-[10px] uppercase tracking-[0.25em] text-brand-600 font-bold">Operations & Coordination</p>
    <p class="text-sm text-slate-700 mt-2 leading-relaxed max-w-3xl">
      Day-to-day operations are coordinated by the Chair with the <strong>SKKU team</strong> — handling ISPE liaison, multi-country study governance, and collaborative protocols.
    </p>
  </div>
</div>
