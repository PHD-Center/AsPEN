---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import WorldMap from "../components/WorldMap.astro";
import databasesRaw from "../data/databases.json";

const siteBase = import.meta.env.BASE_URL.replace(/\/?$/, "/"); // ensure trailing slash

// Filter out databases flagged `hidden: true` — used to temporarily withhold
// data partners that are mid-negotiation (e.g. some Japan commercial DBs as
// of 2026-05). Records stay in databases.json so we can restore them quickly.
const databases = databasesRaw.filter((d) => !(d as { hidden?: boolean }).hidden);

const countryMeta: Record<
  string,
  { code: string; flag: string; lat: number; lng: number; region: "asia" | "external" }
> = {
  Japan:            { code: "JP", flag: "🇯🇵", lat: 35.68, lng: 139.65, region: "asia" },
  "South Korea":    { code: "KR", flag: "🇰🇷", lat: 36.5,  lng: 127.8,  region: "asia" },
  Taiwan:           { code: "TW", flag: "🇹🇼", lat: 23.7,  lng: 121.0,  region: "asia" },
  "Hong Kong":      { code: "HK", flag: "🇭🇰", lat: 22.32, lng: 114.17, region: "asia" },
  "United Kingdom": { code: "GB",     flag: "🇬🇧",                       lat: 51.5,   lng: -0.13,  region: "external" },
  Scotland:         { code: "gb-sct", flag: "🏴\u{E0067}\u{E0062}\u{E0073}\u{E0063}\u{E0074}\u{E007F}", lat: 55.95,  lng: -3.19,  region: "external" },
  "United States":  { code: "US",     flag: "🇺🇸",                       lat: 38.91,  lng: -77.04, region: "external" },
  Netherlands:      { code: "NL",     flag: "🇳🇱",                       lat: 52.09,  lng: 5.12,   region: "external" },
  Finland:          { code: "FI",     flag: "🇫🇮",                       lat: 60.17,  lng: 24.94,  region: "external" },
  Australia:        { code: "AU",     flag: "🇦🇺",                       lat: -25.27, lng: 133.78, region: "external" },
  Singapore:        { code: "SG",     flag: "🇸🇬",                       lat: 1.35,   lng: 103.82, region: "external" },
  Thailand:         { code: "TH",     flag: "🇹🇭",                       lat: 13.76,  lng: 100.50, region: "external" },
};

// Group databases by country for the cards (Scotland's ISD goes under UK section)
const groupedMap = new Map<string, typeof databases>();
for (const d of databases) {
  if (!groupedMap.has(d.country)) groupedMap.set(d.country, []);
  groupedMap.get(d.country)!.push(d);
}
const grouped = Array.from(groupedMap.entries());

const asianGroups = grouped.filter(([c]) => countryMeta[c]?.region === "asia");
const externalGroups = grouped.filter(([c]) => countryMeta[c]?.region === "external");

// Separate grouping for the MAP — allows mapAs override so e.g. Scotland gets its
// own flag marker even though the ISD database is listed under United Kingdom.
const mapGroupedMap = new Map<string, typeof databases>();
for (const d of databases) {
  const key = (d as { mapAs?: string }).mapAs ?? d.country;
  if (!mapGroupedMap.has(key)) mapGroupedMap.set(key, []);
  mapGroupedMap.get(key)!.push(d);
}
const mapGroups = Array.from(mapGroupedMap.entries()).map(([key, dbs]) => {
  const meta = countryMeta[key]!;
  return {
    country: key,
    code: meta.code,
    lat: meta.lat,
    lng: meta.lng,
    items: dbs.map((d) => ({
      name: d.name,
      type: d.type,
      coverage: d.coverage,
      anchor: `db-${d.name.replace(/[^a-z0-9]+/gi, "-").toLowerCase()}`,
    })),
  };
});

// Singapore + Thailand — appear on the map (no anchor since they live in the prose section)
// Inline rather than in databases.json because they're "other sites", not active.
const otherMapEntries: Record<string, { name: string; type: string; coverage?: string }[]> = {
  Singapore: [
    { name: "National Electronic Health Record (NEHR)", type: "National EHR" },
  ],
  Thailand: [
    { name: "Buddhachinaraj Hospital Database (BHD)", type: "Single-hospital EHR" },
    { name: "Hospital Information (HI) — Ubon Ratchathani", type: "Multi-hospital EHR" },
  ],
};
for (const [country, items] of Object.entries(otherMapEntries)) {
  const meta = countryMeta[country];
  if (!meta) continue;
  mapGroups.push({
    country,
    code: meta.code,
    lat: meta.lat,
    lng: meta.lng,
    items: items.map((it) => ({ name: it.name, type: it.type, coverage: it.coverage ?? "", anchor: "other-sites" })),
  });
}

const typeColor: Record<string, string> = {
  Claims: "bg-emerald-50 text-emerald-700 border-emerald-200",
  "National EHR": "bg-sky-50 text-sky-700 border-sky-200",
  "Multi-institutional EHR": "bg-indigo-50 text-indigo-700 border-indigo-200",
  "Primary-care EHR": "bg-violet-50 text-violet-700 border-violet-200",
  Biobank: "bg-amber-50 text-amber-700 border-amber-200",
};

// Comparison data — keyed by database name. Used by the comparison drawer
// and serialised via define:vars to the inline script.
// `since` / `popM` / `lagMonths` come straight from databases.json (editable
// via PagesCMS). Most values are sourced from Figure 1 of the NeuroGEN paper
// (Tsai DHT et al., Clin Epidemiol 2023; PMID 38146486); the 5 not in that
// figure (NDB / JMDC / DeSC / MDV / HIRA) use commonly-cited public estimates.
const compareData: Record<string, {
  country: string;
  flag: string;
  name: string;
  type: string;
  popM: number;
  since: number | null;
  lagMonths: number | null;
  features: string[];
  coverage: string;
  notes: string;
  anchor: string;
}> = {};
for (const d of databases) {
  const meta = countryMeta[d.country];
  const dd = d as typeof d & { since?: number; popM?: number; lagMonths?: number; features?: string[] };
  compareData[d.name] = {
    country: d.country,
    flag: meta?.flag ?? "🏳️",
    name: d.name,
    type: d.type,
    popM: dd.popM ?? 0,
    since: typeof dd.since === "number" ? dd.since : null,
    lagMonths: typeof dd.lagMonths === "number" ? dd.lagMonths : null,
    features: Array.isArray(dd.features) ? dd.features : [],
    coverage: d.coverage,
    notes: d.notes,
    anchor: `db-${d.name.replace(/[^a-z0-9]+/gi, "-").toLowerCase()}`,
  };
}

// Other sites listed in the 2015 AsPEN database survey (Lai ECC et al., Epidemiology 2015)
// that are not part of the current active network. Reference only — not on the map.
const otherSites = [
  { country: "Singapore", flag: "🇸🇬", name: "National Electronic Health Record (NEHR)",     note: "Singapore's national EHR; listed in the 2015 AsPEN survey." },
  { country: "Thailand",  flag: "🇹🇭", name: "Buddhachinaraj Hospital Database (BHD)",       note: "Tertiary referral hospital EHR." },
  { country: "Thailand",  flag: "🇹🇭", name: "Hospital Information (HI) — Ubon Ratchathani", note: "21-community-hospital EHR network." },
];
---

<BaseLayout
  title="Databases — AsPEN"
  description="Healthcare databases accessible to AsPEN collaborators across East Asia, plus an external control."
>
  <PageHeader
    eyebrow="Data"
    title="Databases"
    description="Population-level health databases used in AsPEN multi-national studies. The map is focused on East Asia; pan or zoom out to view partner sites."
  />

  <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-10 space-y-12">
    <div>
      <h2 class="text-xs uppercase tracking-widest text-brand-600 font-semibold mb-3">East Asia network</h2>
      <WorldMap
        groups={mapGroups}
        height="540px"
        initialCenter={[31, 126]}
        initialZoom={5}
      />
    </div>

    <div class="space-y-10">
      {asianGroups.map(([country, dbs]) => {
        const meta = countryMeta[country];
        return (
          <article>
            <header class="flex items-baseline gap-3 mb-4 border-b border-slate-200 pb-2">
              <span class="text-3xl leading-none">{meta?.flag ?? "🏳️"}</span>
              <h2 class="text-2xl font-bold text-slate-900">{country}</h2>
            </header>
            <div class="grid gap-4 md:grid-cols-2">
              {dbs.map((d) => {
                const anchor = `db-${d.name.replace(/[^a-z0-9]+/gi, "-").toLowerCase()}`;
                const chip = typeColor[d.type] ?? "bg-slate-100 text-slate-700 border-slate-200";
                const url = (d as { url?: string }).url;
                const isNhird = d.name === "National Health Insurance Research Database (NHIRD)";
                return (
                  <div
                    id={anchor}
                    data-db-card
                    data-db-name={d.name}
                    draggable="true"
                    class="group scroll-mt-24 border border-slate-200 rounded-lg p-5 bg-white hover:shadow-md transition cursor-grab active:cursor-grabbing data-[compare-on]:border-brand-500 data-[compare-on]:ring-1 data-[compare-on]:ring-brand-500"
                  >
                    <div class="flex items-start justify-between gap-3 mb-2">
                      {url ? (
                        <a
                          href={url}
                          target="_blank"
                          rel="noopener"
                          class="font-semibold text-slate-900 leading-snug hover:text-brand-700 hover:underline decoration-brand-400 underline-offset-2"
                        >
                          {d.name}
                        </a>
                      ) : (
                        <h3 class="font-semibold text-slate-900 leading-snug">{d.name}</h3>
                      )}
                      <span class={`shrink-0 text-xs font-medium px-2 py-0.5 rounded-full border ${chip}`}>{d.type}</span>
                    </div>
                    <p class="text-sm text-slate-700"><strong>Coverage:</strong> {d.coverage}</p>
                    <p class="text-sm text-slate-600 mt-2 leading-relaxed">{d.notes}</p>

                    <div class="mt-3 flex items-center gap-3 flex-wrap">
                      <button
                        type="button"
                        data-compare-add
                        class="inline-flex items-center gap-1 text-xs font-semibold text-brand-700 hover:text-brand-900 hover:underline data-[on]:text-emerald-700"
                      >
                        <span data-compare-icon>＋</span>
                        <span data-compare-label>Add to compare</span>
                      </button>
                      {isNhird && (
                        <a
                          href={`${siteBase}nhird/`}
                          class="inline-flex items-center gap-1 text-xs font-semibold text-brand-700 hover:underline opacity-0 group-hover:opacity-100 focus:opacity-100 transition-opacity"
                        >
                          Explore Taiwan's data infrastructure <span aria-hidden="true">→</span>
                        </a>
                      )}
                    </div>
                  </div>
                );
              })}
            </div>
          </article>
        );
      })}
    </div>

    {externalGroups.length > 0 && (
      <div class="mt-16">
        <h2 class="text-xs uppercase tracking-widest text-brand-600 font-semibold mb-2">International partner sites</h2>
        <p class="text-sm text-slate-600 max-w-3xl mb-6">
          AsPEN collaborators draw on data partners outside East Asia for benchmarking and methodological comparison — including UK, US, European, and Australian sites linked through the NeuroGEN data initiative.
        </p>
        <div class="space-y-8">
          {externalGroups.map(([country, dbs]) => {
            const meta = countryMeta[country];
            return (
              <article>
                <header class="flex items-baseline gap-3 mb-4 border-b border-slate-200 pb-2">
                  <span class="text-3xl leading-none">{meta?.flag ?? "🏳️"}</span>
                  <h2 class="text-2xl font-bold text-slate-900">{country}</h2>
                </header>
                <div class="grid gap-4 md:grid-cols-2">
                  {dbs.map((d) => {
                    const anchor = `db-${d.name.replace(/[^a-z0-9]+/gi, "-").toLowerCase()}`;
                    const chip = typeColor[d.type] ?? "bg-slate-100 text-slate-700 border-slate-200";
                    return (
                      <div
                        id={anchor}
                        data-db-card
                        data-db-name={d.name}
                        draggable="true"
                        class="scroll-mt-24 border border-slate-200 rounded-lg p-5 bg-white hover:shadow-md transition cursor-grab active:cursor-grabbing data-[compare-on]:border-brand-500 data-[compare-on]:ring-1 data-[compare-on]:ring-brand-500"
                      >
                        <div class="flex items-start justify-between gap-3 mb-2">
                          <h3 class="font-semibold text-slate-900 leading-snug">{d.name}</h3>
                          <span class={`shrink-0 text-xs font-medium px-2 py-0.5 rounded-full border ${chip}`}>{d.type}</span>
                        </div>
                        <p class="text-sm text-slate-700"><strong>Coverage:</strong> {d.coverage}</p>
                        <p class="text-sm text-slate-600 mt-2 leading-relaxed">{d.notes}</p>

                        <div class="mt-3 flex items-center gap-3 flex-wrap">
                          <button
                            type="button"
                            data-compare-add
                            class="inline-flex items-center gap-1 text-xs font-semibold text-brand-700 hover:text-brand-900 hover:underline data-[on]:text-emerald-700"
                          >
                            <span data-compare-icon>＋</span>
                            <span data-compare-label>Add to compare</span>
                          </button>
                        </div>
                      </div>
                    );
                  })}
                </div>
              </article>
            );
          })}
        </div>
      </div>
    )}

    <!-- Compare tray.
         Default (mobile / tablet): sits inline below cards, normal flow.
         lg+: becomes a fixed drawer pinned to the right edge of the viewport,
         hidden off-screen until opened via the tab handle (rendered below).
         Single element used in both modes — JS toggles the `data-open`
         attribute on the lg+ drawer. -->
    <section
      id="compare"
      data-compare-tray
      class="mt-12 border border-slate-200 rounded-lg bg-white shadow-sm scroll-mt-24
             lg:mt-0 lg:fixed lg:right-0 lg:top-24 lg:bottom-6 lg:w-[480px] xl:w-[560px] lg:z-30
             lg:translate-x-full lg:rounded-r-none lg:shadow-2xl lg:transition-transform lg:duration-300 lg:ease-out
             lg:data-[open]:translate-x-0 lg:flex lg:flex-col lg:overflow-hidden"
    >
      <header class="flex items-baseline justify-between gap-3 px-4 py-3 border-b border-slate-200 lg:shrink-0">
        <div>
          <h2 class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Compare databases</h2>
          <p class="text-sm text-slate-600 mt-1 lg:hidden">
            Click <span class="font-semibold text-brand-700">＋ Add to compare</span> on any card above to line databases up on a coverage timeline.
          </p>
          <p class="hidden lg:block text-xs text-slate-500 mt-1 leading-snug">
            Drag any card or click <span class="font-semibold text-brand-700">＋ Add</span> to plot it on the timeline.
          </p>
        </div>
        <button
          type="button"
          data-compare-clear
          class="hidden shrink-0 text-xs font-semibold text-slate-500 hover:text-rose-600 hover:underline"
        >Clear</button>
      </header>

      <div
        data-compare-dropzone
        class="m-3 lg:m-3 min-h-[120px] lg:flex-1 lg:overflow-y-auto border-2 border-dashed border-slate-300 rounded-lg p-3 transition data-[dragover]:border-brand-500 data-[dragover]:bg-brand-50/40"
      >
        <p data-compare-empty class="text-sm text-slate-500 italic text-center py-6 px-2 leading-snug">
          <span class="lg:hidden">Tap <span class="font-semibold text-brand-700 not-italic">＋ Add to compare</span> on any card above.</span>
          <span class="hidden lg:inline">Drop cards here<br><span class="text-xs not-italic">or click <span class="font-semibold text-brand-700">＋ Add</span> on any card</span></span>
        </p>
        <div data-compare-grid class="hidden"></div>
      </div>
    </section>

    <!-- Tab handle for the lg+ drawer. Always visible at the right edge;
         click toggles the drawer; drop on it adds + opens. -->
    <button
      type="button"
      data-compare-tab
      class="hidden lg:flex fixed right-0 top-1/2 -translate-y-1/2 z-30 items-center gap-2 bg-brand-700 hover:bg-brand-800 text-white shadow-lg rounded-l-lg pl-2 pr-1.5 py-3 text-xs font-semibold transition data-[dragover]:bg-emerald-600 data-[dragover]:scale-105 origin-right"
      aria-label="Open compare panel"
      aria-expanded="false"
    >
      <span class="[writing-mode:vertical-rl] rotate-180 tracking-widest uppercase text-[10px]">Compare</span>
      <span data-compare-tab-count class="hidden bg-white text-brand-700 rounded-full px-1.5 py-0.5 text-[10px] tabular-nums font-bold">0</span>
    </button>

    <script is:inline define:vars={{ compareData, siteBase }}>
      (() => {
        const tray     = document.querySelector("[data-compare-tray]");
        const dropzone = tray?.querySelector("[data-compare-dropzone]");
        const emptyEl  = tray?.querySelector("[data-compare-empty]");
        const grid     = tray?.querySelector("[data-compare-grid]");
        const clearBtn = tray?.querySelector("[data-compare-clear]");
        const tab      = document.querySelector("[data-compare-tab]");
        const tabCount = tab?.querySelector("[data-compare-tab-count]");
        if (!tray || !dropzone || !grid) return;

        // Drawer open/close (lg+ only — on smaller screens the tray is inline)
        const isDrawerMode = () => window.matchMedia("(min-width: 1024px)").matches;
        const openDrawer = () => {
          tray.setAttribute("data-open", "");
          if (tab) tab.setAttribute("aria-expanded", "true");
        };
        const closeDrawer = () => {
          tray.removeAttribute("data-open");
          if (tab) tab.setAttribute("aria-expanded", "false");
        };
        const toggleDrawer = () => {
          if (tray.hasAttribute("data-open")) closeDrawer();
          else openDrawer();
        };

        const MAX = 20; // all databases on the page
        const selected = [];

        const cards = Array.from(document.querySelectorAll("[data-db-card]"));

        const esc = (s) =>
          String(s ?? "").replace(/[&<>"']/g, (c) => ({
            "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;",
          }[c]));

        // Short label: prefer the acronym in trailing parens (e.g. "NHIRD"),
        // otherwise fall back to first 1–2 words after stripping parentheticals
        // (so "Medicare (20% sample)" → "Medicare", not "Medicare (20%").
        const shortName = (name) => {
          const matches = name.match(/\(([^)]+)\)/g);
          if (matches) {
            const last = matches[matches.length - 1].slice(1, -1).trim();
            if (/^[A-Z][A-Z0-9–\-]{1,14}$/.test(last)) return last;
          }
          return name.replace(/\s*\([^)]*\)\s*/g, " ").trim().split(/\s+/).slice(0, 2).join(" ");
        };

        const CURRENT_YEAR = new Date().getFullYear();

        // Type → bar colour class (matches the chip palette used on the cards)
        const TYPE_COLOR = {
          "Claims":                   "bg-emerald-500",
          "National EHR":             "bg-sky-500",
          "Multi-institutional EHR":  "bg-indigo-500",
          "Primary-care EHR":         "bg-violet-500",
          "Biobank":                  "bg-amber-500",
        };
        const TYPE_TEXT = {
          "Claims":                   "text-emerald-700 bg-emerald-50 border-emerald-200",
          "National EHR":             "text-sky-700 bg-sky-50 border-sky-200",
          "Multi-institutional EHR":  "text-indigo-700 bg-indigo-50 border-indigo-200",
          "Primary-care EHR":         "text-violet-700 bg-violet-50 border-violet-200",
          "Biobank":                  "text-amber-700 bg-amber-50 border-amber-200",
        };
        const colorOf = (t) => TYPE_COLOR[t] ?? "bg-slate-500";
        const textColorOf = (t) => TYPE_TEXT[t] ?? "text-slate-700 bg-slate-50 border-slate-200";

        // Which chart is currently selected (sticky across re-renders + add/remove)
        let activeChart = "timeline"; // "timeline" | "population" | "scope"

        // Fixed feature set for the Data Scope matrix. `id` matches the
        // databases.json `features` enum; `short` is the column header
        // glyph, `label` shows on hover.
        const FEATURES = [
          { id: "rx",        short: "Rx",   label: "Prescriptions" },
          { id: "dx",        short: "Dx",   label: "Diagnoses" },
          { id: "labs",      short: "Lab",  label: "Lab results" },
          { id: "imaging",   short: "Img",  label: "Imaging" },
          { id: "mortality", short: "Mor",  label: "Mortality linkage" },
          { id: "cancer",    short: "Can",  label: "Cancer-registry linkage" },
          { id: "pregnancy", short: "Preg", label: "Birth / pregnancy linkage" },
          { id: "genomics",  short: "Gen",  label: "Genomics / biobank linkage" },
        ];

        // Render helpers shared by all 3 charts
        const buildChipsHtml = (items) => `
          <div class="flex flex-wrap gap-1 mb-3 px-1">
            ${items.map((d) => `
              <span class="inline-flex items-center gap-0.5 text-[10px] bg-brand-100 text-brand-800 rounded-full pl-2 pr-1 py-0.5 font-semibold">
                <span aria-hidden="true">${esc(d.flag)}</span>
                <span>${esc(shortName(d.name))}</span>
                <button type="button" data-compare-remove="${esc(d.name)}" class="ml-0.5 w-4 h-4 inline-flex items-center justify-center rounded-full hover:bg-white hover:text-rose-600" aria-label="Remove ${esc(d.name)}">×</button>
              </span>
            `).join("")}
          </div>
        `;

        const buildTabsHtml = () => `
          <div role="tablist" aria-label="Comparison chart" class="flex gap-0.5 mb-3 p-0.5 bg-slate-100 rounded-lg text-[11px] font-semibold">
            ${[
              { id: "timeline",   label: "Timeline" },
              { id: "population", label: "Population" },
              { id: "scope",      label: "Data scope" },
            ].map((t) => `
              <button type="button" role="tab" data-chart-tab="${t.id}" aria-selected="${activeChart === t.id}"
                class="flex-1 px-2 py-1.5 rounded-md transition aria-selected:bg-white aria-selected:shadow-sm aria-selected:text-brand-700 text-slate-600 hover:text-slate-900">
                ${t.label}
              </button>
            `).join("")}
          </div>
        `;

        const buildLegendHtml = (items) => {
          const typesPresent = Array.from(new Set(items.map((d) => d.type)));
          return `
            <div class="flex flex-wrap gap-1.5 mt-3 px-1">
              ${typesPresent.map((t) => `
                <span class="inline-flex items-center gap-1 text-[9px] uppercase tracking-wider font-semibold px-1.5 py-0.5 rounded border ${textColorOf(t)}">
                  <span class="w-2 h-2 rounded-sm ${colorOf(t)}"></span>${esc(t)}
                </span>
              `).join("")}
            </div>
          `;
        };

        // Compact details panel below the chart (Coverage only — Notes removed)
        const buildDetailsHtml = (items) => `
          <section class="px-1 pt-3 mt-3 border-t border-brand-100">
            <h3 class="text-[10px] uppercase tracking-widest text-brand-600 font-bold mb-1">Details</h3>
            ${items.map((d) => `
              <div class="py-2 border-t border-slate-100 first:border-t-0">
                <div class="flex items-baseline gap-1.5">
                  <span class="text-sm leading-none" aria-hidden="true">${esc(d.flag)}</span>
                  <span class="font-semibold text-slate-800 text-xs">${esc(shortName(d.name))}</span>
                  <span class="text-[10px] text-slate-500 ml-auto tabular-nums">${typeof d.since === "number" ? d.since + "–" : "—"} · ${d.popM > 0 ? d.popM + "M" : "—"}</span>
                </div>
                <p class="text-[11px] text-slate-700 leading-snug mt-1">${esc(d.coverage || "—")}</p>
              </div>
            `).join("")}
          </section>
        `;

        // ── Chart 1: Coverage timeline (Gantt — start year → today; uniform bar
        // height so the rows don't get visually noisy. Population already has
        // its own tab and a numeric label on the right; type is the bar colour.)
        const buildTimelineChart = (items) => {
          const sorted = [...items].sort((a, b) => {
            const ay = typeof a.since === "number" ? a.since : CURRENT_YEAR + 1;
            const by = typeof b.since === "number" ? b.since : CURRENT_YEAR + 1;
            return ay - by;
          });
          const knownYears = sorted.map((d) => d.since).filter((y) => typeof y === "number");
          const minYear = knownYears.length ? Math.min(...knownYears) : CURRENT_YEAR - 5;
          const yearSpan = Math.max(1, CURRENT_YEAR - minYear);
          const tickStart = Math.ceil(minYear / 10) * 10;
          const ticks = [];
          for (let y = tickStart; y < CURRENT_YEAR; y += 10) ticks.push(y);

          const BAR_HEIGHT = 8; // px, uniform across rows

          const rows = sorted.map((d) => {
            const hasYear = typeof d.since === "number";
            const offset = hasYear ? ((d.since - minYear) / yearSpan) * 100 : 0;
            const width  = hasYear ? Math.max(2, 100 - offset) : 100;
            const popLabel = d.popM > 0 ? d.popM + "M" : "—";
            const sinceLabel = hasYear ? d.since : "—";
            return `
              <div class="grid grid-cols-[28px_minmax(0,1fr)_84px] items-center gap-2 py-1.5 hover:bg-brand-50/40 rounded transition">
                <span class="tabular-nums text-[10px] text-slate-500 text-right">${sinceLabel}</span>
                <div class="relative h-5 flex items-center">
                  <div class="absolute inset-x-0 top-1/2 -translate-y-1/2 h-px bg-slate-200"></div>
                  ${ticks.map((y) => {
                    const tickPct = ((y - minYear) / yearSpan) * 100;
                    return `<div class="absolute top-0 bottom-0 w-px bg-slate-100" style="left:${tickPct.toFixed(1)}%"></div>`;
                  }).join("")}
                  <div class="absolute rounded-sm ${colorOf(d.type)} flex items-center justify-start opacity-90 hover:opacity-100"
                       style="left:${offset.toFixed(1)}%; width:${width.toFixed(1)}%; height:${BAR_HEIGHT}px;">
                    ${hasYear ? `<span class="text-[11px] leading-none -ml-1 select-none" aria-hidden="true">${esc(d.flag)}</span>` : ""}
                  </div>
                </div>
                <div class="text-right min-w-0">
                  <a href="#${esc(d.anchor)}" class="block text-[11px] font-semibold text-slate-800 hover:text-brand-700 hover:underline truncate" title="${esc(d.name)}">${esc(shortName(d.name))}</a>
                  <span class="block text-[10px] tabular-nums text-slate-500">${esc(popLabel)}</span>
                </div>
              </div>
            `;
          }).join("");

          const axis = `
            <div class="grid grid-cols-[28px_minmax(0,1fr)_84px] gap-2 pt-1 mt-1 border-t border-slate-100">
              <span></span>
              <div class="relative h-3 text-[9px] text-slate-400 tabular-nums">
                <span class="absolute left-0 -translate-x-1/2">${minYear}</span>
                ${ticks.map((y) => {
                  const pct = ((y - minYear) / yearSpan) * 100;
                  return `<span class="absolute -translate-x-1/2" style="left:${pct.toFixed(1)}%">${y}</span>`;
                }).join("")}
                <span class="absolute right-0 translate-x-1/2">${CURRENT_YEAR}</span>
              </div>
              <span></span>
            </div>
          `;

          return `
            <h3 class="text-[10px] uppercase tracking-widest text-brand-600 font-bold mb-2">Coverage timeline · ${items.length} ${items.length === 1 ? "database" : "databases"}</h3>
            <div>${rows}</div>
            ${axis}
            ${buildLegendHtml(items)}
          `;
        };

        // ── Chart 2: Population — ranked horizontal bars (length ∝ population).
        // Bars are far easier to compare at a glance than circle areas.
        // Sorted largest first; the longest bar fills the row width and others
        // scale linearly off it. Value sits inside long bars or to the right
        // of short ones so it's always readable.
        const buildPopulationChart = (items) => {
          const sorted = [...items].sort((a, b) => (b.popM || 0) - (a.popM || 0));
          const maxPop = Math.max(1, ...sorted.map((d) => d.popM || 0));

          // Choose round tick values relative to max (e.g. 0, 50M, 100M, 150M)
          const niceStep = (max) => {
            const candidates = [0.05, 0.1, 0.2, 0.5, 1, 2, 5, 10, 20, 25, 50, 100];
            for (const s of candidates) if (max / s <= 5) return s;
            return Math.ceil(max / 5);
          };
          const step = niceStep(maxPop);
          const axisMax = Math.ceil(maxPop / step) * step;
          const ticks = [];
          for (let v = 0; v <= axisMax + 1e-9; v += step) ticks.push(v);

          const fmt = (v) => v >= 1 ? v.toLocaleString() : v.toFixed(2);

          const rows = sorted.map((d) => {
            const pop = d.popM || 0;
            const w = pop > 0 ? Math.max(1.5, (pop / axisMax) * 100) : 0;
            const inside = w > 22; // wide enough to fit the label inside the bar
            const label = pop > 0 ? `${fmt(pop)} M` : "—";
            return `
              <div class="grid grid-cols-[minmax(0,108px)_minmax(0,1fr)] items-center gap-2 py-1 hover:bg-brand-50/40 rounded transition">
                <a href="#${esc(d.anchor)}" class="flex items-center gap-1.5 text-[11px] font-semibold text-slate-800 hover:text-brand-700 hover:underline truncate" title="${esc(d.name)}">
                  <span class="text-sm leading-none shrink-0" aria-hidden="true">${esc(d.flag)}</span>
                  <span class="truncate">${esc(shortName(d.name))}</span>
                </a>
                <div class="relative h-6">
                  <!-- background gridlines at each axis tick -->
                  ${ticks.map((v) => {
                    if (v === 0) return "";
                    const pct = (v / axisMax) * 100;
                    return `<div class="absolute top-0 bottom-0 w-px bg-slate-100" style="left:${pct.toFixed(2)}%"></div>`;
                  }).join("")}
                  <!-- the bar itself -->
                  <div class="absolute top-1/2 -translate-y-1/2 h-5 ${colorOf(d.type)} rounded-sm flex items-center px-1.5 opacity-90"
                       style="width:${w.toFixed(2)}%; min-width:${pop > 0 ? "8px" : "0"};">
                    ${inside ? `<span class="text-[10px] font-bold text-white tabular-nums leading-none">${esc(label)}</span>` : ""}
                  </div>
                  ${!inside ? `<span class="absolute top-1/2 -translate-y-1/2 text-[10px] font-semibold text-slate-700 tabular-nums leading-none" style="left:calc(${w.toFixed(2)}% + 4px)">${esc(label)}</span>` : ""}
                </div>
              </div>
            `;
          }).join("");

          // Bottom axis with tick labels (0, 50M, 100M, ...)
          const axis = `
            <div class="grid grid-cols-[minmax(0,108px)_minmax(0,1fr)] gap-2 pt-1 mt-1 border-t border-slate-100">
              <span></span>
              <div class="relative h-3 text-[9px] text-slate-400 tabular-nums">
                ${ticks.map((v) => {
                  const pct = (v / axisMax) * 100;
                  const label = v === 0 ? "0" : (v >= 1 ? v.toLocaleString() : v.toFixed(2)) + " M";
                  const align = v === 0 ? "" : (Math.abs(pct - 100) < 0.5 ? "right-0 translate-x-1/2" : "-translate-x-1/2");
                  const left = v === 0 ? "left:0" : `left:${pct.toFixed(2)}%`;
                  return `<span class="absolute ${align}" style="${left}">${label}</span>`;
                }).join("")}
              </div>
            </div>
          `;

          return `
            <h3 class="text-[10px] uppercase tracking-widest text-brand-600 font-bold mb-1">Population covered · sorted largest first</h3>
            <p class="text-[10px] text-slate-500 mb-3 leading-snug">Bar length is the covered population (millions), on a linear scale. Colour by database type.</p>
            <div>${rows}</div>
            ${axis}
            ${buildLegendHtml(items)}
          `;
        };

        // ── Chart 3: Data scope — what kinds of data each DB actually carries.
        // Matrix: rows = selected DBs (sorted by feature richness, most-loaded
        // on top), columns = the 8 FEATURES (Rx / Dx / Lab / Img / Mor / Can /
        // Preg / Gen). Each cell is a filled (●) or empty (○) circle indicating
        // whether that DB has that feature. Column headers carry full tooltips
        // for the short codes.
        const buildScopeChart = (items) => {
          const sorted = [...items].sort((a, b) => (b.features?.length ?? 0) - (a.features?.length ?? 0));

          const headerCells = FEATURES.map((f) => `
            <div class="text-center" title="${esc(f.label)}">
              <span class="text-[9px] font-bold text-slate-500 uppercase tracking-wider">${esc(f.short)}</span>
            </div>
          `).join("");

          const rows = sorted.map((d) => {
            const set = new Set(d.features ?? []);
            const cells = FEATURES.map((f) => {
              const has = set.has(f.id);
              return `
                <div class="flex items-center justify-center" title="${esc(f.label)}: ${has ? "yes" : "no"}">
                  ${has
                    ? `<span class="block w-3 h-3 rounded-full ${colorOf(d.type)} shadow-sm" aria-hidden="true"></span><span class="sr-only">${esc(f.label)}: yes</span>`
                    : `<span class="block w-3 h-3 rounded-full border border-slate-300 bg-white" aria-hidden="true"></span><span class="sr-only">${esc(f.label)}: no</span>`}
                </div>
              `;
            }).join("");
            return `
              <div class="grid grid-cols-[minmax(0,110px)_repeat(8,minmax(0,1fr))] items-center gap-1 py-1.5 hover:bg-brand-50/40 rounded transition">
                <a href="#${esc(d.anchor)}" class="flex items-center gap-1.5 text-[11px] font-semibold text-slate-800 hover:text-brand-700 hover:underline truncate" title="${esc(d.name)}">
                  <span class="text-sm leading-none shrink-0" aria-hidden="true">${esc(d.flag)}</span>
                  <span class="truncate">${esc(shortName(d.name))}</span>
                </a>
                ${cells}
              </div>
            `;
          }).join("");

          // Header row (matches the grid columns of the data rows)
          const headerRow = `
            <div class="grid grid-cols-[minmax(0,110px)_repeat(8,minmax(0,1fr))] items-center gap-1 pb-1 mb-1 border-b border-slate-100">
              <span></span>
              ${headerCells}
            </div>
          `;

          return `
            <h3 class="text-[10px] uppercase tracking-widest text-brand-600 font-bold mb-1">Data scope</h3>
            <p class="text-[10px] text-slate-500 mb-3 leading-snug">Which clinical data types and registry linkages each database carries — the practical answer to "can I study X here?"</p>
            <div>${headerRow}${rows}</div>
            ${buildLegendHtml(items)}
          `;
        };

        const CHART_BUILDERS = {
          timeline: buildTimelineChart,
          population: buildPopulationChart,
          scope: buildScopeChart,
        };

        const render = () => {
          const has = selected.length > 0;
          emptyEl.classList.toggle("hidden", has);
          grid.classList.toggle("hidden", !has);
          clearBtn.classList.toggle("hidden", !has);

          const items = selected.map((n) => compareData[n]).filter(Boolean);
          if (items.length === 0) { grid.innerHTML = ""; reflect(); return; }

          const chartBuilder = CHART_BUILDERS[activeChart] ?? buildTimelineChart;

          grid.innerHTML = `
            ${buildChipsHtml(items)}
            ${buildTabsHtml()}
            <section class="px-1 pt-2 border-t border-brand-100">
              ${chartBuilder(items)}
            </section>
            ${buildDetailsHtml(items)}
          `;

          reflect();
        };

        // Reflect selection state on source cards
        const reflect = () => {
          cards.forEach((c) => {
            const name = c.dataset.dbName;
            const on = selected.includes(name);
            if (on) c.setAttribute("data-compare-on", "");
            else c.removeAttribute("data-compare-on");

            const btn   = c.querySelector("[data-compare-add]");
            const icon  = c.querySelector("[data-compare-icon]");
            const label = c.querySelector("[data-compare-label]");
            if (btn) {
              if (on) btn.setAttribute("data-on", "");
              else btn.removeAttribute("data-on");
            }
            if (icon)  icon.textContent  = on ? "✓" : "＋";
            if (label) label.textContent = on ? "Added" : "Add to compare";
          });
          if (tabCount) {
            if (selected.length > 0) {
              tabCount.textContent = String(selected.length);
              tabCount.classList.remove("hidden");
            } else {
              tabCount.classList.add("hidden");
            }
          }
          if (tab) {
            tab.setAttribute("aria-label", selected.length > 0
              ? `Compare panel (${selected.length} selected)`
              : "Open compare panel");
          }
        };

        const add = (name) => {
          if (!compareData[name]) return;
          if (selected.includes(name)) return;
          if (selected.length >= MAX) {
            // Drop the oldest one so the new one fits
            selected.shift();
          }
          selected.push(name);
          render();
        };

        const remove = (name) => {
          const i = selected.indexOf(name);
          if (i >= 0) {
            selected.splice(i, 1);
            render();
          }
        };

        const toggle = (name) => {
          if (selected.includes(name)) remove(name);
          else add(name);
        };

        // --- Drag from source cards
        cards.forEach((card) => {
          card.addEventListener("dragstart", (e) => {
            const name = card.dataset.dbName;
            if (!name || !e.dataTransfer) return;
            e.dataTransfer.setData("text/plain", name);
            e.dataTransfer.effectAllowed = "copy";
            card.classList.add("opacity-60");
          });
          card.addEventListener("dragend", () => {
            card.classList.remove("opacity-60");
          });

          // Click "+ Add to compare" → toggle
          const btn = card.querySelector("[data-compare-add]");
          if (btn) {
            btn.addEventListener("click", (e) => {
              e.preventDefault();
              const name = card.dataset.dbName;
              if (!name) return;
              const wasOff = !selected.includes(name);
              toggle(name);
              // On lg+ auto-open the drawer when adding; on smaller screens
              // scroll the inline tray into view so the user sees what happened.
              if (wasOff && selected.includes(name)) {
                if (isDrawerMode()) openDrawer();
                else tray.scrollIntoView({ behavior: "smooth", block: "nearest" });
              }
            });
          }
        });

        // --- Tab handle (lg+ only)
        if (tab) {
          tab.addEventListener("click", () => toggleDrawer());
          tab.addEventListener("dragover", (e) => {
            e.preventDefault();
            if (e.dataTransfer) e.dataTransfer.dropEffect = "copy";
            tab.setAttribute("data-dragover", "");
          });
          tab.addEventListener("dragleave", () => tab.removeAttribute("data-dragover"));
          tab.addEventListener("drop", (e) => {
            e.preventDefault();
            tab.removeAttribute("data-dragover");
            const name = e.dataTransfer?.getData("text/plain");
            if (name) {
              add(name);
              openDrawer();
            }
          });
        }

        // Close drawer on Esc
        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape" && tray.hasAttribute("data-open")) closeDrawer();
        });

        // --- Drop zone
        dropzone.addEventListener("dragover", (e) => {
          e.preventDefault();
          if (e.dataTransfer) e.dataTransfer.dropEffect = "copy";
          dropzone.setAttribute("data-dragover", "");
        });
        dropzone.addEventListener("dragleave", (e) => {
          // Only clear if leaving the dropzone itself, not entering a child
          if (e.target === dropzone) dropzone.removeAttribute("data-dragover");
        });
        dropzone.addEventListener("drop", (e) => {
          e.preventDefault();
          dropzone.removeAttribute("data-dragover");
          const name = e.dataTransfer?.getData("text/plain");
          if (name) {
            add(name);
            if (isDrawerMode()) openDrawer();
          }
        });

        // --- Remove buttons + chart-tab switch (event-delegated since the grid re-renders)
        grid.addEventListener("click", (e) => {
          const t = e.target;
          if (!(t instanceof HTMLElement)) return;
          if (t.dataset.compareRemove) {
            remove(t.dataset.compareRemove);
            return;
          }
          const tabBtn = t.closest("[data-chart-tab]");
          if (tabBtn instanceof HTMLElement && tabBtn.dataset.chartTab && tabBtn.dataset.chartTab !== activeChart) {
            activeChart = tabBtn.dataset.chartTab;
            render();
          }
        });

        // --- Clear all
        clearBtn.addEventListener("click", () => {
          selected.length = 0;
          render();
        });

        render();
      })();
    </script>

    <div class="mt-12" id="other-sites">
      <h2 class="text-xs uppercase tracking-widest text-slate-500 font-semibold mb-2 scroll-mt-24">Other sites</h2>
      <p class="text-sm text-slate-600 max-w-3xl leading-relaxed">
        Additional data sources documented that are not part of the current active network include Singapore's <strong>National Electronic Health Record (NEHR)</strong>, and two Thai sites — <strong>Buddhachinaraj Hospital Database (BHD)</strong> (a tertiary referral hospital EHR) and the <strong>Hospital Information network</strong> across 21 community hospitals in Ubon Ratchathani.
      </p>
    </div>

    <p class="text-xs text-slate-500 italic">
      Database descriptions adapted from the AsPEN paper (Lai ECC et al. <em>Epidemiology.</em> 2015 Nov;26(6):815-20. DOI: <a class="hover:text-brand-700 hover:underline not-italic" href="https://doi.org/10.1097/EDE.0000000000000325" target="_blank" rel="noopener">10.1097/EDE.0000000000000325</a>) and the NeuroGEN data-infrastructure paper (Tsai DHT et al., <em>Clinical Epidemiology</em> 2023; DOI: <a class="hover:text-brand-700 hover:underline not-italic" href="https://doi.org/10.2147/CLEP.S426485" target="_blank" rel="noopener">10.2147/CLEP.S426485</a>). Access policies and coverage may have changed since publication. Please verify with each data custodian before study planning.
    </p>
  </section>
</BaseLayout>
