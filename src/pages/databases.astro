---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import WorldMap from "../components/WorldMap.astro";
import CiteButton from "../components/CiteButton.astro";
import databases from "../data/databases.json";

const siteBase = import.meta.env.BASE_URL.replace(/\/?$/, "/"); // ensure trailing slash
const siteUrl = `https://phd-center.github.io${siteBase}databases/`;

const countryMeta: Record<
  string,
  { code: string; flag: string; lat: number; lng: number; region: "asia" | "external" }
> = {
  Japan:            { code: "JP", flag: "🇯🇵", lat: 35.68, lng: 139.65, region: "asia" },
  "South Korea":    { code: "KR", flag: "🇰🇷", lat: 36.5,  lng: 127.8,  region: "asia" },
  Taiwan:           { code: "TW", flag: "🇹🇼", lat: 23.7,  lng: 121.0,  region: "asia" },
  "Hong Kong":      { code: "HK", flag: "🇭🇰", lat: 22.32, lng: 114.17, region: "asia" },
  "United Kingdom": { code: "GB",     flag: "🇬🇧",                       lat: 51.5,   lng: -0.13,  region: "external" },
  Scotland:         { code: "gb-sct", flag: "🏴\u{E0067}\u{E0062}\u{E0073}\u{E0063}\u{E0074}\u{E007F}", lat: 55.95,  lng: -3.19,  region: "external" },
  "United States":  { code: "US",     flag: "🇺🇸",                       lat: 38.91,  lng: -77.04, region: "external" },
  Netherlands:      { code: "NL",     flag: "🇳🇱",                       lat: 52.09,  lng: 5.12,   region: "external" },
  Finland:          { code: "FI",     flag: "🇫🇮",                       lat: 60.17,  lng: 24.94,  region: "external" },
  Australia:        { code: "AU",     flag: "🇦🇺",                       lat: -25.27, lng: 133.78, region: "external" },
  Singapore:        { code: "SG",     flag: "🇸🇬",                       lat: 1.35,   lng: 103.82, region: "external" },
  Thailand:         { code: "TH",     flag: "🇹🇭",                       lat: 13.76,  lng: 100.50, region: "external" },
};

// Group databases by country for the cards (Scotland's ISD goes under UK section)
const groupedMap = new Map<string, typeof databases>();
for (const d of databases) {
  if (!groupedMap.has(d.country)) groupedMap.set(d.country, []);
  groupedMap.get(d.country)!.push(d);
}
const grouped = Array.from(groupedMap.entries());

const asianGroups = grouped.filter(([c]) => countryMeta[c]?.region === "asia");
const externalGroups = grouped.filter(([c]) => countryMeta[c]?.region === "external");

// Separate grouping for the MAP — allows mapAs override so e.g. Scotland gets its
// own flag marker even though the ISD database is listed under United Kingdom.
const mapGroupedMap = new Map<string, typeof databases>();
for (const d of databases) {
  const key = (d as { mapAs?: string }).mapAs ?? d.country;
  if (!mapGroupedMap.has(key)) mapGroupedMap.set(key, []);
  mapGroupedMap.get(key)!.push(d);
}
const mapGroups = Array.from(mapGroupedMap.entries()).map(([key, dbs]) => {
  const meta = countryMeta[key]!;
  return {
    country: key,
    code: meta.code,
    lat: meta.lat,
    lng: meta.lng,
    items: dbs.map((d) => ({
      name: d.name,
      type: d.type,
      coverage: d.coverage,
      anchor: `db-${d.name.replace(/[^a-z0-9]+/gi, "-").toLowerCase()}`,
    })),
  };
});

// Singapore + Thailand — appear on the map (no anchor since they live in the prose section)
// Inline rather than in databases.json because they're "other sites", not active.
const otherMapEntries: Record<string, { name: string; type: string; coverage?: string }[]> = {
  Singapore: [
    { name: "National Electronic Health Record (NEHR)", type: "National EHR" },
  ],
  Thailand: [
    { name: "Buddhachinaraj Hospital Database (BHD)", type: "Single-hospital EHR" },
    { name: "Hospital Information (HI) — Ubon Ratchathani", type: "Multi-hospital EHR" },
  ],
};
for (const [country, items] of Object.entries(otherMapEntries)) {
  const meta = countryMeta[country];
  if (!meta) continue;
  mapGroups.push({
    country,
    code: meta.code,
    lat: meta.lat,
    lng: meta.lng,
    items: items.map((it) => ({ name: it.name, type: it.type, coverage: it.coverage ?? "", anchor: "other-sites" })),
  });
}

const typeColor: Record<string, string> = {
  Claims: "bg-emerald-50 text-emerald-700 border-emerald-200",
  "National EHR": "bg-sky-50 text-sky-700 border-sky-200",
  "Multi-institutional EHR": "bg-indigo-50 text-indigo-700 border-indigo-200",
  "Primary-care EHR": "bg-violet-50 text-violet-700 border-violet-200",
  Biobank: "bg-amber-50 text-amber-700 border-amber-200",
};

// Numeric derivations for the comparison table. Keyed by database name.
// `popM` = approximate covered population in millions (for sorting).
// `since` = data start year (omit when not confidently known).
const dbStats: Record<string, { popM: number; since?: number }> = {
  "National Health Insurance Research Database (NHIRD)": { popM: 23, since: 1995 },
  "Chang Gung Research Database (CGRD)": { popM: 1.5, since: 2000 },
  "Taiwan Biobank (TWB)": { popM: 0.2, since: 2012 },
  "National Database of Health Insurance Claims and Specific Health Checkups (NDB)": { popM: 120, since: 2008 },
  "JMDC Claims Database": { popM: 13.5 },
  "DeSC Database": { popM: 9.3, since: 2014 },
  "Medical Data Vision (MDV) Database": { popM: 48 },
  "Health Insurance Review and Assessment Service (HIRA)": { popM: 50, since: 2009 },
  "National Health Insurance Service – National Health Information Database (NHIS-NHID)": { popM: 50 },
  "Clinical Data Analysis and Reporting System (CDARS)": { popM: 7, since: 1995 },
  "Clinical Practice Research Datalink (CPRD)": { popM: 60 },
  "The Health Improvement Network (THIN)": { popM: 17, since: 2003 },
  "UK Biobank (UKB)": { popM: 0.5, since: 2006 },
  "Public Health Scotland (ISD)": { popM: 5.4 },
  "PHARMO Database Network": { popM: 7 },
  "Finnish healthcare registers (FinReg)": { popM: 5.5 },
  "Pharmaceutical Benefits Scheme — 10% sample (PBS)": { popM: 2.5 },
  "Victorian Linked Health Data (VLHD)": { popM: 6.5 },
  "Medicare (20% sample)": { popM: 13 },
  "Medicaid": { popM: 70 },
};

// Comparison data — keyed by database name. Used by the drag-and-drop
// comparison tray and serialised via define:vars to the inline script.
const compareData: Record<string, {
  country: string;
  flag: string;
  name: string;
  type: string;
  popM: number;
  since: number | null;
  coverage: string;
  notes: string;
  anchor: string;
}> = {};
for (const d of databases) {
  const meta = countryMeta[d.country];
  const stats = dbStats[d.name] ?? { popM: 0 };
  compareData[d.name] = {
    country: d.country,
    flag: meta?.flag ?? "🏳️",
    name: d.name,
    type: d.type,
    popM: stats.popM,
    since: stats.since ?? null,
    coverage: d.coverage,
    notes: d.notes,
    anchor: `db-${d.name.replace(/[^a-z0-9]+/gi, "-").toLowerCase()}`,
  };
}

// Other sites listed in the 2015 AsPEN database survey (Lai ECC et al., Epidemiology 2015)
// that are not part of the current active network. Reference only — not on the map.
const otherSites = [
  { country: "Singapore", flag: "🇸🇬", name: "National Electronic Health Record (NEHR)",     note: "Singapore's national EHR; listed in the 2015 AsPEN survey." },
  { country: "Thailand",  flag: "🇹🇭", name: "Buddhachinaraj Hospital Database (BHD)",       note: "Tertiary referral hospital EHR." },
  { country: "Thailand",  flag: "🇹🇭", name: "Hospital Information (HI) — Ubon Ratchathani", note: "21-community-hospital EHR network." },
];
---

<BaseLayout
  title="Databases — AsPEN"
  description="Healthcare databases accessible to AsPEN collaborators across East Asia, plus an external control."
>
  <PageHeader
    eyebrow="Data"
    title="Databases"
    description="Population-level health databases used in AsPEN multi-national studies. The map is focused on East Asia; pan or zoom out to view partner sites."
  />

  <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-10 space-y-12">
    <div>
      <h2 class="text-xs uppercase tracking-widest text-brand-600 font-semibold mb-3">East Asia network</h2>
      <WorldMap
        groups={mapGroups}
        height="540px"
        initialCenter={[31, 126]}
        initialZoom={5}
      />
    </div>

    <div class="lg:grid lg:grid-cols-[1fr_320px] lg:gap-8 lg:items-start">
    <div class="space-y-12 min-w-0">
    <div class="space-y-10">
      {asianGroups.map(([country, dbs]) => {
        const meta = countryMeta[country];
        return (
          <article>
            <header class="flex items-baseline gap-3 mb-4 border-b border-slate-200 pb-2">
              <span class="text-3xl leading-none">{meta?.flag ?? "🏳️"}</span>
              <h2 class="text-2xl font-bold text-slate-900">{country}</h2>
            </header>
            <div class="grid gap-4 md:grid-cols-2">
              {dbs.map((d) => {
                const anchor = `db-${d.name.replace(/[^a-z0-9]+/gi, "-").toLowerCase()}`;
                const chip = typeColor[d.type] ?? "bg-slate-100 text-slate-700 border-slate-200";
                const url = (d as { url?: string }).url;
                const isNhird = d.name === "National Health Insurance Research Database (NHIRD)";
                return (
                  <div
                    id={anchor}
                    data-db-card
                    data-db-name={d.name}
                    draggable="true"
                    class="group scroll-mt-24 border border-slate-200 rounded-lg p-5 bg-white hover:shadow-md transition cursor-grab active:cursor-grabbing data-[compare-on]:border-brand-500 data-[compare-on]:ring-1 data-[compare-on]:ring-brand-500"
                  >
                    <div class="flex items-start justify-between gap-3 mb-2">
                      {url ? (
                        <a
                          href={url}
                          target="_blank"
                          rel="noopener"
                          class="font-semibold text-slate-900 leading-snug hover:text-brand-700 hover:underline decoration-brand-400 underline-offset-2"
                        >
                          {d.name}
                        </a>
                      ) : (
                        <h3 class="font-semibold text-slate-900 leading-snug">{d.name}</h3>
                      )}
                      <span class={`shrink-0 text-xs font-medium px-2 py-0.5 rounded-full border ${chip}`}>{d.type}</span>
                    </div>
                    {d.city && <p class="text-xs text-slate-500 mb-2">{d.city}</p>}
                    <p class="text-sm text-slate-700"><strong>Coverage:</strong> {d.coverage}</p>
                    <p class="text-sm text-slate-600 mt-2 leading-relaxed">{d.notes}</p>

                    <div class="mt-3 flex items-center gap-3 flex-wrap">
                      <button
                        type="button"
                        data-compare-add
                        class="inline-flex items-center gap-1 text-xs font-semibold text-brand-700 hover:text-brand-900 hover:underline data-[on]:text-emerald-700"
                      >
                        <span data-compare-icon>＋</span>
                        <span data-compare-label>Add to compare</span>
                      </button>
                      {isNhird && (
                        <a
                          href={`${siteBase}nhird/`}
                          class="inline-flex items-center gap-1 text-xs font-semibold text-brand-700 hover:underline opacity-0 group-hover:opacity-100 focus:opacity-100 transition-opacity"
                        >
                          Explore the ecosystem <span aria-hidden="true">→</span>
                        </a>
                      )}
                    </div>
                  </div>
                );
              })}
            </div>
          </article>
        );
      })}
    </div>

    {externalGroups.length > 0 && (
      <div class="lg:mt-4">
        <h2 class="text-xs uppercase tracking-widest text-brand-600 font-semibold mb-2">International partner sites</h2>
        <p class="text-sm text-slate-600 max-w-3xl mb-6">
          AsPEN collaborators draw on data partners outside East Asia for benchmarking and methodological comparison — including UK, US, European, and Australian sites linked through the NeuroGEN data initiative.
        </p>
        <div class="space-y-8">
          {externalGroups.map(([country, dbs]) => {
            const meta = countryMeta[country];
            return (
              <article>
                <header class="flex items-baseline gap-3 mb-4 border-b border-slate-200 pb-2">
                  <span class="text-3xl leading-none">{meta?.flag ?? "🏳️"}</span>
                  <h2 class="text-2xl font-bold text-slate-900">{country}</h2>
                </header>
                <div class="grid gap-4 md:grid-cols-2">
                  {dbs.map((d) => {
                    const anchor = `db-${d.name.replace(/[^a-z0-9]+/gi, "-").toLowerCase()}`;
                    const chip = typeColor[d.type] ?? "bg-slate-100 text-slate-700 border-slate-200";
                    return (
                      <div
                        id={anchor}
                        data-db-card
                        data-db-name={d.name}
                        draggable="true"
                        class="scroll-mt-24 border border-slate-200 rounded-lg p-5 bg-white hover:shadow-md transition cursor-grab active:cursor-grabbing data-[compare-on]:border-brand-500 data-[compare-on]:ring-1 data-[compare-on]:ring-brand-500"
                      >
                        <div class="flex items-start justify-between gap-3 mb-2">
                          <h3 class="font-semibold text-slate-900 leading-snug">{d.name}</h3>
                          <span class={`shrink-0 text-xs font-medium px-2 py-0.5 rounded-full border ${chip}`}>{d.type}</span>
                        </div>
                        {d.city && <p class="text-xs text-slate-500 mb-2">{d.city}</p>}
                        <p class="text-sm text-slate-700"><strong>Coverage:</strong> {d.coverage}</p>
                        <p class="text-sm text-slate-600 mt-2 leading-relaxed">{d.notes}</p>

                        <div class="mt-3 flex items-center gap-3 flex-wrap">
                          <button
                            type="button"
                            data-compare-add
                            class="inline-flex items-center gap-1 text-xs font-semibold text-brand-700 hover:text-brand-900 hover:underline data-[on]:text-emerald-700"
                          >
                            <span data-compare-icon>＋</span>
                            <span data-compare-label>Add to compare</span>
                          </button>
                        </div>
                      </div>
                    );
                  })}
                </div>
              </article>
            );
          })}
        </div>
      </div>
    )}

    </div>
    <aside class="mt-12 lg:mt-0 lg:sticky lg:top-24 lg:max-h-[calc(100vh-7rem)] lg:overflow-y-auto">
    <section
      id="compare"
      data-compare-tray
      class="border border-slate-200 rounded-lg bg-white shadow-sm scroll-mt-24"
    >
      <header class="flex items-baseline justify-between gap-3 px-4 py-3 border-b border-slate-200">
        <div>
          <h2 class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Compare databases</h2>
          <p class="hidden lg:block text-xs text-slate-500 mt-1 leading-snug">Drag cards here, or click <span class="font-semibold text-brand-700">＋ Add</span> on any card. Up to 4.</p>
          <p class="lg:hidden text-sm text-slate-600 mt-1">
            Drag database cards into the tray — or click <span class="font-semibold text-brand-700">＋ Add to compare</span> — to line them up side-by-side. Up to 4 at a time.
          </p>
        </div>
        <button
          type="button"
          data-compare-clear
          class="hidden shrink-0 text-xs font-semibold text-slate-500 hover:text-rose-600 hover:underline"
        >Clear</button>
      </header>

      <div
        data-compare-dropzone
        class="m-3 lg:m-2 min-h-[120px] border-2 border-dashed border-slate-300 rounded-lg p-3 lg:p-2 transition data-[dragover]:border-brand-500 data-[dragover]:bg-brand-50/40"
      >
        <p
          data-compare-empty
          class="text-sm text-slate-500 italic text-center py-6 px-2 leading-snug"
        >
          Drop cards here<br><span class="text-xs not-italic">or click <span class="font-semibold text-brand-700">＋ Add to compare</span> on any card</span>
        </p>
        <div
          data-compare-grid
          class="hidden"
        ></div>
      </div>
    </section>
    </aside>
    </div>

    <script is:inline define:vars={{ compareData, siteBase }}>
      (() => {
        const tray     = document.querySelector("[data-compare-tray]");
        const dropzone = tray?.querySelector("[data-compare-dropzone]");
        const emptyEl  = tray?.querySelector("[data-compare-empty]");
        const grid     = tray?.querySelector("[data-compare-grid]");
        const clearBtn = tray?.querySelector("[data-compare-clear]");
        if (!tray || !dropzone || !grid) return;

        const MAX = 4;
        const selected = [];

        const cards = Array.from(document.querySelectorAll("[data-db-card]"));

        const esc = (s) =>
          String(s ?? "").replace(/[&<>"']/g, (c) => ({
            "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;",
          }[c]));

        // Short label: prefer the acronym in trailing parens (e.g. "NHIRD"),
        // otherwise fall back to first 1–2 words.
        const shortName = (name) => {
          const matches = name.match(/\(([^)]+)\)/g);
          if (matches) {
            const last = matches[matches.length - 1].slice(1, -1).trim();
            if (/^[A-Z][A-Z0-9–\-]{1,14}$/.test(last)) return last;
          }
          return name.split(/\s+/).slice(0, 2).join(" ");
        };

        const CURRENT_YEAR = new Date().getFullYear();

        const render = () => {
          const has = selected.length > 0;
          emptyEl.classList.toggle("hidden", has);
          grid.classList.toggle("hidden", !has);
          clearBtn.classList.toggle("hidden", !has);

          const items = selected.map((n) => compareData[n]).filter(Boolean);
          if (items.length === 0) { grid.innerHTML = ""; reflect(); return; }

          // Bar scaling
          const maxPop = Math.max(1, ...items.map((d) => d.popM || 0));
          const knownYears = items.map((d) => d.since).filter((y) => typeof y === "number");
          const minYear = knownYears.length ? Math.min(...knownYears) : CURRENT_YEAR - 5;
          const yearSpan = Math.max(1, CURRENT_YEAR - minYear);

          // Row helper — flag + short name (anchor) + content cell
          const row = (d, content) => `
            <div class="flex items-center gap-2 text-xs py-1">
              <span class="text-sm leading-none w-4 shrink-0" aria-hidden="true">${esc(d.flag)}</span>
              <a href="#${esc(d.anchor)}" class="font-semibold text-slate-700 hover:text-brand-700 hover:underline w-16 shrink-0 truncate" title="${esc(d.name)}">${esc(shortName(d.name))}</a>
              <div class="flex-1 min-w-0">${content}</div>
            </div>
          `;

          // Chips (selected items, with × to remove)
          const chipsHtml = `
            <div class="flex flex-wrap gap-1 mb-3 px-1">
              ${items.map((d) => `
                <span class="inline-flex items-center gap-0.5 text-[10px] bg-brand-100 text-brand-800 rounded-full pl-2 pr-1 py-0.5 font-semibold">
                  <span aria-hidden="true">${esc(d.flag)}</span>
                  <span>${esc(shortName(d.name))}</span>
                  <button type="button" data-compare-remove="${esc(d.name)}" class="ml-0.5 w-4 h-4 inline-flex items-center justify-center rounded-full hover:bg-white hover:text-rose-600" aria-label="Remove ${esc(d.name)}">×</button>
                </span>
              `).join("")}
            </div>
          `;

          // Population bars
          const popHtml = `
            <section class="px-1 pt-2 border-t border-brand-100">
              <h3 class="text-[10px] uppercase tracking-widest text-brand-600 font-bold mb-1.5">Population</h3>
              ${items.map((d) => {
                const w = d.popM > 0 ? Math.max(2, (d.popM / maxPop) * 100) : 0;
                const v = d.popM > 0 ? d.popM.toLocaleString() + "M" : "—";
                return row(d, `
                  <div class="flex items-center gap-2">
                    <div class="flex-1 h-2 bg-slate-100 rounded-sm overflow-hidden">
                      ${w > 0 ? `<div class="h-full bg-brand-500" style="width:${w.toFixed(0)}%"></div>` : ""}
                    </div>
                    <span class="tabular-nums text-slate-700 shrink-0 text-right w-12 text-[11px]">${esc(v)}</span>
                  </div>
                `);
              }).join("")}
            </section>
          `;

          // Timespan bars — left edge = oldest start year, right edge = current year
          const tsHtml = `
            <section class="px-1 pt-3 mt-2 border-t border-brand-100">
              <h3 class="text-[10px] uppercase tracking-widest text-brand-600 font-bold mb-1.5">Timespan</h3>
              ${items.map((d) => {
                let content;
                if (typeof d.since === "number") {
                  const offset = ((d.since - minYear) / yearSpan) * 100;
                  const width  = 100 - offset;
                  content = `
                    <div class="flex items-center gap-2">
                      <div class="flex-1 relative h-2 bg-slate-100 rounded-sm">
                        <div class="absolute h-full bg-brand-500 rounded-sm" style="left:${offset.toFixed(0)}%; width:${width.toFixed(0)}%"></div>
                      </div>
                      <span class="tabular-nums text-slate-700 shrink-0 text-right w-12 text-[11px]">${d.since}–</span>
                    </div>
                  `;
                } else {
                  content = `
                    <div class="flex items-center gap-2">
                      <div class="flex-1 h-2 bg-slate-100 rounded-sm"></div>
                      <span class="tabular-nums text-slate-400 italic shrink-0 text-right w-12 text-[11px]">unknown</span>
                    </div>
                  `;
                }
                return row(d, content);
              }).join("")}
              <div class="mt-1 flex justify-between text-[9px] text-slate-400 tabular-nums" style="margin-left:88px; padding-right:52px;">
                <span>${minYear}</span>
                <span>${CURRENT_YEAR}</span>
              </div>
            </section>
          `;

          // Text attribute section (Type, Coverage, Notes)
          const textSection = (label, getter, opts = {}) => `
            <section class="px-1 pt-3 mt-2 border-t border-brand-100">
              <h3 class="text-[10px] uppercase tracking-widest text-brand-600 font-bold mb-1.5">${label}</h3>
              ${items.map((d) => row(d, `<span class="text-[11px] text-slate-700 leading-snug ${opts.clamp ? "line-clamp-3" : ""}">${esc(getter(d) || "—")}</span>`)).join("")}
            </section>
          `;

          grid.innerHTML =
            chipsHtml +
            popHtml +
            tsHtml +
            textSection("Type", (d) => d.type) +
            textSection("Coverage", (d) => d.coverage, { clamp: true }) +
            textSection("Notes", (d) => d.notes, { clamp: true });

          reflect();
        };

        // Reflect selection state on source cards
        const reflect = () => {
          cards.forEach((c) => {
            const name = c.dataset.dbName;
            const on = selected.includes(name);
            if (on) c.setAttribute("data-compare-on", "");
            else c.removeAttribute("data-compare-on");

            const btn   = c.querySelector("[data-compare-add]");
            const icon  = c.querySelector("[data-compare-icon]");
            const label = c.querySelector("[data-compare-label]");
            if (btn) {
              if (on) btn.setAttribute("data-on", "");
              else btn.removeAttribute("data-on");
            }
            if (icon)  icon.textContent  = on ? "✓" : "＋";
            if (label) label.textContent = on ? "Added" : "Add to compare";
          });
        };

        const add = (name) => {
          if (!compareData[name]) return;
          if (selected.includes(name)) return;
          if (selected.length >= MAX) {
            // Drop the oldest one so the new one fits
            selected.shift();
          }
          selected.push(name);
          render();
        };

        const remove = (name) => {
          const i = selected.indexOf(name);
          if (i >= 0) {
            selected.splice(i, 1);
            render();
          }
        };

        const toggle = (name) => {
          if (selected.includes(name)) remove(name);
          else add(name);
        };

        // --- Drag from source cards
        cards.forEach((card) => {
          card.addEventListener("dragstart", (e) => {
            const name = card.dataset.dbName;
            if (!name || !e.dataTransfer) return;
            e.dataTransfer.setData("text/plain", name);
            e.dataTransfer.effectAllowed = "copy";
            card.classList.add("opacity-60");
          });
          card.addEventListener("dragend", () => {
            card.classList.remove("opacity-60");
          });

          // Click "+ Add to compare" → toggle
          const btn = card.querySelector("[data-compare-add]");
          if (btn) {
            btn.addEventListener("click", (e) => {
              e.preventDefault();
              const name = card.dataset.dbName;
              if (name) toggle(name);
              // First add scrolls the tray into view so the user sees what happened
              if (selected.length === 1 && selected[0] === name) {
                tray.scrollIntoView({ behavior: "smooth", block: "nearest" });
              }
            });
          }
        });

        // --- Drop zone
        dropzone.addEventListener("dragover", (e) => {
          e.preventDefault();
          if (e.dataTransfer) e.dataTransfer.dropEffect = "copy";
          dropzone.setAttribute("data-dragover", "");
        });
        dropzone.addEventListener("dragleave", (e) => {
          // Only clear if leaving the dropzone itself, not entering a child
          if (e.target === dropzone) dropzone.removeAttribute("data-dragover");
        });
        dropzone.addEventListener("drop", (e) => {
          e.preventDefault();
          dropzone.removeAttribute("data-dragover");
          const name = e.dataTransfer?.getData("text/plain");
          if (name) add(name);
        });

        // --- Remove buttons (event-delegated since the grid re-renders)
        grid.addEventListener("click", (e) => {
          const t = e.target;
          if (t instanceof HTMLElement && t.dataset.compareRemove) {
            remove(t.dataset.compareRemove);
          }
        });

        // --- Clear all
        clearBtn.addEventListener("click", () => {
          selected.length = 0;
          render();
        });

        render();
      })();
    </script>

    <div class="mt-12" id="other-sites">
      <h2 class="text-xs uppercase tracking-widest text-slate-500 font-semibold mb-2 scroll-mt-24">Other sites</h2>
      <p class="text-sm text-slate-600 max-w-3xl leading-relaxed">
        Additional data sources documented that are not part of the current active network include Singapore's <strong>National Electronic Health Record (NEHR)</strong>, and two Thai sites — <strong>Buddhachinaraj Hospital Database (BHD)</strong> (a tertiary referral hospital EHR) and the <strong>Hospital Information network</strong> across 21 community hospitals in Ubon Ratchathani.
      </p>
    </div>

    <p class="text-xs text-slate-500 italic">
      Database descriptions adapted from the AsPEN paper (Lai ECC et al. <em>Epidemiology.</em> 2015 Nov;26(6):815-20. DOI: <a class="hover:text-brand-700 hover:underline not-italic" href="https://doi.org/10.1097/EDE.0000000000000325" target="_blank" rel="noopener">10.1097/EDE.0000000000000325</a>) and the NeuroGEN data-infrastructure paper (Tsai DHT et al., <em>Clinical Epidemiology</em> 2023; DOI: <a class="hover:text-brand-700 hover:underline not-italic" href="https://doi.org/10.2147/CLEP.S426485" target="_blank" rel="noopener">10.2147/CLEP.S426485</a>). Access policies and coverage may have changed since publication. Please verify with each data custodian before study planning.
    </p>

    <CiteButton title="Databases" url={siteUrl} bibkey="aspen-databases" />
  </section>
</BaseLayout>
