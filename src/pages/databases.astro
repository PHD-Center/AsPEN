---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import WorldMap from "../components/WorldMap.astro";
import CiteButton from "../components/CiteButton.astro";
import databases from "../data/databases.json";

const siteUrl = new URL(import.meta.env.BASE_URL + "databases/", "https://phd-center.github.io").toString();

const countryMeta: Record<
  string,
  { code: string; flag: string; lat: number; lng: number; region: "asia" | "external" }
> = {
  Japan:            { code: "JP", flag: "🇯🇵", lat: 35.68, lng: 139.65, region: "asia" },
  "South Korea":    { code: "KR", flag: "🇰🇷", lat: 36.5,  lng: 127.8,  region: "asia" },
  Taiwan:           { code: "TW", flag: "🇹🇼", lat: 23.7,  lng: 121.0,  region: "asia" },
  "Hong Kong":      { code: "HK", flag: "🇭🇰", lat: 22.32, lng: 114.17, region: "asia" },
  "United Kingdom": { code: "GB",     flag: "🇬🇧",                       lat: 51.5,   lng: -0.13,  region: "external" },
  Scotland:         { code: "gb-sct", flag: "🏴\u{E0067}\u{E0062}\u{E0073}\u{E0063}\u{E0074}\u{E007F}", lat: 55.95,  lng: -3.19,  region: "external" },
  "United States":  { code: "US",     flag: "🇺🇸",                       lat: 38.91,  lng: -77.04, region: "external" },
  Netherlands:      { code: "NL",     flag: "🇳🇱",                       lat: 52.09,  lng: 5.12,   region: "external" },
  Finland:          { code: "FI",     flag: "🇫🇮",                       lat: 60.17,  lng: 24.94,  region: "external" },
  Australia:        { code: "AU",     flag: "🇦🇺",                       lat: -25.27, lng: 133.78, region: "external" },
  Singapore:        { code: "SG",     flag: "🇸🇬",                       lat: 1.35,   lng: 103.82, region: "external" },
  Thailand:         { code: "TH",     flag: "🇹🇭",                       lat: 13.76,  lng: 100.50, region: "external" },
};

// Group databases by country for the cards (Scotland's ISD goes under UK section)
const groupedMap = new Map<string, typeof databases>();
for (const d of databases) {
  if (!groupedMap.has(d.country)) groupedMap.set(d.country, []);
  groupedMap.get(d.country)!.push(d);
}
const grouped = Array.from(groupedMap.entries());

const asianGroups = grouped.filter(([c]) => countryMeta[c]?.region === "asia");
const externalGroups = grouped.filter(([c]) => countryMeta[c]?.region === "external");

// Separate grouping for the MAP — allows mapAs override so e.g. Scotland gets its
// own flag marker even though the ISD database is listed under United Kingdom.
const mapGroupedMap = new Map<string, typeof databases>();
for (const d of databases) {
  const key = (d as { mapAs?: string }).mapAs ?? d.country;
  if (!mapGroupedMap.has(key)) mapGroupedMap.set(key, []);
  mapGroupedMap.get(key)!.push(d);
}
const mapGroups = Array.from(mapGroupedMap.entries()).map(([key, dbs]) => {
  const meta = countryMeta[key]!;
  return {
    country: key,
    code: meta.code,
    lat: meta.lat,
    lng: meta.lng,
    items: dbs.map((d) => ({
      name: d.name,
      type: d.type,
      coverage: d.coverage,
      anchor: `db-${d.name.replace(/[^a-z0-9]+/gi, "-").toLowerCase()}`,
    })),
  };
});

// Singapore + Thailand — appear on the map (no anchor since they live in the prose section)
// Inline rather than in databases.json because they're "other sites", not active.
const otherMapEntries: Record<string, { name: string; type: string; coverage?: string }[]> = {
  Singapore: [
    { name: "National Electronic Health Record (NEHR)", type: "National EHR" },
  ],
  Thailand: [
    { name: "Buddhachinaraj Hospital Database (BHD)", type: "Single-hospital EHR" },
    { name: "Hospital Information (HI) — Ubon Ratchathani", type: "Multi-hospital EHR" },
  ],
};
for (const [country, items] of Object.entries(otherMapEntries)) {
  const meta = countryMeta[country];
  if (!meta) continue;
  mapGroups.push({
    country,
    code: meta.code,
    lat: meta.lat,
    lng: meta.lng,
    items: items.map((it) => ({ name: it.name, type: it.type, coverage: it.coverage ?? "", anchor: "other-sites" })),
  });
}

const typeColor: Record<string, string> = {
  Claims: "bg-emerald-50 text-emerald-700 border-emerald-200",
  "National EHR": "bg-sky-50 text-sky-700 border-sky-200",
  "Multi-institutional EHR": "bg-indigo-50 text-indigo-700 border-indigo-200",
  "Primary-care EHR": "bg-violet-50 text-violet-700 border-violet-200",
  Biobank: "bg-amber-50 text-amber-700 border-amber-200",
};

// Numeric derivations for the comparison table. Keyed by database name.
// `popM` = approximate covered population in millions (for sorting).
// `since` = data start year (omit when not confidently known).
const dbStats: Record<string, { popM: number; since?: number }> = {
  "National Health Insurance Research Database (NHIRD)": { popM: 23, since: 1995 },
  "Chang Gung Research Database (CGRD)": { popM: 1.5, since: 2000 },
  "Taiwan Biobank (TWB)": { popM: 0.2, since: 2012 },
  "National Database of Health Insurance Claims and Specific Health Checkups (NDB)": { popM: 120, since: 2008 },
  "JMDC Claims Database": { popM: 13.5 },
  "DeSC Database": { popM: 9.3, since: 2014 },
  "Medical Data Vision (MDV) Database": { popM: 48 },
  "Health Insurance Review and Assessment Service (HIRA)": { popM: 50, since: 2009 },
  "National Health Insurance Service – National Health Information Database (NHIS-NHID)": { popM: 50 },
  "Clinical Data Analysis and Reporting System (CDARS)": { popM: 7, since: 1995 },
  "Clinical Practice Research Datalink (CPRD)": { popM: 60 },
  "The Health Improvement Network (THIN)": { popM: 17, since: 2003 },
  "UK Biobank (UKB)": { popM: 0.5, since: 2006 },
  "Public Health Scotland (ISD)": { popM: 5.4 },
  "PHARMO Database Network": { popM: 7 },
  "Finnish healthcare registers (FinReg)": { popM: 5.5 },
  "Pharmaceutical Benefits Scheme — 10% sample (PBS)": { popM: 2.5 },
  "Victorian Linked Health Data (VLHD)": { popM: 6.5 },
  "Medicare (20% sample)": { popM: 13 },
  "Medicaid": { popM: 70 },
};

const compareRows = databases.map((d) => {
  const meta = countryMeta[d.country];
  const stats = dbStats[d.name] ?? { popM: 0 };
  return {
    country: d.country,
    flag: meta?.flag ?? "🏳️",
    name: d.name,
    type: d.type,
    popM: stats.popM,
    since: stats.since ?? null,
    coverage: d.coverage,
    anchor: `db-${d.name.replace(/[^a-z0-9]+/gi, "-").toLowerCase()}`,
  };
});

const compareTypes = Array.from(new Set(compareRows.map((r) => r.type))).sort();

// Other sites listed in the 2015 AsPEN database survey (Lai ECC et al., Epidemiology 2015)
// that are not part of the current active network. Reference only — not on the map.
const otherSites = [
  { country: "Singapore", flag: "🇸🇬", name: "National Electronic Health Record (NEHR)",     note: "Singapore's national EHR; listed in the 2015 AsPEN survey." },
  { country: "Thailand",  flag: "🇹🇭", name: "Buddhachinaraj Hospital Database (BHD)",       note: "Tertiary referral hospital EHR." },
  { country: "Thailand",  flag: "🇹🇭", name: "Hospital Information (HI) — Ubon Ratchathani", note: "21-community-hospital EHR network." },
];
---

<BaseLayout
  title="Databases — AsPEN"
  description="Healthcare databases accessible to AsPEN collaborators across East Asia, plus an external control."
>
  <PageHeader
    eyebrow="Data"
    title="Databases"
    description="Population-level health databases used in AsPEN multi-national studies. The map is focused on East Asia; pan or zoom out to view partner sites."
  />

  <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-10 space-y-12">
    <div>
      <h2 class="text-xs uppercase tracking-widest text-brand-600 font-semibold mb-3">East Asia network</h2>
      <WorldMap
        groups={mapGroups}
        height="540px"
        initialCenter={[31, 126]}
        initialZoom={5}
      />
    </div>

    <div class="space-y-10">
      {asianGroups.map(([country, dbs]) => {
        const meta = countryMeta[country];
        return (
          <article>
            <header class="flex items-baseline gap-3 mb-4 border-b border-slate-200 pb-2">
              <span class="text-3xl leading-none">{meta?.flag ?? "🏳️"}</span>
              <h2 class="text-2xl font-bold text-slate-900">{country}</h2>
            </header>
            <div class="grid gap-4 md:grid-cols-2">
              {dbs.map((d) => {
                const anchor = `db-${d.name.replace(/[^a-z0-9]+/gi, "-").toLowerCase()}`;
                const chip = typeColor[d.type] ?? "bg-slate-100 text-slate-700 border-slate-200";
                const url = (d as { url?: string }).url;
                return (
                  <div
                    id={anchor}
                    class="scroll-mt-24 border border-slate-200 rounded-lg p-5 bg-white hover:shadow-md transition"
                  >
                    <div class="flex items-start justify-between gap-3 mb-2">
                      {url ? (
                        <a
                          href={url}
                          target="_blank"
                          rel="noopener"
                          class="font-semibold text-slate-900 leading-snug hover:text-brand-700 hover:underline decoration-brand-400 underline-offset-2"
                        >
                          {d.name}
                        </a>
                      ) : (
                        <h3 class="font-semibold text-slate-900 leading-snug">{d.name}</h3>
                      )}
                      <span class={`shrink-0 text-xs font-medium px-2 py-0.5 rounded-full border ${chip}`}>{d.type}</span>
                    </div>
                    {d.city && <p class="text-xs text-slate-500 mb-2">{d.city}</p>}
                    <p class="text-sm text-slate-700"><strong>Coverage:</strong> {d.coverage}</p>
                    <p class="text-sm text-slate-600 mt-2 leading-relaxed">{d.notes}</p>
                  </div>
                );
              })}
            </div>
          </article>
        );
      })}
    </div>

    {externalGroups.length > 0 && (
      <div class="mt-16">
        <h2 class="text-xs uppercase tracking-widest text-brand-600 font-semibold mb-2">International partner sites</h2>
        <p class="text-sm text-slate-600 max-w-3xl mb-6">
          AsPEN collaborators draw on data partners outside East Asia for benchmarking and methodological comparison — including UK, US, European, and Australian sites linked through the NeuroGEN data initiative.
        </p>
        <div class="space-y-8">
          {externalGroups.map(([country, dbs]) => {
            const meta = countryMeta[country];
            return (
              <article>
                <header class="flex items-baseline gap-3 mb-4 border-b border-slate-200 pb-2">
                  <span class="text-3xl leading-none">{meta?.flag ?? "🏳️"}</span>
                  <h2 class="text-2xl font-bold text-slate-900">{country}</h2>
                </header>
                <div class="grid gap-4 md:grid-cols-2">
                  {dbs.map((d) => {
                    const anchor = `db-${d.name.replace(/[^a-z0-9]+/gi, "-").toLowerCase()}`;
                    const chip = typeColor[d.type] ?? "bg-slate-100 text-slate-700 border-slate-200";
                    return (
                      <div
                        id={anchor}
                        class="scroll-mt-24 border border-slate-200 rounded-lg p-5 bg-white hover:shadow-md transition"
                      >
                        <div class="flex items-start justify-between gap-3 mb-2">
                          <h3 class="font-semibold text-slate-900 leading-snug">{d.name}</h3>
                          <span class={`shrink-0 text-xs font-medium px-2 py-0.5 rounded-full border ${chip}`}>{d.type}</span>
                        </div>
                        {d.city && <p class="text-xs text-slate-500 mb-2">{d.city}</p>}
                        <p class="text-sm text-slate-700"><strong>Coverage:</strong> {d.coverage}</p>
                        <p class="text-sm text-slate-600 mt-2 leading-relaxed">{d.notes}</p>
                      </div>
                    );
                  })}
                </div>
              </article>
            );
          })}
        </div>
      </div>
    )}

    <details class="mt-12 border border-slate-200 rounded-lg bg-white open:shadow-sm">
      <summary class="cursor-pointer select-none px-5 py-4 flex items-center gap-3 hover:bg-slate-50 rounded-lg">
        <span class="text-xs font-semibold uppercase tracking-widest text-brand-700">Compare databases</span>
        <span class="text-sm text-slate-500">— side-by-side sortable table of all {compareRows.length} sites</span>
        <span class="ml-auto text-xs text-slate-400">click to expand</span>
      </summary>
      <div class="border-t border-slate-200 p-5">
        <div class="grid gap-3 sm:grid-cols-[1fr_220px] mb-4">
          <label class="block">
            <span class="text-xs font-semibold text-slate-600 uppercase tracking-wide">Search</span>
            <input
              id="cmp-q"
              type="search"
              placeholder="country, name, coverage…"
              class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-sm"
            />
          </label>
          <label class="block">
            <span class="text-xs font-semibold text-slate-600 uppercase tracking-wide">Type</span>
            <select id="cmp-type" class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-sm">
              <option value="">All types</option>
              {compareTypes.map((t) => <option value={t}>{t}</option>)}
            </select>
          </label>
        </div>

        <div class="overflow-x-auto -mx-5 px-5">
          <table id="cmp-table" class="w-full text-sm border-collapse">
            <thead>
              <tr class="text-left border-b-2 border-slate-200">
                <th class="py-2 pr-3 font-semibold text-slate-700 cursor-pointer select-none whitespace-nowrap" data-sort="country">Country <span class="text-slate-400 text-xs">↕</span></th>
                <th class="py-2 pr-3 font-semibold text-slate-700 cursor-pointer select-none whitespace-nowrap" data-sort="name">Database <span class="text-slate-400 text-xs">↕</span></th>
                <th class="py-2 pr-3 font-semibold text-slate-700 cursor-pointer select-none whitespace-nowrap" data-sort="type">Type <span class="text-slate-400 text-xs">↕</span></th>
                <th class="py-2 pr-3 font-semibold text-slate-700 cursor-pointer select-none whitespace-nowrap text-right" data-sort="popM" data-sort-numeric>Population (M) <span class="text-slate-400 text-xs">↕</span></th>
                <th class="py-2 pr-3 font-semibold text-slate-700 cursor-pointer select-none whitespace-nowrap text-right" data-sort="since" data-sort-numeric>Since <span class="text-slate-400 text-xs">↕</span></th>
                <th class="py-2 pr-3 font-semibold text-slate-700">Coverage</th>
              </tr>
            </thead>
            <tbody>
              {compareRows.map((r) => (
                <tr
                  class="border-b border-slate-100 hover:bg-slate-50 align-top"
                  data-country={r.country}
                  data-name={r.name}
                  data-type={r.type}
                  data-popm={r.popM}
                  data-since={r.since ?? ""}
                  data-search={`${r.country} ${r.name} ${r.type} ${r.coverage}`.toLowerCase()}
                >
                  <td class="py-2 pr-3 whitespace-nowrap"><span class="mr-1">{r.flag}</span>{r.country}</td>
                  <td class="py-2 pr-3">
                    <a href={`#${r.anchor}`} class="text-brand-700 hover:underline font-medium">{r.name}</a>
                  </td>
                  <td class="py-2 pr-3 whitespace-nowrap text-slate-700">{r.type}</td>
                  <td class="py-2 pr-3 text-right tabular-nums text-slate-700">{r.popM > 0 ? r.popM : "—"}</td>
                  <td class="py-2 pr-3 text-right tabular-nums text-slate-700">{r.since ?? "—"}</td>
                  <td class="py-2 pr-3 text-slate-600">{r.coverage}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p id="cmp-empty" class="hidden mt-4 text-sm text-slate-500 italic">No databases match your filters.</p>
        <p class="mt-4 text-xs text-slate-500">Click any database name to jump to its full description above.</p>
      </div>
    </details>

    <script is:inline>
      (() => {
        const table = document.getElementById("cmp-table");
        if (!table) return;
        const tbody = table.querySelector("tbody");
        const rows = Array.from(tbody.querySelectorAll("tr"));
        const qEl = document.getElementById("cmp-q");
        const tEl = document.getElementById("cmp-type");
        const empty = document.getElementById("cmp-empty");

        let sortKey = null;
        let sortDir = 1; // 1 asc, -1 desc

        const applyFilter = () => {
          const q = (qEl.value || "").trim().toLowerCase();
          const t = tEl.value || "";
          let shown = 0;
          rows.forEach((r) => {
            const matchQ = !q || (r.dataset.search || "").includes(q);
            const matchT = !t || r.dataset.type === t;
            const visible = matchQ && matchT;
            r.style.display = visible ? "" : "none";
            if (visible) shown++;
          });
          empty.classList.toggle("hidden", shown !== 0);
        };

        const applySort = () => {
          if (!sortKey) return;
          const th = table.querySelector(`th[data-sort="${sortKey}"]`);
          const numeric = th && th.hasAttribute("data-sort-numeric");
          const get = (row) => {
            const v = row.dataset[sortKey.toLowerCase()] ?? row.dataset[sortKey] ?? "";
            if (numeric) {
              const n = parseFloat(v);
              return Number.isFinite(n) ? n : sortDir === 1 ? Infinity : -Infinity;
            }
            return String(v).toLowerCase();
          };
          const sorted = [...rows].sort((a, b) => {
            const av = get(a);
            const bv = get(b);
            if (av < bv) return -1 * sortDir;
            if (av > bv) return 1 * sortDir;
            return 0;
          });
          sorted.forEach((r) => tbody.appendChild(r));
        };

        table.querySelectorAll("th[data-sort]").forEach((th) => {
          th.addEventListener("click", () => {
            const key = th.dataset.sort;
            if (sortKey === key) sortDir = -sortDir;
            else { sortKey = key; sortDir = 1; }
            // visual indicator
            table.querySelectorAll("th[data-sort] span").forEach((s) => (s.textContent = "↕"));
            const ind = th.querySelector("span");
            if (ind) ind.textContent = sortDir === 1 ? "↑" : "↓";
            applySort();
          });
        });

        qEl.addEventListener("input", applyFilter);
        tEl.addEventListener("change", applyFilter);
      })();
    </script>

    <div class="mt-12" id="other-sites">
      <h2 class="text-xs uppercase tracking-widest text-slate-500 font-semibold mb-2 scroll-mt-24">Other sites</h2>
      <p class="text-sm text-slate-600 max-w-3xl leading-relaxed">
        Additional data sources documented that are not part of the current active network include Singapore's <strong>National Electronic Health Record (NEHR)</strong>, and two Thai sites — <strong>Buddhachinaraj Hospital Database (BHD)</strong> (a tertiary referral hospital EHR) and the <strong>Hospital Information network</strong> across 21 community hospitals in Ubon Ratchathani.
      </p>
    </div>

    <p class="text-xs text-slate-500 italic">
      Database descriptions adapted from the AsPEN paper (Lai ECC et al. <em>Epidemiology.</em> 2015 Nov;26(6):815-20. DOI: <a class="hover:text-brand-700 hover:underline not-italic" href="https://doi.org/10.1097/EDE.0000000000000325" target="_blank" rel="noopener">10.1097/EDE.0000000000000325</a>) and the NeuroGEN data-infrastructure paper (Tsai DHT et al., <em>Clinical Epidemiology</em> 2023; DOI: <a class="hover:text-brand-700 hover:underline not-italic" href="https://doi.org/10.2147/CLEP.S426485" target="_blank" rel="noopener">10.2147/CLEP.S426485</a>). Access policies and coverage may have changed since publication. Please verify with each data custodian before study planning.
    </p>

    <CiteButton title="Databases — AsPEN" url={siteUrl} bibkey="aspen-databases" />
  </section>
</BaseLayout>
