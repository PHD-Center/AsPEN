---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import history from "../data/history.json";
---

<BaseLayout title="History — AsPEN" description="The history of the Asian Pharmacoepidemiology Network.">
  <PageHeader
    eyebrow="History"
    title="History"
    description="Milestones in the development of AsPEN since its founding in 2012."
  />

  <section class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-12">
    <ol class="relative border-l-2 border-brand-200 ml-3 space-y-10">
      {history.map((e) => (
        <li class="ml-6">
          <span class="absolute -left-2 mt-1.5 w-3.5 h-3.5 rounded-full bg-brand-500 ring-4 ring-white"></span>
          <p class="text-xs font-semibold text-brand-700 uppercase tracking-widest">{e.year}</p>
          <h3 class="mt-1 text-lg font-bold text-slate-900">{e.title}</h3>
          <p class="mt-2 text-slate-600 text-sm leading-relaxed">{e.body}</p>
        </li>
      ))}
    </ol>
  </section>
</BaseLayout>
