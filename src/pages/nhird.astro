---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import { NHIRD, MATERNAL_CHILD, SATELLITES } from "../data/nhird-ecosystem";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const hotspots = [NHIRD, MATERNAL_CHILD, ...SATELLITES];

// Manga-style tones — fill / border / ink. Brighter than the chart tones.
const TONES: Record<string, { fill: string; stroke: string; ink: string }> = {
  teal:   { fill: "#ccfbf1", stroke: "#0f766e", ink: "#134e4a" },
  orange: { fill: "#fed7aa", stroke: "#c2410c", ink: "#7c2d12" },
  amber:  { fill: "#fef3c7", stroke: "#b45309", ink: "#78350f" },
  green:  { fill: "#d1fae5", stroke: "#15803d", ink: "#14532d" },
  sky:    { fill: "#e0f2fe", stroke: "#0369a1", ink: "#0c4a6e" },
  pink:   { fill: "#fce7f3", stroke: "#be185d", ink: "#831843" },
  indigo: { fill: "#e0e7ff", stroke: "#4338ca", ink: "#312e81" },
  slate:  { fill: "#e2e8f0", stroke: "#475569", ink: "#1e293b" },
  brown:  { fill: "#e7e5e4", stroke: "#78716c", ink: "#44403c" },
};

// Compact icon emoji per registry — supplements the title typographically
const ICONS: Record<string, string> = {
  nhird: "📋",
  mch: "👶",
  nhis: "🏃",
  hex: "🧪",
  covid: "🦠",
  twb: "🧬",
  ard: "🍼",
  birth: "📜",
  niis: "💉",
  cancer: "🎗️",
  death: "⚱️",
  cir: "🛏️",
  ohdsi: "🗄️",
  sentinel: "🛡️",
  cgrd: "🏥",
};
---

<BaseLayout
  title="NHIRD ecosystem — AsPEN"
  description="Taiwan's National Health Insurance Research Database and its linked registries — hover any panel to see what each data source is."
>
  <PageHeader
    eyebrow="Databases → NHIRD"
    title="NHIRD ecosystem"
    description="Taiwan's National Health Insurance Research Database sits at the centre of a tightly linked set of national registries and survey datasets. Hover (or tap) any panel below to see what it contains."
  />

  <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-8">
    <!-- Diagram container — inline SVG; tooltip overlays the same container -->
    <div
      data-nhird-diagram
      class="relative w-full border border-slate-200 rounded-2xl overflow-hidden shadow-sm bg-[#fffbef] p-3 sm:p-4"
    >
      <svg
        viewBox="0 0 800 640"
        xmlns="http://www.w3.org/2000/svg"
        class="block w-full h-auto"
        role="img"
        aria-label="NHIRD ecosystem diagram"
      >
        <defs>
          <!-- Manga-ish soft drop shadow -->
          <filter id="m-shadow" x="-10%" y="-10%" width="120%" height="125%">
            <feDropShadow dx="2" dy="3" stdDeviation="2.2" flood-color="#000" flood-opacity="0.14" />
          </filter>
          <!-- Subtle dot-screen pattern (manga screentone) for NHIRD background -->
          <pattern id="m-dots" x="0" y="0" width="8" height="8" patternUnits="userSpaceOnUse">
            <circle cx="2" cy="2" r="0.8" fill="#0f766e" opacity="0.18" />
          </pattern>
        </defs>

        <!-- ── CONNECTORS (behind boxes) ──────────────────────── -->
        <g stroke="#475569" stroke-width="1.8" fill="none" stroke-linecap="round" opacity="0.45">
          <!-- top satellites → NHIRD top edge -->
          <path d="M 200 110 Q 220 145 270 180" />
          <path d="M 345 110 Q 360 145 380 180" />
          <path d="M 495 110 Q 480 145 470 180" />
          <path d="M 650 110 Q 620 150 570 180" />

          <!-- left satellites → NHIRD left/top-left -->
          <path d="M 130 190 Q 165 200 200 220" />
          <path d="M 130 310 Q 165 310 200 310" />
          <path d="M 130 430 Q 165 400 200 360" />

          <!-- right satellites → NHIRD right -->
          <path d="M 670 200 Q 635 215 600 230" />
          <path d="M 670 320 Q 635 320 600 320" />
          <path d="M 670 445 Q 635 400 600 360" />

          <!-- bottom satellites → NHIRD bottom -->
          <path d="M 80 510 Q 160 460 260 380" />
          <path d="M 255 510 Q 290 450 340 380" />
          <path d="M 630 510 Q 580 450 520 380" />
        </g>

        <!-- ── BOXES ──────────────────────────────────────────── -->

        <!-- NHIRD: centre, large, screentone bg, sparkle accents -->
        <g class="registry" data-hotspot-id="nhird" filter="url(#m-shadow)" tabindex="0" role="button" aria-label="NHIRD — Claims · All citizens · ~23 million individuals">
          <rect x="200" y="180" width="400" height="200" rx="22" fill="#ccfbf1" stroke="#0f766e" stroke-width="4" />
          <rect x="200" y="180" width="400" height="200" rx="22" fill="url(#m-dots)" />
          <text x="400" y="218" font-size="28" font-weight="900" text-anchor="middle" fill="#134e4a">{ICONS.nhird} NHIRD</text>
          <text x="400" y="240" font-size="11" text-anchor="middle" fill="#134e4a" opacity="0.85">Claims · All citizens · ~23 million</text>
          <!-- sparkle accents (manga "star of the show") -->
          <text x="200" y="178" font-size="18" text-anchor="middle">✨</text>
          <text x="600" y="178" font-size="18" text-anchor="middle">✨</text>
        </g>

        <!-- Maternal & Child sub-box inside NHIRD (left half) -->
        <g class="registry" data-hotspot-id="mch" filter="url(#m-shadow)" tabindex="0" role="button" aria-label="Maternal & Child Health Database">
          <rect x="218" y="258" width="170" height="110" rx="14" fill="#e7e5e4" stroke="#78716c" stroke-width="2.5" />
          <text x="303" y="280" font-size="11" font-weight="800" text-anchor="middle" fill="#44403c">Maternal &amp; Child</text>
          <text x="303" y="294" font-size="10" text-anchor="middle" fill="#44403c">Health Database</text>
          <!-- Mother / Father / Child sub chips -->
          <g font-size="8.5" font-weight="700" fill="#44403c">
            <rect x="232" y="305" width="62" height="20" rx="6" fill="#fff" stroke="#a8a29e" stroke-width="1.5"/>
            <text x="263" y="318" text-anchor="middle">Mother</text>
            <rect x="312" y="305" width="62" height="20" rx="6" fill="#fff" stroke="#a8a29e" stroke-width="1.5"/>
            <text x="343" y="318" text-anchor="middle">Father</text>
            <rect x="270" y="338" width="66" height="20" rx="6" fill="#fff" stroke="#a8a29e" stroke-width="1.5"/>
            <text x="303" y="351" text-anchor="middle">Child</text>
          </g>
        </g>

        <!-- Right-side info chips (purely decorative, no hotspot) -->
        <g font-size="10" font-weight="600" fill="#134e4a">
          <rect x="405" y="258" width="185" height="20" rx="6" fill="#fff" stroke="#5eead4" stroke-width="1.5"/>
          <text x="497" y="271" text-anchor="middle">Demographic info.</text>
          <rect x="405" y="285" width="185" height="20" rx="6" fill="#fff" stroke="#5eead4" stroke-width="1.5"/>
          <text x="497" y="298" text-anchor="middle">Medical records</text>
          <rect x="405" y="312" width="185" height="20" rx="6" fill="#fff" stroke="#5eead4" stroke-width="1.5"/>
          <text x="497" y="325" text-anchor="middle">Intervention</text>
          <rect x="405" y="339" width="185" height="20" rx="6" fill="#fff" stroke="#5eead4" stroke-width="1.5"/>
          <text x="497" y="352" text-anchor="middle">Healthcare Facility Info.</text>
        </g>

        <!-- Helper rendering for each satellite via repeated pattern -->
        <!-- TOP ROW: NHIS, HE, COVID, TWB -->
        <g class="registry" data-hotspot-id="nhis" filter="url(#m-shadow)" tabindex="0" role="button" aria-label="NHIS — Exercises · Diets · Health behaviors">
          <rect x="140" y="20" width="130" height="100" rx="16" fill={TONES.orange.fill} stroke={TONES.orange.stroke} stroke-width="3.5" />
          <text x="205" y="48" font-size="20" font-weight="900" text-anchor="middle" fill={TONES.orange.ink}>{ICONS.nhis} NHIS</text>
          <text x="205" y="78" font-size="10" text-anchor="middle" fill={TONES.orange.ink}>Exercises · Diets</text>
          <text x="205" y="92" font-size="10" text-anchor="middle" fill={TONES.orange.ink}>Health behaviors</text>
        </g>

        <g class="registry" data-hotspot-id="hex" filter="url(#m-shadow)" tabindex="0" role="button" aria-label="Health Examination — Laboratory">
          <rect x="285" y="20" width="135" height="100" rx="16" fill={TONES.amber.fill} stroke={TONES.amber.stroke} stroke-width="3.5" />
          <text x="352" y="46" font-size="16" font-weight="900" text-anchor="middle" fill={TONES.amber.ink}>{ICONS.hex} Health</text>
          <text x="352" y="64" font-size="16" font-weight="900" text-anchor="middle" fill={TONES.amber.ink}>Examination</text>
          <text x="352" y="92" font-size="10" text-anchor="middle" fill={TONES.amber.ink}>Laboratory</text>
        </g>

        <g class="registry" data-hotspot-id="covid" filter="url(#m-shadow)" tabindex="0" role="button" aria-label="COVID-19 — Vaccine · Confirmed cases">
          <rect x="435" y="20" width="135" height="100" rx="16" fill={TONES.green.fill} stroke={TONES.green.stroke} stroke-width="3.5" />
          <text x="502" y="50" font-size="20" font-weight="900" text-anchor="middle" fill={TONES.green.ink}>{ICONS.covid} COVID-19</text>
          <text x="502" y="78" font-size="10" text-anchor="middle" fill={TONES.green.ink}>Vaccine ·</text>
          <text x="502" y="92" font-size="10" text-anchor="middle" fill={TONES.green.ink}>Confirmed cases</text>
        </g>

        <g class="registry" data-hotspot-id="twb" filter="url(#m-shadow)" tabindex="0" role="button" aria-label="Taiwan Biobank — Gene · ~200k individuals">
          <rect x="585" y="20" width="145" height="100" rx="16" fill={TONES.sky.fill} stroke={TONES.sky.stroke} stroke-width="3.5" />
          <text x="657" y="46" font-size="15" font-weight="900" text-anchor="middle" fill={TONES.sky.ink}>{ICONS.twb} Taiwan</text>
          <text x="657" y="64" font-size="15" font-weight="900" text-anchor="middle" fill={TONES.sky.ink}>Biobank</text>
          <text x="657" y="88" font-size="10" text-anchor="middle" fill={TONES.sky.ink}>Gene</text>
          <text x="657" y="102" font-size="10" text-anchor="middle" fill={TONES.sky.ink}>~200k individuals</text>
        </g>

        <!-- LEFT COLUMN: ARD, Birth Certificate, NIIS -->
        <g class="registry" data-hotspot-id="ard" filter="url(#m-shadow)" tabindex="0" role="button" aria-label="ARD — ART · IVF · ~400k records">
          <rect x="10" y="140" width="120" height="100" rx="16" fill={TONES.orange.fill} stroke={TONES.orange.stroke} stroke-width="3.5" />
          <text x="70" y="170" font-size="20" font-weight="900" text-anchor="middle" fill={TONES.orange.ink}>{ICONS.ard} ARD</text>
          <text x="70" y="198" font-size="10" text-anchor="middle" fill={TONES.orange.ink}>ART · IVF</text>
          <text x="70" y="212" font-size="10" text-anchor="middle" fill={TONES.orange.ink}>~400k records</text>
        </g>

        <g class="registry" data-hotspot-id="birth" filter="url(#m-shadow)" tabindex="0" role="button" aria-label="Birth Certificate — ~100k records / year">
          <rect x="10" y="260" width="120" height="100" rx="16" fill={TONES.pink.fill} stroke={TONES.pink.stroke} stroke-width="3.5" />
          <text x="70" y="288" font-size="14" font-weight="900" text-anchor="middle" fill={TONES.pink.ink}>{ICONS.birth} Birth</text>
          <text x="70" y="306" font-size="14" font-weight="900" text-anchor="middle" fill={TONES.pink.ink}>Certificate</text>
          <text x="70" y="332" font-size="10" text-anchor="middle" fill={TONES.pink.ink}>~100k records / yr</text>
        </g>

        <g class="registry" data-hotspot-id="niis" filter="url(#m-shadow)" tabindex="0" role="button" aria-label="NIIS — Vaccine">
          <rect x="10" y="380" width="120" height="100" rx="16" fill={TONES.pink.fill} stroke={TONES.pink.stroke} stroke-width="3.5" />
          <text x="70" y="410" font-size="20" font-weight="900" text-anchor="middle" fill={TONES.pink.ink}>{ICONS.niis} NIIS</text>
          <text x="70" y="440" font-size="10" text-anchor="middle" fill={TONES.pink.ink}>Vaccine</text>
        </g>

        <!-- RIGHT COLUMN: Cancer Registry, Cause of Death, Catastrophic Illness Registry -->
        <g class="registry" data-hotspot-id="cancer" filter="url(#m-shadow)" tabindex="0" role="button" aria-label="Taiwan Cancer Registry">
          <rect x="670" y="140" width="120" height="120" rx="16" fill={TONES.indigo.fill} stroke={TONES.indigo.stroke} stroke-width="3.5" />
          <text x="730" y="166" font-size="13" font-weight="900" text-anchor="middle" fill={TONES.indigo.ink}>{ICONS.cancer} Taiwan</text>
          <text x="730" y="184" font-size="13" font-weight="900" text-anchor="middle" fill={TONES.indigo.ink}>Cancer</text>
          <text x="730" y="202" font-size="13" font-weight="900" text-anchor="middle" fill={TONES.indigo.ink}>Registry</text>
          <text x="730" y="230" font-size="10" text-anchor="middle" fill={TONES.indigo.ink}>since 2003</text>
        </g>

        <g class="registry" data-hotspot-id="death" filter="url(#m-shadow)" tabindex="0" role="button" aria-label="Cause of Death">
          <rect x="670" y="280" width="120" height="80" rx="16" fill={TONES.slate.fill} stroke={TONES.slate.stroke} stroke-width="3.5" />
          <text x="730" y="307" font-size="13" font-weight="900" text-anchor="middle" fill={TONES.slate.ink}>{ICONS.death} Cause of</text>
          <text x="730" y="325" font-size="13" font-weight="900" text-anchor="middle" fill={TONES.slate.ink}>Death</text>
          <text x="730" y="345" font-size="10" text-anchor="middle" fill={TONES.slate.ink}>National registry</text>
        </g>

        <g class="registry" data-hotspot-id="cir" filter="url(#m-shadow)" tabindex="0" role="button" aria-label="Catastrophic Illness Registry">
          <rect x="670" y="380" width="120" height="130" rx="16" fill={TONES.slate.fill} stroke={TONES.slate.stroke} stroke-width="3.5" />
          <text x="730" y="408" font-size="13" font-weight="900" text-anchor="middle" fill={TONES.slate.ink}>{ICONS.cir} Catastrophic</text>
          <text x="730" y="426" font-size="13" font-weight="900" text-anchor="middle" fill={TONES.slate.ink}>Illness</text>
          <text x="730" y="444" font-size="13" font-weight="900" text-anchor="middle" fill={TONES.slate.ink}>Registry</text>
          <text x="730" y="478" font-size="10" text-anchor="middle" fill={TONES.slate.ink}>NHI fee waivers</text>
        </g>

        <!-- BOTTOM ROW: OHDSI, Sentinel, CGRD -->
        <g class="registry" data-hotspot-id="ohdsi" filter="url(#m-shadow)" tabindex="0" role="button" aria-label="OHDSI CDM — OMOP Common Data Model">
          <rect x="10" y="510" width="140" height="100" rx="16" fill={TONES.indigo.fill} stroke={TONES.indigo.stroke} stroke-width="3.5" />
          <text x="80" y="540" font-size="20" font-weight="900" text-anchor="middle" fill={TONES.indigo.ink}>{ICONS.ohdsi} OHDSI</text>
          <text x="80" y="570" font-size="11" text-anchor="middle" fill={TONES.indigo.ink}>OMOP CDM</text>
        </g>

        <g class="registry" data-hotspot-id="sentinel" filter="url(#m-shadow)" tabindex="0" role="button" aria-label="Sentinel CDM — FDA Sentinel Common Data Model">
          <rect x="180" y="510" width="150" height="100" rx="16" fill={TONES.indigo.fill} stroke={TONES.indigo.stroke} stroke-width="3.5" />
          <text x="255" y="540" font-size="20" font-weight="900" text-anchor="middle" fill={TONES.indigo.ink}>{ICONS.sentinel} Sentinel</text>
          <text x="255" y="570" font-size="11" text-anchor="middle" fill={TONES.indigo.ink}>FDA CDM</text>
        </g>

        <g class="registry" data-hotspot-id="cgrd" filter="url(#m-shadow)" tabindex="0" role="button" aria-label="CGRD — EHR · ~1 million individuals">
          <rect x="470" y="510" width="320" height="100" rx="16" fill={TONES.green.fill} stroke={TONES.green.stroke} stroke-width="3.5" />
          <text x="630" y="544" font-size="22" font-weight="900" text-anchor="middle" fill={TONES.green.ink}>{ICONS.cgrd} CGRD</text>
          <text x="630" y="572" font-size="11" text-anchor="middle" fill={TONES.green.ink}>Chang Gung Research Database</text>
          <text x="630" y="588" font-size="10" text-anchor="middle" fill={TONES.green.ink}>EHR · ~1 million individuals</text>
        </g>
      </svg>

      <!-- Tooltip (positioned by JS over the diagram) -->
      <div
        data-nhird-tooltip
        class="absolute hidden pointer-events-none z-20 max-w-xs sm:max-w-sm bg-white border-2 border-slate-700 rounded-xl shadow-xl p-3 sm:p-4"
        role="tooltip"
      >
        <p class="text-sm sm:text-base font-bold text-slate-900" data-tt-name></p>
        <p class="text-[11px] sm:text-xs font-semibold text-brand-700 mt-0.5" data-tt-meta></p>
        <p class="mt-2 text-xs sm:text-sm text-slate-700 leading-relaxed" data-tt-desc></p>
        <a
          data-tt-link
          target="_blank"
          rel="noopener"
          class="hidden mt-2 inline-block text-xs font-semibold text-brand-700 hover:underline"
        >Read more on PHDc ↗</a>
      </div>
    </div>

    <p class="mt-3 text-xs text-slate-500 italic">
      Diagram structure adapted from the Population Health Data Center (PHDc), National Cheng Kung University; redrawn here as an interactive panel. Hover any panel (desktop) or tap it (mobile) to reveal the dataset description; tap outside to dismiss.
    </p>

    <!-- Full list below for accessibility / SEO / fallback -->
    <div class="mt-12 border-t border-slate-200 pt-8">
      <h2 class="text-xs uppercase tracking-widest text-brand-600 font-semibold mb-4">All datasets in this ecosystem</h2>
      <div class="grid gap-4 md:grid-cols-2">
        {hotspots.map((r) => (
          <article id={`registry-${r.id}`} class="border border-slate-200 rounded-lg p-5 bg-white scroll-mt-24">
            <p class="font-semibold text-slate-900 leading-snug">{r.name}</p>
            <p class="text-xs font-semibold text-brand-700 mt-0.5">{r.meta}</p>
            <p class="mt-2 text-sm text-slate-700 leading-relaxed">{r.description}</p>
            {r.link && (
              <a href={r.link} target="_blank" rel="noopener" class="mt-2 inline-block text-xs font-semibold text-brand-700 hover:underline">
                Read more on PHDc ↗
              </a>
            )}
          </article>
        ))}
      </div>
    </div>

    <p class="mt-10 text-xs text-slate-500 italic">
      Source: <a href="https://www.phdcenter.org.tw/database/" target="_blank" rel="noopener" class="text-brand-700 hover:underline">Population Health Data Center (PHDc), NCKU</a>. Dataset descriptions are paraphrased; please consult PHDc or the respective Taiwan government agency for canonical, up-to-date information.
    </p>
  </section>

  <style is:global>
    [data-nhird-diagram] .registry { cursor: pointer; transition: transform 150ms ease; transform-origin: center; transform-box: fill-box; }
    [data-nhird-diagram] .registry:hover { transform: translateY(-2px) scale(1.02); }
    [data-nhird-diagram] .registry:focus { outline: none; }
    [data-nhird-diagram] .registry:focus rect { stroke-width: 5; }
  </style>

  <script is:inline define:vars={{ hotspots }}>
    (() => {
      const diagram = document.querySelector("[data-nhird-diagram]");
      if (!diagram) return;
      const tooltip = diagram.querySelector("[data-nhird-tooltip]");
      const groups = Array.from(diagram.querySelectorAll(".registry[data-hotspot-id]"));
      const byId = Object.fromEntries(hotspots.map((r) => [r.id, r]));

      const ttName = tooltip.querySelector("[data-tt-name]");
      const ttMeta = tooltip.querySelector("[data-tt-meta]");
      const ttDesc = tooltip.querySelector("[data-tt-desc]");
      const ttLink = tooltip.querySelector("[data-tt-link]");

      let activeEl = null;
      let sticky = false;

      const show = (el) => {
        const id = el.dataset.hotspotId;
        const r = byId[id];
        if (!r) return;
        ttName.textContent = r.name;
        ttMeta.textContent = r.meta;
        ttDesc.textContent = r.description;
        if (r.link) {
          ttLink.href = r.link;
          ttLink.classList.remove("hidden");
        } else {
          ttLink.classList.add("hidden");
        }
        tooltip.classList.remove("hidden");
        positionTooltip(el);
        activeEl = el;
      };

      const hide = () => {
        tooltip.classList.add("hidden");
        activeEl = null;
        sticky = false;
      };

      const positionTooltip = (el) => {
        const dRect = diagram.getBoundingClientRect();
        const bRect = el.getBoundingClientRect();
        tooltip.style.top = "0px";
        tooltip.style.left = "0px";
        const tRect = tooltip.getBoundingClientRect();
        let top = (bRect.bottom - dRect.top) + 8;
        let left = (bRect.left - dRect.left);
        if (left + tRect.width > dRect.width - 8) {
          left = Math.max(8, dRect.width - tRect.width - 8);
        }
        if (top + tRect.height > dRect.height - 8) {
          top = (bRect.top - dRect.top) - tRect.height - 8;
        }
        tooltip.style.top = `${Math.max(8, top)}px`;
        tooltip.style.left = `${Math.max(8, left)}px`;
      };

      const isTouch = window.matchMedia("(pointer: coarse)").matches;

      groups.forEach((el) => {
        if (!isTouch) {
          el.addEventListener("mouseenter", () => { if (!sticky) show(el); });
          el.addEventListener("mouseleave", () => { if (!sticky) hide(); });
        }
        el.addEventListener("click", (e) => {
          e.stopPropagation();
          if (activeEl === el && sticky) {
            hide();
          } else {
            sticky = true;
            show(el);
          }
        });
        el.addEventListener("focus", () => { if (!sticky) show(el); });
        el.addEventListener("blur", () => { if (!sticky) hide(); });
      });

      document.addEventListener("click", (e) => {
        if (!diagram.contains(e.target)) hide();
      });
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") hide();
      });
      window.addEventListener("resize", () => {
        if (activeEl) positionTooltip(activeEl);
      });
    })();
  </script>
</BaseLayout>
