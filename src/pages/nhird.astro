---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import { NHIRD, MATERNAL_CHILD, SATELLITES } from "../data/nhird-ecosystem";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const hotspots = [NHIRD, MATERNAL_CHILD, ...SATELLITES];
---

<BaseLayout
  title="Taiwan's Data Infrastructure — AsPEN"
  description="Taiwan's National Health Insurance Research Database and the linked national registries that orbit it — hover or tap each box to see what each data source is."
>
  <PageHeader
    eyebrow="Databases → Taiwan"
    title="Taiwan's Data Infrastructure"
    description="The National Health Insurance Research Database (NHIRD, research data since 2000) sits at the centre of a tightly linked set of national registries and survey datasets. Hover (or tap) any box on the diagram to see what it contains."
  />

  <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-8">
    <!-- Diagram container — image + hotspots overlay -->
    <div
      data-nhird-diagram
      class="relative w-full border border-slate-200 rounded-lg overflow-hidden shadow-sm bg-white"
    >
      <img
        src={`${base}/images/nhird-ecosystem.png`}
        alt="Taiwan's data infrastructure — NHIRD at the centre, linked to national registries and common data models"
        class="block w-full h-auto select-none"
        draggable="false"
      />

      <!-- Hotspots: positioned as % of the image so they scale with it -->
      {hotspots.map((r) => (
        <button
          type="button"
          data-hotspot-id={r.id}
          aria-label={`${r.name} — ${r.meta}`}
          class="absolute cursor-pointer focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-700 focus-visible:rounded"
          style={`top:${r.bbox?.top ?? "0%"}; left:${r.bbox?.left ?? "0%"}; width:${r.bbox?.width ?? "0%"}; height:${r.bbox?.height ?? "0%"};`}
        ></button>
      ))}

      <!-- Tooltip — repositioned via JS to whichever hotspot is active.
           Tooltip body is pointer-events-none to avoid flicker on hover-mouseleave,
           but the "Read more on PHDc" link inside opts back in via pointer-events-auto. -->
      <div
        data-nhird-tooltip
        class="absolute hidden pointer-events-none z-20 max-w-xs sm:max-w-sm bg-white border border-slate-300 rounded-lg shadow-xl p-3 sm:p-4"
        role="tooltip"
      >
        <p class="text-sm sm:text-base font-bold text-slate-900" data-tt-name></p>
        <p class="text-[11px] sm:text-xs font-semibold text-brand-700 mt-0.5" data-tt-meta></p>
        <p class="mt-2 text-xs sm:text-sm text-slate-700 leading-relaxed" data-tt-desc></p>
        <a
          data-tt-link
          target="_blank"
          rel="noopener"
          class="hidden pointer-events-auto mt-2 inline-block text-xs font-semibold text-brand-700 hover:underline"
        >Read more on PHDc ↗</a>
      </div>
    </div>

    <p class="mt-3 text-xs text-slate-500 italic">
      Diagram adapted from the Population Health Data Center (PHDc), National Cheng Kung University. Hover any box (desktop) or tap it (mobile) to reveal the dataset description; tap outside to dismiss.
    </p>

    <!-- Full list below for reference / accessibility / SEO -->
    <div class="mt-12 border-t border-slate-200 pt-8">
      <h2 class="text-xs uppercase tracking-widest text-brand-600 font-semibold mb-4">All datasets in this infrastructure</h2>
      <div class="grid gap-4 md:grid-cols-2">
        {hotspots.map((r) => (
          <article id={`registry-${r.id}`} class="border border-slate-200 rounded-lg p-5 bg-white scroll-mt-24">
            <p class="font-semibold leading-snug">
              {r.link ? (
                <a
                  href={r.link}
                  target="_blank"
                  rel="noopener"
                  class="text-slate-900 hover:text-brand-700 hover:underline decoration-brand-400 underline-offset-2"
                >{r.name}</a>
              ) : (
                <span class="text-slate-900">{r.name}</span>
              )}
            </p>
            <p class="text-xs font-semibold text-brand-700 mt-0.5">{r.meta}</p>
            <p class="mt-2 text-sm text-slate-700 leading-relaxed">{r.description}</p>
          </article>
        ))}
      </div>
    </div>

    <p class="mt-10 text-xs text-slate-500 italic">
      Source: <a href="https://www.phdcenter.org.tw/database/" target="_blank" rel="noopener" class="text-brand-700 hover:underline">Population Health Data Center (PHDc), NCKU</a>. Dataset descriptions are paraphrased; please consult PHDc or the respective Taiwan government agency for canonical, up-to-date information.
    </p>
  </section>

  <script is:inline define:vars={{ hotspots }}>
    (() => {
      const diagram = document.querySelector("[data-nhird-diagram]");
      if (!diagram) return;
      const tooltip = diagram.querySelector("[data-nhird-tooltip]");
      const buttons = Array.from(diagram.querySelectorAll("[data-hotspot-id]"));
      const byId = Object.fromEntries(hotspots.map((r) => [r.id, r]));

      const ttName = tooltip.querySelector("[data-tt-name]");
      const ttMeta = tooltip.querySelector("[data-tt-meta]");
      const ttDesc = tooltip.querySelector("[data-tt-desc]");
      const ttLink = tooltip.querySelector("[data-tt-link]");

      let activeBtn = null;
      let sticky = false;

      const show = (btn) => {
        const id = btn.dataset.hotspotId;
        const r = byId[id];
        if (!r) return;
        ttName.textContent = r.name;
        ttMeta.textContent = r.meta;
        ttDesc.textContent = r.description;
        if (r.link) {
          ttLink.href = r.link;
          ttLink.classList.remove("hidden");
        } else {
          ttLink.classList.add("hidden");
        }
        tooltip.classList.remove("hidden");
        positionTooltip(btn);
        activeBtn = btn;
      };

      const hide = () => {
        tooltip.classList.add("hidden");
        activeBtn = null;
        sticky = false;
      };

      const positionTooltip = (btn) => {
        const dRect = diagram.getBoundingClientRect();
        const bRect = btn.getBoundingClientRect();
        tooltip.style.top = "0px";
        tooltip.style.left = "0px";
        const tRect = tooltip.getBoundingClientRect();
        let top = (bRect.bottom - dRect.top) + 8;
        let left = (bRect.left - dRect.left);
        if (left + tRect.width > dRect.width - 8) {
          left = Math.max(8, dRect.width - tRect.width - 8);
        }
        if (top + tRect.height > dRect.height - 8) {
          top = (bRect.top - dRect.top) - tRect.height - 8;
        }
        tooltip.style.top = `${Math.max(8, top)}px`;
        tooltip.style.left = `${Math.max(8, left)}px`;
      };

      const isTouch = window.matchMedia("(pointer: coarse)").matches;

      buttons.forEach((btn) => {
        if (!isTouch) {
          btn.addEventListener("mouseenter", () => { if (!sticky) show(btn); });
          btn.addEventListener("mouseleave", () => { if (!sticky) hide(); });
        }
        btn.addEventListener("click", (e) => {
          e.stopPropagation();
          if (activeBtn === btn && sticky) {
            hide();
          } else {
            sticky = true;
            show(btn);
          }
        });
        btn.addEventListener("focus", () => { if (!sticky) show(btn); });
        btn.addEventListener("blur", () => { if (!sticky) hide(); });
      });

      document.addEventListener("click", (e) => {
        if (!diagram.contains(e.target)) hide();
      });
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") hide();
      });
      window.addEventListener("resize", () => {
        if (activeBtn) positionTooltip(activeBtn);
      });
    })();
  </script>
</BaseLayout>
