---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import { NHIRD, MATERNAL_CHILD, SATELLITES } from "../data/nhird-ecosystem";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const hotspots = [NHIRD, MATERNAL_CHILD, ...SATELLITES];

// Restrained category palette — each registry gets a subdued accent colour
// (top stripe + border tint). Body fill stays white for clean editorial weight.
// Anchored to PHDc's original category colour-coding but muted ~30%.
const TONES: Record<string, { accent: string }> = {
  teal:   { accent: "#3d736a" }, // brand-500 — NHIRD core only
  orange: { accent: "#c2410c" }, // NHIS, ARD
  amber:  { accent: "#a16207" }, // Health Examination
  green:  { accent: "#15803d" }, // COVID-19, CGRD
  sky:    { accent: "#0369a1" }, // Taiwan Biobank
  pink:   { accent: "#be185d" }, // Birth Certificate, NIIS
  indigo: { accent: "#5b21b6" }, // Cancer Registry, OHDSI, Sentinel
  slate:  { accent: "#475569" }, // Cause of Death, Catastrophic Illness
  brown:  { accent: "#92400e" }, // Maternal & Child
};
---

<BaseLayout
  title="NHIRD ecosystem — AsPEN"
  description="Taiwan's National Health Insurance Research Database and its linked registries — hover any panel to see what each data source is."
>
  <PageHeader
    eyebrow="Databases → NHIRD"
    title="NHIRD ecosystem"
    description="Taiwan's National Health Insurance Research Database sits at the centre of a tightly linked set of national registries and survey datasets. Hover (or tap) any panel below to see what it contains."
  />

  <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-8">
    <div
      data-nhird-diagram
      class="relative w-full border border-slate-200 rounded-lg overflow-hidden shadow-sm bg-white p-3 sm:p-5"
    >
      <svg
        viewBox="0 0 800 640"
        xmlns="http://www.w3.org/2000/svg"
        class="block w-full h-auto"
        role="img"
        aria-label="NHIRD ecosystem diagram"
        font-family="Inter, ui-sans-serif, system-ui, sans-serif"
      >
        <defs>
          <filter id="m-shadow" x="-5%" y="-5%" width="110%" height="115%">
            <feDropShadow dx="0" dy="1" stdDeviation="1" flood-color="#0f172a" flood-opacity="0.06" />
          </filter>
        </defs>

        <!-- Connectors (behind boxes) — thin brand-green lines -->
        <g stroke="#3d736a" stroke-width="1.1" fill="none" stroke-linecap="round" opacity="0.5">
          <!-- top satellites → NHIRD top edge -->
          <path d="M 200 120 L 270 180" />
          <path d="M 352 120 L 380 180" />
          <path d="M 502 120 L 470 180" />
          <path d="M 657 120 L 570 180" />

          <!-- left satellites → NHIRD left edge -->
          <path d="M 130 190 L 200 220" />
          <path d="M 130 310 L 200 310" />
          <path d="M 130 430 L 200 360" />

          <!-- right satellites → NHIRD right edge -->
          <path d="M 670 200 L 600 230" />
          <path d="M 670 320 L 600 320" />
          <path d="M 670 445 L 600 360" />

          <!-- bottom satellites → NHIRD bottom edge -->
          <path d="M 80 510 L 260 380" />
          <path d="M 255 510 L 340 380" />
          <path d="M 630 510 L 520 380" />
        </g>

        <!-- ── NHIRD core ──────────────────────────────────────── -->
        <g class="registry registry-core" data-hotspot-id="nhird" filter="url(#m-shadow)" tabindex="0" role="button" aria-label="NHIRD — Claims · All citizens · ~23 million individuals">
          <rect x="200" y="180" width="400" height="200" rx="8" fill="#ebf3f0" stroke="#3d736a" stroke-width="1.8" />
          <text x="220" y="207" font-size="18" font-weight="700" fill="#21443e">NHIRD</text>
          <text x="220" y="225" font-size="10" font-weight="400" fill="#21443e" opacity="0.75">Claims · All citizens · ~23 million</text>
        </g>

        <!-- Maternal & Child sub-box inside NHIRD -->
        <g class="registry" data-hotspot-id="mch" filter="url(#m-shadow)" tabindex="0" role="button" aria-label="Maternal & Child Health Database">
          <rect x="218" y="248" width="170" height="118" rx="6" fill="#fff" stroke="#92400e" stroke-width="1.3" />
          <rect x="218" y="248" width="170" height="3" fill="#92400e" />
          <text x="303" y="271" font-size="10.5" font-weight="700" text-anchor="middle" fill="#0f172a">Maternal &amp; Child</text>
          <text x="303" y="284" font-size="9" font-weight="400" text-anchor="middle" fill="#475569">Health Database</text>
          <g font-size="8.5" font-weight="600" fill="#0f172a">
            <rect x="232" y="298" width="64" height="18" rx="3" fill="#fff" stroke="#cbd5e1" stroke-width="1"/>
            <text x="264" y="310" text-anchor="middle">Mother</text>
            <rect x="312" y="298" width="64" height="18" rx="3" fill="#fff" stroke="#cbd5e1" stroke-width="1"/>
            <text x="344" y="310" text-anchor="middle">Father</text>
            <rect x="272" y="324" width="64" height="18" rx="3" fill="#fff" stroke="#cbd5e1" stroke-width="1"/>
            <text x="304" y="336" text-anchor="middle">Child</text>
          </g>
        </g>

        <!-- Internal NHIRD chips on the right (decorative, no hotspot) -->
        <g font-size="9.5" font-weight="500" fill="#21443e">
          <rect x="405" y="248" width="180" height="20" rx="3" fill="#fff" stroke="#5eead4" stroke-width="1"/>
          <text x="495" y="261" text-anchor="middle">Demographic info.</text>
          <rect x="405" y="275" width="180" height="20" rx="3" fill="#fff" stroke="#5eead4" stroke-width="1"/>
          <text x="495" y="288" text-anchor="middle">Medical records</text>
          <rect x="405" y="302" width="180" height="20" rx="3" fill="#fff" stroke="#5eead4" stroke-width="1"/>
          <text x="495" y="315" text-anchor="middle">Intervention</text>
          <rect x="405" y="329" width="180" height="20" rx="3" fill="#fff" stroke="#5eead4" stroke-width="1"/>
          <text x="495" y="342" text-anchor="middle">Healthcare facility info.</text>
          <rect x="405" y="356" width="180" height="20" rx="3" fill="#fff" stroke="#5eead4" stroke-width="1"/>
          <text x="495" y="369" text-anchor="middle">HCPs' info.</text>
        </g>

        <!-- ── TOP ROW: NHIS · Health Exam · COVID · TWB ──────── -->
        <g class="registry" data-hotspot-id="nhis" filter="url(#m-shadow)" tabindex="0" role="button" aria-label="NHIS — Exercises · Diets · Health behaviors">
          <rect x="140" y="20" width="130" height="100" rx="6" fill="#fff" stroke="#c2410c" stroke-width="1.3" />
          <rect x="140" y="20" width="130" height="3" fill="#c2410c" />
          <text x="205" y="50" font-size="14" font-weight="700" text-anchor="middle" fill="#0f172a">NHIS</text>
          <text x="205" y="76" font-size="9.5" text-anchor="middle" fill="#475569">Exercises · Diets</text>
          <text x="205" y="92" font-size="9.5" text-anchor="middle" fill="#475569">Health behaviors</text>
        </g>

        <g class="registry" data-hotspot-id="hex" filter="url(#m-shadow)" tabindex="0" role="button" aria-label="Health Examination — Laboratory">
          <rect x="285" y="20" width="135" height="100" rx="6" fill="#fff" stroke="#a16207" stroke-width="1.3" />
          <rect x="285" y="20" width="135" height="3" fill="#a16207" />
          <text x="352" y="50" font-size="13" font-weight="700" text-anchor="middle" fill="#0f172a">Health</text>
          <text x="352" y="68" font-size="13" font-weight="700" text-anchor="middle" fill="#0f172a">Examination</text>
          <text x="352" y="92" font-size="9.5" text-anchor="middle" fill="#475569">Laboratory</text>
        </g>

        <g class="registry" data-hotspot-id="covid" filter="url(#m-shadow)" tabindex="0" role="button" aria-label="COVID-19 — Vaccine · Confirmed cases">
          <rect x="435" y="20" width="135" height="100" rx="6" fill="#fff" stroke="#15803d" stroke-width="1.3" />
          <rect x="435" y="20" width="135" height="3" fill="#15803d" />
          <text x="502" y="50" font-size="14" font-weight="700" text-anchor="middle" fill="#0f172a">COVID-19</text>
          <text x="502" y="76" font-size="9.5" text-anchor="middle" fill="#475569">Vaccine</text>
          <text x="502" y="92" font-size="9.5" text-anchor="middle" fill="#475569">Confirmed cases</text>
        </g>

        <g class="registry" data-hotspot-id="twb" filter="url(#m-shadow)" tabindex="0" role="button" aria-label="Taiwan Biobank — Gene · ~200k individuals">
          <rect x="585" y="20" width="145" height="100" rx="6" fill="#fff" stroke="#0369a1" stroke-width="1.3" />
          <rect x="585" y="20" width="145" height="3" fill="#0369a1" />
          <text x="657" y="50" font-size="13" font-weight="700" text-anchor="middle" fill="#0f172a">Taiwan Biobank</text>
          <text x="657" y="76" font-size="9.5" text-anchor="middle" fill="#475569">Gene</text>
          <text x="657" y="92" font-size="9.5" text-anchor="middle" fill="#475569">~200k individuals</text>
        </g>

        <!-- ── LEFT COLUMN: ARD · Birth Certificate · NIIS ────── -->
        <g class="registry" data-hotspot-id="ard" filter="url(#m-shadow)" tabindex="0" role="button" aria-label="ARD — ART · IVF · ~400k records">
          <rect x="10" y="140" width="120" height="100" rx="6" fill="#fff" stroke="#c2410c" stroke-width="1.3" />
          <rect x="10" y="140" width="120" height="3" fill="#c2410c" />
          <text x="70" y="170" font-size="14" font-weight="700" text-anchor="middle" fill="#0f172a">ARD</text>
          <text x="70" y="196" font-size="9.5" text-anchor="middle" fill="#475569">ART · IVF</text>
          <text x="70" y="212" font-size="9.5" text-anchor="middle" fill="#475569">~400k records</text>
        </g>

        <g class="registry" data-hotspot-id="birth" filter="url(#m-shadow)" tabindex="0" role="button" aria-label="Birth Certificate — ~100k records / year">
          <rect x="10" y="260" width="120" height="100" rx="6" fill="#fff" stroke="#be185d" stroke-width="1.3" />
          <rect x="10" y="260" width="120" height="3" fill="#be185d" />
          <text x="70" y="288" font-size="13" font-weight="700" text-anchor="middle" fill="#0f172a">Birth</text>
          <text x="70" y="306" font-size="13" font-weight="700" text-anchor="middle" fill="#0f172a">Certificate</text>
          <text x="70" y="332" font-size="9.5" text-anchor="middle" fill="#475569">~100k records / yr</text>
        </g>

        <g class="registry" data-hotspot-id="niis" filter="url(#m-shadow)" tabindex="0" role="button" aria-label="NIIS — Vaccine">
          <rect x="10" y="380" width="120" height="100" rx="6" fill="#fff" stroke="#be185d" stroke-width="1.3" />
          <rect x="10" y="380" width="120" height="3" fill="#be185d" />
          <text x="70" y="410" font-size="14" font-weight="700" text-anchor="middle" fill="#0f172a">NIIS</text>
          <text x="70" y="440" font-size="9.5" text-anchor="middle" fill="#475569">Vaccine</text>
        </g>

        <!-- ── RIGHT COLUMN: Cancer Registry · Cause of Death · CIR ─── -->
        <g class="registry" data-hotspot-id="cancer" filter="url(#m-shadow)" tabindex="0" role="button" aria-label="Taiwan Cancer Registry">
          <rect x="670" y="140" width="120" height="120" rx="6" fill="#fff" stroke="#5b21b6" stroke-width="1.3" />
          <rect x="670" y="140" width="120" height="3" fill="#5b21b6" />
          <text x="730" y="168" font-size="12" font-weight="700" text-anchor="middle" fill="#0f172a">Taiwan</text>
          <text x="730" y="184" font-size="12" font-weight="700" text-anchor="middle" fill="#0f172a">Cancer</text>
          <text x="730" y="200" font-size="12" font-weight="700" text-anchor="middle" fill="#0f172a">Registry</text>
          <text x="730" y="230" font-size="9.5" text-anchor="middle" fill="#475569">since 2003</text>
        </g>

        <g class="registry" data-hotspot-id="death" filter="url(#m-shadow)" tabindex="0" role="button" aria-label="Cause of Death">
          <rect x="670" y="280" width="120" height="80" rx="6" fill="#fff" stroke="#475569" stroke-width="1.3" />
          <rect x="670" y="280" width="120" height="3" fill="#475569" />
          <text x="730" y="307" font-size="12" font-weight="700" text-anchor="middle" fill="#0f172a">Cause of</text>
          <text x="730" y="323" font-size="12" font-weight="700" text-anchor="middle" fill="#0f172a">Death</text>
          <text x="730" y="346" font-size="9.5" text-anchor="middle" fill="#475569">National registry</text>
        </g>

        <g class="registry" data-hotspot-id="cir" filter="url(#m-shadow)" tabindex="0" role="button" aria-label="Catastrophic Illness Registry">
          <rect x="670" y="380" width="120" height="130" rx="6" fill="#fff" stroke="#475569" stroke-width="1.3" />
          <rect x="670" y="380" width="120" height="3" fill="#475569" />
          <text x="730" y="408" font-size="12" font-weight="700" text-anchor="middle" fill="#0f172a">Catastrophic</text>
          <text x="730" y="424" font-size="12" font-weight="700" text-anchor="middle" fill="#0f172a">Illness</text>
          <text x="730" y="440" font-size="12" font-weight="700" text-anchor="middle" fill="#0f172a">Registry</text>
          <text x="730" y="476" font-size="9.5" text-anchor="middle" fill="#475569">NHI fee waivers</text>
        </g>

        <!-- ── BOTTOM ROW: OHDSI · Sentinel · CGRD ───────────── -->
        <g class="registry" data-hotspot-id="ohdsi" filter="url(#m-shadow)" tabindex="0" role="button" aria-label="OHDSI CDM — OMOP Common Data Model">
          <rect x="10" y="510" width="140" height="100" rx="6" fill="#fff" stroke="#5b21b6" stroke-width="1.3" />
          <rect x="10" y="510" width="140" height="3" fill="#5b21b6" />
          <text x="80" y="544" font-size="14" font-weight="700" text-anchor="middle" fill="#0f172a">OHDSI</text>
          <text x="80" y="572" font-size="9.5" text-anchor="middle" fill="#475569">OMOP CDM</text>
        </g>

        <g class="registry" data-hotspot-id="sentinel" filter="url(#m-shadow)" tabindex="0" role="button" aria-label="Sentinel CDM — FDA Sentinel Common Data Model">
          <rect x="180" y="510" width="150" height="100" rx="6" fill="#fff" stroke="#5b21b6" stroke-width="1.3" />
          <rect x="180" y="510" width="150" height="3" fill="#5b21b6" />
          <text x="255" y="544" font-size="14" font-weight="700" text-anchor="middle" fill="#0f172a">Sentinel</text>
          <text x="255" y="572" font-size="9.5" text-anchor="middle" fill="#475569">FDA CDM</text>
        </g>

        <g class="registry" data-hotspot-id="cgrd" filter="url(#m-shadow)" tabindex="0" role="button" aria-label="CGRD — EHR · ~1 million individuals">
          <rect x="470" y="510" width="320" height="100" rx="6" fill="#fff" stroke="#15803d" stroke-width="1.3" />
          <rect x="470" y="510" width="320" height="3" fill="#15803d" />
          <text x="630" y="544" font-size="16" font-weight="700" text-anchor="middle" fill="#0f172a">CGRD</text>
          <text x="630" y="568" font-size="11" font-weight="500" text-anchor="middle" fill="#475569">Chang Gung Research Database</text>
          <text x="630" y="586" font-size="9.5" text-anchor="middle" fill="#475569">EHR · ~1 million individuals</text>
        </g>
      </svg>

      <!-- Tooltip (positioned by JS over the diagram) -->
      <div
        data-nhird-tooltip
        class="absolute hidden pointer-events-none z-20 max-w-xs sm:max-w-sm bg-white border border-slate-300 rounded-lg shadow-xl p-3 sm:p-4"
        role="tooltip"
      >
        <p class="text-sm sm:text-base font-bold text-slate-900" data-tt-name></p>
        <p class="text-[11px] sm:text-xs font-semibold text-brand-700 mt-0.5" data-tt-meta></p>
        <p class="mt-2 text-xs sm:text-sm text-slate-700 leading-relaxed" data-tt-desc></p>
        <a
          data-tt-link
          target="_blank"
          rel="noopener"
          class="hidden mt-2 inline-block text-xs font-semibold text-brand-700 hover:underline"
        >Read more on PHDc ↗</a>
      </div>
    </div>

    <p class="mt-3 text-xs text-slate-500 italic">
      Diagram structure adapted from the Population Health Data Center (PHDc), National Cheng Kung University; redrawn here as an interactive panel. Hover any panel (desktop) or tap it (mobile) to reveal the dataset description; tap outside to dismiss.
    </p>

    <!-- Full list below for accessibility / SEO / fallback -->
    <div class="mt-12 border-t border-slate-200 pt-8">
      <h2 class="text-xs uppercase tracking-widest text-brand-600 font-semibold mb-4">All datasets in this ecosystem</h2>
      <div class="grid gap-4 md:grid-cols-2">
        {hotspots.map((r) => (
          <article id={`registry-${r.id}`} class="border border-slate-200 rounded-lg p-5 bg-white scroll-mt-24">
            <p class="font-semibold text-slate-900 leading-snug">{r.name}</p>
            <p class="text-xs font-semibold text-brand-700 mt-0.5">{r.meta}</p>
            <p class="mt-2 text-sm text-slate-700 leading-relaxed">{r.description}</p>
            {r.link && (
              <a href={r.link} target="_blank" rel="noopener" class="mt-2 inline-block text-xs font-semibold text-brand-700 hover:underline">
                Read more on PHDc ↗
              </a>
            )}
          </article>
        ))}
      </div>
    </div>

    <p class="mt-10 text-xs text-slate-500 italic">
      Source: <a href="https://www.phdcenter.org.tw/database/" target="_blank" rel="noopener" class="text-brand-700 hover:underline">Population Health Data Center (PHDc), NCKU</a>. Dataset descriptions are paraphrased; please consult PHDc or the respective Taiwan government agency for canonical, up-to-date information.
    </p>
  </section>

  <style is:global>
    [data-nhird-diagram] .registry { cursor: pointer; transition: filter 150ms ease; }
    [data-nhird-diagram] .registry:hover rect:first-child { stroke-width: 2; }
    [data-nhird-diagram] .registry-core:hover rect:first-child { stroke-width: 2.5; }
    [data-nhird-diagram] .registry:focus { outline: none; }
    [data-nhird-diagram] .registry:focus rect:first-child { stroke-width: 2.5; stroke: #21443e; }
  </style>

  <script is:inline define:vars={{ hotspots }}>
    (() => {
      const diagram = document.querySelector("[data-nhird-diagram]");
      if (!diagram) return;
      const tooltip = diagram.querySelector("[data-nhird-tooltip]");
      const groups = Array.from(diagram.querySelectorAll(".registry[data-hotspot-id]"));
      const byId = Object.fromEntries(hotspots.map((r) => [r.id, r]));

      const ttName = tooltip.querySelector("[data-tt-name]");
      const ttMeta = tooltip.querySelector("[data-tt-meta]");
      const ttDesc = tooltip.querySelector("[data-tt-desc]");
      const ttLink = tooltip.querySelector("[data-tt-link]");

      let activeEl = null;
      let sticky = false;

      const show = (el) => {
        const id = el.dataset.hotspotId;
        const r = byId[id];
        if (!r) return;
        ttName.textContent = r.name;
        ttMeta.textContent = r.meta;
        ttDesc.textContent = r.description;
        if (r.link) {
          ttLink.href = r.link;
          ttLink.classList.remove("hidden");
        } else {
          ttLink.classList.add("hidden");
        }
        tooltip.classList.remove("hidden");
        positionTooltip(el);
        activeEl = el;
      };

      const hide = () => {
        tooltip.classList.add("hidden");
        activeEl = null;
        sticky = false;
      };

      const positionTooltip = (el) => {
        const dRect = diagram.getBoundingClientRect();
        const bRect = el.getBoundingClientRect();
        tooltip.style.top = "0px";
        tooltip.style.left = "0px";
        const tRect = tooltip.getBoundingClientRect();
        let top = (bRect.bottom - dRect.top) + 8;
        let left = (bRect.left - dRect.left);
        if (left + tRect.width > dRect.width - 8) {
          left = Math.max(8, dRect.width - tRect.width - 8);
        }
        if (top + tRect.height > dRect.height - 8) {
          top = (bRect.top - dRect.top) - tRect.height - 8;
        }
        tooltip.style.top = `${Math.max(8, top)}px`;
        tooltip.style.left = `${Math.max(8, left)}px`;
      };

      const isTouch = window.matchMedia("(pointer: coarse)").matches;

      groups.forEach((el) => {
        if (!isTouch) {
          el.addEventListener("mouseenter", () => { if (!sticky) show(el); });
          el.addEventListener("mouseleave", () => { if (!sticky) hide(); });
        }
        el.addEventListener("click", (e) => {
          e.stopPropagation();
          if (activeEl === el && sticky) {
            hide();
          } else {
            sticky = true;
            show(el);
          }
        });
        el.addEventListener("focus", () => { if (!sticky) show(el); });
        el.addEventListener("blur", () => { if (!sticky) hide(); });
      });

      document.addEventListener("click", (e) => {
        if (!diagram.contains(e.target)) hide();
      });
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") hide();
      });
      window.addEventListener("resize", () => {
        if (activeEl) positionTooltip(activeEl);
      });
    })();
  </script>
</BaseLayout>
