---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import CiteButton from "../components/CiteButton.astro";
import PublicationCard from "../components/PublicationCard.astro";
import pubsRaw from "../data/publications.json";

const siteBase = import.meta.env.BASE_URL.replace(/\/?$/, "/"); // ensure trailing slash
const siteUrl = `https://phd-center.github.io${siteBase}publications/`;

const publications = [...pubsRaw].sort((a, b) => b.year - a.year);
const years = Array.from(new Set(publications.map((p) => p.year))).sort((a, b) => b - a);

// Curated achievement milestones per year. Edit this list to tell the AsPEN story.
// `year` drives the filter; click jumps to that year's publications below.
// Each milestone may optionally link to a specific paper by PMID — clicking will
// scroll the publication list below to that paper. Milestones without `pmid`
// (e.g. organisational events) just sit on the timeline.
const milestones: { year: number; text: string; pmid?: string }[] = [
  { year: 2012, text: "AsPEN founded as an ISPE Special Interest Group", pmid: "23653370" },
  { year: 2013, text: "First multi-country PSSA on antipsychotics and acute hyperglycaemia", pmid: "23696036" },
  { year: 2015, text: "Asia-Pacific database survey in Epidemiology, covering 11 Asian databases", pmid: "26133022" },
  { year: 2018, text: "Common Data Model framework applied to Asian databases", pmid: "30100761" },
  { year: 2020, text: "NeuroGEN initiative introduced for big data in CNS drug research", pmid: "32572794" },
  { year: 2021, text: "Vaccine-safety database suitability across 19 Asia-Pacific countries", pmid: "33634545" },
  { year: 2023, text: "NeuroGEN data infrastructure formalised across 15 databases over 4 continents", pmid: "38146486" },
  { year: 2024, text: "Multi-national pregnancy outcomes of 3.6M mother and child pairs (Nature Medicine)", pmid: "38589601" },
  { year: 2026, text: "Asian DUPLICATE initiative emulating RCTs with real-world databases", pmid: "40820495" },
];
---

<BaseLayout title="Publications — AsPEN" description="Peer-reviewed publications from the Asian Pharmacoepidemiology Network.">
  <PageHeader
    eyebrow="Publications"
    title="Publications"
    description="Peer-reviewed output from AsPEN collaborations. Click a milestone to jump to that year, or use the filters below."
  />

  <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-10">
    <!-- Switcher: chronological (this page) vs themed -->
    <div class="mb-8 inline-flex rounded-lg border border-slate-200 bg-white p-1 text-sm">
      <span class="px-3 py-1.5 rounded bg-brand-700 text-white font-semibold">Chronological</span>
      <a href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/publications/themes/`} class="px-3 py-1.5 rounded text-slate-700 hover:bg-slate-100 font-semibold">By theme →</a>
    </div>

    <!-- Year milestone timeline (number line) -->
    <div class="mb-12">
      <p class="text-sm font-semibold text-slate-600 uppercase tracking-wide mb-5">Key milestones</p>

      <div class="relative overflow-x-auto pb-4 pt-1">
        <div class="relative flex items-start gap-2" style="min-width: max-content;">
          <!-- horizontal line behind dots -->
          <div class="absolute left-4 right-4 top-[28px] h-0.5 bg-slate-200 pointer-events-none"></div>

          {milestones.map((m) => (
            <button
              type="button"
              data-pmid={m.pmid ?? ""}
              data-year-btn={String(m.year)}
              class="milestone-node group relative flex flex-col items-center w-48 shrink-0 cursor-pointer text-center px-2"
            >
              <span class="relative z-10 w-5 h-5 rounded-full bg-white border-2 border-brand-500 group-hover:bg-brand-500 transition shadow-sm"></span>
              <span class="text-base font-semibold text-brand-700 mt-2">{m.year}</span>
              <p class="text-sm text-slate-700 mt-2 leading-snug">{m.text}</p>
            </button>
          ))}
        </div>
      </div>
    </div>

    <div class="grid gap-3 sm:grid-cols-2 mb-6">
      <label class="block">
        <span class="text-xs font-semibold text-slate-600 uppercase tracking-wide">Year</span>
        <select id="filter-year" class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-sm">
          <option value="">All years</option>
          {years.map((y) => <option value={String(y)}>{y}</option>)}
        </select>
      </label>
      <label class="block">
        <span class="text-xs font-semibold text-slate-600 uppercase tracking-wide">Search</span>
        <input id="filter-q" type="search" placeholder="title, author, journal…" class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-sm" />
      </label>
    </div>

    <ul id="pub-list" class="divide-y divide-slate-200 border border-slate-200 rounded-lg overflow-hidden bg-white">
      {publications.map((p) => <PublicationCard pub={p} />)}
    </ul>
    <p id="pub-empty" class="hidden mt-6 text-sm text-slate-500 italic">No publications match your filters.</p>

    <CiteButton title="Publications" url={siteUrl} bibkey="aspen-publications" />
  </section>

  <style is:global>
    .milestone-node:hover .text-brand-700 { color: var(--color-brand-900, #0f2e22); }
    @keyframes pub-flash {
      0%   { background-color: rgba(58, 138, 110, 0.25); }
      100% { background-color: transparent; }
    }
    .pub-flash { animation: pub-flash 1.6s ease-out; }
  </style>

  <script is:inline>
    (() => {
      const list = document.getElementById("pub-list");
      const empty = document.getElementById("pub-empty");
      const fYear = document.getElementById("filter-year");
      const fQ = document.getElementById("filter-q");
      const milestoneBtns = document.querySelectorAll("[data-year-btn]");
      if (!list) return;
      const items = Array.from(list.querySelectorAll("li"));

      const apply = () => {
        const y = String(fYear.value || "");
        const q = (fQ.value || "").trim().toLowerCase();
        let shown = 0;
        items.forEach((li) => {
          const matchYear = !y || String(li.dataset.year) === y;
          const matchQ = !q || (li.dataset.search || "").includes(q);
          const visible = matchYear && matchQ;
          li.style.display = visible ? "" : "none";
          if (visible) shown++;
        });
        empty.classList.toggle("hidden", shown !== 0);
        milestoneBtns.forEach((b) => {
          b.classList.toggle("active", b.dataset.yearBtn === y);
        });
      };

      milestoneBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
          const pmid = btn.dataset.pmid;
          // Always clear filters so the linked paper is visible
          fYear.value = "";
          fQ.value = "";
          apply();
          if (pmid) {
            const target = document.getElementById("pub-" + pmid);
            if (target) {
              target.scrollIntoView({ behavior: "smooth", block: "start" });
              target.classList.remove("pub-flash");
              // restart animation
              void target.offsetWidth;
              target.classList.add("pub-flash");
              return;
            }
          }
          // Fallback (e.g. milestone without pmid): just scroll list into view
          list.scrollIntoView({ behavior: "smooth", block: "start" });
        });
      });

      [fYear, fQ].forEach((el) => el && el.addEventListener("input", apply));
      apply();
    })();
  </script>
</BaseLayout>
