---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import pubsRaw from "../data/publications.json";

const publications = [...pubsRaw].sort((a, b) => b.year - a.year);
const years = Array.from(new Set(publications.map((p) => p.year))).sort((a, b) => b - a);

// Build a continuous year axis (fill empty years with 0 so the line stays continuous)
const yearCounts: Record<number, number> = {};
for (const p of publications) yearCounts[p.year] = (yearCounts[p.year] ?? 0) + 1;
const minYear = Math.min(...years);
const maxYear = Math.max(...years);
const yearData: { year: number; count: number }[] = [];
for (let y = minYear; y <= maxYear; y++) {
  yearData.push({ year: y, count: yearCounts[y] ?? 0 });
}
const maxCount = Math.max(...yearData.map((y) => y.count), 1);
---

<BaseLayout title="Publications — AsPEN" description="Peer-reviewed publications from the Asian Pharmacoepidemiology Network.">
  <PageHeader
    eyebrow="Publications"
    title="Publications"
    description="Peer-reviewed output from AsPEN collaborations. Filter by year, or search by keyword."
  />

  <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-10">
    <!-- Year timeline: bar height = publication count; click to filter -->
    <div class="mb-8">
      <p class="text-xs font-semibold text-slate-600 uppercase tracking-wide mb-3 flex items-baseline gap-2">
        Publications by year
        <span class="text-[10px] font-normal text-slate-400 normal-case tracking-normal">click any bar to filter</span>
      </p>
      <div class="relative">
        <div class="flex items-end gap-1.5 h-28 overflow-x-auto pb-1 pl-1 pr-1" id="year-timeline">
          {yearData.map(({ year, count }) => {
            const heightPct = count === 0 ? 0 : Math.max(8, Math.round((count / maxCount) * 100));
            return (
              <button
                type="button"
                data-year-btn={String(year)}
                class={`year-btn group relative flex flex-col items-center justify-end min-w-[38px] h-full cursor-pointer rounded-md transition ${count === 0 ? "opacity-40" : ""}`}
                aria-label={`${count} publication${count === 1 ? "" : "s"} in ${year}`}
              >
                <span class="bar-count text-[10px] font-bold text-slate-700 mb-0.5 opacity-0 group-hover:opacity-100 transition">{count}</span>
                {count > 0 ? (
                  <div
                    class="bar w-5 bg-brand-300 group-hover:bg-brand-600 transition-colors rounded-t"
                    style={`height:${heightPct}%`}
                  ></div>
                ) : (
                  <div class="w-5 h-1 bg-slate-200 rounded"></div>
                )}
                <span class="bar-year text-[10px] text-slate-600 mt-1 font-mono">{year}</span>
              </button>
            );
          })}
        </div>
        <div class="absolute inset-x-0 bottom-7 h-px bg-slate-200 pointer-events-none"></div>
      </div>
    </div>

    <div class="grid gap-3 sm:grid-cols-2 mb-6">
      <label class="block">
        <span class="text-xs font-semibold text-slate-600 uppercase tracking-wide">Year</span>
        <select id="filter-year" class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-sm">
          <option value="">All years</option>
          {years.map((y) => <option value={String(y)}>{y}</option>)}
        </select>
      </label>
      <label class="block">
        <span class="text-xs font-semibold text-slate-600 uppercase tracking-wide">Search</span>
        <input id="filter-q" type="search" placeholder="title, author, journal…" class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-sm" />
      </label>
    </div>

    <ul id="pub-list" class="divide-y divide-slate-200 border border-slate-200 rounded-lg overflow-hidden bg-white">
      {publications.map((p) => {
        const featured = (p as { featured?: boolean }).featured;
        const blurb = (p as { blurb?: string }).blurb;
        return (
          <li
            class={`p-5 hover:bg-slate-50 ${featured ? "border-l-4 border-l-brand-500 bg-brand-50/30" : ""}`}
            data-year={String(p.year)}
            data-search={`${p.title} ${p.authors} ${p.journal}`.toLowerCase()}
          >
            <div class="flex items-center gap-2 text-xs text-slate-500">
              {featured && (
                <span class="inline-flex items-center gap-1 bg-gradient-to-r from-brand-600 to-brand-700 text-white font-semibold px-2 py-0.5 rounded-full text-[10px] uppercase tracking-wider">
                  ⭐ Landmark
                </span>
              )}
              <span>{p.year} · {p.journal}</span>
            </div>
            <p class="font-semibold text-slate-900 mt-1.5 leading-snug">{p.title}</p>
            {blurb && (
              <p class="text-sm text-brand-700 italic mt-1.5 leading-relaxed">{blurb}</p>
            )}
            <p class="text-sm text-slate-600 mt-1.5">{p.authors}</p>
            <div class="mt-2 flex flex-wrap gap-2 text-xs">
              {p.tags.map((t) => <span class="inline-block bg-brand-50 text-brand-700 px-2 py-0.5 rounded">{t}</span>)}
              {p.doi && <a class="text-brand-600 hover:underline" href={`https://doi.org/${p.doi}`} target="_blank" rel="noopener">DOI: {p.doi}</a>}
              {p.pmid && <a class="text-brand-600 hover:underline" href={`https://pubmed.ncbi.nlm.nih.gov/${p.pmid}/`} target="_blank" rel="noopener">PMID: {p.pmid}</a>}
            </div>
          </li>
        );
      })}
    </ul>
    <p id="pub-empty" class="hidden mt-6 text-sm text-slate-500 italic">No publications match your filters.</p>
  </section>

  <style is:global>
    .year-btn .bar { background-color: #c8e4d2; }
    .year-btn.active .bar { background-color: var(--color-brand-600, #2d6e57); }
    .year-btn.active { background-color: rgba(58, 138, 110, 0.08); }
    .year-btn.active .bar-count { opacity: 1 !important; color: var(--color-brand-700, #225641); }
    .year-btn.active .bar-year { color: var(--color-brand-700, #225641); font-weight: 600; }
  </style>

  <script is:inline>
    (() => {
      const list = document.getElementById("pub-list");
      const empty = document.getElementById("pub-empty");
      const fYear = document.getElementById("filter-year");
      const fQ = document.getElementById("filter-q");
      const yearBtns = document.querySelectorAll("[data-year-btn]");
      if (!list) return;
      const items = Array.from(list.querySelectorAll("li"));

      const apply = () => {
        const y = String(fYear.value || "");
        const q = (fQ.value || "").trim().toLowerCase();
        let shown = 0;
        items.forEach((li) => {
          const matchYear = !y || String(li.dataset.year) === y;
          const matchQ = !q || (li.dataset.search || "").includes(q);
          const visible = matchYear && matchQ;
          li.style.display = visible ? "" : "none";
          if (visible) shown++;
        });
        empty.classList.toggle("hidden", shown !== 0);
        // Highlight active year button
        yearBtns.forEach((b) => {
          b.classList.toggle("active", b.dataset.yearBtn === y);
        });
      };

      yearBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
          const y = btn.dataset.yearBtn;
          // Toggle: if already filtered to this year, clear
          if (String(fYear.value) === String(y)) {
            fYear.value = "";
          } else {
            fYear.value = y;
          }
          apply();
          // Scroll publication list into view
          list.scrollIntoView({ behavior: "smooth", block: "start" });
        });
      });

      [fYear, fQ].forEach((el) => el && el.addEventListener("input", apply));
      apply();
    })();
  </script>
</BaseLayout>
