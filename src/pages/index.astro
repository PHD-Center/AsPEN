---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import ChairCard from "../components/ChairCard.astro";
import StatsBar from "../components/StatsBar.astro";
import databases from "../data/databases.json";
import publications from "../data/publications.json";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// Derived stats for the StatsBar. Headline numbers focus on active Asian
// sites only (TW, JP, KR, HK). External partner sites (UK, US, NL, FI, AU)
// are surfaced elsewhere on the page (Databases section, map, etc.).
const FOUNDED_YEAR = 2012;
const ASIAN_CODES = new Set(["TW", "JP", "KR", "HK"]);
const asianDbs = databases.filter((d) => ASIAN_CODES.has(d.code));
const asianCountries = new Set(asianDbs.map((d) => d.country)).size;

// Population covered, summed across the largest national database in each of
// the four core East-Asia countries. Approximate ~200M people:
//   TW NHIRD ~23M · JP NDB ~120M · KR HIRA/NHIS ~50M · HK CDARS ~7M
const POPULATION_M = 200;

const stats = [
  { value: asianCountries, label: "Countries", sublabel: "in Asia" },
  { value: asianDbs.length, label: "Databases", sublabel: "in Asia" },
  { value: POPULATION_M, suffix: "M", label: "Population", sublabel: "covered in Asia" },
  { value: publications.length, label: "Publications", sublabel: "since 2012" },
  { value: new Date().getFullYear() - FOUNDED_YEAR, label: "Years", sublabel: "of collaboration" },
];

// One primary database per country (user-curated). Order = display order.
const primaryNames = [
  "National Health Insurance Research Database (NHIRD)",
  "National Database of Health Insurance Claims and Specific Health Checkups (NDB)",
  "National Health Insurance Service – National Health Information Database (NHIS-NHID)",
  "Clinical Data Analysis and Reporting System (CDARS)",
  "Clinical Practice Research Datalink (CPRD)",
  "Medicare (20% sample)",
];
const flags: Record<string, string> = {
  Taiwan: "🇹🇼",
  Japan: "🇯🇵",
  "South Korea": "🇰🇷",
  "Hong Kong": "🇭🇰",
  "United Kingdom": "🇬🇧",
  "United States": "🇺🇸",
};
const featured = primaryNames
  .map((name) => databases.find((d) => d.name === name))
  .filter((d): d is (typeof databases)[number] => Boolean(d));
const countries = featured.length;
---

<BaseLayout tint>
  <Hero />

  <StatsBar stats={stats} />

  <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-16 grid gap-8 md:grid-cols-3">
    <div>
      <p class="uppercase tracking-widest text-xs text-brand-600 font-semibold">Who we are</p>
      <h3 class="mt-2 text-xl font-semibold text-slate-900">A regional research network</h3>
      <p class="mt-3 text-slate-600 text-sm leading-relaxed">Founded in April 2012, AsPEN is a Special Interest Group of ISPE connecting pharmacoepidemiology researchers across {countries}+ Asia/Pacific countries.</p>
    </div>
    <div>
      <p class="uppercase tracking-widest text-xs text-brand-600 font-semibold">What we do</p>
      <h3 class="mt-2 text-xl font-semibold text-slate-900">Multi-country database studies</h3>
      <p class="mt-3 text-slate-600 text-sm leading-relaxed">Common protocols applied locally to each site's claims or EHR database — rapid signal detection, methodologic harmonisation, and full pharmacoepidemiological studies.</p>
    </div>
    <div>
      <p class="uppercase tracking-widest text-xs text-brand-600 font-semibold">How to join</p>
      <h3 class="mt-2 text-xl font-semibold text-slate-900">Open to ISPE members</h3>
      <p class="mt-3 text-slate-600 text-sm leading-relaxed">Join the SIG through the ISPE Community platform; new collaborators are welcomed across academic, regulatory, and industry settings.</p>
      <a href={`${base}/about/#how-to-join`} class="inline-block mt-3 text-brand-600 font-semibold text-sm hover:underline">Learn more →</a>
    </div>
  </section>

  <section class="bg-slate-50 border-y border-slate-200">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-16 grid gap-10 md:grid-cols-2 items-center">
      <div>
        <p class="uppercase tracking-widest text-xs text-brand-600 font-semibold">Leadership</p>
        <h2 class="mt-2 text-3xl font-bold text-slate-900">Meet the current Chair</h2>
        <p class="mt-4 text-slate-600">AsPEN is led by a Chair elected from member national groups. The current Chair oversees programme strategy, ISPE liaison, and coordination of multi-country studies.</p>
      </div>
      <ChairCard
        name="Ju-Young Shin"
        affiliation="SKKU · SNU"
        photo={`${base}/images/Judy.png`}
        bio="Professor of pharmacoepidemiology and pharmacovigilance; research focuses on drug utilization and safety studies using nationwide healthcare databases."
      />
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-16">
    <h2 class="text-3xl font-bold text-slate-900">Where AsPEN works</h2>
    <p class="mt-3 text-slate-600 max-w-2xl">AsPEN brings together databases and research groups across Asia/Pacific. Below: a snapshot of participating data sources.</p>
    <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {featured.map((d) => {
        const anchor = `db-${d.name.replace(/[^a-z0-9]+/gi, "-").toLowerCase()}`;
        return (
          <a
            href={`${base}/databases/#${anchor}`}
            class="group block border border-slate-200 rounded-lg p-5 hover:shadow-md hover:border-brand-400 transition bg-white"
          >
            <p class="text-xs font-semibold text-brand-600 uppercase tracking-wide flex items-center gap-1.5">
              <span class="text-base leading-none">{flags[d.country] ?? "🏳️"}</span>
              {d.country}
            </p>
            <p class="mt-2 font-semibold text-slate-900 leading-snug group-hover:text-brand-700 transition">{d.name}</p>
            <p class="mt-1 text-xs text-slate-500">{d.type}</p>
          </a>
        );
      })}
    </div>
    <div class="mt-8">
      <a href={`${base}/databases/`} class="text-brand-600 font-semibold hover:underline">See all databases →</a>
    </div>
  </section>
</BaseLayout>
