---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import WorldMap from "../components/WorldMap.astro";
import members from "../data/members.json";

const mapItems = members.map((m) => ({
  lat: m.lat,
  lng: m.lng,
  title: m.country,
  body: m.contact !== "—" ? `${m.contact}<br><em>${m.institution}</em>` : "Contact TBD",
  anchor: `m-${m.code}`,
}));
---

<BaseLayout title="Members — AsPEN" description="National research groups and contact persons participating in AsPEN.">
  <PageHeader
    eyebrow="Members"
    title="National groups & contacts"
    description="AsPEN connects researchers across the Asia/Pacific region and partner sites. Click a marker to jump to that country's contact card."
  />

  <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-10 space-y-10">
    <WorldMap
      items={mapItems}
      height="540px"
      initialCenter={[35, 60]}
      initialZoom={3}
    />

    <div>
      <h2 class="text-2xl font-bold text-slate-900 mb-6">National groups & contact persons</h2>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {members.map((m) => (
          <article id={`m-${m.code}`} class="scroll-mt-24 border border-slate-200 rounded-lg p-5 bg-white hover:shadow-md transition">
            <p class="text-xs font-semibold text-brand-600 uppercase tracking-wide">{m.country}</p>
            <p class="mt-2 font-semibold text-slate-900">{m.contact}</p>
            <p class="text-sm text-slate-600">{m.institution}</p>
            {m.email && <a class="mt-2 inline-block text-sm text-brand-600 hover:underline" href={`mailto:${m.email}`}>{m.email}</a>}
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
