---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import members from "../data/members.json";

const project = (lat: number, lng: number) => {
  // simple equirectangular projection, focused on Asia/Pacific
  const minLng = 60, maxLng = 180;
  const minLat = -45, maxLat = 60;
  const x = ((lng - minLng) / (maxLng - minLng)) * 100;
  const y = ((maxLat - lat) / (maxLat - minLat)) * 100;
  return { x, y };
};
---

<BaseLayout title="Members — AsPEN" description="National research groups and contact persons participating in AsPEN.">
  <PageHeader
    eyebrow="Members"
    title="National groups & contacts"
    description="AsPEN connects researchers across the Asia/Pacific region. Click a marker on the map to jump to that country's contact."
  />

  <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="relative aspect-[16/9] bg-gradient-to-br from-brand-50 to-slate-100 rounded-lg border border-slate-200 overflow-hidden">
      <div class="absolute inset-0 grid grid-cols-12 grid-rows-6 opacity-30 pointer-events-none">
        {Array.from({ length: 72 }).map(() => <div class="border border-slate-200/60"></div>)}
      </div>
      <p class="absolute top-3 left-3 text-xs text-slate-500 bg-white/70 backdrop-blur px-2 py-1 rounded">Asia / Pacific</p>
      {members.map((m) => {
        const { x, y } = project(m.lat, m.lng);
        return (
          <a
            href={`#${m.code}`}
            class="absolute -translate-x-1/2 -translate-y-1/2 group"
            style={`left:${x}%;top:${y}%;`}
            aria-label={m.country}
          >
            <span class="block w-4 h-4 rounded-full bg-brand-600 ring-4 ring-brand-200/70 group-hover:bg-brand-700 group-hover:scale-125 transition shadow-md"></span>
            <span class="absolute left-5 top-1/2 -translate-y-1/2 whitespace-nowrap text-xs font-semibold text-slate-800 bg-white/90 px-1.5 py-0.5 rounded shadow opacity-0 group-hover:opacity-100 pointer-events-none">{m.country}</span>
          </a>
        );
      })}
    </div>
    <p class="mt-3 text-xs text-slate-500">A schematic locator map. For a geographically accurate view, a Leaflet-based interactive version can be added later.</p>

    <h2 class="mt-12 text-2xl font-bold text-slate-900">National groups & contact persons</h2>
    <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {members.map((m) => (
        <article id={m.code} class="border border-slate-200 rounded-lg p-5 bg-white scroll-mt-24">
          <p class="text-xs font-semibold text-brand-600 uppercase tracking-wide">{m.country}</p>
          <p class="mt-2 font-semibold text-slate-900">{m.contact}</p>
          <p class="text-sm text-slate-600">{m.institution}</p>
          {m.email && <a class="mt-2 inline-block text-sm text-brand-600 hover:underline" href={`mailto:${m.email}`}>{m.email}</a>}
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
