---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// Open-source tools + partner organisations AsPEN works alongside.
// `image` is a path under public/images/ (omit for a text-only card that
// shows the site name instead of a logo). `heightClass` tunes each logo so
// they read at a similar visual scale despite different aspect ratios.
const oss = [
  {
    name: "Ocean",
    tagline: "Open Casual Effect Analysis Network; PHDc's open ecology search and visualisation portal.",
    href: "https://ocean-dev.phdcenter.org.tw",
    image: "open-source/ocean.svg",
    heightClass: "h-16",
  },
  {
    name: "GitHub",
    tagline: "Source code for this site, the auth Worker, and the AsPEN-members data files lives in public PHD-Center repositories.",
    href: "https://github.com/",
    image: "open-source/github.svg",
    heightClass: "h-24",
  },
  {
    name: "ISPE AsPEN SIG",
    tagline: "AsPEN's page as a Special Interest Group within the International Society for Pharmacoepidemiology (ISPE).",
    href: "https://www.pharmacoepi.org/communities/sigs/aspen/",
    image: "websites/ispe.jpg",
    heightClass: "h-20",
  },
  {
    name: "Population Health Data Center, NCKU",
    tagline: "PHDc at National Cheng Kung University; the data infrastructure behind much of AsPEN's Taiwan-based work.",
    href: "https://www.phdcenter.org.tw/database/",
    image: "websites/phdc-wide.png",
    heightClass: "h-24",
  },
  {
    name: "NeuroGEN",
    // No supplied logo; render a styled wordmark instead of plain text.
    wordmark: 'Neuro<span class="text-brand-600">GEN</span>',
    tagline: "The Neurological and mental health Global Epidemiology Network; a multi-database platform spanning Asia, Oceania, Europe, and North America.",
    href: "https://neurogen.hku.hk/",
  },
  {
    name: "DARWIN EU",
    tagline: "Data Analysis and Real World Interrogation Network; the European Medicines Agency's federated real-world evidence network.",
    href: "https://www.darwin-eu.org/",
    image: "websites/darwin-eu.png",
    heightClass: "h-36",
  },
];
---

<BaseLayout
  title="Open source · AsPEN"
  description="Open-source tools and partner organisations AsPEN works alongside."
>
  <PageHeader
    eyebrow="Friendship links"
    title="Open source"
    description="Open-source tools and partner organisations AsPEN works alongside."
  />

  <section class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid gap-6 sm:grid-cols-2">
      {oss.map((s) => (
        <a href={s.href} target="_blank" rel="noopener noreferrer"
           class="group block border border-slate-200 rounded-2xl p-8 bg-white hover:shadow-md hover:border-brand-400 transition">
          <div class="h-36 flex items-center">
            {s.image ? (
              <img src={`${base}/images/${s.image}`} alt={s.name} class:list={[s.heightClass, "w-auto"]} />
            ) : (
              <!-- NeuroGEN: the wordmark itself is filled with the flags of its 9
                   partner regions (PMID 38146486). Sits on a grey plate (no stroke)
                   so the letters over mostly-white flags (Finland, Netherlands,
                   Scotland) still read against the background. -->
              <div class="inline-flex items-center rounded-2xl bg-slate-300 px-5 py-3">
                <h2
                  class="text-6xl font-black tracking-tight leading-none"
                  style={`background:url('${base}/images/flags/neurogen-name.png') center / 100% 100% no-repeat; -webkit-background-clip:text; background-clip:text; -webkit-text-fill-color:transparent; color:transparent;`}
                  title="NeuroGEN partner regions: Taiwan, South Korea, Hong Kong, Australia, United Kingdom, Scotland, Netherlands, Finland, United States"
                >{s.name}</h2>
              </div>
            )}
          </div>
          <p class="mt-6 text-sm text-slate-700 leading-relaxed">{s.tagline}</p>
          <p class="mt-4 text-xs text-brand-700 font-semibold group-hover:underline">
            {s.href.replace(/^https?:\/\//, "")} ↗
          </p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
