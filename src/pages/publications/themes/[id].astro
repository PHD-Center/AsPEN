---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHeader from "../../../components/PageHeader.astro";
import PublicationCard from "../../../components/PublicationCard.astro";
import pubsRaw from "../../../data/publications.json";
import { THEMES, type Theme } from "../../../data/themes";

export async function getStaticPaths() {
  return THEMES.map((t) => ({ params: { id: t.id }, props: { theme: t } }));
}

interface Props { theme: Theme }
const { theme } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

type Pub = (typeof pubsRaw)[number];
const tagSet = new Set(theme.tags.map((x) => x.toLowerCase()));
const matched: Pub[] = (pubsRaw as Pub[])
  .filter((p) => (p.tags ?? []).some((tag) => tagSet.has(tag.toLowerCase())))
  .sort((a, b) => b.year - a.year);

const yearMin = matched.length ? Math.min(...matched.map((p) => p.year)) : 0;
const yearMax = matched.length ? Math.max(...matched.map((p) => p.year)) : 0;
---

<BaseLayout
  title={`${theme.name} — Publications — AsPEN`}
  description={`AsPEN publications in the ${theme.name} theme.`}
>
  <PageHeader
    eyebrow={`Publications → Themes → ${theme.number}`}
    title={theme.name}
    description={theme.story}
  />

  <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-10">
    <div class="mb-8 flex items-center justify-between gap-3 flex-wrap text-sm">
      <div class="flex gap-4">
        <a href={`${base}/publications/themes/`} class="text-brand-700 font-semibold hover:underline">← Magazine view</a>
        <a href={`${base}/publications/`} class="text-slate-600 hover:text-brand-700 hover:underline">Full chronological list</a>
      </div>
      <p class="text-slate-500 tabular-nums">{matched.length} {matched.length === 1 ? "paper" : "papers"} · {yearMin === yearMax ? yearMin : `${yearMin}–${yearMax}`}</p>
    </div>

    {matched.length === 0 ? (
      <p class="text-sm italic text-slate-500">No publications matched this theme yet.</p>
    ) : (
      <ul class="divide-y divide-slate-200 border border-slate-200 rounded-lg overflow-hidden bg-white">
        {matched.map((p) => <PublicationCard pub={p} />)}
      </ul>
    )}
  </section>
</BaseLayout>
