---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHeader from "../../../components/PageHeader.astro";
import pubsRaw from "../../../data/publications.json";
import affiliations from "../../../data/affiliations.json";
import { THEMES } from "../../../data/themes";
import ThemeCoverVisual from "../../../components/ThemeCoverVisual.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

type Pub = (typeof pubsRaw)[number];
const pubs: Pub[] = pubsRaw as Pub[];
type Aff = Record<string, { countries: string[] }>;
const aff = affiliations as Aff;

// Compute per-theme dataset. Highlight = explicit `highlightPmid` override
// when set on the theme, otherwise featured > blurbed > most-recent.
const buckets = THEMES.map((t) => {
  const tagSet = new Set(t.tags.map((x) => x.toLowerCase()));
  const matched = pubs
    .filter((p) => (p.tags ?? []).some((tag) => tagSet.has(tag.toLowerCase())))
    .sort((a, b) => b.year - a.year);

  let highlight: Pub | undefined;
  if (t.highlightPmid) {
    highlight = pubs.find((p) => p.pmid === t.highlightPmid);
  }
  if (!highlight) {
    const featured = matched.filter((p) => (p as { featured?: boolean }).featured);
    const blurbed = matched.filter((p) => (p as { blurb?: string }).blurb);
    highlight = (featured[0] as Pub | undefined) ?? (blurbed[0] as Pub | undefined) ?? matched[0];
  }

  const years = matched.map((p) => p.year);
  const yearMin = years.length ? Math.min(...years) : 0;
  const yearMax = years.length ? Math.max(...years) : 0;
  const countries = new Set<string>();
  for (const p of matched) for (const c of aff[p.pmid ?? ""]?.countries ?? []) countries.add(c);

  return { ...t, papers: matched, highlight, yearMin, yearMax, countries: countries.size };
});

const totalPapers = pubs.length;
const globalMin = Math.min(...pubs.map((p) => p.year));
const globalMax = Math.max(...pubs.map((p) => p.year));

const allThemeTags = new Set(THEMES.flatMap((t) => t.tags.map((x) => x.toLowerCase())));
const orphanPubs = pubs.filter((p) => !(p.tags ?? []).some((t) => allThemeTags.has(t.toLowerCase())));

// Bento layout sizing per tile, keyed by theme id.
// 4-column grid on desktop; rows are 260px each. Methods is a 2×2 hero;
// Neuro + Pregnancy are 2×1 wide tiles; the rest are 1×1 squares.
const tileSpan: Record<string, string> = {
  "methods-infrastructure": "lg:col-span-2 lg:row-span-2",
  "neuropsychiatric":       "lg:col-span-2 lg:row-span-1",
  "pregnancy-paediatric":   "lg:col-span-2 lg:row-span-1",
  "diabetes-cardiometabolic": "lg:col-span-1 lg:row-span-1",
  "pain-opioids":           "lg:col-span-1 lg:row-span-1",
  "oncology-endocrine":     "lg:col-span-1 lg:row-span-1",
  "older-adults":           "lg:col-span-1 lg:row-span-1",
};
---

<BaseLayout
  title="Research themes — AsPEN"
  description="All seven AsPEN research themes on a single page — clinical areas and methodological strands."
>
  <PageHeader
    eyebrow="Publications → by theme"
    title="Research themes"
    description="AsPEN's portfolio at a glance. Each tile links to the full chronological list of papers in that theme."
  />

  <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-10">
    <div class="mb-6 flex items-center justify-between gap-3 flex-wrap text-sm">
      <a href={`${base}/publications/`} class="text-brand-700 font-semibold hover:underline">← Back to chronological list</a>
      <p class="text-slate-500 tabular-nums">{totalPapers} papers · {buckets.length} themes · {globalMin}–{globalMax}</p>
    </div>

    <!-- BENTO GRID -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 lg:auto-rows-[260px]">
      {buckets.map((t) => (
        <a
          href={`${base}/publications/themes/${t.id}/`}
          class:list={[
            "group relative flex flex-col bg-[#f3eee3] border border-slate-200 rounded-2xl overflow-hidden",
            "hover:shadow-lg hover:border-brand-400 hover:-translate-y-0.5 transition",
            tileSpan[t.id] ?? "lg:col-span-1 lg:row-span-1",
            // On mobile/tablet, give every tile a sane minimum height so the visual breathes
            "min-h-[280px]",
          ]}
          aria-label={`${t.name} — ${t.papers.length} papers`}
        >
          <!-- Top metadata row -->
          <div class="px-5 pt-4 flex items-baseline justify-between gap-3">
            <p class="text-[10px] uppercase tracking-[0.25em] font-bold text-slate-500 tabular-nums">Theme {t.number}</p>
            <p class="text-[10px] uppercase tracking-[0.22em] font-semibold text-slate-500 tabular-nums whitespace-nowrap">
              {t.papers.length} {t.papers.length === 1 ? "paper" : "papers"} · {t.yearMin === t.yearMax ? t.yearMin : `${String(t.yearMin).slice(-2)}–${String(t.yearMax).slice(-2)}`}
            </p>
          </div>

          <!-- Hero visual -->
          <div class="flex-1 flex items-center justify-center px-6 py-3 min-h-0">
            <ThemeCoverVisual variant={t.coverVisual ?? "rings"} class="max-h-full max-w-full" />
          </div>

          <!-- Caption: headline + theme name -->
          <div class="px-5 pb-4 pt-2 border-t border-slate-300/60">
            <p class="text-sm sm:text-base font-bold text-slate-900 leading-tight uppercase tracking-tight group-hover:text-brand-700 transition-colors">
              {t.headline}
            </p>
            <p class="mt-1 font-serif italic text-xs sm:text-sm text-slate-600 leading-snug">
              {t.name}.
            </p>
          </div>

          <!-- Hover affordance: arrow in corner -->
          <span
            class="absolute top-3 right-3 w-7 h-7 rounded-full bg-white/0 group-hover:bg-brand-700 grid place-items-center opacity-0 group-hover:opacity-100 transition"
            aria-hidden="true"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="9 7 17 7 17 15"/></svg>
          </span>
        </a>
      ))}
    </div>

    {orphanPubs.length > 0 && (
      <div class="mt-16 border-t border-slate-200 pt-6">
        <p class="text-xs uppercase tracking-widest text-slate-500 font-semibold mb-2">Uncategorised</p>
        <p class="text-xs text-slate-500 mb-3">{orphanPubs.length} {orphanPubs.length === 1 ? "paper" : "papers"} whose tags don't yet map to any theme. Edit <code class="text-[11px]">src/data/themes.ts</code> to add them.</p>
        <ul class="text-xs text-slate-600 space-y-1">
          {orphanPubs.map((p) => (
            <li><span class="tabular-nums font-medium">{p.year}</span> · {p.title}</li>
          ))}
        </ul>
      </div>
    )}
  </section>
</BaseLayout>
