---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHeader from "../../../components/PageHeader.astro";
import pubsRaw from "../../../data/publications.json";
import affiliations from "../../../data/affiliations.json";
import { THEMES } from "../../../data/themes";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

type Pub = (typeof pubsRaw)[number];
const pubs: Pub[] = pubsRaw as Pub[];
type Aff = Record<string, { countries: string[] }>;
const aff = affiliations as Aff;

// Compute per-theme dataset. Mutually exclusive — each publication has
// exactly one primary theme (the `theme` field on publications.json).
// Highlight = explicit `highlightPmid` override when set on the theme,
// otherwise featured > blurbed > most-recent.
const buckets = THEMES.map((t) => {
  const matched = pubs
    .filter((p) => (p as { theme?: string }).theme === t.id)
    .sort((a, b) => b.year - a.year);

  let highlight: Pub | undefined;
  if (t.highlightPmid) {
    highlight = pubs.find((p) => p.pmid === t.highlightPmid);
  }
  if (!highlight) {
    const featured = matched.filter((p) => (p as { featured?: boolean }).featured);
    const blurbed = matched.filter((p) => (p as { blurb?: string }).blurb);
    highlight = (featured[0] as Pub | undefined) ?? (blurbed[0] as Pub | undefined) ?? matched[0];
  }

  const years = matched.map((p) => p.year);
  const yearMin = years.length ? Math.min(...years) : 0;
  const yearMax = years.length ? Math.max(...years) : 0;
  const countries = new Set<string>();
  for (const p of matched) for (const c of aff[p.pmid ?? ""]?.countries ?? []) countries.add(c);

  return { ...t, papers: matched, highlight, yearMin, yearMax, countries: countries.size };
});

const totalPapers = pubs.length;
const globalMin = Math.min(...pubs.map((p) => p.year));
const globalMax = Math.max(...pubs.map((p) => p.year));

const themeIds = new Set(THEMES.map((t) => t.id));
const orphanPubs = pubs.filter((p) => !themeIds.has((p as { theme?: string }).theme ?? ""));
---

<BaseLayout
  title="Research themes — AsPEN"
  description="All seven AsPEN research themes on a single page — clinical areas and methodological strands."
>
  <PageHeader
    eyebrow="Publications → Theme"
    title="Research themes"
    description="AsPEN's portfolio grouped into seven clinical and methodological strands. Each card links to the full chronological list of papers in that theme."
  />

  <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-10 space-y-8">
    <div class="flex items-center justify-between gap-3 flex-wrap text-sm">
      <a href={`${base}/publications/`} class="text-brand-700 font-semibold hover:underline">← Back to chronological list</a>
      <p class="text-slate-500 tabular-nums">{totalPapers} papers · {buckets.length} themes · {globalMin}–{globalMax}</p>
    </div>

    <div class="grid gap-4 md:grid-cols-2">
      {buckets.map((t) => (
        <article
          id={t.id}
          class="scroll-mt-24 border border-slate-200 rounded-lg p-5 bg-white hover:shadow-md transition flex flex-col"
        >
          <!-- Header: title only -->
          <div class="mb-2">
            <h3 class="font-semibold text-slate-900 leading-snug text-lg">{t.name}</h3>
          </div>

          <!-- Stats line (mirrors database "Coverage" treatment) -->
          <p class="text-xs text-slate-500 mb-3 tabular-nums">
            {t.papers.length} {t.papers.length === 1 ? "paper" : "papers"}
            {t.yearMin > 0 && <> · {t.yearMin === t.yearMax ? t.yearMin : `${t.yearMin}–${t.yearMax}`}</>}
            {t.countries > 0 && <> · {t.countries} {t.countries === 1 ? "country" : "countries"}</>}
          </p>

          <!-- Editorial story -->
          <p class="text-sm text-slate-700 leading-relaxed">{t.story}</p>

          <!-- Highlight paper -->
          {t.highlight && (
            <div class="mt-3 pt-3 border-t border-slate-100">
              <p class="text-[10px] uppercase tracking-widest text-brand-600 font-bold">Highlight</p>
              <p class="mt-1 text-sm font-semibold text-slate-900 leading-snug">{t.highlight.title}</p>
              <p class="mt-1 text-xs text-slate-500">
                {t.highlight.year} · {t.highlight.journal}
              </p>
            </div>
          )}

          <!-- "See all papers" link, pinned to the bottom so cards align nicely -->
          <a
            href={`${base}/publications/themes/${t.id}/`}
            class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-brand-700 hover:underline self-start"
          >
            See all {t.papers.length} papers <span aria-hidden="true">→</span>
          </a>
        </article>
      ))}
    </div>

    {orphanPubs.length > 0 && (
      <div class="mt-8 border-t border-slate-200 pt-6">
        <p class="text-xs uppercase tracking-widest text-slate-500 font-semibold mb-2">Uncategorised</p>
        <p class="text-xs text-slate-500 mb-3">{orphanPubs.length} {orphanPubs.length === 1 ? "paper" : "papers"} whose tags don't yet map to any theme. Edit <code class="text-[11px]">src/data/themes.ts</code> to add them.</p>
        <ul class="text-xs text-slate-600 space-y-1">
          {orphanPubs.map((p) => (
            <li><span class="tabular-nums font-medium">{p.year}</span> · {p.title}</li>
          ))}
        </ul>
      </div>
    )}
  </section>
</BaseLayout>
