---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHeader from "../../../components/PageHeader.astro";
import pubsRaw from "../../../data/publications.json";
import affiliations from "../../../data/affiliations.json";
import { THEMES } from "../../../data/themes";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

type Pub = (typeof pubsRaw)[number];
const pubs: Pub[] = pubsRaw as Pub[];
type Aff = Record<string, { countries: string[] }>;
const aff = affiliations as Aff;

// Compute per-theme dataset. Highlight = explicit `highlightPmid` override
// when set on the theme, otherwise featured > blurbed > most-recent.
const buckets = THEMES.map((t) => {
  const tagSet = new Set(t.tags.map((x) => x.toLowerCase()));
  const matched = pubs
    .filter((p) => (p.tags ?? []).some((tag) => tagSet.has(tag.toLowerCase())))
    .sort((a, b) => b.year - a.year);

  let highlight: Pub | undefined;
  if (t.highlightPmid) {
    highlight = pubs.find((p) => p.pmid === t.highlightPmid);
  }
  if (!highlight) {
    const featured = matched.filter((p) => (p as { featured?: boolean }).featured);
    const blurbed = matched.filter((p) => (p as { blurb?: string }).blurb);
    highlight = (featured[0] as Pub | undefined) ?? (blurbed[0] as Pub | undefined) ?? matched[0];
  }

  const years = matched.map((p) => p.year);
  const yearMin = years.length ? Math.min(...years) : 0;
  const yearMax = years.length ? Math.max(...years) : 0;
  const countries = new Set<string>();
  for (const p of matched) for (const c of aff[p.pmid ?? ""]?.countries ?? []) countries.add(c);

  return { ...t, papers: matched, highlight, yearMin, yearMax, countries: countries.size };
});

const totalPapers = pubs.length;
const globalMin = Math.min(...pubs.map((p) => p.year));
const globalMax = Math.max(...pubs.map((p) => p.year));

const allThemeTags = new Set(THEMES.flatMap((t) => t.tags.map((x) => x.toLowerCase())));
const orphanPubs = pubs.filter((p) => !(p.tags ?? []).some((t) => allThemeTags.has(t.toLowerCase())));
---

<BaseLayout
  title="Research themes — AsPEN"
  description="AsPEN publications as a flip-through magazine — one editorial spread per research theme."
>
  <PageHeader
    eyebrow="Publications → by theme"
    title="Research themes"
    description="A flip-through magazine of AsPEN's portfolio. Use the arrows, swipe, or the keyboard ← → to turn pages."
  />

  <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-6 flex items-center justify-between gap-3 flex-wrap text-sm">
      <a href={`${base}/publications/`} class="text-brand-700 font-semibold hover:underline">← Back to chronological list</a>
      <p class="text-slate-500 tabular-nums">{totalPapers} papers · {buckets.length} themes · {globalMin}–{globalMax}</p>
    </div>

    <!-- ── MAGAZINE CAROUSEL ───────────────────────────────────── -->
    <div class="relative">
      <!-- Page controls (top bar) -->
      <div class="flex items-center justify-between mb-3">
        <button
          type="button"
          data-mag-prev
          class="inline-flex items-center gap-1.5 px-3 py-2 rounded-lg border border-slate-300 bg-white text-sm font-semibold text-slate-700 hover:bg-slate-50 disabled:opacity-30 disabled:cursor-not-allowed transition"
          aria-label="Previous spread"
        >
          <span aria-hidden="true">←</span> Prev
        </button>
        <p class="text-xs font-semibold text-slate-500 tracking-widest uppercase">
          Spread <span data-mag-current class="text-slate-900 tabular-nums">1</span> of {buckets.length}
        </p>
        <button
          type="button"
          data-mag-next
          class="inline-flex items-center gap-1.5 px-3 py-2 rounded-lg border border-slate-300 bg-white text-sm font-semibold text-slate-700 hover:bg-slate-50 disabled:opacity-30 disabled:cursor-not-allowed transition"
          aria-label="Next spread"
        >
          Next <span aria-hidden="true">→</span>
        </button>
      </div>

      <!-- Scroll-snap rail. Each spread is one viewport-wide page. -->
      <div
        data-mag-rail
        class="overflow-x-auto snap-x snap-mandatory rounded-2xl border border-slate-200 bg-[#fbfaf7] shadow-sm focus:outline-none focus:ring-2 focus:ring-brand-400"
        tabindex="0"
        aria-roledescription="Magazine carousel"
        style="scroll-behavior: smooth; scrollbar-width: thin;"
      >
        <div class="flex">
          {buckets.map((t, idx) => (
            <article
              id={t.id}
              data-mag-spread
              data-mag-idx={idx}
              class="snap-start shrink-0 w-full px-6 sm:px-10 py-10"
              style="flex: 0 0 100%;"
              aria-label={`Theme ${t.number}: ${t.name}`}
            >
              <div class="grid gap-8 md:gap-10 lg:gap-14 md:grid-cols-2 items-start">
                <!-- LEFT: cover image (or editorial typographic cover) -->
                <div class="md:sticky md:top-4">
                  <div class="aspect-[3/4] w-full max-w-md mx-auto md:mx-0 overflow-hidden rounded-sm shadow-lg bg-white border border-slate-200 relative">
                    {t.cover ? (
                      <img
                        src={`${base}/images/${t.cover}`}
                        alt={`Cover image for ${t.name}`}
                        class="block w-full h-full object-cover"
                        loading="lazy"
                      />
                    ) : (
                      <!-- Editorial typographic cover: masthead + headline + theme line + journal credit -->
                      <div class="w-full h-full flex flex-col p-7 sm:p-9 bg-[#f3eee3]">
                        <!-- Masthead -->
                        <div class="flex items-baseline justify-between border-b-2 border-slate-900 pb-3">
                          <p class="text-2xl sm:text-3xl font-black tracking-tighter text-slate-900">AsPEN</p>
                          <p class="text-[10px] uppercase tracking-[0.3em] text-slate-700 font-bold tabular-nums">№ {t.number} · {globalMax}</p>
                        </div>

                        <!-- Headline (pull quote) -->
                        <div class="flex-1 flex flex-col justify-center py-6">
                          <p class="text-[34px] sm:text-[40px] leading-[0.95] font-bold text-slate-900 tracking-tight uppercase">
                            {t.headline}
                          </p>
                          {t.highlight && (
                            <p class="mt-5 text-xs sm:text-sm text-slate-700 leading-relaxed italic">
                              {t.highlight.title}
                            </p>
                          )}
                        </div>

                        <!-- Bottom credits -->
                        <div class="border-t border-slate-900 pt-3 flex items-end justify-between gap-3">
                          <div>
                            <p class="text-[10px] uppercase tracking-[0.25em] text-slate-700 font-bold">Theme {t.number}</p>
                            <p class="text-sm font-bold text-slate-900 mt-0.5 leading-tight">{t.name}</p>
                          </div>
                          {t.highlight && (
                            <p class="text-[10px] uppercase tracking-[0.2em] text-slate-600 font-semibold text-right shrink-0">
                              {t.highlight.journal}<br/>{t.highlight.year}
                            </p>
                          )}
                        </div>
                      </div>
                    )}
                  </div>
                  {t.coverCaption && (
                    <p class="mt-2 text-[11px] text-slate-500 italic max-w-md mx-auto md:mx-0">{t.coverCaption}</p>
                  )}
                </div>

                <!-- RIGHT: editorial column -->
                <div>
                  <p class="text-[11px] uppercase tracking-[0.3em] text-slate-500 font-bold">Theme {t.number}</p>
                  <h2 class="mt-2 text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 leading-[1.05] tracking-tight">{t.name}</h2>

                  <!-- Lede -->
                  <p class="mt-5 text-base sm:text-lg text-slate-700 leading-relaxed">{t.story}</p>

                  <!-- Highlight paper -->
                  {t.highlight && (
                    <aside class="mt-8 border-t border-slate-200 pt-5">
                      <p class="text-[11px] uppercase tracking-[0.25em] text-brand-700 font-bold">Highlight paper</p>
                      <p class="mt-2 text-xs text-slate-500 tabular-nums">{t.highlight.year} · {t.highlight.journal}</p>
                      <p class="mt-1 text-lg font-bold text-slate-900 leading-snug">{t.highlight.title}</p>
                      <p class="mt-1 text-xs text-slate-600 line-clamp-2">{t.highlight.authors}</p>
                      {(t.highlight as { blurb?: string }).blurb && (
                        <p class="mt-3 text-sm italic text-slate-700 leading-relaxed border-l-2 border-brand-300 pl-3">
                          {(t.highlight as { blurb?: string }).blurb}
                        </p>
                      )}
                      <div class="mt-3 flex flex-wrap gap-3 text-xs">
                        {t.highlight.pmid && (
                          <a href={`${base}/publications/#pub-${t.highlight.pmid}`} class="text-brand-700 hover:underline font-semibold">See full entry →</a>
                        )}
                        {t.highlight.pmid && (
                          <a href={`https://pubmed.ncbi.nlm.nih.gov/${t.highlight.pmid}/`} target="_blank" rel="noopener" class="text-slate-500 hover:text-brand-700 hover:underline">PMID {t.highlight.pmid}</a>
                        )}
                      </div>
                    </aside>
                  )}

                  <!-- Stats strip -->
                  <dl class="mt-7 grid grid-cols-3 gap-4 border-y border-slate-200 py-4 text-center">
                    <div>
                      <dt class="text-[10px] uppercase tracking-widest text-slate-500 font-semibold">Papers</dt>
                      <dd class="text-2xl font-bold text-slate-900 tabular-nums mt-1">{t.papers.length}</dd>
                    </div>
                    <div>
                      <dt class="text-[10px] uppercase tracking-widest text-slate-500 font-semibold">Span</dt>
                      <dd class="text-2xl font-bold text-slate-900 tabular-nums mt-1">{t.yearMin === t.yearMax ? t.yearMin : `${String(t.yearMin).slice(-2)}–${String(t.yearMax).slice(-2)}`}</dd>
                    </div>
                    <div>
                      <dt class="text-[10px] uppercase tracking-widest text-slate-500 font-semibold">Countries</dt>
                      <dd class="text-2xl font-bold text-slate-900 tabular-nums mt-1">{t.countries}</dd>
                    </div>
                  </dl>

                  <!-- Link to per-theme chronological list -->
                  {t.papers.length > 1 && (
                    <a
                      href={`${base}/publications/themes/${t.id}/`}
                      class="mt-6 inline-flex items-center gap-2 px-4 py-2.5 rounded-lg bg-brand-700 hover:bg-brand-800 text-white text-sm font-semibold transition"
                    >
                      All {t.papers.length} papers in this theme
                      <span aria-hidden="true">→</span>
                    </a>
                  )}
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>

      <!-- Page dots -->
      <div class="mt-5 flex justify-center gap-1.5">
        {buckets.map((t, idx) => (
          <button
            type="button"
            data-mag-dot={idx}
            class="w-2 h-2 rounded-full bg-slate-300 hover:bg-slate-400 transition aria-current:bg-brand-700 aria-current:w-6"
            aria-label={`Jump to ${t.name}`}
            aria-current={idx === 0 ? "true" : undefined}
          ></button>
        ))}
      </div>

      <!-- Theme quick-jump (text labels under dots, for keyboard / a11y) -->
      <nav class="mt-3 text-center text-xs text-slate-500 flex flex-wrap justify-center gap-x-3 gap-y-1" aria-label="Jump to theme">
        {buckets.map((t, idx) => (
          <a href={`#${t.id}`} data-mag-link={idx} class="hover:text-brand-700 hover:underline">{t.number} · {t.name}</a>
        ))}
      </nav>
    </div>

    {orphanPubs.length > 0 && (
      <div class="mt-16 border-t border-slate-200 pt-6">
        <p class="text-xs uppercase tracking-widest text-slate-500 font-semibold mb-2">Uncategorised</p>
        <p class="text-xs text-slate-500 mb-3">{orphanPubs.length} {orphanPubs.length === 1 ? "paper" : "papers"} whose tags don't yet map to any theme. Edit <code class="text-[11px]">src/data/themes.ts</code> to add them.</p>
        <ul class="text-xs text-slate-600 space-y-1">
          {orphanPubs.map((p) => (
            <li><span class="tabular-nums font-medium">{p.year}</span> · {p.title}</li>
          ))}
        </ul>
      </div>
    )}
  </section>

  <script is:inline>
    (() => {
      const rail = document.querySelector("[data-mag-rail]");
      if (!rail) return;
      const spreads = Array.from(rail.querySelectorAll("[data-mag-spread]"));
      const prevBtn = document.querySelector("[data-mag-prev]");
      const nextBtn = document.querySelector("[data-mag-next]");
      const currentEl = document.querySelector("[data-mag-current]");
      const dots = Array.from(document.querySelectorAll("[data-mag-dot]"));

      const total = spreads.length;
      let current = 0;

      const goTo = (idx) => {
        current = Math.max(0, Math.min(total - 1, idx));
        const target = spreads[current];
        if (!target) return;
        rail.scrollTo({ left: target.offsetLeft - rail.offsetLeft, behavior: "smooth" });
        updateUI();
      };

      const updateUI = () => {
        if (currentEl) currentEl.textContent = String(current + 1);
        if (prevBtn) prevBtn.toggleAttribute("disabled", current === 0);
        if (nextBtn) nextBtn.toggleAttribute("disabled", current === total - 1);
        dots.forEach((d, i) => {
          if (i === current) d.setAttribute("aria-current", "true");
          else d.removeAttribute("aria-current");
        });
      };

      let scrollTimer;
      rail.addEventListener("scroll", () => {
        clearTimeout(scrollTimer);
        scrollTimer = setTimeout(() => {
          const railLeft = rail.scrollLeft;
          const widths = spreads.map((s) => s.offsetLeft - rail.offsetLeft);
          let nearest = 0;
          let best = Infinity;
          widths.forEach((w, i) => {
            const d = Math.abs(w - railLeft);
            if (d < best) { best = d; nearest = i; }
          });
          if (nearest !== current) {
            current = nearest;
            updateUI();
          }
        }, 80);
      });

      prevBtn && prevBtn.addEventListener("click", () => goTo(current - 1));
      nextBtn && nextBtn.addEventListener("click", () => goTo(current + 1));
      dots.forEach((d) => d.addEventListener("click", () => goTo(Number(d.dataset.magDot))));

      const onKey = (e) => {
        if (e.target.matches("input, textarea, select, [contenteditable]")) return;
        if (e.key === "ArrowRight") { e.preventDefault(); goTo(current + 1); }
        else if (e.key === "ArrowLeft") { e.preventDefault(); goTo(current - 1); }
      };
      document.addEventListener("keydown", onKey);

      const hash = location.hash.replace("#", "");
      if (hash) {
        const idx = spreads.findIndex((s) => s.id === hash);
        if (idx >= 0) setTimeout(() => goTo(idx), 50);
      }

      document.querySelectorAll("[data-mag-link]").forEach((a) => {
        a.addEventListener("click", (e) => {
          e.preventDefault();
          goTo(Number(a.dataset.magLink));
        });
      });

      updateUI();
    })();
  </script>
</BaseLayout>
