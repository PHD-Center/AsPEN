---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";

const contactName = "Daniel Tsai, NCKU";
const contactEmail = "danielhttsai@gmail.com";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const linkedinGroups = [
  {
    name: "PHDc, NCKU",
    fullName: "Population Health Data Center, National Cheng Kung University",
    href: "https://www.linkedin.com/company/population-health-data-center-ncku/?viewAsMember=true",
    location: "Tainan, Taiwan",
    accent: "from-emerald-500 to-teal-600",
    logo: `${base}/images/PHDc.png`,
    initials: "PHD",
  },
  {
    name: "Pharmacoepidemiology Lab, SKKU",
    fullName: "Pharmacoepidemiology Laboratory, Sungkyunkwan University",
    href: "https://www.linkedin.com/in/pharmacoepidemiology-lab-7b1b3020a/?locale=en",
    location: "Suwon, South Korea",
    accent: "from-sky-500 to-blue-600",
    logo: `${base}/images/SKKU.jpg`,
    initials: "PE",
  },
  {
    name: "CSMPR, HKU",
    fullName: "Centre for Safe Medication Practice and Research, The University of Hong Kong",
    href: "https://www.linkedin.com/company/csmpr2012/posts/?feedView=all",
    location: "Hong Kong",
    accent: "from-rose-500 to-pink-600",
    logo: `${base}/images/CSMPR.jpg`,
    initials: "CSM",
  },
];
---

<BaseLayout
  title="Contact — AsPEN"
  description="How to contact AsPEN and follow our partner research labs on LinkedIn."
>
  <PageHeader
    eyebrow="Contact"
    title="Contact & follow"
    description="Reach out for collaboration enquiries, and follow our partner research groups on LinkedIn for the latest updates."
  />

  <section class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-12 space-y-10">
    <div class="border border-slate-200 rounded-lg p-6 bg-white">
      <p class="text-xs font-semibold text-brand-600 uppercase tracking-wide">General inquiries</p>
      <p class="mt-2 text-lg font-semibold text-slate-900">{contactName}</p>
      <p class="mt-1">
        <a href={`mailto:${contactEmail}`} class="text-brand-600 hover:underline">{contactEmail}</a>
      </p>
      <p class="mt-3 text-sm text-slate-600">Please include your name, affiliation, and a brief description of your inquiry.</p>
    </div>

    <div class="border border-slate-200 rounded-lg p-6 bg-white">
      <p class="text-xs font-semibold text-brand-600 uppercase tracking-wide">Joining AsPEN</p>
      <p class="mt-2 text-slate-700 text-sm">
        Membership is coordinated through the ISPE Community platform. Visit the
        <a class="text-brand-600 hover:underline" href="https://www.pharmacoepi.org/communities/sigs/aspen/" target="_blank" rel="noopener">AsPEN SIG page on pharmacoepi.org</a> to request access.
      </p>
    </div>

    <div>
      <div class="flex items-end justify-between gap-4 flex-wrap mb-6">
        <div>
          <h2 class="text-2xl font-bold text-slate-900 flex items-center gap-2">
            <svg viewBox="0 0 24 24" class="w-7 h-7" fill="#0A66C2" aria-hidden="true"><path d="M20.5 2h-17A1.5 1.5 0 0 0 2 3.5v17A1.5 1.5 0 0 0 3.5 22h17a1.5 1.5 0 0 0 1.5-1.5v-17A1.5 1.5 0 0 0 20.5 2zM8 19H5v-9h3v9zM6.5 8.25A1.75 1.75 0 1 1 8.3 6.5a1.78 1.78 0 0 1-1.8 1.75zM19 19h-3v-4.74c0-1.42-.6-1.93-1.38-1.93A1.74 1.74 0 0 0 13 14.19a.66.66 0 0 0 0 .14V19h-3v-9h2.9v1.3a3.11 3.11 0 0 1 2.7-1.4c1.55 0 3.36.86 3.36 3.66z"/></svg>
            Follow our partner labs
          </h2>
          <p class="text-sm text-slate-600 mt-1">Click any card to open the LinkedIn page and see the latest posts.</p>
        </div>
      </div>

      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {linkedinGroups.map((g) => (
          <a
            href={g.href}
            target="_blank"
            rel="noopener"
            class="group block bg-white border border-slate-200 rounded-xl overflow-hidden hover:shadow-lg hover:border-[#0A66C2] transition"
          >
            <div class={`h-20 bg-gradient-to-br ${g.accent} relative`}>
              <div class="absolute -bottom-8 left-5 w-16 h-16 rounded-lg bg-white border-4 border-white shadow-md overflow-hidden">
                {(g as { logo?: string }).logo ? (
                  <img
                    src={(g as { logo: string }).logo}
                    alt={`${g.name} logo`}
                    class="block w-full h-full object-contain p-1.5"
                  />
                ) : (
                  <div class="w-full h-full grid place-items-center text-slate-900 font-extrabold text-xl tracking-tight">
                    {g.initials}
                  </div>
                )}
              </div>
              <span class="absolute top-3 right-3 inline-flex items-center gap-1 text-white/95 text-xs font-semibold bg-black/20 backdrop-blur px-2 py-0.5 rounded">
                <svg viewBox="0 0 24 24" class="w-3.5 h-3.5" fill="currentColor" aria-hidden="true"><path d="M20.5 2h-17A1.5 1.5 0 0 0 2 3.5v17A1.5 1.5 0 0 0 3.5 22h17a1.5 1.5 0 0 0 1.5-1.5v-17A1.5 1.5 0 0 0 20.5 2zM8 19H5v-9h3v9zM6.5 8.25A1.75 1.75 0 1 1 8.3 6.5a1.78 1.78 0 0 1-1.8 1.75zM19 19h-3v-4.74c0-1.42-.6-1.93-1.38-1.93A1.74 1.74 0 0 0 13 14.19a.66.66 0 0 0 0 .14V19h-3v-9h2.9v1.3a3.11 3.11 0 0 1 2.7-1.4c1.55 0 3.36.86 3.36 3.66z"/></svg>
                LinkedIn
              </span>
            </div>
            <div class="pt-10 px-5 pb-5">
              <p class="font-semibold text-slate-900 group-hover:text-[#0A66C2]">{g.name}</p>
              <p class="text-sm text-slate-600 mt-0.5">{g.fullName}</p>
              <p class="text-xs text-slate-500 mt-2 flex items-center gap-1">
                <svg viewBox="0 0 24 24" class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                {g.location}
              </p>
              <div class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-[#0A66C2]">
                View latest posts
                <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <p class="mt-6 text-xs text-slate-500 italic">
        Note: LinkedIn does not allow embedding live post feeds on static sites. To replace these cards with a real auto-updating feed, a paid widget (Elfsight, SociableKit, etc.) can be added later.
      </p>
    </div>
  </section>
</BaseLayout>
