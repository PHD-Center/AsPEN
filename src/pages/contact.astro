---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";

// Primary inbox routes to the Academic & Education office (Daniel Tsai, NCKU)
// with the AsPEN Chair / co-lead CC'd. The email addresses are kept off the
// rendered page (mailto: only) so they're not scraped from the HTML source.
const danielEmail = "danielhttsai@gmail.com";
const edEmail = ""; // TODO: add Edward Lai's preferred address; until then, only Daniel is CC'd
const mailtoHref = edEmail
  ? `mailto:${danielEmail}?cc=${encodeURIComponent(edEmail)}`
  : `mailto:${danielEmail}`;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const linkedinGroups = [
  {
    name: "PHDc, NCKU",
    fullName: "Population Health Data Center, National Cheng Kung University",
    href: "https://www.linkedin.com/company/population-health-data-center-ncku/?viewAsMember=true",
    location: "Tainan, Taiwan",
    accent: "from-emerald-500 to-teal-600",
    logo: `${base}/images/PHDc.png`,
    initials: "PHD",
  },
  {
    name: "Pharmacoepidemiology Lab, SKKU",
    fullName: "Pharmacoepidemiology Laboratory, Sungkyunkwan University",
    href: "https://www.linkedin.com/in/pharmacoepidemiology-lab-7b1b3020a/?locale=en",
    location: "Suwon, South Korea",
    accent: "from-sky-500 to-blue-600",
    logo: `${base}/images/SKKU.jpg`,
    initials: "PE",
  },
  {
    name: "CSMPR, HKU",
    fullName: "Centre for Safe Medication Practice and Research, The University of Hong Kong",
    href: "https://www.linkedin.com/company/csmpr2012/posts/?feedView=all",
    location: "Hong Kong",
    accent: "from-rose-500 to-pink-600",
    logo: `${base}/images/CSMPR.jpg`,
    initials: "CSM",
  },
];
---

<BaseLayout
  title="Contact & propose — AsPEN"
  description="Get in touch with AsPEN to propose a study, join the SIG, or follow our partner research groups."
>
  <PageHeader
    eyebrow="Contact"
    title="Get in touch"
    description="For study proposals, collaboration discussions, and general inquiries — please reach out to the AsPEN Chair and the Academic & Education office."
  />

  <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-10 space-y-16">

    <!-- ── PRIMARY CTA ─────────────────────────────────────────── -->
    <div class="border border-slate-200 rounded-2xl p-6 sm:p-8 bg-white shadow-sm">
      <div class="grid gap-6 md:grid-cols-[1fr_auto] md:items-center">
        <div>
          <p class="text-xs uppercase tracking-widest text-brand-600 font-semibold">Chair · Academic & Education office</p>
          <p class="mt-2 text-slate-700">Inquiries are routed to the AsPEN Chair and the Academic &amp; Education office. Please include your name, affiliation, and a brief note of what you'd like to discuss (a study idea, a potential collaboration, joining the network, or any other questions).</p>
        </div>
        <a
          href={mailtoHref}
          class="inline-flex items-center gap-2 bg-brand-700 hover:bg-brand-800 text-white font-semibold px-5 py-3 rounded-lg transition shrink-0 self-start md:self-auto"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          Email AsPEN
        </a>
      </div>
    </div>

    <!-- ── PROPOSE A STUDY ─────────────────────────────────────── -->
    <div id="propose" class="scroll-mt-24">
      <h2 class="text-2xl font-bold text-slate-900">Propose a study to AsPEN</h2>
      <p class="mt-2 text-slate-600 max-w-3xl">How a multi-country pharmacoepidemiology study takes shape through AsPEN.</p>

      <p class="mt-6 text-slate-700 leading-relaxed max-w-4xl">
        AsPEN provides one coordinated channel across 20+ population-level databases in Asia-Pacific and partner sites in the UK, US, and Europe. The network's standing methodological expertise covers signal-detection, drug utilisation, and effectiveness or safety comparison.
      </p>

      <!-- What fits well -->
      <div class="mt-10 max-w-3xl">
        <h3 class="text-xs uppercase tracking-widest text-brand-600 font-semibold mb-3">What fits well</h3>
        <ul class="space-y-1.5 text-sm text-slate-700">
          <li>Drug-utilisation comparisons across health systems</li>
          <li>Multi-country drug-safety signal assessment</li>
          <li>Cross-national validation studies in different healthcare settings</li>
          <li>Pregnancy / paediatric / older-adult / other vulnerable population safety where Asian databases are under-represented</li>
          <li>Distributed network (common data model)</li>
          <li>Regulatory or policy questions where cross-jurisdiction evidence supports decision-making</li>
        </ul>
      </div>

      <!-- Process -->
      <div class="mt-10">
        <h3 class="text-xs uppercase tracking-widest text-brand-600 font-semibold mb-4">The proposal process</h3>
        <ol class="space-y-2.5">
          {[
            { n: 1, t: "Pre-discussion",              d: "Send a 2–3 sentence question by email; the Academic & Education office identifies relevant national leads.", w: "1–3 wks" },
            { n: 2, t: "Concept note",                d: "1–2 page concept (question, population, exposure, outcome, candidate sites, lead author) submitted by email.", w: "2–4 wks" },
            { n: 3, t: "Network review",              d: "Concept circulated at the next SIG teleconference or ISPE Asian / ICPE meeting; interested sites signal willingness.", w: "1–3 mo" },
            { n: 4, t: "Protocol drafting",           d: "Participating sites finalise common data definitions, statistical analysis plan, and feasibility checks.", w: "3–6 mo" },
            { n: 5, t: "Local IRB & analysis",        d: "Each site obtains IRB approval, executes locally, and returns site-level estimates.", w: "6–12 mo" },
            { n: 6, t: "Meta-analysis & publication", d: "Site-level results pooled centrally; manuscript drafted under AsPEN multi-site authorship conventions.", w: "3–6 mo" },
          ].map((s) => (
            <li class="flex items-baseline gap-4 border-b border-slate-100 pb-2.5">
              <div class="shrink-0 w-7 h-7 rounded-full bg-brand-50 text-brand-700 font-bold text-sm grid place-items-center tabular-nums">{s.n}</div>
              <div class="flex-1">
                <div class="flex items-baseline justify-between gap-3 flex-wrap">
                  <p class="font-semibold text-slate-900 text-sm">{s.t}</p>
                  <p class="text-xs text-slate-500 tabular-nums">{s.w}</p>
                </div>
                <p class="text-sm text-slate-600 mt-0.5">{s.d}</p>
              </div>
            </li>
          ))}
        </ol>
        <p class="text-xs text-slate-500 mt-4 italic">Concept to publication typically runs 18–30 months; site recruitment and IRB approval are the most variable steps.</p>
      </div>

      <!-- Bring / provide -->
      <div class="mt-10 grid gap-6 md:grid-cols-2">
        <div>
          <h3 class="text-xs uppercase tracking-widest text-brand-600 font-semibold mb-3">What you bring</h3>
          <ul class="space-y-1.5 text-sm text-slate-700">
            <li>A clearly-scoped research question and draft analysis plan.</li>
            <li>Willingness to lead protocol drafting and meta-analysis.</li>
            <li>Database access at your home institution (see FAQ for who this applies to).</li>
            <li>ISPE membership if formally joining the SIG.</li>
          </ul>
        </div>
        <div>
          <h3 class="text-xs uppercase tracking-widest text-brand-600 font-semibold mb-3">What AsPEN provides</h3>
          <ul class="space-y-1.5 text-sm text-slate-700">
            <li>Site recruitment across the network — one channel, many databases.</li>
            <li>Methodological consultation across the toolkit listed below.</li>
            <li>Protocol review at SIG meetings and ICPE.</li>
            <li>Multi-site authorship and publication coordination.</li>
          </ul>
        </div>
      </div>

      <!-- Methods we apply -->
      <div class="mt-10">
        <h3 class="text-xs uppercase tracking-widest text-brand-600 font-semibold mb-3">Methods we apply</h3>
        <p class="text-sm text-slate-600 max-w-3xl mb-5">
          AsPEN studies draw on a broad design and analytic toolkit chosen to fit the question, the available data, and the multi-country setting.
        </p>
        <dl class="grid gap-x-8 gap-y-4 sm:grid-cols-2 text-sm">
          {[
            { cat: "Study design", items: "Active Comparator / New User · Target Trial Emulation · Sequential Trial Emulation" },
            { cat: "Quasi-experimental", items: "Regression Discontinuity Design (RDD) · Difference-in-Differences (DID) · Instrumental Variable (IV) · Trend-in-Trend (TIT) · Proximal Causal Inference" },
            { cat: "Self-controlled / signal detection", items: "Prescription Sequence Symmetry Analysis (PSSA) · Self-Controlled Case Series (SCCS)" },
            { cat: "Confounding control", items: "Propensity Score Matching / IPTW · Clone-Censor-Weight (CCW) · Machine-learning–based confounding adjustment (Causal Forest, TMLE, Doubly Robust)" },
            { cat: "Trajectory & data infrastructure", items: "Group-based trajectory modeling · Common Data Models (CDM)" },
          ].map((m) => (
            <div>
              <dt class="text-xs font-bold text-slate-800 uppercase tracking-wide">{m.cat}</dt>
              <dd class="mt-1 text-slate-700 leading-relaxed">{m.items}</dd>
            </div>
          ))}
        </dl>
      </div>

      <!-- FAQ -->
      <div class="mt-10">
        <h3 class="text-xs uppercase tracking-widest text-brand-600 font-semibold mb-4">FAQ</h3>
        <div class="space-y-3">
          {[
            { q: "Do I need to be an ISPE member to propose?", a: "No. Informal pre-discussion is open to anyone. To formally join the SIG and present proposals at SIG meetings, ISPE membership (including student rates) is required." },
            { q: "Do I need my own database access?", a: "For academic investigators, yes — access to a database at your home institution lets us assess feasibility and study design realistically up-front. For industry partners, regulators, and clinicians without database access, this is not required; AsPEN sites can host the analysis on your behalf." },
            { q: "Is there any cost?", a: "AsPEN does not charge for participation. Site-level costs are limited to data access (which varies by database) and the human resources required to execute the local analysis." },
            { q: "What if my study is industry-funded?", a: "Very welcome. Discussion is coordinated through the AsPEN Academic & Education office — please outline the research question, the analytical scope, and the AsPEN sites you would like to involve." },
            { q: "Can I propose a methods-only study?", a: "Yes — methodological work is a long-standing AsPEN strand. See the Methods we apply section above for the design and analytic toolkit currently in use across the network." },
          ].map((item) => (
            <details class="border border-slate-200 rounded-lg bg-white group">
              <summary class="cursor-pointer select-none px-5 py-4 font-semibold text-slate-800 hover:bg-slate-50 rounded-lg flex items-start gap-3">
                <span class="text-brand-700 text-xl leading-none group-open:rotate-45 transition">+</span>
                <span>{item.q}</span>
              </summary>
              <p class="px-5 pb-5 text-sm text-slate-600 leading-relaxed pl-12">{item.a}</p>
            </details>
          ))}
        </div>
      </div>
    </div>

    <!-- ── OTHER WAYS TO REACH US ──────────────────────────────── -->
    <div>
      <h2 class="text-2xl font-bold text-slate-900">Other ways to reach us</h2>
      <p class="mt-2 text-slate-600 max-w-3xl">For network membership and updates from individual labs.</p>

      <div class="mt-6 grid gap-5 md:grid-cols-2">
        <div class="border border-slate-200 rounded-lg p-6 bg-white">
          <p class="text-xs font-semibold text-brand-600 uppercase tracking-wide">Joining the SIG</p>
          <p class="mt-2 text-slate-700 text-sm leading-relaxed">
            Network membership is coordinated through the ISPE Community platform. Visit the
            <a class="text-brand-600 hover:underline font-semibold" href="https://www.pharmacoepi.org/communities/sigs/aspen/" target="_blank" rel="noopener">AsPEN SIG page on pharmacoepi.org</a> to request access.
          </p>
        </div>
        <div class="border border-slate-200 rounded-lg p-6 bg-white">
          <p class="text-xs font-semibold text-brand-600 uppercase tracking-wide">Browse what we publish</p>
          <p class="mt-2 text-slate-700 text-sm leading-relaxed">
            See AsPEN's publication portfolio
            <a class="text-brand-600 hover:underline font-semibold" href={`${base}/publications/themes/`}>by research theme</a>
            or the
            <a class="text-brand-600 hover:underline font-semibold" href={`${base}/publications/`}>full chronological list</a>.
          </p>
        </div>
      </div>
    </div>

    <!-- ── PARTNER LABS LINKEDIN ──────────────────────────────── -->
    <div>
      <div class="flex items-end justify-between gap-4 flex-wrap mb-6">
        <div>
          <h2 class="text-2xl font-bold text-slate-900 flex items-center gap-2">
            <svg viewBox="0 0 24 24" class="w-7 h-7" fill="#0A66C2" aria-hidden="true"><path d="M20.5 2h-17A1.5 1.5 0 0 0 2 3.5v17A1.5 1.5 0 0 0 3.5 22h17a1.5 1.5 0 0 0 1.5-1.5v-17A1.5 1.5 0 0 0 20.5 2zM8 19H5v-9h3v9zM6.5 8.25A1.75 1.75 0 1 1 8.3 6.5a1.78 1.78 0 0 1-1.8 1.75zM19 19h-3v-4.74c0-1.42-.6-1.93-1.38-1.93A1.74 1.74 0 0 0 13 14.19a.66.66 0 0 0 0 .14V19h-3v-9h2.9v1.3a3.11 3.11 0 0 1 2.7-1.4c1.55 0 3.36.86 3.36 3.66z"/></svg>
            Follow our partner labs
          </h2>
          <p class="text-sm text-slate-600 mt-1">Click any card to open the LinkedIn page and see the latest posts.</p>
        </div>
      </div>

      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {linkedinGroups.map((g) => (
          <a
            href={g.href}
            target="_blank"
            rel="noopener"
            class="group block bg-white border border-slate-200 rounded-xl overflow-hidden hover:shadow-lg hover:border-[#0A66C2] transition"
          >
            <div class={`h-20 bg-gradient-to-br ${g.accent} relative`}>
              <div class="absolute -bottom-8 left-5 w-16 h-16 rounded-lg bg-white border-4 border-white shadow-md overflow-hidden">
                {(g as { logo?: string }).logo ? (
                  <img
                    src={(g as { logo: string }).logo}
                    alt={`${g.name} logo`}
                    class="block w-full h-full object-contain p-1.5"
                  />
                ) : (
                  <div class="w-full h-full grid place-items-center text-slate-900 font-extrabold text-xl tracking-tight">
                    {g.initials}
                  </div>
                )}
              </div>
              <span class="absolute top-3 right-3 inline-flex items-center gap-1 text-white/95 text-xs font-semibold bg-black/20 backdrop-blur px-2 py-0.5 rounded">
                <svg viewBox="0 0 24 24" class="w-3.5 h-3.5" fill="currentColor" aria-hidden="true"><path d="M20.5 2h-17A1.5 1.5 0 0 0 2 3.5v17A1.5 1.5 0 0 0 3.5 22h17a1.5 1.5 0 0 0 1.5-1.5v-17A1.5 1.5 0 0 0 20.5 2zM8 19H5v-9h3v9zM6.5 8.25A1.75 1.75 0 1 1 8.3 6.5a1.78 1.78 0 0 1-1.8 1.75zM19 19h-3v-4.74c0-1.42-.6-1.93-1.38-1.93A1.74 1.74 0 0 0 13 14.19a.66.66 0 0 0 0 .14V19h-3v-9h2.9v1.3a3.11 3.11 0 0 1 2.7-1.4c1.55 0 3.36.86 3.36 3.66z"/></svg>
                LinkedIn
              </span>
            </div>
            <div class="pt-10 px-5 pb-5">
              <p class="font-semibold text-slate-900 group-hover:text-[#0A66C2]">{g.name}</p>
              <p class="text-sm text-slate-600 mt-0.5">{g.fullName}</p>
              <p class="text-xs text-slate-500 mt-2 flex items-center gap-1">
                <svg viewBox="0 0 24 24" class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                {g.location}
              </p>
              <div class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-[#0A66C2]">
                View latest posts
                <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>

  </section>
</BaseLayout>
