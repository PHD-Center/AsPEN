---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";

const contactName = "Daniel Tsai";
const contactEmail = "danielhttsai@gmail.com";

const partners = [
  {
    name: "NeuroGEN",
    href: "https://neurogen.hku.hk/",
    blurb:
      "Cross-regional research network for the assessment and development of treatment for neurological and mental disorders.",
  },
  {
    name: "Population Health Data Center (PHDc)",
    href: "https://www.phdcenter.org.tw/",
    blurb:
      "National Cheng Kung University centre advancing real-world evidence research from population-level health data in Taiwan.",
  },
  {
    name: "DARWIN EU",
    href: "https://www.darwin-eu.org/",
    blurb:
      "European Medicines Agency coordination centre for real-world evidence from European healthcare databases.",
  },
];
---

<BaseLayout
  title="Contact — AsPEN"
  description="How to contact the AsPEN SIG and submit inquiries."
>
  <PageHeader
    eyebrow="Contact"
    title="Contact"
    description="For collaboration inquiries, membership questions, or media requests, please reach out."
  />

  <section class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-12 space-y-6">
    <div class="border border-slate-200 rounded-lg p-6 bg-white">
      <p class="text-xs font-semibold text-brand-600 uppercase tracking-wide">General inquiries</p>
      <p class="mt-2 text-lg font-semibold text-slate-900">{contactName}</p>
      <p class="mt-1">
        <a href={`mailto:${contactEmail}`} class="text-brand-600 hover:underline">{contactEmail}</a>
      </p>
      <p class="mt-3 text-sm text-slate-600">Please include your name, affiliation, and a brief description of your inquiry.</p>
    </div>

    <div class="border border-slate-200 rounded-lg p-6 bg-white">
      <p class="text-xs font-semibold text-brand-600 uppercase tracking-wide">Joining AsPEN</p>
      <p class="mt-2 text-slate-700 text-sm">
        Membership is coordinated through the ISPE Community platform. Visit the
        <a class="text-brand-600 hover:underline" href="https://www.pharmacoepi.org/communities/sigs/aspen/" target="_blank" rel="noopener">AsPEN SIG page on pharmacoepi.org</a> to request access.
      </p>
    </div>

    <div>
      <h2 class="text-2xl font-bold text-slate-900 mt-8 mb-4">Related research networks</h2>
      <div class="grid gap-4">
        {partners.map((p) => (
          <a
            href={p.href}
            target="_blank"
            rel="noopener"
            class="block border border-slate-200 rounded-lg p-5 bg-white hover:border-brand-500 hover:shadow-md transition group"
          >
            <p class="font-semibold text-slate-900 group-hover:text-brand-700 flex items-center gap-2">
              {p.name}
              <span class="text-xs text-slate-400 group-hover:text-brand-500" aria-hidden="true">↗</span>
            </p>
            <p class="text-sm text-slate-600 mt-1">{p.blurb}</p>
            <p class="text-xs text-brand-600 mt-2 break-all">{p.href}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
