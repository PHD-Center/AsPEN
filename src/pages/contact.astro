---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";

const contactName = "Daniel Tsai, NCKU";
const contactEmail = "danielhttsai@gmail.com";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const linkedinGroups = [
  {
    name: "PHDc, NCKU",
    fullName: "Population Health Data Center, National Cheng Kung University",
    href: "https://www.linkedin.com/company/population-health-data-center-ncku/?viewAsMember=true",
    location: "Tainan, Taiwan",
    accent: "from-emerald-500 to-teal-600",
    logo: `${base}/images/PHDc.png`,
    initials: "PHD",
  },
  {
    name: "Pharmacoepidemiology Lab, SKKU",
    fullName: "Pharmacoepidemiology Laboratory, Sungkyunkwan University",
    href: "https://www.linkedin.com/in/pharmacoepidemiology-lab-7b1b3020a/?locale=en",
    location: "Suwon, South Korea",
    accent: "from-sky-500 to-blue-600",
    logo: `${base}/images/SKKU.jpg`,
    initials: "PE",
  },
  {
    name: "CSMPR, HKU",
    fullName: "Centre for Safe Medication Practice and Research, The University of Hong Kong",
    href: "https://www.linkedin.com/company/csmpr2012/posts/?feedView=all",
    location: "Hong Kong",
    accent: "from-rose-500 to-pink-600",
    logo: `${base}/images/CSMPR.jpg`,
    initials: "CSM",
  },
];
---

<BaseLayout
  title="Contact & propose — AsPEN"
  description="Get in touch with AsPEN to propose a study, join the SIG, or follow our partner research groups."
>
  <PageHeader
    eyebrow="Contact"
    title="Get in touch"
    description="Bring a study idea, join the network, or just say hello. Everything below is one inbox away."
  />

  <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-10 space-y-16">

    <!-- ── PRIMARY CTA ─────────────────────────────────────────── -->
    <div class="border-2 border-brand-200 rounded-2xl p-6 sm:p-8 bg-gradient-to-br from-brand-50 to-white">
      <div class="grid gap-6 md:grid-cols-[1fr_auto] md:items-center">
        <div>
          <p class="text-xs uppercase tracking-widest text-brand-600 font-semibold">General inquiries · proposals · collaboration</p>
          <h2 class="mt-2 text-2xl sm:text-3xl font-bold text-slate-900">{contactName}</h2>
          <p class="mt-1 text-slate-700">Please include your name, affiliation, and a 2–3 sentence summary — research question, why it benefits from multi-country data, any AsPEN sites you already work with.</p>
        </div>
        <a
          href={`mailto:${contactEmail}`}
          class="inline-flex items-center gap-2 bg-brand-700 hover:bg-brand-800 text-white font-semibold px-5 py-3 rounded-lg transition shrink-0 self-start md:self-auto"
        >
          ✉ {contactEmail}
        </a>
      </div>
    </div>

    <!-- ── PROPOSE A STUDY ─────────────────────────────────────── -->
    <div id="propose" class="scroll-mt-24">
      <h2 class="text-2xl font-bold text-slate-900">Propose a study to AsPEN</h2>
      <p class="mt-2 text-slate-600 max-w-3xl">If you're bringing a multi-country pharmacoepidemiology question, here's how a study idea moves from a research question into a coordinated AsPEN study.</p>

      <!-- Why -->
      <div class="mt-8">
        <h3 class="text-xs uppercase tracking-widest text-brand-600 font-semibold mb-4">Why propose through AsPEN</h3>
        <div class="grid gap-5 md:grid-cols-3">
          <div class="border border-slate-200 rounded-lg p-5 bg-white">
            <p class="text-2xl">🌏</p>
            <p class="mt-2 font-semibold text-slate-900">Multi-country reach</p>
            <p class="mt-2 text-sm text-slate-600 leading-relaxed">Access to 20+ population-level databases across Asia-Pacific, plus NeuroGEN partner sites in the UK, US, and Europe — a single coordinated channel rather than 20 individual conversations.</p>
          </div>
          <div class="border border-slate-200 rounded-lg p-5 bg-white">
            <p class="text-2xl">🧭</p>
            <p class="mt-2 font-semibold text-slate-900">Methodological harmonisation</p>
            <p class="mt-2 text-sm text-slate-600 leading-relaxed">A common protocol is applied locally at each site; site-level estimates are then meta-analysed. AsPEN has standing expertise in PSSA, SCCS, common data models, and target-trial emulation.</p>
          </div>
          <div class="border border-slate-200 rounded-lg p-5 bg-white">
            <p class="text-2xl">🤝</p>
            <p class="mt-2 font-semibold text-slate-900">Mentorship & network</p>
            <p class="mt-2 text-sm text-slate-600 leading-relaxed">Early-career researchers can co-lead studies under senior-PI mentorship across sites, with a built-in path to ISPE / ICPE presentation and peer-reviewed publication.</p>
          </div>
        </div>
      </div>

      <!-- Fit / no-fit -->
      <div class="mt-10 grid gap-6 md:grid-cols-2">
        <div>
          <h3 class="text-xs uppercase tracking-widest text-brand-600 font-semibold mb-3">What fits well</h3>
          <ul class="space-y-2 text-sm text-slate-700">
            <li class="flex gap-2"><span class="text-brand-600 font-bold">✓</span><span>Multi-country drug-safety signal assessment (PSSA, SCCS, target-trial emulation)</span></li>
            <li class="flex gap-2"><span class="text-brand-600 font-bold">✓</span><span>Drug-utilisation comparisons across health systems</span></li>
            <li class="flex gap-2"><span class="text-brand-600 font-bold">✓</span><span>Pregnancy / paediatric / older-adult safety where Asian databases are under-represented</span></li>
            <li class="flex gap-2"><span class="text-brand-600 font-bold">✓</span><span>Methods work — distributed analysis, CDM extensions, federated learning</span></li>
            <li class="flex gap-2"><span class="text-brand-600 font-bold">✓</span><span>Regulatory / policy questions where cross-jurisdiction evidence strengthens conclusions</span></li>
          </ul>
        </div>
        <div>
          <h3 class="text-xs uppercase tracking-widest text-slate-500 font-semibold mb-3">Less suitable</h3>
          <ul class="space-y-2 text-sm text-slate-600">
            <li class="flex gap-2"><span class="text-slate-400 font-bold">✗</span><span>Single-site studies that don't benefit from multi-country data</span></li>
            <li class="flex gap-2"><span class="text-slate-400 font-bold">✗</span><span>Interventional trials — AsPEN is observational / database-based</span></li>
            <li class="flex gap-2"><span class="text-slate-400 font-bold">✗</span><span>Research questions where no AsPEN site has relevant exposure / outcome data</span></li>
            <li class="flex gap-2"><span class="text-slate-400 font-bold">✗</span><span>Pre-commercial industry-sponsored work without an academic co-lead</span></li>
          </ul>
        </div>
      </div>

      <!-- Process -->
      <div class="mt-10">
        <h3 class="text-xs uppercase tracking-widest text-brand-600 font-semibold mb-4">The proposal process</h3>
        <ol class="space-y-4">
          {[
            { n: 1, t: "Pre-discussion",       d: "Email a 2–3 sentence question. The Chair and relevant national leads sound out whether the idea fits and which sites might have appetite. Informal — no concept note yet.", w: "1–3 weeks" },
            { n: 2, t: "Concept note",         d: "If the topic fits, write a 1–2 page concept (research question, target population, exposure, outcome, candidate sites, lead author). Submit by email — no formal template required at this stage.", w: "2–4 weeks" },
            { n: 3, t: "Network review",       d: "The concept is circulated at the next SIG teleconference or ISPE Asian / ICPE in-person meeting. Sites with relevant data and interest signal willingness to participate.", w: "1–3 months (depends on meeting cadence)" },
            { n: 4, t: "Protocol drafting",    d: "Interested sites collaborate on a full protocol — common data definitions, statistical analysis plan, site-specific feasibility checks.", w: "3–6 months" },
            { n: 5, t: "Local IRB + analysis", d: "Each site obtains its own IRB approval, executes the analysis locally against its own database, and returns site-level estimates.", w: "6–12 months" },
            { n: 6, t: "Meta-analysis & publication", d: "Site-level results are pooled centrally; manuscript drafted with multi-site authorship under AsPEN co-authorship conventions.", w: "3–6 months" },
          ].map((s) => (
            <li class="flex gap-4 border border-slate-200 rounded-lg p-5 bg-white">
              <div class="shrink-0 w-9 h-9 rounded-full bg-brand-100 text-brand-700 font-bold grid place-items-center">{s.n}</div>
              <div class="flex-1">
                <div class="flex items-baseline justify-between gap-3 flex-wrap">
                  <p class="font-semibold text-slate-900">{s.t}</p>
                  <p class="text-xs text-slate-500 italic">{s.w}</p>
                </div>
                <p class="text-sm text-slate-600 mt-1 leading-relaxed">{s.d}</p>
              </div>
            </li>
          ))}
        </ol>
        <p class="text-xs text-slate-500 mt-4 italic">Concept-to-publication typically runs 18–30 months end-to-end. The biggest variability is in site recruitment and IRB approval — both ease considerably when the proposer already has a relationship with one or two AsPEN sites.</p>
      </div>

      <!-- Bring / provide -->
      <div class="mt-10 grid gap-6 md:grid-cols-2">
        <div class="border border-slate-200 rounded-lg p-6 bg-white">
          <h3 class="text-xs uppercase tracking-widest text-brand-600 font-semibold mb-3">What you bring</h3>
          <ul class="space-y-2 text-sm text-slate-700">
            <li>• A clearly-scoped research question and rationale</li>
            <li>• A draft analysis plan — exposure, comparator, outcome, study design</li>
            <li>• Willingness to lead protocol drafting and meta-analysis</li>
            <li>• Database access at your home institution (helpful but not strictly required)</li>
            <li>• ISPE membership if you intend to formally join the SIG</li>
          </ul>
        </div>
        <div class="border border-slate-200 rounded-lg p-6 bg-white">
          <h3 class="text-xs uppercase tracking-widest text-brand-600 font-semibold mb-3">What AsPEN provides</h3>
          <ul class="space-y-2 text-sm text-slate-700">
            <li>• Site recruitment across the network — one channel, many databases</li>
            <li>• Methodological consultation (PSSA / SCCS / CDM / target-trial)</li>
            <li>• Forum for protocol review at SIG meetings and ICPE</li>
            <li>• Multi-site authorship and publication coordination</li>
            <li>• Mentorship for early-career investigators</li>
          </ul>
        </div>
      </div>

      <!-- FAQ -->
      <div class="mt-10">
        <h3 class="text-xs uppercase tracking-widest text-brand-600 font-semibold mb-4">FAQ</h3>
        <div class="space-y-3">
          {[
            { q: "Do I need to be an ISPE member to propose?", a: "No — informal pre-discussion is open. To formally join the SIG and present proposals at SIG meetings, ISPE membership (including student rates) is required." },
            { q: "Do I need my own database access?", a: "Helpful but not required. Many AsPEN studies are initiated by methodologists or policy researchers who bring the question; site PIs with database access handle local execution." },
            { q: "Is there any cost?", a: "AsPEN itself does not charge. Each participating site bears its own analysis costs; data-access fees vary by database (e.g. NHIRD / NDB) and are arranged at the site level." },
            { q: "How is authorship handled?", a: "Multi-site co-authorship with the proposing investigator typically as first author (or as agreed during protocol drafting). Each contributing site usually nominates one analyst-author plus a senior PI." },
            { q: "What if my study is industry-funded?", a: "Industry-funded studies are accepted when there is a clear academic co-lead and study design / publication decisions remain investigator-led. Pre-discussion with the Chair is essential." },
            { q: "Can I propose a methods-only study (no clinical question)?", a: "Yes. Methodological work — federated analysis, common data models, target-trial emulation extensions — is a long-standing AsPEN strand." },
          ].map((item) => (
            <details class="border border-slate-200 rounded-lg bg-white group">
              <summary class="cursor-pointer select-none px-5 py-4 font-semibold text-slate-800 hover:bg-slate-50 rounded-lg flex items-start gap-3">
                <span class="text-brand-700 text-xl leading-none group-open:rotate-45 transition">+</span>
                <span>{item.q}</span>
              </summary>
              <p class="px-5 pb-5 text-sm text-slate-600 leading-relaxed pl-12">{item.a}</p>
            </details>
          ))}
        </div>
      </div>
    </div>

    <!-- ── OTHER WAYS TO REACH US ──────────────────────────────── -->
    <div>
      <h2 class="text-2xl font-bold text-slate-900">Other ways to reach us</h2>
      <p class="mt-2 text-slate-600 max-w-3xl">For network membership and updates from individual labs.</p>

      <div class="mt-6 grid gap-5 md:grid-cols-2">
        <div class="border border-slate-200 rounded-lg p-6 bg-white">
          <p class="text-xs font-semibold text-brand-600 uppercase tracking-wide">Joining the SIG</p>
          <p class="mt-2 text-slate-700 text-sm leading-relaxed">
            Network membership is coordinated through the ISPE Community platform. Visit the
            <a class="text-brand-600 hover:underline font-semibold" href="https://www.pharmacoepi.org/communities/sigs/aspen/" target="_blank" rel="noopener">AsPEN SIG page on pharmacoepi.org</a> to request access.
          </p>
        </div>
        <div class="border border-slate-200 rounded-lg p-6 bg-white">
          <p class="text-xs font-semibold text-brand-600 uppercase tracking-wide">Browse what we publish</p>
          <p class="mt-2 text-slate-700 text-sm leading-relaxed">
            See AsPEN's publication portfolio
            <a class="text-brand-600 hover:underline font-semibold" href={`${base}/publications/themes/`}>by research theme</a>
            or the
            <a class="text-brand-600 hover:underline font-semibold" href={`${base}/publications/`}>full chronological list</a>.
          </p>
        </div>
      </div>
    </div>

    <!-- ── PARTNER LABS LINKEDIN ──────────────────────────────── -->
    <div>
      <div class="flex items-end justify-between gap-4 flex-wrap mb-6">
        <div>
          <h2 class="text-2xl font-bold text-slate-900 flex items-center gap-2">
            <svg viewBox="0 0 24 24" class="w-7 h-7" fill="#0A66C2" aria-hidden="true"><path d="M20.5 2h-17A1.5 1.5 0 0 0 2 3.5v17A1.5 1.5 0 0 0 3.5 22h17a1.5 1.5 0 0 0 1.5-1.5v-17A1.5 1.5 0 0 0 20.5 2zM8 19H5v-9h3v9zM6.5 8.25A1.75 1.75 0 1 1 8.3 6.5a1.78 1.78 0 0 1-1.8 1.75zM19 19h-3v-4.74c0-1.42-.6-1.93-1.38-1.93A1.74 1.74 0 0 0 13 14.19a.66.66 0 0 0 0 .14V19h-3v-9h2.9v1.3a3.11 3.11 0 0 1 2.7-1.4c1.55 0 3.36.86 3.36 3.66z"/></svg>
            Follow our partner labs
          </h2>
          <p class="text-sm text-slate-600 mt-1">Click any card to open the LinkedIn page and see the latest posts.</p>
        </div>
      </div>

      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {linkedinGroups.map((g) => (
          <a
            href={g.href}
            target="_blank"
            rel="noopener"
            class="group block bg-white border border-slate-200 rounded-xl overflow-hidden hover:shadow-lg hover:border-[#0A66C2] transition"
          >
            <div class={`h-20 bg-gradient-to-br ${g.accent} relative`}>
              <div class="absolute -bottom-8 left-5 w-16 h-16 rounded-lg bg-white border-4 border-white shadow-md overflow-hidden">
                {(g as { logo?: string }).logo ? (
                  <img
                    src={(g as { logo: string }).logo}
                    alt={`${g.name} logo`}
                    class="block w-full h-full object-contain p-1.5"
                  />
                ) : (
                  <div class="w-full h-full grid place-items-center text-slate-900 font-extrabold text-xl tracking-tight">
                    {g.initials}
                  </div>
                )}
              </div>
              <span class="absolute top-3 right-3 inline-flex items-center gap-1 text-white/95 text-xs font-semibold bg-black/20 backdrop-blur px-2 py-0.5 rounded">
                <svg viewBox="0 0 24 24" class="w-3.5 h-3.5" fill="currentColor" aria-hidden="true"><path d="M20.5 2h-17A1.5 1.5 0 0 0 2 3.5v17A1.5 1.5 0 0 0 3.5 22h17a1.5 1.5 0 0 0 1.5-1.5v-17A1.5 1.5 0 0 0 20.5 2zM8 19H5v-9h3v9zM6.5 8.25A1.75 1.75 0 1 1 8.3 6.5a1.78 1.78 0 0 1-1.8 1.75zM19 19h-3v-4.74c0-1.42-.6-1.93-1.38-1.93A1.74 1.74 0 0 0 13 14.19a.66.66 0 0 0 0 .14V19h-3v-9h2.9v1.3a3.11 3.11 0 0 1 2.7-1.4c1.55 0 3.36.86 3.36 3.66z"/></svg>
                LinkedIn
              </span>
            </div>
            <div class="pt-10 px-5 pb-5">
              <p class="font-semibold text-slate-900 group-hover:text-[#0A66C2]">{g.name}</p>
              <p class="text-sm text-slate-600 mt-0.5">{g.fullName}</p>
              <p class="text-xs text-slate-500 mt-2 flex items-center gap-1">
                <svg viewBox="0 0 24 24" class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                {g.location}
              </p>
              <div class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-[#0A66C2]">
                View latest posts
                <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>

  </section>
</BaseLayout>
