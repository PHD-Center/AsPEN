---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHeader from "../../../components/PageHeader.astro";
import { WORKER_URL } from "../../../data/site-config";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// AsPEN-relevant sites. Order: TW / KR / JP / HK first, then others A-Z.
const SITES = [
  { code: "TW", name: "Taiwan (NHIRD / CGRD)" },
  { code: "KR", name: "South Korea (HIRA / NHIS-NHID)" },
  { code: "JP", name: "Japan (NDB)" },
  { code: "HK", name: "Hong Kong (CDARS)" },
  { code: "AU", name: "Australia (PBS / VLHD)" },
  { code: "CN", name: "China" },
  { code: "FI", name: "Finland (FinReg)" },
  { code: "GB", name: "United Kingdom (CPRD / THIN)" },
  { code: "ID", name: "Indonesia" },
  { code: "IN", name: "India" },
  { code: "MY", name: "Malaysia" },
  { code: "NL", name: "Netherlands (PHARMO)" },
  { code: "PH", name: "Philippines" },
  { code: "SG", name: "Singapore" },
  { code: "TH", name: "Thailand" },
  { code: "US", name: "United States (Medicare / Medicaid / Sentinel)" },
  { code: "VN", name: "Vietnam" },
];

// Curated checkbox lists — keeps the form selectable; user can add custom
// lines below each list.
const CENSORING = [
  "Discontinuation of index drug (gap > grace period)",
  "Switch to the comparator drug class",
  "Disenrolment from the source health-insurance database",
  "Death from a non-outcome cause",
  "End of database availability / study period",
  "Pregnancy",
  "Cancer diagnosis (if not an outcome)",
  "Hospice or palliative-care enrolment",
];

const COVARIATES = [
  { group: "Demographics", items: [
    "Age (continuous)",
    "Sex",
    "Year of index",
    "Insurance type",
    "Region / urbanicity",
  ]},
  { group: "Comorbidities (binary, ever in look-back)", items: [
    "Hypertension",
    "Dyslipidaemia",
    "Chronic kidney disease",
    "Prior myocardial infarction",
    "Prior stroke / TIA",
    "Heart failure",
    "Atrial fibrillation",
    "COPD",
    "Depression",
    "Active cancer",
    "Liver disease",
    "Peripheral artery disease",
    "Charlson Comorbidity Index (CCI)",
  ]},
  { group: "Medications (binary, dispensed in look-back)", items: [
    "ACEi / ARB",
    "Beta-blockers",
    "Calcium channel blockers",
    "Diuretics",
    "Statins",
    "Antiplatelets",
    "Anticoagulants",
    "NSAIDs",
    "Glucocorticoids",
    "Metformin",
    "Sulfonylureas",
    "TZDs",
    "Insulin",
    "GLP-1 receptor agonists",
  ]},
  { group: "Healthcare utilisation", items: [
    "Outpatient visit count",
    "Inpatient admission count",
    "ED visit count",
    "Polypharmacy (≥5 drug classes)",
  ]},
  { group: "Clinical / lab (where available)", items: [
    "HbA1c",
    "BMI",
    "eGFR",
    "Smoking status",
    "Blood pressure",
  ]},
];

const SUBGROUPS = [
  "Age (≥65 vs <65 years)",
  "Sex (male vs female)",
  "Baseline CKD (eGFR <60 vs ≥60)",
  "Prior CV disease (yes vs no)",
  "Country / site",
  "Index year (e.g., before vs after 2018)",
  "Insulin use at baseline",
  "Baseline HbA1c (≥8% vs <8%)",
];

// Common inclusion / exclusion criteria — surfaced as checkboxes so a
// typical AsPEN ACNU protocol can be assembled almost entirely by ticking.
const INCLUSION = [
  "Adult (≥18 years) at index date",
  "Continuous enrolment in the source database for ≥365 d before index",
  "≥1 outpatient visit in the 365 d before index (engagement with care)",
  "≥1 prior dispensing of indication-defining drug class in look-back",
  "Available primary-care record (CPRD / linked EHR studies only)",
];

const EXCLUSION = [
  "Prior dispensing of EITHER exposure or comparator within the washout window",
  "Type 1 diabetes (ICD-10 E10.x) ever before index",
  "Pregnancy at or in the 90 d before index",
  "eGFR <30 ml/min/1.73m² at index (where available)",
  "End-stage renal disease / chronic dialysis ever",
  "Active cancer in the 365 d before index (solid or haematologic)",
  "Hospice or palliative-care enrolment in the 90 d before index",
  "Severe liver disease ever (cirrhosis, decompensated)",
  "Type 2 MI / unstable angina in the 30 d before index (if CV outcome)",
  "In-hospital at index date",
];

// Twelve confounding-control approaches the user can pick from — covers
// the standard pharmacoepi toolkit, including doubly-robust and HD-PS.
const PS_METHODS: { value: string; label: string }[] = [
  { value: "iptw",         label: "Stabilised IPTW with PS trimming (1st/99th percentile)" },
  { value: "iptw-overlap", label: "Overlap weights (Li & Greene 2018) — downweights extreme PS" },
  { value: "match-1to1",   label: "1:1 PS matching (nearest neighbour, caliper 0.2 × SD logit PS)" },
  { value: "match-1ton",   label: "1:N variable-ratio PS matching (e.g., up to 1:4)" },
  { value: "match-greedy", label: "Greedy PS matching with replacement" },
  { value: "strat",        label: "PS stratification (deciles)" },
  { value: "hdps",         label: "High-dimensional propensity score (HDPS, Schneeweiss 2009)" },
  { value: "drs",          label: "Disease risk score (DRS) adjustment" },
  { value: "tmle",         label: "Targeted maximum likelihood estimation (TMLE) — doubly robust" },
  { value: "gformula",     label: "G-formula / parametric standardisation" },
  { value: "msm",          label: "Marginal structural model (stabilised IPTW + Cox)" },
  { value: "outcome-reg",  label: "Multivariable outcome regression (Cox PH with covariates)" },
  { value: "iv",           label: "Instrumental variable (IV) analysis" },
];

const PS_METHOD_DESCRIPTIONS: Record<string, string> = Object.fromEntries(PS_METHODS.map((m) => [m.value, m.label]));

const INDEX_DATE_OPTIONS: { value: string; label: string }[] = [
  { value: "after-washout",      label: "First dispensing of exposure or comparator after the washout period" },
  { value: "after-indication",   label: "First dispensing of exposure or comparator after first diagnosis of the indication" },
  { value: "calendar-incident",  label: "First dispensing in the study period (incident new-user)" },
  { value: "after-treatment",    label: "First dispensing after failure of a first-line treatment (treatment-pathway start)" },
];

const MAX_FOLLOWUP_OPTIONS = [
  "1 year per patient",
  "2 years per patient",
  "3 years per patient",
  "5 years per patient, or until censoring (whichever first)",
  "10 years per patient, or until censoring",
  "Until end of database availability (no cap)",
];

const CDM_OPTIONS = [
  "Not applicable (no CDM)",
  "OMOP CDM v5.4",
  "OMOP CDM v6.0",
  "Sentinel CDM v8.x",
  "PCORnet CDM v6.x",
  "Mini-Sentinel CDM",
  "AsPEN harmonised local CDM",
];

const SENSITIVITY = [
  "PS trimming to area of common support",
  "Alternative washout period (180 d, 730 d)",
  "Alternative grace period (0, 60, 90 d)",
  "ITT vs on-treatment (whichever is not the primary)",
  "Active-comparator restriction to a single agent",
  "Negative-control outcome (e.g., fracture or skin infection)",
  "Exclude first 30 days of follow-up (latency analysis)",
  "High-dimensional propensity score (HDPS)",
  "Restrict to incident users only (≥1 year look-back required)",
  "Exclude pregnant patients",
  "E-value for unmeasured confounding",
];

const TIMELINE_PRESETS: Record<string, string> = {
  "12-month": [
    "Month 0: Protocol finalised, site IRB submissions begin",
    "Month 3: All site IRB approvals received",
    "Month 4-6: Local data extraction and cohort assembly",
    "Month 7-9: PS modelling and analytic execution at each site",
    "Month 10-11: Site estimates returned to coordinating centre; meta-analysis",
    "Month 12: First draft manuscript circulated; conference abstract",
  ].join("\n"),
  "18-month": [
    "Month 0: Protocol finalised, site IRB submissions begin",
    "Month 4: All site IRB approvals received",
    "Month 5-8: Local data extraction and cohort assembly",
    "Month 9-12: PS modelling and analytic execution at each site",
    "Month 13-15: Sensitivity analyses; meta-analysis",
    "Month 16-17: Manuscript drafting and internal review",
    "Month 18: Manuscript submission",
  ].join("\n"),
  "24-month": [
    "Month 0-3: Protocol finalisation, code-set harmonisation, IRB submissions",
    "Month 4-6: IRB approvals; pilot data extraction at each site",
    "Month 7-12: Full cohort assembly, PS modelling, primary analysis",
    "Month 13-18: Sensitivity analyses; subgroup analyses; meta-analysis",
    "Month 19-21: Manuscript drafting; conference presentations",
    "Month 22-24: Peer review, revisions, publication",
  ].join("\n"),
};
---

<BaseLayout
  title="Protocol template · ACNU — AsPEN members"
  description="Guided form that drafts a multi-national active-comparator new-user (ACNU) study protocol for AsPEN sites."
>
  <PageHeader
    eyebrow="Members → Templates"
    title="Multi-national ACNU protocol builder"
    description="Active-comparator new-user design. Tick the boxes for the operational pieces; the protocol draft updates on the right. Export as Word (.docx) or Markdown."
  />

  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8 space-y-6">
    <a class="text-sm text-brand-700 hover:underline font-semibold" href={`${base}/members/`}>← Members area</a>

    <div data-state="loading" class="text-sm text-slate-600 italic">Checking your session…</div>
    <div data-state="signed-out" class="hidden border border-slate-200 rounded-lg p-6 bg-slate-50">
      <p class="text-sm text-slate-700">Sign in to use the protocol builder. <a class="text-brand-700 hover:underline font-semibold" href={`${base}/members/login`}>Sign in →</a></p>
    </div>
    <div data-state="forbidden" class="hidden border border-slate-200 rounded-lg p-6 bg-slate-50">
      <p class="text-sm text-slate-700">The protocol builder is currently restricted to AsPEN admins. Ask the chair if you need access.</p>
    </div>

    <div data-state="ready" class="hidden grid gap-8 lg:grid-cols-[1fr,1fr] items-start">

      <!-- ── Wizard form (left) ─────────────────────────────── -->
      <form data-builder class="space-y-6">

        <details open class="border border-slate-200 rounded-2xl bg-white shadow-sm">
          <summary class="cursor-pointer select-none px-5 py-4 font-semibold text-slate-900 hover:bg-slate-50 rounded-2xl">
            1 · Study identification
          </summary>
          <div class="px-5 pb-5 grid sm:grid-cols-2 gap-3">
            <label class="flex flex-col gap-1 sm:col-span-2">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Study title</span>
              <input type="text" name="title" placeholder="e.g. SGLT2 inhibitors vs DPP-4 inhibitors and risk of MACE"
                     class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Short ID</span>
              <input type="text" name="shortId" placeholder="AsPEN-SGLT2-MACE-2026"
                     class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Version · Date</span>
              <input type="text" name="version" placeholder="v0.1 draft · 2026-05-28"
                     class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
            <label class="flex flex-col gap-1 sm:col-span-2">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Lead investigator(s)</span>
              <input type="text" name="leadInvestigator" placeholder="Name, affiliation; co-leads if any"
                     class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
          </div>
        </details>

        <details open class="border border-slate-200 rounded-2xl bg-white shadow-sm">
          <summary class="cursor-pointer select-none px-5 py-4 font-semibold text-slate-900 hover:bg-slate-50 rounded-2xl">
            2 · Research question (one-line summary)
          </summary>
          <div class="px-5 pb-5 grid sm:grid-cols-2 gap-3">
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Population</span>
              <input type="text" name="picoP" placeholder="Adults ≥40y initiating second-line T2DM therapy"
                     class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Exposure</span>
              <input type="text" name="picoI" placeholder="SGLT2 inhibitors (any agent)"
                     class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Comparator</span>
              <input type="text" name="picoC" placeholder="DPP-4 inhibitors (any agent)"
                     class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Primary outcome</span>
              <input type="text" name="picoO" placeholder="3-point MACE (CV death, MI, stroke)"
                     class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
          </div>
        </details>

        <details open class="border border-slate-200 rounded-2xl bg-white shadow-sm">
          <summary class="cursor-pointer select-none px-5 py-4 font-semibold text-slate-900 hover:bg-slate-50 rounded-2xl">
            3 · Sites
          </summary>
          <div class="px-5 pb-5 space-y-3">
            <p class="text-xs text-slate-500">Tick every site whose data partner has agreed to run the common protocol locally.</p>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
              {SITES.map((s) => (
                <label class="flex items-center gap-2 text-xs border border-slate-200 rounded px-3 py-2 hover:bg-slate-50 cursor-pointer">
                  <input type="checkbox" name="sites" value={s.code} class="rounded border-slate-400 text-brand-700 focus:ring-brand-500" />
                  <span><span class="font-semibold">{s.code}</span> · {s.name}</span>
                </label>
              ))}
            </div>
          </div>
        </details>

        <details open class="border border-slate-200 rounded-2xl bg-white shadow-sm">
          <summary class="cursor-pointer select-none px-5 py-4 font-semibold text-slate-900 hover:bg-slate-50 rounded-2xl">
            4 · Cohort definition
          </summary>
          <div class="px-5 pb-5 grid sm:grid-cols-2 gap-3">
            <label class="flex flex-col gap-1 sm:col-span-2">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Indication / cohort entry condition</span>
              <input type="text" name="indication" placeholder="T2DM (ICD-10 E11.x) ever before index"
                     class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Age range (years)</span>
              <input type="text" name="ageRange" placeholder="≥18, no upper limit"
                     class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Sex</span>
              <select name="sex" class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500">
                <option value="both">Both</option>
                <option value="female">Female only</option>
                <option value="male">Male only</option>
              </select>
            </label>
            <div class="sm:col-span-2">
              <p class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Inclusion criteria — tick those to apply</p>
              <div class="mt-2 grid sm:grid-cols-2 gap-1.5">
                {INCLUSION.map((c, i) => (
                  <label class="flex items-start gap-2 text-xs border border-slate-200 rounded px-3 py-2 hover:bg-slate-50 cursor-pointer">
                    <input type="checkbox" name="inclusionPick" value={c} checked={i < 2} class="mt-0.5 rounded border-slate-400 text-brand-700 focus:ring-brand-500" />
                    <span>{c}</span>
                  </label>
                ))}
              </div>
              <label class="flex flex-col gap-1 mt-3">
                <span class="text-[11px] uppercase tracking-widest text-slate-500 font-semibold">Custom inclusion criteria (one per line)</span>
                <textarea name="inclusionCustom" rows="2" placeholder="Study-specific criteria"
                          class="w-full border border-slate-300 rounded px-3 py-2 text-xs focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500"></textarea>
              </label>
            </div>
            <div class="sm:col-span-2">
              <p class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Exclusion criteria — tick those to apply</p>
              <div class="mt-2 grid sm:grid-cols-2 gap-1.5">
                {EXCLUSION.map((c, i) => (
                  <label class="flex items-start gap-2 text-xs border border-slate-200 rounded px-3 py-2 hover:bg-slate-50 cursor-pointer">
                    <input type="checkbox" name="exclusionPick" value={c} checked={i < 5} class="mt-0.5 rounded border-slate-400 text-brand-700 focus:ring-brand-500" />
                    <span>{c}</span>
                  </label>
                ))}
              </div>
              <label class="flex flex-col gap-1 mt-3">
                <span class="text-[11px] uppercase tracking-widest text-slate-500 font-semibold">Custom exclusion criteria (one per line)</span>
                <textarea name="exclusionCustom" rows="2" placeholder="Study-specific criteria"
                          class="w-full border border-slate-300 rounded px-3 py-2 text-xs focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500"></textarea>
              </label>
            </div>
          </div>
        </details>

        <details open class="border border-slate-200 rounded-2xl bg-white shadow-sm">
          <summary class="cursor-pointer select-none px-5 py-4 font-semibold text-slate-900 hover:bg-slate-50 rounded-2xl">
            5 · Exposure &amp; comparator
          </summary>
          <div class="px-5 pb-5 grid sm:grid-cols-2 gap-3">
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Exposure — name</span>
              <input type="text" name="exposureName" placeholder="SGLT2 inhibitors"
                     class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Exposure — code set</span>
              <input type="text" name="exposureCodes" placeholder="ATC A10BK*"
                     class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Comparator — name</span>
              <input type="text" name="comparatorName" placeholder="DPP-4 inhibitors"
                     class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Comparator — code set</span>
              <input type="text" name="comparatorCodes" placeholder="ATC A10BH*"
                     class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Washout (days)</span>
              <input type="number" name="washout" value="365" min="0" step="1"
                     class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
              <div class="flex gap-1 mt-1 flex-wrap">
                {[90, 180, 365, 730].map((d) => (
                  <button type="button" data-set-input="washout" data-value={d}
                          class="text-[10px] border border-slate-300 hover:border-brand-500 hover:bg-brand-50 hover:text-brand-700 text-slate-600 px-2 py-0.5 rounded transition">{d}</button>
                ))}
              </div>
            </label>
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Index date definition</span>
              <select name="indexDateChoice" class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500">
                {INDEX_DATE_OPTIONS.map((o, i) => (
                  <option value={o.value} selected={i === 0}>{o.label}</option>
                ))}
                <option value="custom">Custom — specify below</option>
              </select>
              <input type="text" name="indexDateCustom" placeholder="Used only if 'Custom' selected"
                     class="border border-slate-300 rounded px-3 py-2 text-xs focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
          </div>
        </details>

        <details open class="border border-slate-200 rounded-2xl bg-white shadow-sm">
          <summary class="cursor-pointer select-none px-5 py-4 font-semibold text-slate-900 hover:bg-slate-50 rounded-2xl">
            6 · Outcome ascertainment
          </summary>
          <div class="px-5 pb-5 space-y-3">
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Operational definition</span>
              <textarea name="outcomeDef" rows="3" placeholder="First hospitalisation with primary discharge diagnosis I21.x (MI), I63.x (ischemic stroke), or CV death — composite, time-to-first-event."
                        class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500"></textarea>
            </label>
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Code set</span>
              <input type="text" name="outcomeCodes" placeholder="ICD-10 I21.*, I63.*; cause-of-death I00-I99"
                     class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Validation (if any)</span>
              <input type="text" name="outcomeValidation" placeholder="Inpatient primary-diagnosis algorithm PPV ~85% (Lai 2018)"
                     class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Secondary outcomes (one per line)</span>
              <textarea name="secondaryOutcomes" rows="3" placeholder="Heart failure hospitalisation&#10;All-cause mortality"
                        class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500"></textarea>
            </label>
          </div>
        </details>

