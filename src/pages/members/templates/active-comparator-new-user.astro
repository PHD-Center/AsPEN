      };

      // ── Render preview from current form state ──────
      const render = () => {
        const state = readForm();
        preview.textContent = buildMarkdown(state);
        try { localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); } catch {}
      };

      // ── Restore saved state, then render ────────────
      try {
        const saved = localStorage.getItem(STORAGE_KEY);
        if (saved) writeForm(JSON.parse(saved));
      } catch {}
      // Always pre-fill a default timeline so the section isn't empty
      const timelineTa = form.querySelector('[name="timeline"]');
      if (timelineTa && !timelineTa.value) timelineTa.value = TIMELINE_PRESETS["12-month"];
      render();

      form.addEventListener("input", render);
      form.addEventListener("change", render);

      // Timeline preset buttons + numeric chip presets
      form.addEventListener("click", (e) => {
        const tl = e.target?.closest?.("[data-timeline-preset]");
        if (tl) {
          const ta = form.querySelector('[name="timeline"]');
          if (ta) { ta.value = TIMELINE_PRESETS[tl.dataset.timelinePreset] || ta.value; render(); }
          return;
        }
        const chip = e.target?.closest?.("[data-set-input]");
        if (chip) {
          const target = form.querySelector(`[name="${chip.dataset.setInput}"]`);
          if (target) { target.value = chip.dataset.value; render(); }
          return;
        }
      });

      // ── Filename ─────────────────────────────────────
      const buildFilename = (ext) => {
        const state = readForm();
        const slug = (state.shortId || "aspen-protocol-acnu")
          .toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "").slice(0, 60) || "aspen-protocol-acnu";
        const today = new Date().toISOString().slice(0, 10);
        return slug + "-" + today + "." + ext;
      };

      // ── Markdown download / copy ─────────────────────
      document.querySelector("[data-action='download-md']")?.addEventListener("click", () => {
        const blob = new Blob([preview.textContent || ""], { type: "text/markdown;charset=utf-8" });
        const url = URL.createObjectURL(blob);
        const a = document.createElement("a");
        a.href = url; a.download = buildFilename("md");
        document.body.appendChild(a); a.click(); a.remove();
        URL.revokeObjectURL(url);
        setMsg("Downloaded " + a.download);
      });

      document.querySelector("[data-action='copy']")?.addEventListener("click", async () => {
        try {
          await navigator.clipboard.writeText(preview.textContent || "");
          setMsg("Copied to clipboard.");
        } catch {
          setMsg("Couldn't copy — your browser may block clipboard access.", true);
        }
      });

      document.querySelector("[data-action='reset']")?.addEventListener("click", () => {
        if (!confirm("Clear every field and forget the saved draft?")) return;
        localStorage.removeItem(STORAGE_KEY);
        form.reset();
        const ta = form.querySelector('[name="timeline"]');
        if (ta) ta.value = TIMELINE_PRESETS["12-month"];
        render();
        setMsg("Cleared.");
      });

      // ── Word .docx download (Times New Roman, with tables) ─
      document.querySelector("[data-action='download-docx']")?.addEventListener("click", async () => {
        if (typeof docx === "undefined") {
          setMsg("Word library failed to load — check your network and try again.", true);
          return;
        }
        setMsg("Building Word document…");
        try {
          const blob = await buildDocx(readForm());
          const url = URL.createObjectURL(blob);
          const a = document.createElement("a");
          a.href = url; a.download = buildFilename("docx");
          document.body.appendChild(a); a.click(); a.remove();
          URL.revokeObjectURL(url);
          setMsg("Downloaded " + a.download);
        } catch (e) {
          console.error(e);
          setMsg("Couldn't build the Word file: " + String(e), true);
        }
      });

      const buildDocx = async (s) => {
        const D = docx;
        const today = new Date().toISOString().slice(0, 10);

        // ── Style helpers (Times New Roman everywhere) ────
        const FONT = "Times New Roman";
        const text = (str, opts = {}) => new D.TextRun({ text: String(str ?? ""), font: FONT, size: 22, ...opts });
        const p = (children, opts = {}) => new D.Paragraph({
          children: Array.isArray(children) ? children : [children],
          spacing: { before: 60, after: 60, ...(opts.spacing || {}) },
          ...opts,
        });
        const h1 = (str) => new D.Paragraph({
          children: [text(str, { bold: true, size: 28 })],
          spacing: { before: 200, after: 80 },
          heading: D.HeadingLevel.HEADING_1,
        });
        const h2 = (str) => new D.Paragraph({
          children: [text(str, { bold: true, size: 24 })],
          spacing: { before: 160, after: 60 },
          heading: D.HeadingLevel.HEADING_2,
        });
        const para = (str) => p([text(str)]);
        const bullet = (str) => new D.Paragraph({
          children: [text(str)],
          bullet: { level: 0 },
          spacing: { before: 0, after: 0 },
        });
        const numItem = (str) => new D.Paragraph({
          children: [text(str)],
          numbering: { reference: "ordered", level: 0 },
          spacing: { before: 0, after: 0 },
        });

        const border = { style: D.BorderStyle.SINGLE, size: 4, color: "BBBBBB" };
        const cellBorders = { top: border, bottom: border, left: border, right: border };

        // Build a 2-col labelled table (label · value rows).
        // Total width 9026 DXA (A4 minus 1" margins).
        const labelTable = (rows) => new D.Table({
          width: { size: 9026, type: D.WidthType.DXA },
          columnWidths: [3000, 6026],
          rows: rows.map(([label, value]) => new D.TableRow({
            children: [
              new D.TableCell({
                borders: cellBorders,
                width: { size: 3000, type: D.WidthType.DXA },
                margins: { top: 60, bottom: 60, left: 100, right: 100 },
                shading: { fill: "F5F5F5", type: D.ShadingType.CLEAR },
                children: [p([text(label, { bold: true })])],
              }),
              new D.TableCell({
                borders: cellBorders,
                width: { size: 6026, type: D.WidthType.DXA },
                margins: { top: 60, bottom: 60, left: 100, right: 100 },
                children: [p([text(value || "—")])],
              }),
            ],
          })),
        });

        // 3-col table for exposure/comparator
        const threeColTable = (header, rows) => new D.Table({
          width: { size: 9026, type: D.WidthType.DXA },
          columnWidths: [2200, 3000, 3826],
          rows: [
            new D.TableRow({
              tableHeader: true,
              children: header.map((h, i) => new D.TableCell({
                borders: cellBorders,
                width: { size: [2200, 3000, 3826][i], type: D.WidthType.DXA },
                margins: { top: 60, bottom: 60, left: 100, right: 100 },
                shading: { fill: "21443E", type: D.ShadingType.CLEAR },
                children: [p([text(h, { bold: true, color: "FFFFFF" })])],
              })),
            }),
            ...rows.map((cells) => new D.TableRow({
              children: cells.map((c, i) => new D.TableCell({
                borders: cellBorders,
                width: { size: [2200, 3000, 3826][i], type: D.WidthType.DXA },
                margins: { top: 60, bottom: 60, left: 100, right: 100 },
                children: [p([text(c || "—")])],
              })),
            })),
          ],
        });

        const inclusion  = mergeList(s.inclusionPick,    s.inclusionCustom);
        const exclusion  = mergeList(s.exclusionPick,    s.exclusionCustom);
        const secondary  = (s.secondaryOutcomes || "").split(/\r?\n/).map((l) => l.trim()).filter(Boolean);
        const refs       = (s.references || "").split(/\r?\n/).map((l) => l.trim()).filter(Boolean);
        const milestones = (s.timeline   || "").split(/\r?\n/).map((l) => l.trim()).filter(Boolean);
        const censoring  = mergeList(s.censoringPick,    s.censoringCustom);
        const covariates = mergeList(s.covariatesPick,   s.covariatesCustom);
        const subgroups  = mergeList(s.subgroupsPick,    s.subgroupsCustom);
        const sensitivity = mergeList(s.sensitivityPick, s.sensitivityCustom);

        const indexDateLabel = (val) => (INDEX_DATE_OPTIONS.find((o) => o.value === val) || {}).label || "";
        const resolvedIndexDate = s.indexDateChoice === "custom"
          ? (s.indexDateCustom || "Custom — see study-specific protocol")
          : indexDateLabel(s.indexDateChoice) || indexDateLabel("after-washout");
        const resolvedMaxFu = s.maxFollowupChoice === "custom"
          ? (s.maxFollowupCustom || "Custom — see study-specific protocol")
          : (s.maxFollowupChoice || "5 years per patient, or until censoring (whichever first)");

        const sex      = ({ both: "both sexes", female: "female only", male: "male only" })[s.sex] || "both sexes";
        const primAn   = ({ ITT: "Intention-to-treat (ITT)", OT: "On-treatment (per-protocol)", both: "Both ITT and on-treatment" })[s.primaryAnalysisType] || "On-treatment";
        const psM      = PS_METHOD_DESCRIPTIONS[s.psMethod] || "PS-based adjustment";
        const eff      = ({ HR: "Hazard ratio (95% CI) from Cox proportional-hazards models", RR: "Risk ratio (95% CI) from Poisson regression", RD: "Risk difference (95% CI)", IRR: "Incidence rate ratio (95% CI)" })[s.effectMeasure] || "Hazard ratio";
        const meta     = ({
          re: "Random-effects (DerSimonian-Laird) meta-analysis pooling site-specific estimates; report I² and τ². Forest plot per outcome.",
          "re-reml": "Random-effects (REML) meta-analysis pooling site-specific estimates; report I² and τ². Forest plot per outcome.",
          fe: "Fixed-effects (inverse-variance) meta-analysis pooling site-specific estimates. Forest plot per outcome.",
        })[s.metaMethod] || "Random-effects meta-analysis.";
        const arch     = ({
          federated:   "Federated — each AsPEN site executes a common analytic package locally and shares only aggregate site-level estimates with the coordinating centre.",
          cdm:         "Common Data Model — each site first transforms its source database into the agreed CDM (e.g. OMOP), then runs the shared SQL/R/Python package.",
          centralised: "Centralised — site-level individual data are pooled at the coordinating centre under appropriate data-sharing agreements.",
        })[s.arch] || "Federated";

        const sitesText = (s.sites && s.sites.length > 0)
          ? s.sites.map((c) => c + " — " + (SITE_LABEL[c] || c)).join("; ")
          : "(no sites selected)";

        const children = [];

        // Title block
        children.push(new D.Paragraph({
          children: [text(s.title || "(Untitled multi-national ACNU study)", { bold: true, size: 32 })],
          spacing: { before: 0, after: 120 },
        }));
        children.push(labelTable([
          ["Study ID", s.shortId || ""],
          ["Lead investigator(s)", s.leadInvestigator || ""],
          ["Version", s.version || ("v0.1 draft · " + today)],
          ["Design", "Multi-national active-comparator new-user (ACNU) cohort study"],
        ]));

        children.push(h1("1. Research question"));
        children.push(labelTable([
          ["Population", s.picoP || ""],
          ["Exposure", s.picoI || ""],
          ["Comparator", s.picoC || ""],
          ["Primary outcome", s.picoO || ""],
        ]));

        children.push(h1("2. Sites"));
        children.push(para(sitesText));

        children.push(h1("3. Cohort definition"));
        children.push(labelTable([
          ["Indication / cohort entry", s.indication || ""],
          ["Age range", s.ageRange || ""],
          ["Sex", sex],
        ]));
        children.push(h2("Inclusion criteria"));
        inclusion.length ? inclusion.forEach((l) => children.push(bullet(l))) : children.push(para("(none specified)"));
        children.push(h2("Exclusion criteria"));
        exclusion.length ? exclusion.forEach((l) => children.push(bullet(l))) : children.push(para("(none specified)"));

        children.push(h1("4. Exposure and comparator"));
        children.push(threeColTable(
          ["", "Name", "Code set"],
          [
            ["Exposure",   s.exposureName,   s.exposureCodes],
            ["Comparator", s.comparatorName, s.comparatorCodes],
          ],
        ));
        children.push(para("Washout period: " + (s.washout || "365") + " days — no prior dispensing of EITHER exposure or comparator in this window before index."));
        children.push(para("Index date: " + resolvedIndexDate));

        children.push(h1("5. Outcome ascertainment"));
        children.push(p([text("Operational definition. ", { bold: true }), text(s.outcomeDef || "—")]));
        children.push(p([text("Code set. ", { bold: true }), text(s.outcomeCodes || "—")]));
        children.push(p([text("Validation. ", { bold: true }), text(s.outcomeValidation || "—")]));
        children.push(h2("Secondary outcomes"));
        secondary.length ? secondary.forEach((l) => children.push(bullet(l))) : children.push(para("(none specified)"));

        children.push(h1("6. Follow-up and censoring"));
        children.push(labelTable([
          ["Primary analysis", primAn],
          ["Grace period", (s.grace || "30") + " days"],
          ["Maximum follow-up", resolvedMaxFu],
        ]));
        children.push(h2("Censoring rules"));
        censoring.length ? censoring.forEach((l) => children.push(bullet(l))) : children.push(para("(none specified)"));

        children.push(h1("7. Confounding control"));
        children.push(labelTable([
          ["Method", psM],
          ["Covariate look-back", (s.lookback || "365") + " days prior to index date"],
        ]));
        children.push(h2("Baseline covariates"));
        covariates.length ? covariates.forEach((l) => children.push(bullet(l))) : children.push(para("(none specified)"));
        children.push(para("PS model performance is assessed via standardised mean differences (SMDs) before/after weighting/matching (target < 0.1 across all covariates) and the c-statistic of the PS model."));

        children.push(h1("8. Statistical analysis"));
        children.push(labelTable([
          ["Effect estimate", eff],
          ["Meta-analysis", meta],
        ]));
        children.push(h2("Subgroup analyses"));
        subgroups.length ? subgroups.forEach((l) => children.push(bullet(l))) : children.push(para("(none specified)"));
        children.push(h2("Sensitivity analyses"));
        sensitivity.length ? sensitivity.forEach((l) => children.push(bullet(l))) : children.push(para("(none specified)"));

        children.push(h1("9. Sample size and power"));
        children.push(para("To be calculated per site using observed event rates among comparator users in pilot extractions; aim for ≥80% power to detect the smallest clinically meaningful effect for the primary outcome at α = 0.05, two-sided, after pooling. Pilot estimates are circulated before final analytic execution."));

        children.push(h1("10. Execution and timeline"));
        children.push(labelTable([
          ["Architecture", arch],
          ["CDM", s.cdm || "—"],
        ]));
        children.push(h2("Timeline milestones"));
        milestones.length ? milestones.forEach((l) => children.push(numItem(l))) : children.push(para("(none)"));

        children.push(h1("11. Ethics, data sharing, dissemination"));
        children.push(p([text("Ethics. ", { bold: true }), text(s.ethics || "Each participating site obtains local IRB / ethics approval before data extraction.")]));
        children.push(p([text("Dissemination. ", { bold: true }), text(s.dissemination || "Primary manuscript to a peer-reviewed pharmacoepidemiology journal; conference presentation at ICPE / ISPE Asian conference.")]));

        children.push(h1("12. Key references"));
        refs.length ? refs.forEach((l) => children.push(numItem(l))) : children.push(para("(none)"));

        // Footer-style line
        children.push(p([new D.TextRun({ text: "Drafted with the AsPEN protocol builder (" + today + ").", font: FONT, size: 18, italics: true, color: "808080" })], { spacing: { before: 400 } }));

        const doc = new D.Document({
          creator: "AsPEN protocol builder",
          title: s.title || "AsPEN ACNU protocol",
          styles: {
            default: { document: { run: { font: FONT, size: 22 } } },   // 11pt body
            paragraphStyles: [
              { id: "Heading1", name: "Heading 1", basedOn: "Normal", next: "Normal", quickFormat: true,
                run: { size: 28, bold: true, font: FONT },
                paragraph: { spacing: { before: 200, after: 80 }, outlineLevel: 0 } },
              { id: "Heading2", name: "Heading 2", basedOn: "Normal", next: "Normal", quickFormat: true,
                run: { size: 24, bold: true, font: FONT },
                paragraph: { spacing: { before: 160, after: 60 }, outlineLevel: 1 } },
            ],
          },
          numbering: {
            config: [{
              reference: "ordered",
              levels: [{
                level: 0, format: D.LevelFormat.DECIMAL, text: "%1.",
                alignment: D.AlignmentType.LEFT,
                style: { paragraph: { indent: { left: 720, hanging: 360 } } },
              }],
            }],
          },
          sections: [{
            properties: {
              page: {
                size: { width: 11906, height: 16838 },  // A4
                margin: { top: 1440, right: 1440, bottom: 1440, left: 1440 },
              },
            },
            children,
          }],
        });

        return await D.Packer.toBlob(doc);
      };

      // ── Auth gate (admin only) ──────────────────────
      fetch(`${WORKER_URL}/api/me`, { credentials: "include" })
        .then((r) => r.ok ? r.json() : null)
        .then((data) => {
          if (!data || !data.ok) return setState("signed-out");
          if (!data.member?.isAdmin) return setState("forbidden");
          setState("ready");
        })
        .catch(() => setState("signed-out"));
    })();
  </script>
</BaseLayout>
