                  <label class="flex items-start gap-2 text-xs border border-slate-200 rounded px-3 py-2 hover:bg-slate-50 cursor-pointer">
                    <input type="checkbox" name="subgroupsPick" value={s} checked={i < 5} class="mt-0.5 rounded border-slate-400 text-brand-700 focus:ring-brand-500" />
                    <span>{s}</span>
                  </label>
                ))}
              </div>
              <label class="flex flex-col gap-1 mt-3">
                <span class="text-[11px] uppercase tracking-widest text-slate-500 font-semibold">Custom subgroups (one per line)</span>
                <textarea name="subgroupsCustom" rows="2" class="w-full border border-slate-300 rounded px-3 py-2 text-xs focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500"></textarea>
              </label>
            </div>
            <div>
              <p class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Sensitivity analyses — tick those to include</p>
              <div class="mt-2 grid sm:grid-cols-2 gap-1.5">
                {SENSITIVITY.map((s, i) => (
                  <label class="flex items-start gap-2 text-xs border border-slate-200 rounded px-3 py-2 hover:bg-slate-50 cursor-pointer">
                    <input type="checkbox" name="sensitivityPick" value={s} checked={i < 6} class="mt-0.5 rounded border-slate-400 text-brand-700 focus:ring-brand-500" />
                    <span>{s}</span>
                  </label>
                ))}
              </div>
              <label class="flex flex-col gap-1 mt-3">
                <span class="text-[11px] uppercase tracking-widest text-slate-500 font-semibold">Custom sensitivity analyses (one per line)</span>
                <textarea name="sensitivityCustom" rows="2" class="w-full border border-slate-300 rounded px-3 py-2 text-xs focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500"></textarea>
              </label>
            </div>
          </div>
        </details>

        <details open class="border border-slate-200 rounded-2xl bg-white shadow-sm">
          <summary class="cursor-pointer select-none px-5 py-4 font-semibold text-slate-900 hover:bg-slate-50 rounded-2xl">
            10 · Execution &amp; timeline
          </summary>
          <div class="px-5 pb-5 space-y-3">
            <div class="grid sm:grid-cols-2 gap-3">
              <label class="flex flex-col gap-1">
                <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Architecture</span>
                <select name="arch" class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500">
                  <option value="federated" selected>Federated (local analysis, share aggregates)</option>
                  <option value="cdm">Common Data Model (OMOP / Sentinel)</option>
                  <option value="centralised">Centralised (pooled individual data, where DUA permits)</option>
                </select>
              </label>
              <label class="flex flex-col gap-1">
                <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">CDM</span>
                <select name="cdm" class="border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500">
                  {CDM_OPTIONS.map((o, i) => (
                    <option value={o} selected={i === 0}>{o}</option>
                  ))}
                </select>
              </label>
            </div>
            <div>
              <p class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Timeline preset</p>
              <div class="mt-2 flex gap-2 flex-wrap">
                <button type="button" data-timeline-preset="12-month" class="text-xs border border-brand-300 text-brand-700 hover:bg-brand-50 font-semibold px-3 py-1.5 rounded transition">Use 12-month plan</button>
                <button type="button" data-timeline-preset="18-month" class="text-xs border border-brand-300 text-brand-700 hover:bg-brand-50 font-semibold px-3 py-1.5 rounded transition">Use 18-month plan</button>
                <button type="button" data-timeline-preset="24-month" class="text-xs border border-brand-300 text-brand-700 hover:bg-brand-50 font-semibold px-3 py-1.5 rounded transition">Use 24-month plan</button>
              </div>
              <label class="flex flex-col gap-1 mt-3">
                <span class="text-[11px] uppercase tracking-widest text-slate-500 font-semibold">Milestones (one per line)</span>
                <textarea name="timeline" rows="6" class="w-full border border-slate-300 rounded px-3 py-2 text-xs focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500"></textarea>
              </label>
            </div>
          </div>
        </details>

        <details class="border border-slate-200 rounded-2xl bg-white shadow-sm">
          <summary class="cursor-pointer select-none px-5 py-4 font-semibold text-slate-900 hover:bg-slate-50 rounded-2xl">
            11 · Ethics, dissemination, references (optional)
          </summary>
          <div class="px-5 pb-5 space-y-3">
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Ethics</span>
              <textarea name="ethics" rows="2" class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500">Each participating site obtains local IRB / ethics approval before data extraction. Under a federated design, only aggregate site-level estimates are shared with the coordinating centre.</textarea>
            </label>
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Dissemination</span>
              <textarea name="dissemination" rows="2" class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500">Primary manuscript to a peer-reviewed pharmacoepidemiology journal; presentation at ICPE / ISPE Asian conference; registration on ENCePP EU PAS Register and/or ClinicalTrials.gov where applicable.</textarea>
            </label>
            <label class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Key references (one per line)</span>
              <textarea name="references" rows="8" class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500">Andersen M, Pratt N, Sanfélix-Gimeno G et al. Pharmacoepidemiol Drug Saf. 2013 (AsPEN founding methods paper; PSSA on antipsychotics and acute hyperglycaemia).
Lai EC, Man KK, Chaiyakunapruk N et al. Epidemiology 2015 (AsPEN database survey of Asia-Pacific population-level data sources).
Pratt NL, Mack CD, Meyer AM et al. Pharmacoepidemiol Drug Saf 2018 (AsPEN common data model framework).
Hsieh CY, Su CC, Shao SC, Sung SF, Lin SJ, Kao Yang YH, Lai EC. Taiwan's NHIRD: past and future. Clin Epidemiol 2019;11:349-358.
Shao SC, Chan YY, Kao Yang YH, Lin SJ, Hung MJ, Chien RN, Lai CC, Lai EC. The Chang Gung Research Database (CGRD). Pharmacoepidemiol Drug Saf 2019;28(5):593-600.
Tsai DHT, Wong ICK, Pratt N et al. Clin Epidemiol 2023 (NeuroGEN multi-database infrastructure for CNS drug research).
Lund JL et al. Pharmacoepidemiol Drug Saf 2015 (active comparator design).
Hernán MA, Robins JM. JAMA 2008 (new-user design; target trial).
Schneeweiss S et al. Epidemiology 2009 (high-dimensional propensity score).</textarea>
            </label>
          </div>
        </details>

        <div class="flex flex-wrap gap-3 pt-2 items-center">
          <button type="button" data-action="download-docx" class="bg-brand-700 hover:bg-brand-800 text-white font-semibold px-5 py-2.5 rounded-lg transition text-sm">
            ⬇ Download Word (.docx)
          </button>
          <button type="button" data-action="download-md" class="bg-white border border-brand-700 text-brand-700 hover:bg-brand-50 font-semibold px-5 py-2.5 rounded-lg transition text-sm">
            ⬇ Markdown (.md)
          </button>
          <button type="button" data-action="copy" class="text-brand-700 hover:underline font-semibold text-sm">
            📋 Copy Markdown
          </button>
          <button type="button" data-action="reset" class="ml-auto text-slate-500 hover:text-rose-600 hover:underline text-sm font-semibold">
            Clear all
          </button>
          <p data-action-msg class="basis-full text-xs"></p>
        </div>
      </form>

      <!-- ── Live Markdown preview (right) ──────────────────── -->
      <aside class="lg:sticky lg:top-20">
        <div class="border border-slate-200 rounded-2xl bg-slate-50 shadow-sm overflow-hidden">
          <header class="flex items-center justify-between px-4 py-2 bg-white border-b border-slate-200">
            <p class="text-xs uppercase tracking-widest text-brand-700 font-bold">Live preview</p>
            <p class="text-[10px] text-slate-500">Auto-saved to this browser · server save coming soon</p>
          </header>
          <pre data-preview class="text-xs leading-relaxed text-slate-800 p-4 overflow-auto max-h-[calc(100vh-12rem)] whitespace-pre-wrap font-mono"></pre>
        </div>
      </aside>

    </div>

    <!-- ── Phenotype-library modal ───────────────────────── -->
    <div data-library-modal class="hidden fixed inset-0 z-50 bg-slate-900/40 backdrop-blur-sm flex items-start justify-center p-4 sm:p-8 overflow-y-auto">
      <div class="bg-white border border-slate-200 rounded-2xl shadow-2xl w-full max-w-3xl my-8">
        <header class="flex items-center justify-between gap-3 px-5 py-4 border-b border-slate-100">
          <div>
            <p class="text-xs uppercase tracking-widest text-brand-700 font-bold">Validated phenotype library</p>
            <h3 class="text-lg font-bold text-slate-900 mt-0.5" data-library-title>Pick a phenotype</h3>
          </div>
          <button type="button" data-library-close class="text-slate-400 hover:text-slate-700 text-2xl leading-none">×</button>
        </header>
        <div class="px-5 py-3 border-b border-slate-100">
          <input type="text" data-library-search placeholder="Filter… (e.g., 'MI', 'SGLT2', 'cancer')"
                 class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
        </div>
        <div data-library-list class="px-2 py-2 max-h-[60vh] overflow-y-auto"></div>
        <footer class="px-5 py-3 border-t border-slate-100 text-[11px] text-slate-500 leading-relaxed">
          Code sets are starting points based on published literature — always confirm against your site's coding system version and indication-specific guidance before locking the protocol.
        </footer>
      </div>
    </div>

  </section>

  <!-- docx library (UMD bundle) — used to generate Word files client-side -->
  <script src="https://unpkg.com/docx@8.5.0/build/index.umd.js" is:inline></script>

  <script is:inline define:vars={{ WORKER_URL, BASE: base, SITES, TIMELINE_PRESETS, PS_METHOD_DESCRIPTIONS, INDEX_DATE_OPTIONS, PHENOTYPES }}>
    (() => {
      const setState = (name) => {
        document.querySelectorAll("[data-state]").forEach((el) => {
          el.classList.toggle("hidden", el.dataset.state !== name);
        });
      };

      if (!WORKER_URL) return setState("signed-out");

      const STORAGE_KEY = "aspen.protocol-builder.acnu";
      const STORAGE_CITATIONS_KEY = "aspen.protocol-builder.acnu.citations";
      const form = document.querySelector("[data-builder]");
      const preview = document.querySelector("[data-preview]");
      const actionMsg = document.querySelector("[data-action-msg]");

      // ── Picked citations (from library picks) — appended to References on export.
      // Stored as { phenotypeName: citationString } so we dedup and can clear.
      let pickedCitations = {};
      try { pickedCitations = JSON.parse(localStorage.getItem(STORAGE_CITATIONS_KEY) || "{}") || {}; } catch {}
      const savePickedCitations = () => {
        try { localStorage.setItem(STORAGE_CITATIONS_KEY, JSON.stringify(pickedCitations)); } catch {}
      };

      const setMsg = (msg, isError = false) => {
        if (!actionMsg) return;
        actionMsg.textContent = msg;
        actionMsg.classList.toggle("text-rose-700", isError);
        actionMsg.classList.toggle("text-brand-700", !isError);
      };

      const SITE_LABEL = Object.fromEntries(SITES.map((s) => [s.code, s.name]));

      // ── Form state read / write ─────────────────────
      const readForm = () => {
        const data = new FormData(form);
        const out = {};
        // Multi-value keys → arrays
        const multi = new Set(["sites", "censoringPick", "covariatesPick", "subgroupsPick", "sensitivityPick", "inclusionPick", "exclusionPick", "secondaryOutcomesPick"]);
        for (const k of multi) out[k] = [];
        for (const [k, v] of data.entries()) {
          if (multi.has(k)) out[k].push(String(v));
          else out[k] = String(v);
        }
        return out;
      };

      const writeForm = (state) => {
        const multi = new Set(["sites", "censoringPick", "covariatesPick", "subgroupsPick", "sensitivityPick", "inclusionPick", "exclusionPick", "secondaryOutcomesPick"]);
        for (const el of form.querySelectorAll("input, textarea, select")) {
          const name = el.name;
          if (!name) continue;
          if (el.type === "checkbox" && multi.has(name)) {
            el.checked = (state[name] || []).includes(el.value);
          } else if (state[name] !== undefined) {
            el.value = state[name];
          }
        }
      };

      // ── Merge built-in checkboxes + custom textarea ───
      const mergeList = (picks, customText) => {
        const lines = (customText || "")
          .split(/\r?\n/).map((l) => l.trim()).filter(Boolean);
        return [...(picks || []), ...lines];
      };

      const bullets = (arr) =>
        arr.length === 0 ? "_(none specified)_" : arr.map((l) => "- " + l).join("\n");
      const numbered = (arr) =>
        arr.length === 0 ? "_(none)_" : arr.map((l, i) => (i + 1) + ". " + l).join("\n");

      const orFb = (s, fb) => (s && s.trim()) ? s : fb;
      const sitesLine = (codes) => {
        if (!codes || codes.length === 0) return "_(no sites selected)_";
        return codes.map((c) => "**" + c + "** — " + (SITE_LABEL[c] || c)).join(" · ");
      };

      // ── Markdown template ───────────────────────────
      const buildMarkdown = (s) => {
        const today    = new Date().toISOString().slice(0, 10);
        const title    = orFb(s.title,    "(Untitled multi-national ACNU study)");
        const shortId  = orFb(s.shortId,  "(short id)");
        const lead     = orFb(s.leadInvestigator, "(lead investigator)");
        const version  = orFb(s.version,  "v0.1 draft · " + today);

        // Resolve dropdown choices to free-text used in the protocol body
        const indexDateLabel = (val) => (INDEX_DATE_OPTIONS.find((o) => o.value === val) || {}).label || "";
        const resolvedIndexDate = s.indexDateChoice === "custom"
          ? (s.indexDateCustom || "Custom — see study-specific protocol")
          : indexDateLabel(s.indexDateChoice) || indexDateLabel("after-washout");
        const resolvedMaxFu = s.maxFollowupChoice === "custom"
          ? (s.maxFollowupCustom || "Custom — see study-specific protocol")
          : (s.maxFollowupChoice || "5 years per patient, or until censoring (whichever first)");

        const sex      = ({ both: "both sexes", female: "female only", male: "male only" })[s.sex] || "both sexes";
        const primAn   = ({ ITT: "Intention-to-treat (ITT)", OT: "On-treatment (per-protocol)", both: "Both ITT and on-treatment" })[s.primaryAnalysisType] || "On-treatment";
        const psM      = PS_METHOD_DESCRIPTIONS[s.psMethod] || "PS-based adjustment";
        const eff      = ({
          HR: "Hazard ratio (95% CI) from Cox proportional-hazards models",
          RR: "Risk ratio (95% CI) from Poisson regression",
          RD: "Risk difference (95% CI)",
          IRR: "Incidence rate ratio (95% CI)",
        })[s.effectMeasure] || "Hazard ratio";
        const meta     = ({
          re: "Random-effects (DerSimonian-Laird) meta-analysis pooling site-specific estimates; report I² and τ². Forest plot per outcome.",
          "re-reml": "Random-effects (REML) meta-analysis pooling site-specific estimates; report I² and τ². Forest plot per outcome.",
          fe: "Fixed-effects (inverse-variance) meta-analysis pooling site-specific estimates. Forest plot per outcome.",
        })[s.metaMethod] || "Random-effects meta-analysis.";
        const arch     = ({
          federated:   "Federated — each AsPEN site executes a common analytic package locally and shares only aggregate site-level estimates with the coordinating centre.",
          cdm:         "Common Data Model — each site first transforms its source database into the agreed CDM (e.g. OMOP), then runs the shared SQL/R/Python package.",
          centralised: "Centralised — site-level individual data are pooled at the coordinating centre under appropriate data-sharing agreements.",
        })[s.arch] || "Federated";

        const refsUser   = (s.references || "").split(/\r?\n/).map((l) => l.trim()).filter(Boolean);
        // Merge user-typed references with citations harvested from library
        // picks (dedup by exact string).
        const refsAll    = (() => {
          const set = new Set(refsUser);
          for (const cite of Object.values(pickedCitations)) {
            if (cite && cite.trim()) set.add(cite.trim());
          }
          return Array.from(set);
        })();
        const refs       = refsAll;
        const milestones = (s.timeline   || "").split(/\r?\n/).map((l) => l.trim()).filter(Boolean);
        const inclusion  = mergeList(s.inclusionPick,    s.inclusionCustom);
        const exclusion  = mergeList(s.exclusionPick,    s.exclusionCustom);
        const censoring  = mergeList(s.censoringPick,    s.censoringCustom);
        const covariates = mergeList(s.covariatesPick,   s.covariatesCustom);
        const subgroups  = mergeList(s.subgroupsPick,    s.subgroupsCustom);
        const sensitivity = mergeList(s.sensitivityPick, s.sensitivityCustom);
        const secondary   = mergeList(s.secondaryOutcomesPick, s.secondaryOutcomesCustom);
        const resolvedAge = s.ageRangeChoice === "custom"
          ? (s.ageRangeCustom || "(specify)")
          : (s.ageRangeChoice || "≥18, no upper limit");

        return `# ${title}

**Study ID:** ${shortId}
**Lead investigator(s):** ${lead}
**Version:** ${version}
**Design:** Multi-national active-comparator new-user (ACNU) cohort study

---

## 1. Research question

| | |
|---|---|
| **Population** | ${orFb(s.picoP, "_(population)_")} |
| **Exposure** | ${orFb(s.picoI, "_(exposure)_")} |
| **Comparator** | ${orFb(s.picoC, "_(comparator)_")} |
| **Primary outcome** | ${orFb(s.picoO, "_(outcome)_")} |

## 2. Sites

${sitesLine(s.sites)}

## 3. Cohort definition

- **Indication / cohort entry:** ${orFb(s.indication, "_(condition)_")}
- **Age:** ${resolvedAge}
- **Sex:** ${sex}

**Inclusion criteria**

${bullets(inclusion)}

**Exclusion criteria**

${bullets(exclusion)}

## 4. Exposure and comparator

| | Name | Code set |
|---|---|---|
| **Exposure** | ${orFb(s.exposureName, "_(exposure)_")} | ${orFb(s.exposureCodes, "_(codes)_")} |
| **Comparator** | ${orFb(s.comparatorName, "_(comparator)_")} | ${orFb(s.comparatorCodes, "_(codes)_")} |

- **Washout period:** ${s.washout || "365"} days — no prior dispensing of EITHER exposure or comparator in this window before index.
- **Index date:** ${resolvedIndexDate}

## 5. Outcome ascertainment

**Operational definition.** ${orFb(s.outcomeDef, "_(operational outcome definition)_")}

**Code set.** ${orFb(s.outcomeCodes, "_(code set)_")}

**Secondary outcomes**

${bullets(secondary)}

## 6. Follow-up and censoring

- **Primary analysis:** ${primAn}
- **Grace period:** ${s.grace || "30"} days
- **Maximum follow-up:** ${resolvedMaxFu}

**Censoring rules**

${bullets(censoring)}

## 7. Confounding control

- **Method:** ${psM}
- **Covariate look-back window:** ${s.lookback || "365"} days prior to index date

**Baseline covariates**

${bullets(covariates)}

PS model performance is assessed via standardised mean differences (SMDs) before/after weighting/matching (target < 0.1 across all covariates) and the c-statistic of the PS model.

## 8. Statistical analysis

- **Effect estimate:** ${eff}
- **Meta-analysis across sites:** ${meta}

**Subgroup analyses**

${bullets(subgroups)}

**Sensitivity analyses**

${bullets(sensitivity)}

## 9. Sample size and power

To be calculated per site using observed event rates among comparator users in pilot extractions; aim for ≥80% power to detect the smallest clinically meaningful effect for the primary outcome at α = 0.05, two-sided, after pooling. Pilot estimates are circulated before final analytic execution.

## 10. Execution and timeline

**Architecture.** ${arch}

**CDM:** ${orFb(s.cdm, "_(specify CDM if applicable)_")}

**Timeline milestones**

${numbered(milestones)}

## 11. Ethics, data sharing, dissemination

**Ethics.** ${orFb(s.ethics, "Each participating site obtains local IRB / ethics approval before data extraction.")}

**Dissemination.** ${orFb(s.dissemination, "Primary manuscript to a peer-reviewed pharmacoepidemiology journal; conference presentation at ICPE / ISPE Asian conference.")}

## 12. Key references

${numbered(refs)}

---

_Drafted with the AsPEN protocol builder (${today})._
`;
      };

      // ── Render preview from current form state ──────
      const render = () => {
        const state = readForm();
        preview.textContent = buildMarkdown(state);
        try { localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); } catch {}
      };

      // ── Restore saved state, then render ────────────
      try {
        const saved = localStorage.getItem(STORAGE_KEY);
        if (saved) writeForm(JSON.parse(saved));
      } catch {}
      // Always pre-fill a default timeline so the section isn't empty
      const timelineTa = form.querySelector('[name="timeline"]');
      if (timelineTa && !timelineTa.value) timelineTa.value = TIMELINE_PRESETS["12-month"];
      render();

      form.addEventListener("input", render);
      form.addEventListener("change", render);

      // Timeline preset buttons + numeric chip presets
      form.addEventListener("click", (e) => {
        const tl = e.target?.closest?.("[data-timeline-preset]");
        if (tl) {
          const ta = form.querySelector('[name="timeline"]');
          if (ta) { ta.value = TIMELINE_PRESETS[tl.dataset.timelinePreset] || ta.value; render(); }
          return;
        }
        const chip = e.target?.closest?.("[data-set-input]");
        if (chip) {
          const target = form.querySelector(`[name="${chip.dataset.setInput}"]`);
          if (target) { target.value = chip.dataset.value; render(); }
          return;
        }
      });

      // ── Filename ─────────────────────────────────────
      const buildFilename = (ext) => {
        const state = readForm();
        const slug = (state.shortId || "aspen-protocol-acnu")
          .toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "").slice(0, 60) || "aspen-protocol-acnu";
        const today = new Date().toISOString().slice(0, 10);
        return slug + "-" + today + "." + ext;
      };

      // ── Markdown download / copy ─────────────────────
      document.querySelector("[data-action='download-md']")?.addEventListener("click", () => {
        const blob = new Blob([preview.textContent || ""], { type: "text/markdown;charset=utf-8" });
        const url = URL.createObjectURL(blob);
        const a = document.createElement("a");
        a.href = url; a.download = buildFilename("md");
        document.body.appendChild(a); a.click(); a.remove();
        URL.revokeObjectURL(url);
        setMsg("Downloaded " + a.download);
      });

      document.querySelector("[data-action='copy']")?.addEventListener("click", async () => {
        try {
          await navigator.clipboard.writeText(preview.textContent || "");
          setMsg("Copied to clipboard.");
        } catch {
          setMsg("Couldn't copy — your browser may block clipboard access.", true);
        }
      });

      const doReset = () => {
        if (!confirm("Clear every field and forget the saved draft?")) return;
        localStorage.removeItem(STORAGE_KEY);
        localStorage.removeItem(STORAGE_CITATIONS_KEY);
        pickedCitations = {};
        form.reset();
        const ta = form.querySelector('[name="timeline"]');
        if (ta) ta.value = TIMELINE_PRESETS["12-month"];
        render();
        setMsg("Cleared.");
      };
      document.querySelector("[data-action='reset']")?.addEventListener("click", doReset);
      document.querySelector("[data-action='reset-top']")?.addEventListener("click", doReset);

      // ── Word .docx download (Times New Roman, with tables) ─
      document.querySelector("[data-action='download-docx']")?.addEventListener("click", async () => {
        if (typeof docx === "undefined") {
          setMsg("Word library failed to load — check your network and try again.", true);
          return;
        }
        setMsg("Building Word document…");
        try {
          const blob = await buildDocx(readForm());
          const url = URL.createObjectURL(blob);
          const a = document.createElement("a");
          a.href = url; a.download = buildFilename("docx");
          document.body.appendChild(a); a.click(); a.remove();
          URL.revokeObjectURL(url);
          setMsg("Downloaded " + a.download);
        } catch (e) {
          console.error(e);
          setMsg("Couldn't build the Word file: " + String(e), true);
        }
      });

      const buildDocx = async (s) => {
        const D = docx;
        const today = new Date().toISOString().slice(0, 10);

        // ── Style helpers (Times New Roman everywhere) ────
        const FONT = "Times New Roman";
        const text = (str, opts = {}) => new D.TextRun({ text: String(str ?? ""), font: FONT, size: 22, ...opts });
        const p = (children, opts = {}) => new D.Paragraph({
          children: Array.isArray(children) ? children : [children],
          spacing: { before: 60, after: 60, ...(opts.spacing || {}) },
          ...opts,
        });
        const h1 = (str) => new D.Paragraph({
          children: [text(str, { bold: true, size: 28 })],
          spacing: { before: 200, after: 80 },
          heading: D.HeadingLevel.HEADING_1,
        });
        const h2 = (str) => new D.Paragraph({
          children: [text(str, { bold: true, size: 24 })],
          spacing: { before: 160, after: 60 },
          heading: D.HeadingLevel.HEADING_2,
        });
        const para = (str) => p([text(str)]);
        const bullet = (str) => new D.Paragraph({
          children: [text(str)],
          bullet: { level: 0 },
          spacing: { before: 0, after: 0 },
        });
        const numItem = (str) => new D.Paragraph({
          children: [text(str)],
          numbering: { reference: "ordered", level: 0 },
          spacing: { before: 0, after: 0 },
        });

        const border = { style: D.BorderStyle.SINGLE, size: 4, color: "BBBBBB" };
        const cellBorders = { top: border, bottom: border, left: border, right: border };

        // Build a 2-col labelled table (label · value rows).
        // Total width 9026 DXA (A4 minus 1" margins).
        const labelTable = (rows) => new D.Table({
          width: { size: 9026, type: D.WidthType.DXA },
          columnWidths: [3000, 6026],
          rows: rows.map(([label, value]) => new D.TableRow({
            children: [
              new D.TableCell({
                borders: cellBorders,
                width: { size: 3000, type: D.WidthType.DXA },
                margins: { top: 60, bottom: 60, left: 100, right: 100 },
                shading: { fill: "F5F5F5", type: D.ShadingType.CLEAR },
                children: [p([text(label, { bold: true })])],
              }),
              new D.TableCell({
                borders: cellBorders,
                width: { size: 6026, type: D.WidthType.DXA },
                margins: { top: 60, bottom: 60, left: 100, right: 100 },
                children: [p([text(value || "—")])],
              }),
            ],
          })),
        });

        // 3-col table for exposure/comparator
        const threeColTable = (header, rows) => new D.Table({
          width: { size: 9026, type: D.WidthType.DXA },
          columnWidths: [2200, 3000, 3826],
          rows: [
            new D.TableRow({
              tableHeader: true,
              children: header.map((h, i) => new D.TableCell({
                borders: cellBorders,
                width: { size: [2200, 3000, 3826][i], type: D.WidthType.DXA },
                margins: { top: 60, bottom: 60, left: 100, right: 100 },
                shading: { fill: "21443E", type: D.ShadingType.CLEAR },
                children: [p([text(h, { bold: true, color: "FFFFFF" })])],
              })),
            }),
            ...rows.map((cells) => new D.TableRow({
              children: cells.map((c, i) => new D.TableCell({
                borders: cellBorders,
                width: { size: [2200, 3000, 3826][i], type: D.WidthType.DXA },
                margins: { top: 60, bottom: 60, left: 100, right: 100 },
                children: [p([text(c || "—")])],
              })),
            })),
          ],
        });

        const inclusion  = mergeList(s.inclusionPick,    s.inclusionCustom);
        const exclusion  = mergeList(s.exclusionPick,    s.exclusionCustom);
        const refsUser   = (s.references || "").split(/\r?\n/).map((l) => l.trim()).filter(Boolean);
        const refs       = (() => {
          const set = new Set(refsUser);
          for (const cite of Object.values(pickedCitations)) {
            if (cite && cite.trim()) set.add(cite.trim());
          }
          return Array.from(set);
        })();
        const milestones = (s.timeline   || "").split(/\r?\n/).map((l) => l.trim()).filter(Boolean);
        const censoring  = mergeList(s.censoringPick,    s.censoringCustom);
        const covariates = mergeList(s.covariatesPick,   s.covariatesCustom);
        const subgroups  = mergeList(s.subgroupsPick,    s.subgroupsCustom);
        const sensitivity = mergeList(s.sensitivityPick, s.sensitivityCustom);
        const secondary   = mergeList(s.secondaryOutcomesPick, s.secondaryOutcomesCustom);
        const resolvedAge = s.ageRangeChoice === "custom"
          ? (s.ageRangeCustom || "(specify)")
          : (s.ageRangeChoice || "≥18, no upper limit");

        const indexDateLabel = (val) => (INDEX_DATE_OPTIONS.find((o) => o.value === val) || {}).label || "";
        const resolvedIndexDate = s.indexDateChoice === "custom"
          ? (s.indexDateCustom || "Custom — see study-specific protocol")
          : indexDateLabel(s.indexDateChoice) || indexDateLabel("after-washout");
        const resolvedMaxFu = s.maxFollowupChoice === "custom"
          ? (s.maxFollowupCustom || "Custom — see study-specific protocol")
          : (s.maxFollowupChoice || "5 years per patient, or until censoring (whichever first)");

        const sex      = ({ both: "both sexes", female: "female only", male: "male only" })[s.sex] || "both sexes";
        const primAn   = ({ ITT: "Intention-to-treat (ITT)", OT: "On-treatment (per-protocol)", both: "Both ITT and on-treatment" })[s.primaryAnalysisType] || "On-treatment";
        const psM      = PS_METHOD_DESCRIPTIONS[s.psMethod] || "PS-based adjustment";
        const eff      = ({ HR: "Hazard ratio (95% CI) from Cox proportional-hazards models", RR: "Risk ratio (95% CI) from Poisson regression", RD: "Risk difference (95% CI)", IRR: "Incidence rate ratio (95% CI)" })[s.effectMeasure] || "Hazard ratio";
        const meta     = ({
          re: "Random-effects (DerSimonian-Laird) meta-analysis pooling site-specific estimates; report I² and τ². Forest plot per outcome.",
          "re-reml": "Random-effects (REML) meta-analysis pooling site-specific estimates; report I² and τ². Forest plot per outcome.",
          fe: "Fixed-effects (inverse-variance) meta-analysis pooling site-specific estimates. Forest plot per outcome.",
        })[s.metaMethod] || "Random-effects meta-analysis.";
        const arch     = ({
          federated:   "Federated — each AsPEN site executes a common analytic package locally and shares only aggregate site-level estimates with the coordinating centre.",
          cdm:         "Common Data Model — each site first transforms its source database into the agreed CDM (e.g. OMOP), then runs the shared SQL/R/Python package.",
          centralised: "Centralised — site-level individual data are pooled at the coordinating centre under appropriate data-sharing agreements.",
        })[s.arch] || "Federated";

        const sitesText = (s.sites && s.sites.length > 0)
          ? s.sites.map((c) => c + " — " + (SITE_LABEL[c] || c)).join("; ")
          : "(no sites selected)";

        const children = [];

        // Title block
        children.push(new D.Paragraph({
          children: [text(s.title || "(Untitled multi-national ACNU study)", { bold: true, size: 32 })],
          spacing: { before: 0, after: 120 },
        }));
        children.push(labelTable([
          ["Study ID", s.shortId || ""],
          ["Lead investigator(s)", s.leadInvestigator || ""],
          ["Version", s.version || ("v0.1 draft · " + today)],
          ["Design", "Multi-national active-comparator new-user (ACNU) cohort study"],
        ]));

        children.push(h1("1. Research question"));
        children.push(labelTable([
          ["Population", s.picoP || ""],
          ["Exposure", s.picoI || ""],
          ["Comparator", s.picoC || ""],
          ["Primary outcome", s.picoO || ""],
        ]));

        children.push(h1("2. Sites"));
        children.push(para(sitesText));

        children.push(h1("3. Cohort definition"));
        children.push(labelTable([
          ["Indication / cohort entry", s.indication || ""],
          ["Age range", resolvedAge],
          ["Sex", sex],
        ]));
        children.push(h2("Inclusion criteria"));
        inclusion.length ? inclusion.forEach((l) => children.push(bullet(l))) : children.push(para("(none specified)"));
        children.push(h2("Exclusion criteria"));
        exclusion.length ? exclusion.forEach((l) => children.push(bullet(l))) : children.push(para("(none specified)"));

        children.push(h1("4. Exposure and comparator"));
        children.push(threeColTable(
          ["", "Name", "Code set"],
          [
            ["Exposure",   s.exposureName,   s.exposureCodes],
            ["Comparator", s.comparatorName, s.comparatorCodes],
          ],
        ));
        children.push(para("Washout period: " + (s.washout || "365") + " days — no prior dispensing of EITHER exposure or comparator in this window before index."));
        children.push(para("Index date: " + resolvedIndexDate));

        children.push(h1("5. Outcome ascertainment"));
        children.push(p([text("Operational definition. ", { bold: true }), text(s.outcomeDef || "—")]));
        children.push(p([text("Code set. ", { bold: true }), text(s.outcomeCodes || "—")]));
        children.push(h2("Secondary outcomes"));
        secondary.length ? secondary.forEach((l) => children.push(bullet(l))) : children.push(para("(none specified)"));

        children.push(h1("6. Follow-up and censoring"));
        children.push(labelTable([
          ["Primary analysis", primAn],
          ["Grace period", (s.grace || "30") + " days"],
          ["Maximum follow-up", resolvedMaxFu],
        ]));
        children.push(h2("Censoring rules"));
        censoring.length ? censoring.forEach((l) => children.push(bullet(l))) : children.push(para("(none specified)"));

        children.push(h1("7. Confounding control"));
        children.push(labelTable([
          ["Method", psM],
          ["Covariate look-back", (s.lookback || "365") + " days prior to index date"],
        ]));
        children.push(h2("Baseline covariates"));
        covariates.length ? covariates.forEach((l) => children.push(bullet(l))) : children.push(para("(none specified)"));
        children.push(para("PS model performance is assessed via standardised mean differences (SMDs) before/after weighting/matching (target < 0.1 across all covariates) and the c-statistic of the PS model."));

        children.push(h1("8. Statistical analysis"));
        children.push(labelTable([
          ["Effect estimate", eff],
          ["Meta-analysis", meta],
        ]));
        children.push(h2("Subgroup analyses"));
        subgroups.length ? subgroups.forEach((l) => children.push(bullet(l))) : children.push(para("(none specified)"));
        children.push(h2("Sensitivity analyses"));
        sensitivity.length ? sensitivity.forEach((l) => children.push(bullet(l))) : children.push(para("(none specified)"));

        children.push(h1("9. Sample size and power"));
        children.push(para("To be calculated per site using observed event rates among comparator users in pilot extractions; aim for ≥80% power to detect the smallest clinically meaningful effect for the primary outcome at α = 0.05, two-sided, after pooling. Pilot estimates are circulated before final analytic execution."));

        children.push(h1("10. Execution and timeline"));
        children.push(labelTable([
          ["Architecture", arch],
          ["CDM", s.cdm || "—"],
        ]));
        children.push(h2("Timeline milestones"));
        milestones.length ? milestones.forEach((l) => children.push(numItem(l))) : children.push(para("(none)"));

        children.push(h1("11. Ethics, data sharing, dissemination"));
        children.push(p([text("Ethics. ", { bold: true }), text(s.ethics || "Each participating site obtains local IRB / ethics approval before data extraction.")]));
        children.push(p([text("Dissemination. ", { bold: true }), text(s.dissemination || "Primary manuscript to a peer-reviewed pharmacoepidemiology journal; conference presentation at ICPE / ISPE Asian conference.")]));

        children.push(h1("12. Key references"));
        refs.length ? refs.forEach((l) => children.push(numItem(l))) : children.push(para("(none)"));

        // Footer-style line
        children.push(p([new D.TextRun({ text: "Drafted with the AsPEN protocol builder (" + today + ").", font: FONT, size: 18, italics: true, color: "808080" })], { spacing: { before: 400 } }));

        const doc = new D.Document({
          creator: "AsPEN protocol builder",
          title: s.title || "AsPEN ACNU protocol",
          styles: {
            default: { document: { run: { font: FONT, size: 22 } } },   // 11pt body
            paragraphStyles: [
              { id: "Heading1", name: "Heading 1", basedOn: "Normal", next: "Normal", quickFormat: true,
                run: { size: 28, bold: true, font: FONT },
                paragraph: { spacing: { before: 200, after: 80 }, outlineLevel: 0 } },
              { id: "Heading2", name: "Heading 2", basedOn: "Normal", next: "Normal", quickFormat: true,
                run: { size: 24, bold: true, font: FONT },
                paragraph: { spacing: { before: 160, after: 60 }, outlineLevel: 1 } },
            ],
          },
          numbering: {
            config: [{
              reference: "ordered",
              levels: [{
                level: 0, format: D.LevelFormat.DECIMAL, text: "%1.",
                alignment: D.AlignmentType.LEFT,
                style: { paragraph: { indent: { left: 720, hanging: 360 } } },
              }],
            }],
          },
          sections: [{
            properties: {
              page: {
                size: { width: 11906, height: 16838 },  // A4
                margin: { top: 1440, right: 1440, bottom: 1440, left: 1440 },
              },
            },
            children,
          }],
        });

        return await D.Packer.toBlob(doc);
      };

      // ── Phenotype library modal ─────────────────────
      const modal      = document.querySelector("[data-library-modal]");
      const modalTitle = document.querySelector("[data-library-title]");
      const modalList  = document.querySelector("[data-library-list]");
      const modalSearch= document.querySelector("[data-library-search]");
      let currentCategory = "indications";
      let currentTargets  = {}; // { name?, codes?, def?, validation? }

      const esc = (s) => String(s ?? "").replace(/[&<>"']/g, (c) => ({
        "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;",
      }[c]));

      const renderLibrary = (filter = "") => {
        const items = PHENOTYPES[currentCategory] || [];
        const f = filter.trim().toLowerCase();
        const filtered = f
          ? items.filter((it) =>
              (it.name || "").toLowerCase().includes(f) ||
              (it.codes || "").toLowerCase().includes(f) ||
              (it.notes || "").toLowerCase().includes(f) ||
              (it.definition || "").toLowerCase().includes(f) ||
              (it.validation || "").toLowerCase().includes(f))
          : items;
        if (filtered.length === 0) {
          modalList.innerHTML = '<p class="px-3 py-6 text-sm text-slate-500 italic text-center">No phenotype matches.</p>';
          return;
        }
        modalList.innerHTML = filtered.map((it, idx) => `
          <button type="button" data-phenotype-idx="${idx}"
                  class="block w-full text-left px-4 py-3 rounded-lg border border-transparent hover:border-brand-300 hover:bg-brand-50/40 transition">
            <p class="font-semibold text-slate-900 text-sm">${esc(it.name)}</p>
            <p class="mt-1 text-xs text-slate-700 font-mono leading-relaxed">${esc(it.codes || "")}</p>
            ${it.definition ? `<p class="mt-1 text-xs text-slate-600 leading-relaxed">${esc(it.definition)}</p>` : ""}
            ${it.validation ? `<p class="mt-1 text-[11px] text-slate-500 italic leading-relaxed">${esc(it.validation)}</p>` : ""}
            ${it.notes ? `<p class="mt-1 text-[11px] text-slate-500 leading-relaxed">${esc(it.notes)}</p>` : ""}
          </button>
        `).join("");
        // Click handler — fill targets + close
        modalList.querySelectorAll("[data-phenotype-idx]").forEach((btn) => {
          btn.addEventListener("click", () => {
            const it = filtered[parseInt(btn.dataset.phenotypeIdx, 10)];
            if (!it) return;
            const fill = (key, val) => {
              const fieldName = currentTargets[key];
              if (!fieldName || val === undefined) return;
              const el = form.querySelector(`[name="${fieldName}"]`);
              if (el) el.value = val;
            };
            fill("name",  it.name);
            fill("codes", it.codes);
            fill("def",   it.definition);
            // Also-fill: mirror the phenotype name into a PICO field
            if (currentTargets.alsoFill) {
              const el = form.querySelector(`[name="${currentTargets.alsoFill}"]`);
              if (el && it.name) el.value = it.name;
            }
            // Record citation for the References section
            if (it.validation) {
              pickedCitations[it.name] = it.validation;
              savePickedCitations();
            }
            closeLibrary();
            render();
          });
        });
      };

      const openLibrary = (category, targets) => {
        currentCategory = category;
        currentTargets  = targets;
        modalTitle.textContent = ({
          indications: "Pick an indication (cohort definition)",
          exposures:   "Pick a drug class (exposure or comparator)",
          outcomes:    "Pick an outcome — fills definition, codes & validation",
        })[category] || "Pick a phenotype";
        modalSearch.value = "";
        renderLibrary("");
        modal.classList.remove("hidden");
        setTimeout(() => modalSearch.focus(), 50);
      };
      const closeLibrary = () => modal.classList.add("hidden");

      // Bind library triggers (from form section headers)
      document.querySelectorAll("[data-open-library]").forEach((btn) => {
        btn.addEventListener("click", () => {
          openLibrary(btn.dataset.category, {
            name:     btn.dataset.targetName,
            codes:    btn.dataset.targetCodes,
            def:      btn.dataset.targetDef,
            alsoFill: btn.dataset.alsoFill,
          });
        });
      });
      document.querySelector("[data-library-close]")?.addEventListener("click", closeLibrary);
      modal.addEventListener("click", (e) => { if (e.target === modal) closeLibrary(); });
      document.addEventListener("keydown", (e) => { if (e.key === "Escape") closeLibrary(); });
      modalSearch.addEventListener("input", () => renderLibrary(modalSearch.value));

      // ── Auth gate (admin only) ──────────────────────
      fetch(`${WORKER_URL}/api/me`, { credentials: "include" })
        .then((r) => r.ok ? r.json() : null)
        .then((data) => {
          if (!data || !data.ok) return setState("signed-out");
          if (!data.member?.isAdmin) return setState("forbidden");
          setState("ready");
        })
        .catch(() => setState("signed-out"));
    })();
  </script>
</BaseLayout>
