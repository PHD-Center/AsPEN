---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import { WORKER_URL } from "../../data/site-config";
import eventsRaw from "../../data/events.json";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

type EventEntry = {
  date: string;
  endDate?: string;
  title: string;
  type?: string;
  location?: string;
  url?: string;
  description?: string;
};

// Build-time sort:
//   · Upcoming  (date >= today) — ascending by date (next event first)
//   · Past      (date <  today) — descending by date (most recent first)
// "Today" is computed at build time; since GH Actions rebuilds on every push
// and the calendar is mostly informational, build-time freshness is fine.
// The iCal feed (/events.ics) is also static so the same model applies.
const today = new Date();
today.setHours(0, 0, 0, 0);
const todayIso = today.toISOString().slice(0, 10);

const events = (eventsRaw as EventEntry[]).map((e) => ({ ...e }));

const upcoming = events
  .filter((e) => (e.endDate ?? e.date) >= todayIso)
  .sort((a, b) => a.date.localeCompare(b.date));

const past = events
  .filter((e) => (e.endDate ?? e.date) < todayIso)
  .sort((a, b) => b.date.localeCompare(a.date));

// Type chip colours — kept restrained so a long list doesn't look like a circus.
const TYPE_TONE: Record<string, string> = {
  conference: "bg-brand-100 text-brand-800 border-brand-200",
  deadline:   "bg-rose-100 text-rose-800 border-rose-200",
  webinar:    "bg-sky-100 text-sky-800 border-sky-200",
  training:   "bg-amber-100 text-amber-800 border-amber-200",
  other:      "bg-slate-100 text-slate-700 border-slate-200",
};
const TYPE_LABEL: Record<string, string> = {
  conference: "Conference",
  deadline:   "Deadline",
  webinar:    "Webinar",
  training:   "Training",
  other:      "Other",
};

// Date pretty-printer: "Aug 24, 2026" or "Aug 24–27, 2026" / "Aug 24, 2026 – Sep 2, 2026"
const fmtSingle = (iso: string): string => {
  const d = new Date(iso + "T00:00:00");
  return d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });
};
const fmtRange = (start: string, end?: string): string => {
  if (!end || end === start) return fmtSingle(start);
  const a = new Date(start + "T00:00:00");
  const b = new Date(end   + "T00:00:00");
  // Same month + year → "Aug 24–27, 2026"
  if (a.getFullYear() === b.getFullYear() && a.getMonth() === b.getMonth()) {
    const month = a.toLocaleDateString("en-US", { month: "short" });
    return `${month} ${a.getDate()}–${b.getDate()}, ${a.getFullYear()}`;
  }
  // Different month → "Aug 24 – Sep 2, 2026"
  if (a.getFullYear() === b.getFullYear()) {
    return `${a.toLocaleDateString("en-US", { month: "short", day: "numeric" })} – ${b.toLocaleDateString("en-US", { month: "short", day: "numeric" })}, ${a.getFullYear()}`;
  }
  // Different year → "Aug 24, 2026 – Jan 2, 2027"
  return `${fmtSingle(start)} – ${fmtSingle(end)}`;
};

// iCal feed lives at /events.ics (public — calendar clients don't carry auth).
// We render it absolute when possible so the "copy this URL" UI is unambiguous.
const SITE_BASE = "https://www.aspensig.asia";
const ICS_URL = `${SITE_BASE}/events.ics`;
---

<BaseLayout
  title="Events — AsPEN members"
  description="Upcoming ICPE, ISPE Asian, AsPEN webinars, and submission deadlines. Subscribe in Google Calendar / Outlook."
>
  <PageHeader
    eyebrow="Members → Events"
    title="AsPEN events"
    description="Conferences, teleconferences, training, and submission deadlines that matter to AsPEN members. Subscribe below to get them in your calendar."
  />

  <section class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-10 space-y-8">
    <a class="text-sm text-brand-700 hover:underline font-semibold" href={`${base}/members/`}>← Members area</a>

    <div data-state="loading" class="text-sm text-slate-600 italic">Checking your session…</div>

    <div data-state="signed-out" class="hidden border border-slate-200 rounded-lg p-6 bg-slate-50">
      <p class="text-sm text-slate-700">Sign in to see the AsPEN events calendar. <a class="text-brand-700 hover:underline font-semibold" href={`${base}/members/login`}>Sign in →</a></p>
    </div>

    <div data-state="ready" class="hidden space-y-8">

      <!-- ── Admin-only "+ Add event" form ───────────────────── -->
      <!-- Revealed by JS when /api/me reports isAdmin. Worker writes
           the new entry to events.json in the main repo; GH Actions
           rebuilds the site (~2 min) and the page below + /events.ics
           pick up the change. -->
      <details data-admin-only class="hidden border border-brand-200 bg-brand-50/40 rounded-lg">
        <summary class="cursor-pointer select-none px-4 py-3 text-sm font-semibold text-brand-700 hover:bg-brand-100/40 rounded-lg flex items-center gap-2">
          ＋ Add event
        </summary>
        <form data-add-event-form class="px-4 pb-4 pt-1 space-y-3 border-t border-brand-100">
          <p class="text-xs text-slate-600 leading-relaxed">
            Adds a new entry to <code class="font-mono text-[10px] bg-white border border-slate-200 rounded px-1 py-0.5">events.json</code>. GH Actions rebuilds the site within about 2 minutes; the event then appears below and in the .ics feed.
          </p>
          <div class="grid sm:grid-cols-2 gap-3">
            <label class="block">
              <span class="text-[11px] uppercase tracking-widest text-brand-700 font-semibold">Date *</span>
              <input type="date" name="date" required class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
            <label class="block">
              <span class="text-[11px] uppercase tracking-widest text-brand-700 font-semibold">End date (multi-day only)</span>
              <input type="date" name="endDate" class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
          </div>
          <label class="block">
            <span class="text-[11px] uppercase tracking-widest text-brand-700 font-semibold">Title *</span>
            <input type="text" name="title" required maxlength="300" placeholder="e.g. ICPE 2027 Annual Meeting" class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
          </label>
          <div class="grid sm:grid-cols-2 gap-3">
            <label class="block">
              <span class="text-[11px] uppercase tracking-widest text-brand-700 font-semibold">Type</span>
              <select name="type" class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500">
                <option value="conference">Conference</option>
                <option value="deadline">Deadline / submission</option>
                <option value="webinar">Webinar / teleconference</option>
                <option value="training">Training / workshop</option>
                <option value="other">Other</option>
              </select>
            </label>
            <label class="block">
              <span class="text-[11px] uppercase tracking-widest text-brand-700 font-semibold">Location</span>
              <input type="text" name="location" maxlength="300" placeholder="e.g. Tokyo, Japan / Zoom" class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
          </div>
          <label class="block">
            <span class="text-[11px] uppercase tracking-widest text-brand-700 font-semibold">URL</span>
            <input type="url" name="url" maxlength="500" placeholder="https://..." class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
          </label>
          <label class="block">
            <span class="text-[11px] uppercase tracking-widest text-brand-700 font-semibold">Description</span>
            <textarea name="description" rows="2" maxlength="2000" class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500"></textarea>
          </label>
          <div class="flex items-center gap-3">
            <button type="submit" class="bg-brand-700 hover:bg-brand-800 text-white font-semibold px-4 py-2 rounded text-sm transition">
              Save event
            </button>
            <p data-add-event-msg class="text-xs"></p>
          </div>
        </form>
      </details>

      <!-- ── Subscribe panel ─────────────────────────────────── -->
      <details class="border border-brand-200 bg-brand-50/40 rounded-lg">
        <summary class="cursor-pointer select-none px-4 py-3 text-sm font-semibold text-brand-700 hover:bg-brand-100/40 rounded-lg flex items-center gap-2">
          📥 Subscribe in Google Calendar / Outlook
        </summary>
        <div class="px-4 pb-4 pt-1 text-xs text-slate-700 leading-relaxed space-y-3 border-t border-brand-100">
          <p>
            Copy the subscription URL below and add it in your calendar app — events stay current as the AsPEN office updates them.
          </p>
          <div class="flex flex-wrap items-center gap-2">
            <input type="text" readonly value={ICS_URL} data-ics-url
                   class="flex-1 min-w-[260px] border border-slate-300 rounded px-3 py-2 text-xs font-mono bg-white" />
            <button type="button" data-copy-ics class="text-xs font-semibold bg-brand-700 hover:bg-brand-800 text-white px-3 py-2 rounded transition">
              Copy URL
            </button>
            <a href="/events.ics" class="text-xs font-semibold text-brand-700 hover:underline">Download .ics</a>
          </div>
          <ul class="list-disc list-inside text-[11px] text-slate-600 space-y-1 mt-2">
            <li><strong>Google Calendar:</strong> Other calendars → ＋ → From URL → paste.</li>
            <li><strong>Apple Calendar:</strong> File → New Calendar Subscription → paste.</li>
            <li><strong>Outlook:</strong> Add calendar → Subscribe from web → paste.</li>
          </ul>
          <p class="text-[11px] text-slate-500 mt-2">
            The feed refreshes on each site update (typically within minutes of a chair edit).
          </p>
        </div>
      </details>

      <!-- ── Upcoming events ─────────────────────────────────── -->
      <div>
        <h2 class="text-xs uppercase tracking-widest text-brand-600 font-semibold mb-3">
          Upcoming · <span class="tabular-nums">{upcoming.length}</span>
        </h2>
        {upcoming.length === 0 ? (
          <p class="text-sm text-slate-500 italic border border-slate-200 rounded-lg bg-slate-50 px-4 py-6">
            No upcoming events on the calendar yet. The AsPEN office will post ICPE / Asian conference / teleconference dates here.
          </p>
        ) : (
          <ul class="space-y-3 list-none pl-0">
            {upcoming.map((e) => {
              const tone = TYPE_TONE[e.type ?? "other"] ?? TYPE_TONE.other;
              const label = TYPE_LABEL[e.type ?? "other"] ?? "Other";
              return (
                <li class="border border-slate-200 rounded-lg p-4 bg-white hover:shadow-sm hover:border-brand-300 transition">
                  <div class="flex items-start justify-between gap-3 flex-wrap">
                    <div class="min-w-0 flex-1">
                      <div class="flex items-center gap-2 flex-wrap">
                        <span class={`text-[10px] uppercase tracking-widest font-bold border px-1.5 py-0.5 rounded ${tone}`}>{label}</span>
                        <p class="text-sm font-mono text-slate-700 tabular-nums">{fmtRange(e.date, e.endDate)}</p>
                      </div>
                      <h3 class="mt-1.5 text-base font-bold text-slate-900 leading-snug">
                        {e.url ? (
                          <a href={e.url} target="_blank" rel="noopener" class="hover:text-brand-700 hover:underline decoration-brand-400 underline-offset-2">{e.title}</a>
                        ) : e.title}
                      </h3>
                      {e.location && (<p class="mt-1 text-xs text-slate-600">📍 {e.location}</p>)}
                      {e.description && (<p class="mt-2 text-xs text-slate-700 leading-relaxed">{e.description}</p>)}
                    </div>
                  </div>
                </li>
              );
            })}
          </ul>
        )}
      </div>

      <!-- ── Past events ─────────────────────────────────────── -->
      {past.length > 0 && (
        <div>
          <h2 class="text-xs uppercase tracking-widest text-slate-500 font-semibold mb-3">
            Past · <span class="tabular-nums">{past.length}</span>
          </h2>
          <ul class="space-y-2 list-none pl-0">
            {past.slice(0, 10).map((e) => {
              const tone = TYPE_TONE[e.type ?? "other"] ?? TYPE_TONE.other;
              const label = TYPE_LABEL[e.type ?? "other"] ?? "Other";
              return (
                <li class="border border-slate-200 rounded p-3 bg-slate-50/50">
                  <div class="flex items-center gap-2 flex-wrap text-xs">
                    <span class={`text-[10px] uppercase tracking-widest font-bold border px-1.5 py-0.5 rounded ${tone} opacity-70`}>{label}</span>
                    <p class="font-mono text-slate-600 tabular-nums">{fmtRange(e.date, e.endDate)}</p>
                  </div>
                  <p class="mt-1 text-sm text-slate-700">
                    {e.url ? (
                      <a href={e.url} target="_blank" rel="noopener" class="hover:text-brand-700 hover:underline">{e.title}</a>
                    ) : e.title}
                    {e.location && (<span class="text-slate-500"> · {e.location}</span>)}
                  </p>
                </li>
              );
            })}
          </ul>
          {past.length > 10 && (
            <p class="mt-3 text-xs text-slate-500 italic">
              Showing the 10 most recent past events. Older events live in <code class="font-mono text-[10px] bg-slate-100 border border-slate-200 rounded px-1 py-0.5">events.json</code> on the repo.
            </p>
          )}
        </div>
      )}

    </div>
  </section>

  <script is:inline define:vars={{ WORKER_URL, BASE: base }}>
    (() => {
      const setState = (name) => {
        document.querySelectorAll("[data-state]").forEach((el) => {
          el.classList.toggle("hidden", el.dataset.state !== name);
        });
      };
      if (!WORKER_URL) return setState("signed-out");

      // Copy-to-clipboard for the iCal URL.
      document.querySelector("[data-copy-ics]")?.addEventListener("click", async () => {
        const input = document.querySelector("[data-ics-url]");
        const url = input?.value || "";
        try {
          await navigator.clipboard.writeText(url);
          const btn = document.querySelector("[data-copy-ics]");
          if (btn) {
            const orig = btn.textContent;
            btn.textContent = "Copied ✓";
            setTimeout(() => { btn.textContent = orig; }, 1500);
          }
        } catch {
          // Fallback: select the input so the user can ⌘C manually.
          input?.select?.();
        }
      });

      // ── + Add event form (admin only) ───────────────────────
      // Posts to /api/admin/events. Worker writes to events.json in the
      // main repo via MAIN_REPO_PAT; GH Actions then auto-rebuilds the
      // site and the new event shows up here + in /events.ics about
      // two minutes later.
      const addForm = document.querySelector("[data-add-event-form]");
      const addMsg  = document.querySelector("[data-add-event-msg]");
      addForm?.addEventListener("submit", async (e) => {
        e.preventDefault();
        const fd = new FormData(addForm);
        const payload = {
          date:        String(fd.get("date") || ""),
          endDate:     String(fd.get("endDate") || "") || undefined,
          title:       String(fd.get("title") || ""),
          type:        String(fd.get("type") || "other"),
          location:    String(fd.get("location") || "") || undefined,
          url:         String(fd.get("url") || "") || undefined,
          description: String(fd.get("description") || "") || undefined,
        };
        if (!payload.date || !payload.title) {
          if (addMsg) { addMsg.textContent = "Date and title are required."; addMsg.className = "text-xs text-rose-700"; }
          return;
        }
        const btn = addForm.querySelector("button[type='submit']");
        if (btn) btn.disabled = true;
        if (addMsg) { addMsg.textContent = "Saving…"; addMsg.className = "text-xs text-slate-500 italic"; }
        try {
          const r = await fetch(`${WORKER_URL}/api/admin/events`, {
            method: "POST", credentials: "include",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ action: "create", payload }),
          });
          const d = await r.json().catch(() => ({}));
          if (r.ok && d.ok) {
            if (addMsg) { addMsg.textContent = d.message || "Saved. Site rebuild ~2 minutes."; addMsg.className = "text-xs text-brand-700"; }
            addForm.reset();
          } else {
            if (addMsg) { addMsg.textContent = (d.error || "Couldn't save event.") + " (HTTP " + r.status + ")"; addMsg.className = "text-xs text-rose-700"; }
          }
        } catch (err) {
          if (addMsg) { addMsg.textContent = "Network error: " + String((err && err.message) || err); addMsg.className = "text-xs text-rose-700"; }
        } finally {
          if (btn) btn.disabled = false;
        }
      });

      // Auth gate — any signed-in member can view. Admins also get the
      // "+ Add event" details revealed.
      fetch(`${WORKER_URL}/api/me`, { credentials: "include" })
        .then((r) => r.ok ? r.json() : null)
        .then((data) => {
          if (!data || !data.ok) return setState("signed-out");
          if (data.member?.isAdmin) {
            document.querySelector("[data-admin-only]")?.classList.remove("hidden");
          }
          setState("ready");
        })
        .catch(() => setState("signed-out"));
    })();
  </script>
</BaseLayout>
