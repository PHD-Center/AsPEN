---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import { WORKER_URL } from "../../data/site-config";
import pubsRaw from "../../data/publications.json";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

type Pub = (typeof pubsRaw)[number];
const pubsForPicker = (pubsRaw as Pub[])
  .filter((p) => p.pmid)
  .sort((a, b) => b.year - a.year)
  .map((p) => ({ pmid: p.pmid!, label: `${p.year} · ${p.authors.split(",")[0].trim()} et al. — ${p.title.slice(0, 75)}${p.title.length > 75 ? "…" : ""}` }));
---

<BaseLayout
  title="Admin — AsPEN members"
  description="AsPEN office admin tools: review uploads, manage reading group, manage members."
>
  <PageHeader
    eyebrow="Members → Admin"
    title="Office admin"
    description="Review uploads, curate the reading group, and manage members."
  />

  <section class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-10 space-y-6">
    <p class="text-sm">
      <a class="text-brand-700 hover:underline font-semibold" href={`${base}/members/`}>← Members area</a>
    </p>

    <div data-state="loading" class="text-sm text-slate-600 italic">Loading…</div>

    <div data-state="signed-out" class="hidden border border-slate-200 rounded-lg p-6 bg-slate-50">
      <p class="text-sm text-slate-700">
        You're not signed in. <a class="text-brand-700 hover:underline font-semibold" href={`${base}/members/login`}>Sign in →</a>
      </p>
    </div>

    <div data-state="forbidden" class="hidden border border-rose-300 bg-rose-50 rounded-lg p-6">
      <p class="text-sm text-rose-800">
        Admin only.
      </p>
    </div>

    <div data-state="ready" class="hidden space-y-6">
      <!-- ── Tab switcher ────────────────────────────────────── -->
      <div role="tablist" class="flex gap-0.5 p-0.5 bg-slate-100 rounded-lg text-sm font-semibold">
        <button type="button" role="tab" data-tab="uploads" aria-selected="true"
                class="flex-1 px-3 py-2 rounded-md transition aria-selected:bg-white aria-selected:shadow-sm aria-selected:text-brand-700 text-slate-600 hover:text-slate-900">
          Review queue <span data-uploads-count class="hidden ml-1 bg-brand-700 text-white text-[10px] rounded-full px-1.5 py-0.5 tabular-nums"></span>
        </button>
        <button type="button" role="tab" data-tab="reading" aria-selected="false"
                class="flex-1 px-3 py-2 rounded-md transition aria-selected:bg-white aria-selected:shadow-sm aria-selected:text-brand-700 text-slate-600 hover:text-slate-900">
          Reading group
        </button>
        <button type="button" role="tab" data-tab="members" aria-selected="false"
                class="flex-1 px-3 py-2 rounded-md transition aria-selected:bg-white aria-selected:shadow-sm aria-selected:text-brand-700 text-slate-600 hover:text-slate-900">
          Members
        </button>
      </div>

      <!-- ── Pane: Pending uploads + delete requests ────────── -->
      <div data-pane="uploads" class="space-y-8">
        <!-- Delete requests first (usually faster to action) -->
        <div data-delete-requests-wrap class="hidden">
          <p class="text-xs uppercase tracking-widest text-rose-600 font-semibold mb-2">
            Delete requests · <span data-delete-requests-count>0</span>
          </p>
          <div data-delete-requests class="space-y-2"></div>
        </div>

        <!-- Then upload submissions -->
        <div>
          <p data-uploads-header class="hidden text-xs uppercase tracking-widest text-brand-600 font-semibold mb-2">
            Upload submissions
          </p>
          <div data-queue class="space-y-4"></div>
        </div>
      </div>

      <!-- ── Pane: Reading group ─────────────────────────────── -->
      <div data-pane="reading" class="hidden space-y-6">
        <!-- Orphan papers — PDFs in papers/ with no matching pick (= won't show on the magazine page) -->
        <div data-orphans-wrap class="hidden">
          <p class="text-xs uppercase tracking-widest text-rose-700 font-semibold mb-2">
            Orphan PDFs · <span data-orphans-count>0</span>
            <span class="ml-1 text-[10px] normal-case tracking-normal text-slate-500 font-normal">approved PDFs that don't have a matching reading-group pick yet — they're invisible to members until you add a pick.</span>
          </p>
          <div data-orphans class="space-y-2"></div>
        </div>

        <!-- Member-suggested papers -->
        <div data-suggestions-wrap class="hidden">
          <p class="text-xs uppercase tracking-widest text-brand-600 font-semibold mb-2">
            Member suggestions · <span data-suggestions-count>0</span>
          </p>
          <div data-suggestions class="space-y-2"></div>
        </div>

        <details data-pick-details class="border border-slate-200 rounded-lg bg-white">
          <summary class="cursor-pointer select-none px-4 py-3 text-sm font-semibold text-brand-700 hover:bg-brand-50/40 rounded-lg">
            ＋ Add a reading-group pick
          </summary>
          <form data-pick-form class="p-4 space-y-3 border-t border-slate-100">
            <label class="block">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Paper</span>
              <input type="text" data-paper-input
                     placeholder="Paste a PubMed URL, DOI, PMID, or type the title to search…"
                     class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
              <input type="hidden" name="pmid" required />
              <div data-paper-state class="mt-2 text-xs"></div>
            </label>
            <details class="text-xs">
              <summary class="cursor-pointer text-brand-700 font-semibold hover:underline select-none">Or browse {pubsForPicker.length} AsPEN publications…</summary>
              <select data-pub-browser class="mt-2 w-full border border-slate-300 rounded px-3 py-2 text-xs focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500">
                <option value="">Click to pick one from publications.json</option>
                {pubsForPicker.map((p) => <option value={p.pmid}>{p.label}</option>)}
              </select>
            </details>
            <label class="block">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Headline</span>
              <input type="text" name="headline" required maxlength="120" placeholder="A one-line take, e.g. 'Where AsPEN began'"
                     class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
            <label class="block">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Commentary</span>
              <textarea name="commentary" rows="4" maxlength="3000"
                        placeholder="Why this paper is worth reading. Plain text; line breaks preserved."
                        class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500"></textarea>
            </label>
            <button type="submit" class="inline-flex items-center gap-2 bg-brand-700 hover:bg-brand-800 text-white font-semibold px-4 py-2 rounded text-sm transition disabled:opacity-60">
              Pick this paper
            </button>
            <p data-pick-msg class="hidden text-sm bg-slate-50 border border-slate-200 rounded p-3" role="status" aria-live="polite"></p>
          </form>
        </details>

        <div data-reading-list class="space-y-3"></div>
      </div>

      <!-- ── Pane: Members ───────────────────────────────────── -->
      <div data-pane="members" class="hidden space-y-6">
        <details class="border border-slate-200 rounded-lg bg-white">
          <summary class="cursor-pointer select-none px-4 py-3 text-sm font-semibold text-brand-700 hover:bg-brand-50/40 rounded-lg">
            ＋ Add a member
          </summary>
          <form data-member-form class="p-4 grid sm:grid-cols-2 gap-3 border-t border-slate-100">
            <label class="block sm:col-span-2">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Email *</span>
              <input type="email" name="email" required class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
            <label class="block">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Name *</span>
              <input type="text" name="name" required class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
            <label class="block">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Affiliation</span>
              <input type="text" name="affiliation" class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
            <label class="block">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Country</span>
              <select name="country" class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500">
                <option value="">— select —</option>
                <option value="TW">Taiwan (TW)</option>
                <option value="KR">South Korea (KR)</option>
                <option value="JP">Japan (JP)</option>
                <option value="HK">Hong Kong (HK)</option>
                <option disabled>──────────</option>
                <option value="AU">Australia (AU)</option>
                <option value="CN">China (CN)</option>
                <option value="DE">Germany (DE)</option>
                <option value="FI">Finland (FI)</option>
                <option value="FR">France (FR)</option>
                <option value="GB">United Kingdom (GB)</option>
                <option value="ID">Indonesia (ID)</option>
                <option value="IN">India (IN)</option>
                <option value="IT">Italy (IT)</option>
                <option value="MO">Macau (MO)</option>
                <option value="MY">Malaysia (MY)</option>
                <option value="NL">Netherlands (NL)</option>
                <option value="PH">Philippines (PH)</option>
                <option value="SE">Sweden (SE)</option>
                <option value="SG">Singapore (SG)</option>
                <option value="TH">Thailand (TH)</option>
                <option value="US">United States (US)</option>
                <option value="VN">Vietnam (VN)</option>
                <option value="OTHER">Other</option>
              </select>
            </label>
            <label class="block">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Role</span>
              <select name="role" class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500">
                <option value="academic">Academic</option>
                <option value="industry">Industry</option>
                <option value="regulator">Regulator</option>
                <option value="clinician">Clinician</option>
                <option value="student">Student</option>
                <option value="other">Other</option>
              </select>
            </label>
            <label class="block">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Status</span>
              <select name="status" class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500">
                <option value="active" selected>active</option>
                <option value="removed">removed</option>
              </select>
            </label>
            <label class="flex items-center gap-2 sm:col-span-2 text-xs text-slate-700">
              <input type="checkbox" name="admin" class="rounded border-slate-400 text-brand-700 focus:ring-brand-500" />
              Admin (can review uploads, manage members, curate reading group)
            </label>
            <div class="sm:col-span-2">
              <button type="submit" class="inline-flex items-center gap-2 bg-brand-700 hover:bg-brand-800 text-white font-semibold px-4 py-2 rounded text-sm transition disabled:opacity-60">
                Add member
              </button>
              <p data-member-msg class="hidden mt-3 text-sm bg-slate-50 border border-slate-200 rounded p-3" role="status" aria-live="polite"></p>
            </div>
          </form>
        </details>

        <div data-member-list class="border border-slate-200 rounded-lg overflow-hidden bg-white">
          <div class="px-4 py-3 border-b border-slate-100 flex items-center justify-between">
            <p class="text-xs uppercase tracking-widest text-brand-600 font-semibold">All members · <span data-member-count>0</span></p>
          </div>
          <ul data-member-rows class="divide-y divide-slate-100"></ul>
        </div>
      </div>
    </div>
  </section>

  <script is:inline define:vars={{ WORKER_URL, BASE: base, pubsForPicker }}>
    (() => {
      const setState = (name) => {
        document.querySelectorAll("[data-state]").forEach((el) => {
          el.classList.toggle("hidden", el.dataset.state !== name);
        });
      };

      if (!WORKER_URL) {
        document.querySelector("[data-state='loading']").textContent = "Members area isn't enabled yet.";
        return;
      }

      const esc = (s) => String(s ?? "").replace(/[&<>"']/g, (c) => ({
        "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;",
      }[c]));
      const fmtDate = (iso) => { try { return new Date(iso).toLocaleString("en-US", { dateStyle: "medium", timeStyle: "short" }); } catch { return iso; } };
      const fmtSize = (n) => !n ? "" : n < 1024 ? n + " B" : n < 1024*1024 ? (n/1024).toFixed(1)+" KB" : (n/1024/1024).toFixed(1)+" MB";

      // Tab switching
      const tabs = Array.from(document.querySelectorAll("[data-tab]"));
      const panes = Array.from(document.querySelectorAll("[data-pane]"));
      const showTab = (name) => {
        tabs.forEach((t) => t.setAttribute("aria-selected", t.dataset.tab === name ? "true" : "false"));
        panes.forEach((p) => p.classList.toggle("hidden", p.dataset.pane !== name));
      };
      tabs.forEach((t) => t.addEventListener("click", () => showTab(t.dataset.tab)));

      // ── Pending uploads ──
      const queueRoot = document.querySelector("[data-queue]");
      const renderQueue = (items) => {
        if (items.length === 0) {
          queueRoot.innerHTML = '<p class="text-sm text-slate-500 italic text-center py-8 border border-slate-200 rounded-lg bg-white">No pending uploads.</p>';
        } else {
          queueRoot.innerHTML = items.map((it) => {
            const meta = it.meta || {};
            const files = it.files || [];
            const subfolderLabel = meta.subfolder ? ` / ${esc(meta.subfolder)}` : "";
            const pmidLabel = meta.category === "reading" && meta.pmid
              ? ` · PMID ${esc(meta.pmid)}`
              : "";
            const sugLabel = meta.category === "reading" && meta.suggestionId
              ? ` · suggestion`
              : "";
            const sugTitleLine = meta.category === "reading" && meta.suggestionId && meta.suggestionTitle
              ? `<p class="mt-1 text-xs text-slate-600 italic">For suggestion: "${esc(meta.suggestionTitle)}"</p>`
              : "";
            const renamePlaceholder = (meta.category === "reading" && meta.suggestionId)
              ? "Destination PMID (digits only)"
              : "Optional rename (single file only)";
            return `
              <article class="border border-slate-200 rounded-2xl bg-white shadow-sm p-5 space-y-3">
                <header class="flex items-start justify-between gap-3">
                  <div>
                    <p class="text-[10px] uppercase tracking-widest text-brand-700 font-bold">${esc(meta.category || "?")}${subfolderLabel}${pmidLabel}${sugLabel}</p>
                    ${sugTitleLine}
                    <p class="mt-1 text-sm font-semibold text-slate-900">${esc(meta.uploaderName || meta.uploader || "Unknown uploader")}</p>
                    <p class="text-xs text-slate-500">${esc(meta.uploader || "")} · ${esc(fmtDate(meta.uploadedAt))}</p>
                  </div>
                </header>
                ${meta.description ? `<p class="text-sm text-slate-700 leading-relaxed bg-slate-50 border border-slate-200 rounded p-3">${esc(meta.description)}</p>` : ""}
                <div class="text-xs space-y-1">
                  ${files.map((f) => `
                    <div class="flex items-center justify-between gap-2">
                      <a href="${esc(WORKER_URL)}/api/content/${esc(f.path)}" target="_blank" rel="noopener" class="text-brand-700 hover:underline truncate">${esc(f.path.split("/").pop())}</a>
                      <span class="text-slate-500 tabular-nums">${esc(fmtSize(f.size))}</span>
                    </div>
                  `).join("")}
                </div>
                <div class="flex items-center gap-2 pt-2 border-t border-slate-100">
                  <input type="text" data-rename placeholder="${esc(renamePlaceholder)}" class="flex-1 border border-slate-300 rounded px-3 py-1.5 text-xs focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
                  <button type="button" data-action="approve" data-id="${esc(it.id)}" class="bg-brand-700 hover:bg-brand-800 text-white text-xs font-semibold px-3 py-1.5 rounded transition">Approve</button>
                  <button type="button" data-action="reject" data-id="${esc(it.id)}" class="bg-white hover:bg-rose-50 border border-rose-300 text-rose-700 text-xs font-semibold px-3 py-1.5 rounded transition">Reject</button>
                </div>
                <p data-row-msg class="hidden text-xs"></p>
              </article>
            `;
          }).join("");
        }
      };

      let uploadsCount = 0;
      let deletesCount = 0;
      const updateBadge = () => {
        const badge = document.querySelector("[data-uploads-count]");
        const total = uploadsCount + deletesCount;
        if (total > 0) { badge.textContent = String(total); badge.classList.remove("hidden"); }
        else badge.classList.add("hidden");
      };

      const loadUploads = async () => {
        try {
          const r = await fetch(`${WORKER_URL}/api/pending`, { credentials: "include" });
          if (!r.ok) return;
          const data = await r.json();
          const items = (data && data.items) || [];
          renderQueue(items);
          document.querySelector("[data-uploads-header]")?.classList.toggle("hidden", items.length === 0);
          uploadsCount = items.length;
          updateBadge();
        } catch {}
      };

      // ── Delete requests ──
      const dreqWrap = document.querySelector("[data-delete-requests-wrap]");
      const dreqRoot = document.querySelector("[data-delete-requests]");
      const dreqCount = document.querySelector("[data-delete-requests-count]");

      const renderDeleteRequests = (reqs) => {
        const open = reqs.filter((r) => r.status === "open");
        dreqCount.textContent = open.length;
        if (open.length === 0) {
          dreqWrap.classList.add("hidden");
          return;
        }
        dreqWrap.classList.remove("hidden");
        dreqRoot.innerHTML = open.map((r) => `
          <article class="border border-rose-200 rounded-lg p-3 bg-rose-50/40">
            <p class="text-sm font-semibold text-slate-900 break-all">${esc(r.path)}</p>
            <p class="text-xs text-slate-500 mt-0.5">requested by ${esc(r.requestedByName || r.requestedBy)} · ${esc(fmtDate(r.requestedAt))}</p>
            <p class="text-sm text-slate-700 leading-relaxed mt-2 whitespace-pre-line bg-white border border-slate-200 rounded p-2">${esc(r.reason)}</p>
            <div class="mt-2 flex gap-2">
              <button type="button" data-dreq-approve data-path="${esc(r.path)}" data-requested-at="${esc(r.requestedAt)}" class="text-xs font-semibold bg-rose-600 hover:bg-rose-700 text-white px-3 py-1.5 rounded transition">Delete file</button>
              <button type="button" data-dreq-dismiss data-path="${esc(r.path)}" data-requested-at="${esc(r.requestedAt)}" class="text-xs font-semibold text-slate-500 hover:text-slate-700 hover:underline">Dismiss request</button>
            </div>
          </article>
        `).join("");
      };

      const loadDeleteRequests = async () => {
        try {
          const r = await fetch(`${WORKER_URL}/api/delete-requests`, { credentials: "include" });
          if (!r.ok) return;
          const data = await r.json();
          const reqs = (data && data.requests) || [];
          renderDeleteRequests(reqs);
          deletesCount = reqs.filter((r) => r.status === "open").length;
          updateBadge();
        } catch {}
      };

      dreqRoot?.addEventListener("click", async (e) => {
        const t = e.target;
        if (!(t instanceof HTMLElement)) return;
        const path = t.dataset.path;
        const requestedAt = t.dataset.requestedAt;
        if (!path || !requestedAt) return;
        let action;
        if (t.hasAttribute("data-dreq-approve")) {
          if (!confirm(`Permanently delete "${path}"?`)) return;
          action = "approve";
        } else if (t.hasAttribute("data-dreq-dismiss")) {
          if (!confirm("Dismiss this request? File stays as-is.")) return;
          action = "dismiss";
        } else return;
        t.disabled = true;
        const r = await fetch(`${WORKER_URL}/api/admin/delete-requests`, {
          method: "POST", credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ path, requestedAt, action }),
        });
        const d = await r.json().catch(() => ({}));
        if (r.ok && d.ok) {
          loadDeleteRequests();
        } else {
          alert(d.error || "Failed.");
          t.disabled = false;
        }
      });

      queueRoot.addEventListener("click", async (e) => {
        const t = e.target;
        if (!(t instanceof HTMLElement) || !t.dataset.action) return;
        const action = t.dataset.action;
        const id = t.dataset.id;
        const card = t.closest("article");
        const renameInput = card?.querySelector("[data-rename]");
        const rename = renameInput instanceof HTMLInputElement ? renameInput.value.trim() : "";
        const msgEl = card?.querySelector("[data-row-msg]");
        if (action === "reject" && !confirm("Reject and delete this submission?")) return;
        if (msgEl) { msgEl.textContent = action === "approve" ? "Approving…" : "Rejecting…"; msgEl.classList.remove("hidden"); }
        const r = await fetch(`${WORKER_URL}/api/review`, {
          method: "POST", credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ id, action, rename: rename || undefined }),
        });
        const data = await r.json().catch(() => ({}));
        if (r.ok && data.ok) {
          if (msgEl) msgEl.textContent = action === "approve" ? "Approved → " + (data.destinations || []).join(", ") : "Rejected.";
          setTimeout(loadUploads, 1200);
        } else if (msgEl) {
          msgEl.textContent = data.error || "Failed.";
          msgEl.classList.add("text-rose-700");
        }
      });

      // ── Reading group ──
      const readingRoot = document.querySelector("[data-reading-list]");
      const pubLabel = (pmid) => (pubsForPicker.find((p) => p.pmid === pmid) || {}).label || `PMID ${pmid}`;

      const renderReading = (picks) => {
        if (picks.length === 0) {
          readingRoot.innerHTML = '<p class="text-sm text-slate-500 italic text-center py-6 border border-slate-200 rounded-lg bg-white">No picks yet.</p>';
        } else {
          readingRoot.innerHTML = picks.map((p) => `
            <article class="border border-slate-200 rounded-lg bg-white p-4 flex items-start justify-between gap-3">
              <div class="min-w-0">
                <p class="font-semibold text-slate-900 text-sm">${esc(p.headline)}</p>
                <p class="text-xs text-slate-500 mt-0.5 truncate">${esc(pubLabel(p.pmid))}</p>
                <p class="text-[10px] text-slate-400 mt-0.5">Picked ${esc(fmtDate(p.pickedAt))} by ${esc(p.pickedBy || "")}</p>
              </div>
              <button type="button" data-remove-pmid="${esc(p.pmid)}" class="shrink-0 text-xs font-semibold text-slate-500 hover:text-rose-600 hover:underline">Remove</button>
            </article>
          `).join("");
        }
      };

      const loadReading = async () => {
        try {
          const r = await fetch(`${WORKER_URL}/api/reading`, { credentials: "include" });
          if (!r.ok) return;
          const data = await r.json();
          renderReading(data.picks || []);
        } catch {}
      };

      readingRoot.addEventListener("click", async (e) => {
        const t = e.target;
        if (!(t instanceof HTMLElement) || !t.dataset.removePmid) return;
        if (!confirm("Remove this pick from the reading group?")) return;
        const r = await fetch(`${WORKER_URL}/api/admin/reading`, {
          method: "POST", credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ action: "remove", pmid: t.dataset.removePmid }),
        });
        if (r.ok) loadReading();
      });

      // ── Orphan papers sub-section ──
      const orphansWrap  = document.querySelector("[data-orphans-wrap]");
      const orphansRoot  = document.querySelector("[data-orphans]");
      const orphansCount = document.querySelector("[data-orphans-count]");

      const renderOrphans = (items) => {
        orphansCount.textContent = String(items.length);
        if (items.length === 0) {
          orphansWrap.classList.add("hidden");
          return;
        }
        orphansWrap.classList.remove("hidden");
        orphansRoot.innerHTML = items.map((o) => `
          <article class="border border-rose-200 rounded-lg p-3 bg-rose-50/30">
            <p class="text-xs text-slate-500">
              <a href="https://pubmed.ncbi.nlm.nih.gov/${esc(o.pmid)}/" target="_blank" rel="noopener" class="text-brand-700 hover:underline font-semibold">PMID ${esc(o.pmid)}</a>
              · <span class="font-mono text-[10px]">${esc(o.path)}</span>
            </p>
            ${o.suggestedHeadline ? `<p class="text-sm font-semibold text-slate-900 mt-1">${esc(o.suggestedHeadline)}</p>` : ""}
            ${o.suggestedCommentary ? `<p class="text-sm text-slate-700 leading-relaxed mt-1 whitespace-pre-line">${esc(o.suggestedCommentary)}</p>` : ""}
            <div class="mt-2">
              <button type="button" data-orphan-pmid="${esc(o.pmid)}" data-headline="${esc(o.suggestedHeadline || "")}" data-commentary="${esc(o.suggestedCommentary || "")}"
                      class="text-xs font-semibold bg-brand-700 hover:bg-brand-800 text-white px-3 py-1.5 rounded transition">
                Create matching pick →
              </button>
            </div>
          </article>
        `).join("");
      };

      const loadOrphans = async () => {
        try {
          const r = await fetch(`${WORKER_URL}/api/admin/orphan-papers`, { credentials: "include" });
          if (!r.ok) return;
          const data = await r.json();
          renderOrphans(data.orphans || []);
        } catch {}
      };

      // Click "Create matching pick" — pre-fills the Add-pick form (same
      // flow as promoting a suggestion) so admin just confirms.
      orphansRoot?.addEventListener("click", (e) => {
        const t = e.target;
        if (!(t instanceof HTMLElement)) return;
        const pmid = t.dataset.orphanPmid;
        if (!pmid) return;
        const form = document.querySelector("[data-pick-form]");
        const details = document.querySelector("[data-pick-details]");
        if (form) {
          const paperEl       = form.querySelector('[data-paper-input]');
          const pmidEl        = form.querySelector('input[name="pmid"]');
          const headlineInput = form.querySelector('input[name="headline"]');
          const commentaryArea= form.querySelector('textarea[name="commentary"]');
          if (paperEl) { paperEl.value = pmid; paperEl.dispatchEvent(new Event("input", { bubbles: true })); }
          else if (pmidEl) pmidEl.value = pmid;
          if (headlineInput) headlineInput.value = t.dataset.headline || "";
          if (commentaryArea) commentaryArea.value = t.dataset.commentary || "";
          if (headlineInput && !headlineInput.value) headlineInput.focus();
        }
        if (details) details.open = true;
        details?.scrollIntoView({ behavior: "smooth", block: "start" });
      });

      // Suggestions sub-section
      const suggestionsWrap = document.querySelector("[data-suggestions-wrap]");
      const suggestionsRoot = document.querySelector("[data-suggestions]");
      const suggestionsCount = document.querySelector("[data-suggestions-count]");

      const renderSuggestions = (items) => {
        const open = items.filter((s) => s.status === "open");
        suggestionsCount.textContent = open.length;
        if (open.length === 0) {
          suggestionsWrap.classList.add("hidden");
          return;
        }
        suggestionsWrap.classList.remove("hidden");
        suggestionsRoot.innerHTML = open.map((s) => {
          const sid = s.id || s.pmid || "";
          const titleLine = s.title
            ? `<p class="text-sm font-semibold text-slate-900">${esc(s.title)}</p>`
            : "";
          const pmidLink = s.pmid
            ? `<a href="https://pubmed.ncbi.nlm.nih.gov/${esc(s.pmid)}/" target="_blank" rel="noopener" class="text-brand-700 hover:underline">PMID ${esc(s.pmid)}</a> · `
            : "";
          const searchLink = !s.pmid && s.title
            ? `<a href="https://pubmed.ncbi.nlm.nih.gov/?term=${encodeURIComponent(s.title)}" target="_blank" rel="noopener" class="text-brand-700 hover:underline">Look up on PubMed</a> · `
            : "";
          return `
            <article class="border border-slate-200 rounded-lg p-3 bg-white">
              ${titleLine}
              <p class="text-xs text-slate-500">${pmidLink}${searchLink}suggested by ${esc(s.suggestedByName || s.suggestedBy)} · ${esc(fmtDate(s.suggestedAt))}</p>
              <p class="text-sm text-slate-700 leading-relaxed mt-1 whitespace-pre-line">${esc(s.reason)}</p>
              <div class="mt-2 flex gap-2">
                <button type="button" data-promote-sid="${esc(sid)}" data-promote-pmid="${esc(s.pmid || "")}" data-title="${esc(s.title || "")}" data-reason="${esc(s.reason)}" class="text-xs font-semibold bg-brand-700 hover:bg-brand-800 text-white px-3 py-1.5 rounded transition">Use as a pick →</button>
                <button type="button" data-dismiss-sid="${esc(sid)}" class="text-xs font-semibold text-slate-500 hover:text-rose-600 hover:underline">Dismiss</button>
              </div>
            </article>
          `;
        }).join("");
      };

      const loadSuggestions = async () => {
        try {
          const r = await fetch(`${WORKER_URL}/api/reading/suggestions`, { credentials: "include" });
          if (!r.ok) return;
          const data = await r.json();
          renderSuggestions(data.suggestions || []);
        } catch {}
      };

      suggestionsRoot?.addEventListener("click", async (e) => {
        const t = e.target;
        if (!(t instanceof HTMLElement)) return;
        if (t.dataset.dismissSid) {
          if (!confirm("Dismiss this suggestion?")) return;
          await fetch(`${WORKER_URL}/api/admin/reading/promote-suggestion`, {
            method: "POST", credentials: "include",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ id: t.dataset.dismissSid, action: "dismiss" }),
          });
          loadSuggestions();
        } else if (t.dataset.promoteSid !== undefined) {
          // Pre-fill the pick form, scroll to it, open it
          const form = document.querySelector("[data-pick-form]");
          const details = document.querySelector("[data-pick-details]");
          if (form) {
            const paperEl       = form.querySelector('[data-paper-input]');
            const headlineInput = form.querySelector('input[name="headline"]');
            const commentaryArea = form.querySelector('textarea[name="commentary"]');
            // Pre-fill paper field with PMID if suggestion had one; otherwise
            // pre-fill with the suggestion's title so PubMed lookup fires.
            if (paperEl) {
              paperEl.value = t.dataset.promotePmid || t.dataset.title || "";
              paperEl.dispatchEvent(new Event("input", { bubbles: true }));
            }
            if (headlineInput && t.dataset.title) headlineInput.value = t.dataset.title;
            if (commentaryArea && t.dataset.reason) commentaryArea.value = t.dataset.reason;
            if (paperEl && !paperEl.value) paperEl.focus();
            else if (headlineInput) headlineInput.focus();
            form.dataset.promotingSid = t.dataset.promoteSid;
          }
          if (details) details.open = true;
          details?.scrollIntoView({ behavior: "smooth", block: "start" });
        }
      });

      const pickForm = document.querySelector("[data-pick-form]");

      // ── Smart Paper input ──────────────────────────────
      // Accept anything — PMID, DOI, PubMed URL, or title — and resolve
      // to a canonical PMID + display title/authors confirmation.
      const paperInput  = pickForm?.querySelector("[data-paper-input]");
      const pmidHidden  = pickForm?.querySelector('input[name="pmid"]');
      const paperState  = pickForm?.querySelector("[data-paper-state]");

      const setPaperState = (html, cls = "text-slate-500") => {
        if (!paperState) return;
        paperState.className = "mt-2 text-xs " + cls;
        paperState.innerHTML = html;
      };

      // Show a paper as the "selected" state
      const showSelectedPaper = (pmid, title, authors, journal, year) => {
        if (pmidHidden) pmidHidden.value = pmid;
        setPaperState(
          `<div class="bg-brand-50/60 border border-brand-200 rounded p-2">
             <p class="font-semibold text-brand-700">PMID ${pmid} · selected</p>
             ${title ? `<p class="mt-1 text-slate-800">${title.replace(/</g, "&lt;")}</p>` : ""}
             ${authors ? `<p class="mt-1 text-slate-600">${authors.replace(/</g, "&lt;")}</p>` : ""}
             ${journal || year ? `<p class="text-slate-500 italic">${(journal || "").replace(/</g, "&lt;")}${year ? ` · ${year}` : ""}</p>` : ""}
           </div>`,
          "mt-2 text-xs"
        );
      };

      const fetchSummary = async (pmid) => {
        try {
          const r = await fetch(`https://eutils.ncbi.nlm.nih.gov/entrez/eutils/esummary.fcgi?db=pubmed&id=${pmid}&retmode=json`);
          if (!r.ok) return null;
          const d = await r.json();
          const item = d?.result?.[pmid];
          if (!item) return null;
          return {
            title:   item.title || "",
            authors: (item.authors || []).slice(0, 3).map((a) => a.name).join(", ")
                     + ((item.authors || []).length > 3 ? ", et al." : ""),
            journal: item.fulljournalname || item.source || "",
            year:    String(item.pubdate || "").slice(0, 4),
          };
        } catch { return null; }
      };

      const searchByTerm = async (term) => {
        const url = `https://eutils.ncbi.nlm.nih.gov/entrez/eutils/esearch.fcgi?db=pubmed&term=${encodeURIComponent(term)}&retmode=json&retmax=5`;
        const r = await fetch(url);
        if (!r.ok) throw new Error("PubMed search failed");
        const d = await r.json();
        return d?.esearchresult?.idlist || [];
      };

      // Pure helper — extract a PMID from various input shapes.
      const parsePaperInput = (raw) => {
        const s = (raw || "").trim();
        if (!s) return { kind: "empty" };
        // PubMed URL: pubmed.ncbi.nlm.nih.gov/123456
        const urlM = s.match(/pubmed\.ncbi\.nlm\.nih\.gov\/(\d{6,9})/i);
        if (urlM) return { kind: "pmid", pmid: urlM[1] };
        // PMC URL — only use if it's of the form /articles/PMC\d+ — but we
        // need PMID, so fall through to title search if we see a PMCID
        // Bare PMID
        if (/^\d{6,9}$/.test(s)) return { kind: "pmid", pmid: s };
        // DOI
        const doiM = s.match(/10\.\d{4,9}\/\S+/);
        if (doiM) return { kind: "doi", doi: doiM[0] };
        // Anything else — treat as a title to search
        return { kind: "title", query: s };
      };

      const resolvePaper = async (raw) => {
        const parsed = parsePaperInput(raw);
        if (parsed.kind === "empty") {
          if (pmidHidden) pmidHidden.value = "";
          setPaperState("");
          return;
        }
        setPaperState("Looking up on PubMed…", "mt-2 text-xs text-slate-500 italic");
        try {
          let pmid = null;
          if (parsed.kind === "pmid") {
            pmid = parsed.pmid;
          } else if (parsed.kind === "doi") {
            const ids = await searchByTerm(`${parsed.doi}[doi]`);
            if (ids.length > 0) pmid = ids[0];
          } else if (parsed.kind === "title") {
            const ids = await searchByTerm(parsed.query);
            if (ids.length > 0) pmid = ids[0];
          }
          if (!pmid) {
            if (pmidHidden) pmidHidden.value = "";
            setPaperState("Couldn't find a PubMed match. Try pasting the PMID directly or a PubMed URL.", "mt-2 text-xs text-rose-700");
            return;
          }
          const meta = await fetchSummary(pmid);
          if (meta) {
            showSelectedPaper(pmid, meta.title, meta.authors, meta.journal, meta.year);
          } else {
            // Couldn't get metadata but PMID is good
            if (pmidHidden) pmidHidden.value = pmid;
            setPaperState(`PMID ${pmid} · selected (couldn't fetch title from PubMed)`, "mt-2 text-xs text-brand-700");
          }
        } catch (e) {
          if (pmidHidden) pmidHidden.value = "";
          setPaperState("PubMed lookup failed (network?). Try again or paste a PMID directly.", "mt-2 text-xs text-rose-700");
        }
      };

      // Debounced lookup as the chair types/pastes
      let resolveTimer = null;
      paperInput?.addEventListener("input", () => {
        if (resolveTimer) clearTimeout(resolveTimer);
        resolveTimer = setTimeout(() => resolvePaper(paperInput.value), 400);
      });

      // Browse-publications helper still works — picking fills the input
      // with the selected PMID and triggers resolution.
      const pubBrowser = pickForm?.querySelector("[data-pub-browser]");
      pubBrowser?.addEventListener("change", (e) => {
        const target = e.target;
        if (!(target instanceof HTMLSelectElement)) return;
        const pmid = target.value;
        if (!pmid) return;
        if (paperInput) paperInput.value = pmid;
        resolvePaper(pmid);
        target.value = "";
      });

      const pickMsg = pickForm?.querySelector("[data-pick-msg]");
      const setPickMsg = (msg, isError = false) => {
        if (!pickMsg) return;
        pickMsg.textContent = msg;
        pickMsg.classList.remove("hidden");
        pickMsg.classList.toggle("text-rose-700", isError);
      };
      pickForm?.addEventListener("submit", async (e) => {
        e.preventDefault();
        const data = new FormData(pickForm);
        const body = {
          action: "add",
          pmid: String(data.get("pmid") || ""),
          headline: String(data.get("headline") || ""),
          commentary: String(data.get("commentary") || ""),
        };
        const btn = pickForm.querySelector("button[type='submit']");
        btn.disabled = true;
        setPickMsg("Saving…");
        const r = await fetch(`${WORKER_URL}/api/admin/reading`, {
          method: "POST", credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(body),
        });
        const d = await r.json().catch(() => ({}));
        if (r.ok && d.ok) {
          setPickMsg("Added.");
          // If this pick was promoted from a suggestion, mark the suggestion
          // as promoted and record the resolved pmid so attached PDFs route
          // to the right destination.
          const promotingSid = pickForm.dataset.promotingSid;
          if (promotingSid) {
            await fetch(`${WORKER_URL}/api/admin/reading/promote-suggestion`, {
              method: "POST", credentials: "include",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ id: promotingSid, action: "promote", resolvedPmid: body.pmid }),
            });
            delete pickForm.dataset.promotingSid;
            loadSuggestions();
          }
          pickForm.reset();
          if (paperInput) paperInput.value = "";
          if (paperState) paperState.innerHTML = "";
          loadReading();
          loadOrphans();
        } else {
          setPickMsg(d.error || "Failed.", true);
        }
        btn.disabled = false;
      });

      // ── Members ──
      const memberRows = document.querySelector("[data-member-rows]");
      const renderMembers = (members) => {
        document.querySelector("[data-member-count]").textContent = members.length;
        memberRows.innerHTML = members.map((m) => {
          // Badges: SUPER ADMIN (= super admin, enforced server-side, can't
          // be modified) takes precedence over ADMIN (= can review uploads,
          // manage members, etc.).
          const badge = m.superAdmin
            ? ' <span class="ml-1 text-[9px] uppercase tracking-widest font-bold text-white bg-brand-700 border border-brand-700 rounded px-1.5 py-0.5 align-middle">super admin</span>'
            : m.admin
              ? ' <span class="ml-1 text-[9px] uppercase tracking-widest font-bold text-brand-700 align-middle">admin</span>'
              : "";
          // Controls for super-admin rows stay disabled (so nobody can
          // accidentally demote them in the UI) — just no visible label.
          const sa = m.superAdmin ? " disabled title=\"Cannot be modified\"" : "";
          return `
            <li class="px-4 py-3 flex items-center justify-between gap-3 hover:bg-slate-50">
              <div class="min-w-0">
                <p class="text-sm font-semibold text-slate-900 truncate">${esc(m.name || m.email)}${badge}</p>
                <p class="text-xs text-slate-600 truncate">${esc(m.email)}${m.affiliation ? " · " + esc(m.affiliation) : ""}${m.country ? " · " + esc(m.country) : ""}</p>
              </div>
              <div class="flex items-center gap-3 shrink-0">
                <label class="inline-flex items-center gap-1 text-xs text-slate-600 cursor-pointer ${m.superAdmin ? "opacity-50 cursor-not-allowed" : ""}">
                  <input type="checkbox" data-admin-email="${esc(m.email)}"${m.admin ? " checked" : ""}${sa}
                         class="rounded border-slate-400 text-brand-700 focus:ring-brand-500" />
                  admin
                </label>
                <select data-status-pmid="${esc(m.email)}"${sa}
                        class="text-xs border border-slate-300 rounded px-2 py-1 focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500 ${m.superAdmin ? "opacity-50" : ""}">
                  <option value="active"  ${m.status === "active"  ? "selected" : ""}>active</option>
                  <option value="removed" ${m.status === "removed" ? "selected" : ""}>removed</option>
                  ${m.status === "invited" ? '<option value="invited" selected>invited (legacy)</option>' : ""}
                </select>
                ${m.hasPassword ? '<span class="text-[10px] text-slate-500 italic" title="Has set a password">pwd</span>' : ""}
              </div>
            </li>
          `;
        }).join("");
      };

      const loadMembers = async () => {
        try {
          const r = await fetch(`${WORKER_URL}/api/admin/members`, { credentials: "include" });
          if (!r.ok) return;
          const data = await r.json();
          renderMembers(data.members || []);
        } catch {}
      };

      memberRows.addEventListener("change", async (e) => {
        const t = e.target;
        if (!(t instanceof HTMLElement)) return;
        let body = null;
        if (t instanceof HTMLSelectElement && t.dataset.statusPmid) {
          body = { email: t.dataset.statusPmid, status: t.value };
        } else if (t instanceof HTMLInputElement && t.dataset.adminEmail) {
          body = { email: t.dataset.adminEmail, admin: t.checked };
        }
        if (!body) return;
        const r = await fetch(`${WORKER_URL}/api/admin/members`, {
          method: "POST", credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(body),
        });
        if (!r.ok) {
          const d = await r.json().catch(() => ({}));
          alert(d.error || "Couldn't update.");
          loadMembers(); // revert UI
        }
      });

      const memberForm = document.querySelector("[data-member-form]");
      const memberMsg = memberForm?.querySelector("[data-member-msg]");
      const setMemberMsg = (msg, isError = false) => {
        if (!memberMsg) return;
        memberMsg.textContent = msg;
        memberMsg.classList.remove("hidden");
        memberMsg.classList.toggle("text-rose-700", isError);
      };
      memberForm?.addEventListener("submit", async (e) => {
        e.preventDefault();
        const data = new FormData(memberForm);
        const body = {
          email: String(data.get("email") || ""),
          name: String(data.get("name") || ""),
          affiliation: String(data.get("affiliation") || ""),
          country: String(data.get("country") || "").toUpperCase(),
          role: String(data.get("role") || ""),
          status: String(data.get("status") || "active"),
          admin: data.get("admin") === "on",
        };
        const btn = memberForm.querySelector("button[type='submit']");
        btn.disabled = true;
        setMemberMsg("Saving…");
        const r = await fetch(`${WORKER_URL}/api/admin/members`, {
          method: "POST", credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(body),
        });
        const d = await r.json().catch(() => ({}));
        if (r.ok && d.ok) {
          setMemberMsg("Added.");
          memberForm.reset();
          loadMembers();
        } else {
          setMemberMsg(d.error || "Failed.", true);
        }
        btn.disabled = false;
      });

      // ── Boot ──
      (async () => {
        try {
          const meR = await fetch(`${WORKER_URL}/api/me`, { credentials: "include" });
          if (!meR.ok) return setState("signed-out");
          const me = await meR.json();
          if (!me?.member?.isAdmin) return setState("forbidden");
          setState("ready");
          loadUploads();
          loadDeleteRequests();
          loadReading();
          loadOrphans();
          loadSuggestions();
          loadMembers();
        } catch { setState("signed-out"); }
      })();
    })();
  </script>
</BaseLayout>
