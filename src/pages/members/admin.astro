---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import { WORKER_URL } from "../../data/site-config";
import databasesRaw from "../../data/databases.json";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// Site catalogue for the Studies admin tab (mirrors templates + studies page).
const shortDbName = (full: string): string => {
  const m = full.match(/\(([^)]+)\)$/);
  return m ? m[1] : full;
};
const COUNTRY_ORDER = ["TW", "KR", "JP", "HK", "AU", "FI", "GB", "NL", "US"];
type DbRow = typeof databasesRaw[number] & { hidden?: boolean; features?: string[] };
const SITES_DB = (databasesRaw as DbRow[])
  .filter((d) => !d.hidden && COUNTRY_ORDER.includes(d.code))
  .map((d) => ({
    id:      `${d.code}-${shortDbName(d.name).replace(/[^A-Za-z0-9]/g, "")}`,
    country: d.country,
    code:    d.code,
    short:   shortDbName(d.name),
  }))
  .sort((a, b) => {
    const ai = COUNTRY_ORDER.indexOf(a.code);
    const bi = COUNTRY_ORDER.indexOf(b.code);
    if (ai !== bi) return ai - bi;
    return a.short.localeCompare(b.short);
  });
const SITES_LABEL_MAP: Record<string, { country: string; code: string; short: string }> =
  Object.fromEntries(SITES_DB.map((d) => [d.id, d]));
const SITES_BY_COUNTRY: Record<string, typeof SITES_DB> = SITES_DB.reduce((acc, d) => {
  (acc[d.country] ??= []).push(d);
  return acc;
}, {} as Record<string, typeof SITES_DB>);

const STAGES = [
  { id: "concept",    label: "Concept" },
  { id: "protocol",   label: "Protocol" },
  { id: "site-irb",   label: "Site IRB" },
  { id: "extraction", label: "Extraction" },
  { id: "analysis",   label: "Analysis" },
  { id: "drafting",   label: "Drafting" },
  { id: "published",  label: "Published" },
];
---

<BaseLayout
  title="Admin · AsPEN members"
  description="AsPEN office admin tools: review uploads, manage active studies, manage members."
>
  <PageHeader
    eyebrow="Members → Admin"
    title="Office admin"
    description="Review uploads, curate the active-studies tracker, and manage members."
  />

  <section class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-10 space-y-6">
    <p class="text-sm">
      <a class="text-brand-700 hover:underline font-semibold" href={`${base}/members/`}>← Members area</a>
    </p>

    <div data-state="loading" class="text-sm text-slate-600 italic">Loading…</div>

    <div data-state="signed-out" class="hidden border border-slate-200 rounded-lg p-6 bg-slate-50">
      <p class="text-sm text-slate-700">
        You're not signed in. <a class="text-brand-700 hover:underline font-semibold" href={`${base}/members/login`}>Sign in →</a>
      </p>
    </div>

    <div data-state="forbidden" class="hidden border border-rose-300 bg-rose-50 rounded-lg p-6">
      <p class="text-sm text-rose-800">
        Admin only.
      </p>
    </div>

    <div data-state="ready" class="hidden space-y-6">
      <!-- ── Tab switcher ────────────────────────────────────── -->
      <div role="tablist" class="flex gap-0.5 p-0.5 bg-slate-100 rounded-lg text-sm font-semibold">
        <button type="button" role="tab" data-tab="uploads" aria-selected="true"
                class="flex-1 px-3 py-2 rounded-md transition aria-selected:bg-white aria-selected:shadow-sm aria-selected:text-brand-700 text-slate-600 hover:text-slate-900">
          Review queue <span data-uploads-count class="hidden ml-1 bg-brand-700 text-white text-[10px] rounded-full px-1.5 py-0.5 tabular-nums"></span>
        </button>
        <button type="button" role="tab" data-tab="studies" aria-selected="false" data-superadmin-only
                class="hidden flex-1 px-3 py-2 rounded-md transition aria-selected:bg-white aria-selected:shadow-sm aria-selected:text-brand-700 text-slate-600 hover:text-slate-900">
          Studies <span data-studies-count class="hidden ml-1 bg-brand-700 text-white text-[10px] rounded-full px-1.5 py-0.5 tabular-nums"></span>
        </button>
        <button type="button" role="tab" data-tab="members" aria-selected="false"
                class="flex-1 px-3 py-2 rounded-md transition aria-selected:bg-white aria-selected:shadow-sm aria-selected:text-brand-700 text-slate-600 hover:text-slate-900">
          Members
        </button>
      </div>

      <!-- ── Pane: Pending uploads + delete requests ────────── -->
      <div data-pane="uploads" class="space-y-8">
        <!-- Delete requests first (usually faster to action) -->
        <div data-delete-requests-wrap class="hidden">
          <p class="text-xs uppercase tracking-widest text-rose-600 font-semibold mb-2">
            Delete requests · <span data-delete-requests-count>0</span>
          </p>
          <div data-delete-requests class="space-y-2"></div>
        </div>

        <!-- Then upload submissions -->
        <div>
          <p data-uploads-header class="hidden text-xs uppercase tracking-widest text-brand-600 font-semibold mb-2">
            Upload submissions
          </p>
          <div data-queue class="space-y-4"></div>
        </div>
      </div>

      <!-- ── Pane: Studies (Active Studies Tracker) ──────────── -->
      <div data-pane="studies" class="hidden space-y-6">
        <p class="text-xs text-slate-500 leading-relaxed bg-slate-50 border border-slate-200 rounded p-3">
          <strong class="text-slate-700">Studies are created via the protocol-template builders.</strong>
          Open <a href={`${base}/members/templates/`} class="text-brand-700 hover:underline font-semibold">a template</a> → fill in → click <strong>📤 Send to AsPEN office</strong>.
          Admins land studies directly on the Kanban; member submissions show up as proposals below for promotion.
        </p>

        <!-- Member-proposed studies -->
        <div data-proposals-wrap class="hidden">
          <p class="text-xs uppercase tracking-widest text-brand-600 font-semibold mb-2">
            Member proposals · <span data-proposals-count>0</span>
            <span class="ml-1 text-[10px] normal-case tracking-normal text-slate-500 font-normal">studies proposed by members; Promote pre-fills the edit form below.</span>
          </p>
          <div data-proposals class="space-y-2"></div>
        </div>

        <!-- Edit form: only shown when Edit or Promote opens it. -->
        <details data-study-details class="hidden border border-slate-200 rounded-lg bg-white" open>
          <summary class="cursor-pointer select-none px-4 py-3 text-sm font-semibold text-brand-700 hover:bg-brand-50/40 rounded-lg">
            ✎ Edit study
          </summary>
          <form data-study-form class="p-4 space-y-3 border-t border-slate-100">
            <input type="hidden" name="editingSlug" />
            <label class="block">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Title *</span>
              <input type="text" name="title" required maxlength="300"
                     placeholder="e.g. SGLT2 inhibitors vs DPP-4 and MACE; an AsPEN multi-country ACNU study"
                     class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
            <div class="grid sm:grid-cols-3 gap-3">
              <label class="block">
                <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Design</span>
                <select name="design" class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500">
                  <option value="ACNU">ACNU</option>
                  <option value="SCCS">SCCS</option>
                  <option value="CCO">Case-crossover</option>
                  <option value="DA">Descriptive</option>
                  <option value="Other" selected>Other</option>
                </select>
              </label>
              <label class="block">
                <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Stage</span>
                <select name="stage" class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500">
                  {STAGES.map((s) => (<option value={s.id}>{s.label}</option>))}
                </select>
              </label>
              <label class="block">
                <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Slug (auto)</span>
                <input type="text" name="slug" maxlength="80" placeholder="e.g. sglt2-mace-acnu-2026"
                       class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
              </label>
            </div>
            <div class="grid sm:grid-cols-2 gap-3">
              <label class="block">
                <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Lead; name</span>
                <input type="text" name="leadName" maxlength="120" class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
              </label>
              <label class="block">
                <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Lead; email</span>
                <input type="email" name="leadEmail" maxlength="200" class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
              </label>
            </div>
            <label class="block">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Description</span>
              <textarea name="description" rows="3" maxlength="3000"
                        placeholder="A few sentences for members. Plain text; line breaks preserved."
                        class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500"></textarea>
            </label>
            <div class="grid sm:grid-cols-2 gap-3">
              <label class="block">
                <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Sites confirmed (Ctrl/Cmd-click for multi)</span>
                <select name="sites" multiple size="6" class="mt-1 w-full border border-slate-300 rounded px-2 py-1 text-xs focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500">
                  {Object.entries(SITES_BY_COUNTRY).map(([country, dbs]) => (
                    <optgroup label={country}>
                      {dbs.map((d) => (<option value={d.id}>{d.short}</option>))}
                    </optgroup>
                  ))}
                </select>
              </label>
              <label class="block">
                <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Sites wanted (recruiting)</span>
                <select name="sitesWanted" multiple size="6" class="mt-1 w-full border border-slate-300 rounded px-2 py-1 text-xs focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500">
                  {Object.entries(SITES_BY_COUNTRY).map(([country, dbs]) => (
                    <optgroup label={country}>
                      {dbs.map((d) => (<option value={d.id}>{d.short}</option>))}
                    </optgroup>
                  ))}
                </select>
              </label>
            </div>
            <label class="block">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Milestones (one per line; YYYY-MM-DD: note)</span>
              <textarea name="milestones" rows="3" placeholder="2026-03-15: Protocol v0.3 circulated for site comment&#10;2026-05-01: First site IRB submission (TW)"
                        class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-xs focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500 font-mono"></textarea>
            </label>
            <div class="grid sm:grid-cols-2 gap-3">
              <label class="block">
                <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Protocol PDF path (optional)</span>
                <input type="text" name="protocolUrl" maxlength="300" placeholder="papers/sglt2-mace-protocol-v0.3.pdf"
                       class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-xs focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500 font-mono" />
              </label>
              <label class="block">
                <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Published PMID (optional)</span>
                <input type="text" data-paper-input placeholder="Paste PMID, DOI, PubMed URL or title…"
                       class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
                <input type="hidden" name="pmid" />
                <div data-paper-state class="mt-2 text-xs"></div>
              </label>
            </div>
            <div class="flex flex-wrap gap-2 items-center">
              <button type="submit" class="inline-flex items-center gap-2 bg-brand-700 hover:bg-brand-800 text-white font-semibold px-4 py-2 rounded text-sm transition disabled:opacity-60">
                <span data-submit-label>Create study</span>
              </button>
              <button type="button" data-study-cancel-edit class="hidden text-xs text-slate-500 hover:text-rose-600 hover:underline font-semibold">Cancel edit</button>
              <p data-study-msg class="basis-full text-xs hidden bg-slate-50 border border-slate-200 rounded p-2" role="status" aria-live="polite"></p>
            </div>
          </form>
        </details>

        <div data-study-list class="space-y-3"></div>
      </div>

      <!-- ── Pane: Members ───────────────────────────────────── -->
      <div data-pane="members" class="hidden space-y-6">
        <details class="border border-slate-200 rounded-lg bg-white">
          <summary class="cursor-pointer select-none px-4 py-3 text-sm font-semibold text-brand-700 hover:bg-brand-50/40 rounded-lg">
            ＋ Add a member
          </summary>
          <form data-member-form class="p-4 grid sm:grid-cols-2 gap-3 border-t border-slate-100">
            <label class="block sm:col-span-2">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Email *</span>
              <input type="email" name="email" required class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
            <label class="block">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Name *</span>
              <input type="text" name="name" required class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
            <label class="block">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Affiliation</span>
              <input type="text" name="affiliation" class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
            </label>
            <label class="block">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Country</span>
              <select name="country" class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500">
                <option value="">- select -</option>
                <option value="TW">Taiwan (TW)</option>
                <option value="KR">South Korea (KR)</option>
                <option value="JP">Japan (JP)</option>
                <option value="HK">Hong Kong (HK)</option>
                <option disabled>──────────</option>
                <option value="AU">Australia (AU)</option>
                <option value="CN">China (CN)</option>
                <option value="DE">Germany (DE)</option>
                <option value="FI">Finland (FI)</option>
                <option value="FR">France (FR)</option>
                <option value="GB">United Kingdom (GB)</option>
                <option value="ID">Indonesia (ID)</option>
                <option value="IN">India (IN)</option>
                <option value="IT">Italy (IT)</option>
                <option value="MO">Macau (MO)</option>
                <option value="MY">Malaysia (MY)</option>
                <option value="NL">Netherlands (NL)</option>
                <option value="PH">Philippines (PH)</option>
                <option value="SE">Sweden (SE)</option>
                <option value="SG">Singapore (SG)</option>
                <option value="TH">Thailand (TH)</option>
                <option value="US">United States (US)</option>
                <option value="VN">Vietnam (VN)</option>
                <option value="OTHER">Other</option>
              </select>
            </label>
            <label class="block">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Role</span>
              <select name="role" class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500">
                <option value="academic">academic</option>
                <option value="industry">industry</option>
                <option value="regulator">regulator</option>
                <option value="clinician">clinician</option>
                <option value="student">student</option>
                <option value="other">other</option>
              </select>
            </label>
            <label class="block">
              <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Status</span>
              <select name="status" class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500">
                <option value="active" selected>active</option>
                <option value="removed">removed</option>
              </select>
            </label>
            <label class="flex items-center gap-2 sm:col-span-2 text-xs text-slate-700">
              <input type="checkbox" name="admin" class="rounded border-slate-400 text-brand-700 focus:ring-brand-500" />
              Admin (can review uploads, manage members, curate active studies)
            </label>
            <div class="sm:col-span-2">
              <button type="submit" class="inline-flex items-center gap-2 bg-brand-700 hover:bg-brand-800 text-white font-semibold px-4 py-2 rounded text-sm transition disabled:opacity-60">
                Add member
              </button>
              <p data-member-msg class="hidden mt-3 text-sm bg-slate-50 border border-slate-200 rounded p-3" role="status" aria-live="polite"></p>
            </div>
          </form>
        </details>

        <div data-member-list class="border border-slate-200 rounded-lg overflow-hidden bg-white">
          <div class="px-4 py-3 border-b border-slate-100 flex items-center justify-between">
            <p class="text-xs uppercase tracking-widest text-brand-600 font-semibold">All members · <span data-member-count>0</span></p>
          </div>
          <ul data-member-rows class="divide-y divide-slate-100"></ul>
        </div>
      </div>
    </div>
  </section>

  <script is:inline define:vars={{ WORKER_URL, BASE: base, SITES_LABEL_MAP, STAGES }}>
    (() => {
      const setState = (name) => {
        document.querySelectorAll("[data-state]").forEach((el) => {
          el.classList.toggle("hidden", el.dataset.state !== name);
        });
      };

      if (!WORKER_URL) {
        document.querySelector("[data-state='loading']").textContent = "Members area isn't enabled yet.";
        return;
      }

      const esc = (s) => String(s ?? "").replace(/[&<>"']/g, (c) => ({
        "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;",
      }[c]));
      const fmtDate = (iso) => { try { return new Date(iso).toLocaleString("en-US", { dateStyle: "medium", timeStyle: "short" }); } catch { return iso; } };
      const fmtSize = (n) => !n ? "" : n < 1024 ? n + " B" : n < 1024*1024 ? (n/1024).toFixed(1)+" KB" : (n/1024/1024).toFixed(1)+" MB";

      // Tab switching
      const tabs = Array.from(document.querySelectorAll("[data-tab]"));
      const panes = Array.from(document.querySelectorAll("[data-pane]"));
      const showTab = (name) => {
        tabs.forEach((t) => t.setAttribute("aria-selected", t.dataset.tab === name ? "true" : "false"));
        panes.forEach((p) => p.classList.toggle("hidden", p.dataset.pane !== name));
      };
      tabs.forEach((t) => t.addEventListener("click", () => showTab(t.dataset.tab)));

      // ── Pending uploads ──
      const queueRoot = document.querySelector("[data-queue]");
      const renderQueue = (items) => {
        if (items.length === 0) {
          queueRoot.innerHTML = '<p class="text-sm text-slate-500 italic text-center py-8 border border-slate-200 rounded-lg bg-white">No pending uploads.</p>';
        } else {
          queueRoot.innerHTML = items.map((it) => {
            const meta = it.meta || {};
            const files = it.files || [];
            const subfolderLabel = meta.subfolder ? ` / ${esc(meta.subfolder)}` : "";
            const renamePlaceholder = "Optional rename (single file only)";
            return `
              <article class="border border-slate-200 rounded-2xl bg-white shadow-sm p-5 space-y-3">
                <header class="flex items-start justify-between gap-3">
                  <div>
                    <p class="text-[10px] uppercase tracking-widest text-brand-700 font-bold">${esc(meta.category || "?")}${subfolderLabel}</p>
                    <p class="mt-1 text-sm font-semibold text-slate-900">${esc(meta.uploaderName || meta.uploader || "Unknown uploader")}</p>
                    <p class="text-xs text-slate-500">${esc(meta.uploader || "")} · ${esc(fmtDate(meta.uploadedAt))}</p>
                  </div>
                </header>
                ${meta.description ? `<p class="text-sm text-slate-700 leading-relaxed bg-slate-50 border border-slate-200 rounded p-3">${esc(meta.description)}</p>` : ""}
                <div class="text-xs space-y-1">
                  ${files.map((f) => `
                    <div class="flex items-center justify-between gap-2">
                      <a href="${esc(WORKER_URL)}/api/content/${esc(f.path)}" target="_blank" rel="noopener" class="text-brand-700 hover:underline truncate">${esc(f.path.split("/").pop())}</a>
                      <span class="text-slate-500 tabular-nums">${esc(fmtSize(f.size))}</span>
                    </div>
                  `).join("")}
                </div>
                <div class="flex items-center gap-2 pt-2 border-t border-slate-100">
                  <input type="text" data-rename placeholder="${esc(renamePlaceholder)}" class="flex-1 border border-slate-300 rounded px-3 py-1.5 text-xs focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
                  <button type="button" data-action="approve" data-id="${esc(it.id)}" class="bg-brand-700 hover:bg-brand-800 text-white text-xs font-semibold px-3 py-1.5 rounded transition">Approve</button>
                  <button type="button" data-action="reject" data-id="${esc(it.id)}" class="bg-white hover:bg-rose-50 border border-rose-300 text-rose-700 text-xs font-semibold px-3 py-1.5 rounded transition">Reject</button>
                </div>
                <p data-row-msg class="hidden text-xs"></p>
              </article>
            `;
          }).join("");
        }
      };

      let uploadsCount = 0;
      let deletesCount = 0;
      const updateBadge = () => {
        const badge = document.querySelector("[data-uploads-count]");
        const total = uploadsCount + deletesCount;
        if (total > 0) { badge.textContent = String(total); badge.classList.remove("hidden"); }
        else badge.classList.add("hidden");
      };

      const loadUploads = async () => {
        try {
          const r = await fetch(`${WORKER_URL}/api/pending`, { credentials: "include" });
          if (!r.ok) return;
          const data = await r.json();
          const items = (data && data.items) || [];
          renderQueue(items);
          document.querySelector("[data-uploads-header]")?.classList.toggle("hidden", items.length === 0);
          uploadsCount = items.length;
          updateBadge();
        } catch {}
      };

      // ── Delete requests ──
      const dreqWrap = document.querySelector("[data-delete-requests-wrap]");
      const dreqRoot = document.querySelector("[data-delete-requests]");
      const dreqCount = document.querySelector("[data-delete-requests-count]");

      const renderDeleteRequests = (reqs) => {
        const open = reqs.filter((r) => r.status === "open");
        dreqCount.textContent = open.length;
        if (open.length === 0) {
          dreqWrap.classList.add("hidden");
          return;
        }
        dreqWrap.classList.remove("hidden");
        dreqRoot.innerHTML = open.map((r) => `
          <article class="border border-rose-200 rounded-lg p-3 bg-rose-50/40">
            <p class="text-sm font-semibold text-slate-900 break-all">${esc(r.path)}</p>
            <p class="text-xs text-slate-500 mt-0.5">requested by ${esc(r.requestedByName || r.requestedBy)} · ${esc(fmtDate(r.requestedAt))}</p>
            <p class="text-sm text-slate-700 leading-relaxed mt-2 whitespace-pre-line bg-white border border-slate-200 rounded p-2">${esc(r.reason)}</p>
            <div class="mt-2 flex gap-2">
              <button type="button" data-dreq-approve data-path="${esc(r.path)}" data-requested-at="${esc(r.requestedAt)}" class="text-xs font-semibold bg-rose-600 hover:bg-rose-700 text-white px-3 py-1.5 rounded transition">Delete file</button>
              <button type="button" data-dreq-dismiss data-path="${esc(r.path)}" data-requested-at="${esc(r.requestedAt)}" class="text-xs font-semibold text-slate-500 hover:text-slate-700 hover:underline">Dismiss request</button>
            </div>
          </article>
        `).join("");
      };

      const loadDeleteRequests = async () => {
        try {
          const r = await fetch(`${WORKER_URL}/api/delete-requests`, { credentials: "include" });
          if (!r.ok) return;
          const data = await r.json();
          const reqs = (data && data.requests) || [];
          renderDeleteRequests(reqs);
          deletesCount = reqs.filter((r) => r.status === "open").length;
          updateBadge();
        } catch {}
      };

      dreqRoot?.addEventListener("click", async (e) => {
        const t = e.target;
        if (!(t instanceof HTMLElement)) return;
        const path = t.dataset.path;
        const requestedAt = t.dataset.requestedAt;
        if (!path || !requestedAt) return;
        let action;
        if (t.hasAttribute("data-dreq-approve")) {
          if (!confirm(`Permanently delete "${path}"?`)) return;
          action = "approve";
        } else if (t.hasAttribute("data-dreq-dismiss")) {
          if (!confirm("Dismiss this request? File stays as-is.")) return;
          action = "dismiss";
        } else return;
        t.disabled = true;
        const r = await fetch(`${WORKER_URL}/api/admin/delete-requests`, {
          method: "POST", credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ path, requestedAt, action }),
        });
        const d = await r.json().catch(() => ({}));
        if (r.ok && d.ok) {
          loadDeleteRequests();
        } else {
          alert(d.error || "Failed.");
          t.disabled = false;
        }
      });

      queueRoot.addEventListener("click", async (e) => {
        const t = e.target;
        if (!(t instanceof HTMLElement) || !t.dataset.action) return;
        const action = t.dataset.action;
        const id = t.dataset.id;
        const card = t.closest("article");
        const renameInput = card?.querySelector("[data-rename]");
        const rename = renameInput instanceof HTMLInputElement ? renameInput.value.trim() : "";
        const msgEl = card?.querySelector("[data-row-msg]");
        if (action === "reject" && !confirm("Reject and delete this submission?")) return;
        if (msgEl) { msgEl.textContent = action === "approve" ? "Approving…" : "Rejecting…"; msgEl.classList.remove("hidden"); }
        const r = await fetch(`${WORKER_URL}/api/review`, {
          method: "POST", credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ id, action, rename: rename || undefined }),
        });
        const data = await r.json().catch(() => ({}));
        if (r.ok && data.ok) {
          if (msgEl) msgEl.textContent = action === "approve" ? "Approved → " + (data.destinations || []).join(", ") : "Rejected.";
          setTimeout(loadUploads, 1200);
        } else if (msgEl) {
          msgEl.textContent = data.error || "Failed.";
          msgEl.classList.add("text-rose-700");
        }
      });

      // ── Studies (Active Studies Tracker) ─────────────────
      const studyForm    = document.querySelector("[data-study-form]");
      const studyDetails = document.querySelector("[data-study-details]");
      const studyMsg     = document.querySelector("[data-study-msg]");
      const studyListEl  = document.querySelector("[data-study-list]");
      const submitLabel  = studyForm?.querySelector("[data-submit-label]");
      const cancelEdit   = document.querySelector("[data-study-cancel-edit]");

      const setStudyMsg = (msg, isError = false) => {
        if (!studyMsg) return;
        studyMsg.textContent = msg;
        studyMsg.classList.remove("hidden");
        studyMsg.classList.toggle("text-rose-700", isError);
        studyMsg.classList.toggle("text-brand-700", !isError);
      };

      const siteLabel = (id) => {
        const d = SITES_LABEL_MAP[id];
        return d ? d.short : id;
      };

      const stageLabel = (id) => (STAGES.find((s) => s.id === id) || { label: id }).label;

      const parseMilestones = (text) => {
        return (text || "").split(/\r?\n/).map((l) => l.trim()).filter(Boolean).map((l) => {
          const m = l.match(/^(\d{4}-\d{2}-\d{2})\s*[:|]\s*(.+)$/);
          if (m) return { date: m[1], note: m[2] };
          return { date: "", note: l };
        });
      };

      const milestonesToText = (arr) => {
        return (arr || []).map((m) => (m.date ? m.date + ": " : "") + m.note).join("\n");
      };

      const setMultiSelect = (selectEl, values) => {
        if (!selectEl) return;
        const set = new Set(values || []);
        for (const opt of selectEl.options) opt.selected = set.has(opt.value);
      };

      const getMultiSelect = (selectEl) => {
        if (!selectEl) return [];
        return Array.from(selectEl.selectedOptions).map((o) => o.value);
      };

      const resetForm = () => {
        if (!studyForm) return;
        studyForm.reset();
        studyForm.querySelector("[name='editingSlug']").value = "";
        studyForm.querySelector("[name='pmid']").value = "";
        const ps = studyForm.querySelector("[data-paper-state]");
        if (ps) ps.innerHTML = "";
        if (submitLabel) submitLabel.textContent = "Save changes";
        cancelEdit?.classList.add("hidden");
        setStudyMsg("");
        studyMsg?.classList.add("hidden");
      };

      // Show / hide the edit form details. Default state is hidden; it
      // only appears when Edit on a row or Promote on a proposal opens it.
      const showStudyForm = () => {
        if (!studyDetails) return;
        studyDetails.classList.remove("hidden");
        studyDetails.open = true;
        studyDetails.scrollIntoView({ behavior: "smooth", block: "start" });
      };
      const hideStudyForm = () => {
        if (!studyDetails) return;
        studyDetails.classList.add("hidden");
        studyDetails.open = false;
      };

      cancelEdit?.addEventListener("click", () => {
        delete studyForm.dataset.promotingProposalId;
        resetForm();
        hideStudyForm();
      });

      let studies = [];

      const renderStudies = () => {
        const badge = document.querySelector("[data-studies-count]");
        if (badge) {
          if (studies.length > 0) { badge.textContent = String(studies.length); badge.classList.remove("hidden"); }
          else badge.classList.add("hidden");
        }
        if (studies.length === 0) {
          studyListEl.innerHTML = '<p class="text-sm text-slate-500 italic text-center py-6 border border-slate-200 rounded-lg bg-white">No studies yet. Create one by sending a protocol from a <a class="text-brand-700 hover:underline font-semibold" href="' + BASE + '/members/templates/">template builder</a>.</p>';
          return;
        }
        studyListEl.innerHTML = studies.map((s) => {
          const confirmed = (s.sites || []).map((id) => `<span class="text-[10px] bg-brand-50 text-brand-700 border border-brand-100 px-1.5 py-0.5 rounded">${esc(siteLabel(id))}</span>`).join(" ");
          const wanted    = (s.sitesWanted || []).map((id) => `<span class="text-[10px] bg-slate-50 text-slate-500 border border-slate-200 px-1.5 py-0.5 rounded italic">want ${esc(siteLabel(id))}</span>`).join(" ");
          const interested = (s.interested || []).map((i) => `
            <li class="text-xs flex items-start gap-2 py-1.5 border-b border-slate-100 last:border-b-0">
              <div class="flex-1 min-w-0">
                <p class="font-semibold text-slate-800">${esc(i.name)} <span class="text-slate-400 font-normal">· ${esc(i.email)}</span></p>
                <p class="text-slate-600">Site: <strong>${esc(siteLabel(i.site))}</strong></p>
                ${i.note ? `<p class="text-slate-500 italic mt-0.5">${esc(i.note)}</p>` : ""}
              </div>
              <div class="flex items-center gap-1 shrink-0">
                <button type="button" data-interest-confirm data-slug="${esc(s.slug)}" data-email="${esc(i.email)}" data-site="${esc(i.site)}"
                        class="text-[10px] font-semibold bg-brand-700 hover:bg-brand-800 text-white px-2 py-1 rounded">Confirm</button>
                <button type="button" data-interest-reject data-slug="${esc(s.slug)}" data-email="${esc(i.email)}" data-site="${esc(i.site)}"
                        class="text-[10px] font-semibold text-slate-500 hover:text-rose-600 hover:underline">Reject</button>
              </div>
            </li>
          `).join("");
          const stageOptions = STAGES.map((st) => `<option value="${st.id}" ${st.id === s.stage ? "selected" : ""}>${esc(st.label)}</option>`).join("");
          return `
            <article class="border border-slate-200 rounded-lg bg-white" data-study-row data-slug="${esc(s.slug)}">
              <header class="px-4 py-3 flex items-start justify-between gap-3 border-b border-slate-100">
                <div class="min-w-0">
                  <p class="font-semibold text-slate-900 text-sm leading-snug">${esc(s.title)}</p>
                  <p class="text-xs text-slate-500 mt-0.5">${esc(s.design)} · Lead: ${esc(s.lead?.name || "-")} · ${(s.sites||[]).length} confirmed · ${(s.interested||[]).length} interested</p>
                </div>
                <div class="flex items-center gap-2 shrink-0">
                  <select data-stage-select data-slug="${esc(s.slug)}" class="text-xs border border-slate-300 rounded px-2 py-1 focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500">
                    ${stageOptions}
                  </select>
                </div>
              </header>
              <div class="px-4 py-3 space-y-2">
                <div class="flex flex-wrap gap-1">${confirmed}${confirmed && wanted ? " " : ""}${wanted}</div>
                ${s.description ? `<p class="text-xs text-slate-700 whitespace-pre-line">${esc(s.description)}</p>` : ""}
              </div>
              <div class="px-4 py-2 border-t border-slate-100 flex items-center gap-3">
                <button type="button" data-edit-slug="${esc(s.slug)}" class="text-xs font-semibold text-brand-700 hover:underline">Edit</button>
                <button type="button" data-delete-slug="${esc(s.slug)}" class="text-xs font-semibold text-slate-500 hover:text-rose-600 hover:underline">Delete</button>
                ${(s.interested||[]).length > 0
                  ? `<details class="ml-auto"><summary class="cursor-pointer text-xs font-semibold text-amber-700 hover:underline">Manage interest (${(s.interested||[]).length})</summary>
                       <ul class="mt-2 list-none pl-0">${interested}</ul></details>`
                  : ""}
              </div>
            </article>
          `;
        }).join("");
      };

      const loadStudies = async () => {
        try {
          const r = await fetch(`${WORKER_URL}/api/studies`, { credentials: "include" });
          if (!r.ok) return;
          const data = await r.json();
          studies = data.studies || [];
          renderStudies();
        } catch {}
      };

      // Click-delegated handlers on the study list
      studyListEl?.addEventListener("click", async (e) => {
        const t = e.target;
        if (!(t instanceof HTMLElement)) return;

        if (t.dataset.editSlug) {
          const s = studies.find((x) => x.slug === t.dataset.editSlug);
          if (!s) return;
          studyForm.querySelector("[name='editingSlug']").value = s.slug;
          studyForm.querySelector("[name='title']").value = s.title || "";
          studyForm.querySelector("[name='design']").value = s.design || "Other";
          studyForm.querySelector("[name='stage']").value = s.stage || "concept";
          studyForm.querySelector("[name='slug']").value = s.slug || "";
          studyForm.querySelector("[name='leadName']").value = s.lead?.name || "";
          studyForm.querySelector("[name='leadEmail']").value = s.lead?.email || "";
          studyForm.querySelector("[name='description']").value = s.description || "";
          setMultiSelect(studyForm.querySelector("[name='sites']"), s.sites);
          setMultiSelect(studyForm.querySelector("[name='sitesWanted']"), s.sitesWanted);
          studyForm.querySelector("[name='milestones']").value = milestonesToText(s.milestones);
          studyForm.querySelector("[name='protocolUrl']").value = s.protocolUrl || "";
          studyForm.querySelector("[name='pmid']").value = s.pmid || "";
          const paperEl = studyForm.querySelector("[data-paper-input]");
          if (paperEl) paperEl.value = s.pmid || "";
          if (submitLabel) submitLabel.textContent = "Save changes";
          cancelEdit?.classList.remove("hidden");
          showStudyForm();
          return;
        }

        if (t.dataset.deleteSlug) {
          if (!confirm("Delete this study? This cannot be undone.")) return;
          const r = await fetch(`${WORKER_URL}/api/admin/studies`, {
            method: "POST", credentials: "include",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ action: "delete", slug: t.dataset.deleteSlug }),
          });
          if (r.ok) loadStudies();
          else alert("Couldn't delete.");
          return;
        }

        if (t.hasAttribute("data-interest-confirm") || t.hasAttribute("data-interest-reject")) {
          const action = t.hasAttribute("data-interest-confirm") ? "confirm" : "reject";
          const r = await fetch(`${WORKER_URL}/api/admin/studies/confirm-interest`, {
            method: "POST", credentials: "include",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              slug: t.dataset.slug,
              interestedEmail: t.dataset.email,
              site: t.dataset.site,
              action,
            }),
          });
          if (r.ok) loadStudies();
          else alert("Couldn't update interest.");
        }
      });

      studyListEl?.addEventListener("change", async (e) => {
        const t = e.target;
        if (!(t instanceof HTMLSelectElement) || !t.dataset.stageSelect) return;
        const r = await fetch(`${WORKER_URL}/api/admin/studies`, {
          method: "POST", credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            action: "move-stage",
            slug: t.dataset.slug,
            payload: { stage: t.value },
          }),
        });
        if (r.ok) loadStudies();
        else { alert("Couldn't update stage."); loadStudies(); }
      });

      // ── Member proposals (above the New Study form) ──
      const proposalsWrap  = document.querySelector("[data-proposals-wrap]");
      const proposalsRoot  = document.querySelector("[data-proposals]");
      const proposalsCount = document.querySelector("[data-proposals-count]");

      const renderProposals = (items) => {
        const open = items.filter((p) => p.status === "open");
        proposalsCount.textContent = open.length;
        if (open.length === 0) { proposalsWrap.classList.add("hidden"); return; }
        proposalsWrap.classList.remove("hidden");
        proposalsRoot.innerHTML = open.map((p) => {
          const sitesWanted = (p.sitesWanted || []).map((id) => `<span class="text-[10px] bg-slate-50 text-slate-500 border border-slate-200 px-1.5 py-0.5 rounded italic">want ${esc(siteLabel(id))}</span>`).join(" ");
          return `
            <article class="border border-brand-200 rounded-lg p-3 bg-brand-50/30">
              <p class="text-sm font-semibold text-slate-900">${esc(p.title)}</p>
              <p class="text-xs text-slate-500 mt-0.5">${esc(p.design || "Other")} · proposed by ${esc(p.proposedByName || p.proposedBy)} · ${esc(fmtDate(p.proposedAt))}${p.leadCandidate?.name ? ` · lead candidate: <strong>${esc(p.leadCandidate.name)}</strong>` : ""}</p>
              ${p.description ? `<p class="text-sm text-slate-700 leading-relaxed mt-1 whitespace-pre-line">${esc(p.description)}</p>` : ""}
              <p class="text-xs text-slate-700 leading-relaxed mt-1 whitespace-pre-line"><strong>Why:</strong> ${esc(p.reason)}</p>
              ${sitesWanted ? `<div class="mt-1 flex flex-wrap gap-1">${sitesWanted}</div>` : ""}
              <div class="mt-2 flex gap-2">
                <button type="button" data-promote-pid="${esc(p.id)}" data-payload="${esc(JSON.stringify(p))}"
                        class="text-xs font-semibold bg-brand-700 hover:bg-brand-800 text-white px-3 py-1.5 rounded transition">
                  Use as new study →
                </button>
                <button type="button" data-dismiss-pid="${esc(p.id)}" class="text-xs font-semibold text-slate-500 hover:text-rose-600 hover:underline">Dismiss</button>
              </div>
            </article>
          `;
        }).join("");
      };

      const loadProposals = async () => {
        try {
          const r = await fetch(`${WORKER_URL}/api/admin/studies/proposals`, { credentials: "include" });
          if (!r.ok) return;
          const data = await r.json();
          renderProposals(data.proposals || []);
        } catch {}
      };

      proposalsRoot?.addEventListener("click", async (e) => {
        const t = e.target;
        if (!(t instanceof HTMLElement)) return;
        if (t.dataset.dismissPid) {
          if (!confirm("Dismiss this proposal?")) return;
          await fetch(`${WORKER_URL}/api/admin/studies/proposals/action`, {
            method: "POST", credentials: "include",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ id: t.dataset.dismissPid, action: "dismiss" }),
          });
          loadProposals();
          return;
        }
        if (t.dataset.promotePid) {
          let payload;
          try { payload = JSON.parse(t.dataset.payload); } catch { return; }
          // Pre-fill the New Study form with proposal contents.
          studyForm.querySelector("[name='editingSlug']").value = "";
          studyForm.querySelector("[name='title']").value = payload.title || "";
          studyForm.querySelector("[name='design']").value = payload.design || "Other";
          studyForm.querySelector("[name='stage']").value = "concept";
          studyForm.querySelector("[name='slug']").value = "";
          studyForm.querySelector("[name='leadName']").value  = payload.leadCandidate?.name  || "";
          studyForm.querySelector("[name='leadEmail']").value = payload.leadCandidate?.email || "";
          studyForm.querySelector("[name='description']").value = payload.description || "";
          setMultiSelect(studyForm.querySelector("[name='sites']"), []);
          setMultiSelect(studyForm.querySelector("[name='sitesWanted']"), payload.sitesWanted || []);
          studyForm.querySelector("[name='milestones']").value = "";
          studyForm.querySelector("[name='protocolUrl']").value = "";
          studyForm.querySelector("[name='pmid']").value = "";
          const paperEl = studyForm.querySelector("[data-paper-input]");
          if (paperEl) paperEl.value = "";
          if (submitLabel) submitLabel.textContent = "Create study from proposal";
          cancelEdit?.classList.remove("hidden");
          studyForm.dataset.promotingProposalId = t.dataset.promotePid;
          showStudyForm();
        }
      });

      // ── Smart Paper input (for optional Published PMID) ──
      // Same helpers as before, repointed to the studies form.
      const paperInput  = studyForm?.querySelector("[data-paper-input]");
      const pmidHidden  = studyForm?.querySelector('input[name="pmid"]');
      const paperState  = studyForm?.querySelector("[data-paper-state]");

      const setPaperState = (html, cls = "text-slate-500") => {
        if (!paperState) return;
        paperState.className = "mt-2 text-xs " + cls;
        paperState.innerHTML = html;
      };
      const showSelectedPaper = (pmid, title, authors, journal, year) => {
        if (pmidHidden) pmidHidden.value = pmid;
        setPaperState(
          `<div class="bg-brand-50/60 border border-brand-200 rounded p-2">
             <p class="font-semibold text-brand-700">PMID ${pmid} · selected</p>
             ${title ? `<p class="mt-1 text-slate-800">${title.replace(/</g, "&lt;")}</p>` : ""}
             ${authors ? `<p class="mt-1 text-slate-600">${authors.replace(/</g, "&lt;")}</p>` : ""}
             ${journal || year ? `<p class="text-slate-500 italic">${(journal || "").replace(/</g, "&lt;")}${year ? ` · ${year}` : ""}</p>` : ""}
           </div>`,
          "mt-2 text-xs"
        );
      };
      const fetchSummary = async (pmid) => {
        try {
          const r = await fetch(`https://eutils.ncbi.nlm.nih.gov/entrez/eutils/esummary.fcgi?db=pubmed&id=${pmid}&retmode=json`);
          if (!r.ok) return null;
          const d = await r.json();
          const item = d?.result?.[pmid];
          if (!item) return null;
          return {
            title:   item.title || "",
            authors: (item.authors || []).slice(0, 3).map((a) => a.name).join(", ")
                     + ((item.authors || []).length > 3 ? ", et al." : ""),
            journal: item.fulljournalname || item.source || "",
            year:    String(item.pubdate || "").slice(0, 4),
          };
        } catch { return null; }
      };
      const searchByTerm = async (term) => {
        const url = `https://eutils.ncbi.nlm.nih.gov/entrez/eutils/esearch.fcgi?db=pubmed&term=${encodeURIComponent(term)}&retmode=json&retmax=5`;
        const r = await fetch(url);
        if (!r.ok) throw new Error("PubMed search failed");
        const d = await r.json();
        return d?.esearchresult?.idlist || [];
      };
      const parsePaperInput = (raw) => {
        const s = (raw || "").trim();
        if (!s) return { kind: "empty" };
        const urlM = s.match(/pubmed\.ncbi\.nlm\.nih\.gov\/(\d{6,9})/i);
        if (urlM) return { kind: "pmid", pmid: urlM[1] };
        if (/^\d{6,9}$/.test(s)) return { kind: "pmid", pmid: s };
        const doiM = s.match(/10\.\d{4,9}\/\S+/);
        if (doiM) return { kind: "doi", doi: doiM[0] };
        return { kind: "title", query: s };
      };
      const resolvePaper = async (raw) => {
        const parsed = parsePaperInput(raw);
        if (parsed.kind === "empty") {
          if (pmidHidden) pmidHidden.value = "";
          setPaperState("");
          return;
        }
        setPaperState("Looking up on PubMed…", "mt-2 text-xs text-slate-500 italic");
        try {
          let pmid = null;
          if (parsed.kind === "pmid") {
            pmid = parsed.pmid;
          } else if (parsed.kind === "doi") {
            const ids = await searchByTerm(`${parsed.doi}[doi]`);
            if (ids.length > 0) pmid = ids[0];
          } else if (parsed.kind === "title") {
            const ids = await searchByTerm(parsed.query);
            if (ids.length > 0) pmid = ids[0];
          }
          if (!pmid) {
            if (pmidHidden) pmidHidden.value = "";
            setPaperState("Couldn't find a PubMed match. Try pasting the PMID directly or a PubMed URL.", "mt-2 text-xs text-rose-700");
            return;
          }
          const meta = await fetchSummary(pmid);
          if (meta) {
            showSelectedPaper(pmid, meta.title, meta.authors, meta.journal, meta.year);
          } else {
            if (pmidHidden) pmidHidden.value = pmid;
            setPaperState(`PMID ${pmid} · selected (couldn't fetch title from PubMed)`, "mt-2 text-xs text-brand-700");
          }
        } catch (e) {
          if (pmidHidden) pmidHidden.value = "";
          setPaperState("PubMed lookup failed (network?). Try again or paste a PMID directly.", "mt-2 text-xs text-rose-700");
        }
      };
      let resolveTimer = null;
      paperInput?.addEventListener("input", () => {
        if (resolveTimer) clearTimeout(resolveTimer);
        resolveTimer = setTimeout(() => resolvePaper(paperInput.value), 400);
      });

      // ── Create / update study ──
      studyForm?.addEventListener("submit", async (e) => {
        e.preventDefault();
        const data = new FormData(studyForm);
        const editingSlug = String(data.get("editingSlug") || "").trim();
        const payload = {
          title: String(data.get("title") || ""),
          design: String(data.get("design") || "Other"),
          stage: String(data.get("stage") || "concept"),
          lead: {
            name:  String(data.get("leadName") || ""),
            email: String(data.get("leadEmail") || ""),
          },
          description: String(data.get("description") || ""),
          sites:       getMultiSelect(studyForm.querySelector("[name='sites']")),
          sitesWanted: getMultiSelect(studyForm.querySelector("[name='sitesWanted']")),
          milestones:  parseMilestones(String(data.get("milestones") || "")),
          protocolUrl: String(data.get("protocolUrl") || "").trim() || undefined,
          pmid:        String(data.get("pmid") || "").trim() || undefined,
        };
        const body = editingSlug
          ? { action: "update", slug: editingSlug, payload }
          : { action: "create", slug: String(data.get("slug") || "").trim(), payload };
        const btn = studyForm.querySelector("button[type='submit']");
        btn.disabled = true;
        setStudyMsg("Saving…");
        const r = await fetch(`${WORKER_URL}/api/admin/studies`, {
          method: "POST", credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(body),
        });
        const d = await r.json().catch(() => ({}));
        if (r.ok && d.ok) {
          // If this study was promoted from a member proposal, mark the
          // proposal as promoted so it disappears from the queue.
          const promotingId = studyForm.dataset.promotingProposalId;
          if (promotingId && !editingSlug) {
            const resolvedSlug = String(data.get("slug") || "").trim() || (payload.title || "")
              .toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "").slice(0, 60);
            await fetch(`${WORKER_URL}/api/admin/studies/proposals/action`, {
              method: "POST", credentials: "include",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ id: promotingId, action: "promote", resolvedSlug }),
            });
            delete studyForm.dataset.promotingProposalId;
            loadProposals();
          }
          setStudyMsg(editingSlug ? "Updated." : "Created.");
          resetForm();
          hideStudyForm();
          loadStudies();
        } else {
          setStudyMsg(d.error || "Failed.", true);
        }
        btn.disabled = false;
      });

      // ── Members ──
      const memberRows = document.querySelector("[data-member-rows]");
      // Sort order: super admins first, then plain admins, then everyone
      // else; within each tier alphabetical by display name (fallback to
      // email) so the list scans like a phone book.
      const memberRank = (m) => m.superAdmin ? 0 : (m.admin ? 1 : 2);
      const sortMembers = (arr) => [...arr].sort((a, b) => {
        const r = memberRank(a) - memberRank(b);
        if (r !== 0) return r;
        const an = (a.name || a.email || "").toLowerCase();
        const bn = (b.name || b.email || "").toLowerCase();
        return an.localeCompare(bn);
      });
      // Country dropdown options; same set as the "Add a member" form
      // above. Inlined here as a string template so each row can stamp it
      // with the current member's country pre-selected.
      const COUNTRY_OPTS = [
        { v: "",    l: "- select -" },
        { v: "TW",  l: "Taiwan (TW)" },
        { v: "KR",  l: "South Korea (KR)" },
        { v: "JP",  l: "Japan (JP)" },
        { v: "HK",  l: "Hong Kong (HK)" },
        { v: "AU",  l: "Australia (AU)" },
        { v: "CN",  l: "China (CN)" },
        { v: "DE",  l: "Germany (DE)" },
        { v: "FI",  l: "Finland (FI)" },
        { v: "FR",  l: "France (FR)" },
        { v: "GB",  l: "United Kingdom (GB)" },
        { v: "ID",  l: "Indonesia (ID)" },
        { v: "IN",  l: "India (IN)" },
        { v: "IT",  l: "Italy (IT)" },
        { v: "MO",  l: "Macau (MO)" },
        { v: "MY",  l: "Malaysia (MY)" },
        { v: "NL",  l: "Netherlands (NL)" },
        { v: "PH",  l: "Philippines (PH)" },
        { v: "SE",  l: "Sweden (SE)" },
        { v: "SG",  l: "Singapore (SG)" },
        { v: "TH",  l: "Thailand (TH)" },
        { v: "US",  l: "United States (US)" },
        { v: "VN",  l: "Vietnam (VN)" },
        { v: "OTHER", l: "Other" },
      ];
      const ROLE_OPTS = ["academic", "industry", "regulator", "clinician", "student", "other"];
      const countryOptionsFor = (current) =>
        COUNTRY_OPTS.map((o) => `<option value="${esc(o.v)}"${(current || "") === o.v ? " selected" : ""}>${esc(o.l)}</option>`).join("");
      const roleOptionsFor = (current) =>
        `<option value=""${!current ? " selected" : ""}>- select -</option>` +
        ROLE_OPTS.map((r) => `<option value="${r}"${(current || "") === r ? " selected" : ""}>${r}</option>`).join("");

      const renderMembers = (membersRaw) => {
        const members = sortMembers(membersRaw);
        document.querySelector("[data-member-count]").textContent = members.length;
        memberRows.innerHTML = members.map((m) => {
          // Badges: SUPER ADMIN (= super admin, enforced server-side, can't
          // be modified) takes precedence over ADMIN (= can review uploads,
          // manage members, etc.).
          const badge = m.superAdmin
            ? ' <span class="ml-1 text-[9px] uppercase tracking-widest font-bold text-white bg-brand-700 border border-brand-700 rounded px-1.5 py-0.5 align-middle">super admin</span>'
            : m.admin
              ? ' <span class="ml-1 text-[9px] uppercase tracking-widest font-bold text-brand-700 align-middle">admin</span>'
              : "";
          // Controls for super-admin rows stay disabled (so nobody can
          // accidentally demote them in the UI); just no visible label.
          const sa = m.superAdmin ? " disabled title=\"Cannot be modified\"" : "";
          return `
            <li class="hover:bg-slate-50">
              <details data-member-row data-email="${esc(m.email)}">
                <summary class="cursor-pointer list-none px-4 py-3 flex items-center justify-between gap-3">
                  <div class="min-w-0">
                    <p class="text-sm font-semibold text-slate-900 truncate">${esc(m.name || m.email)}${badge}</p>
                    <p class="text-xs text-slate-600 truncate">${[m.affiliation, m.country, m.role].filter(Boolean).map(esc).join(" · ") || esc(m.email)}</p>
                  </div>
                  <div class="flex items-center gap-2 shrink-0">
                    <label class="inline-flex items-center gap-1 text-xs text-slate-600 cursor-pointer ${m.superAdmin ? "opacity-50 cursor-not-allowed" : ""}" onclick="event.stopPropagation()">
                      <input type="checkbox" data-admin-email="${esc(m.email)}"${m.admin ? " checked" : ""}${sa}
                             class="rounded border-slate-400 text-brand-700 focus:ring-brand-500" />
                      admin
                    </label>
                    ${m.hasPassword ? '<span class="text-[10px] text-slate-500 italic" title="Has set a password">pwd</span>' : ""}
                    <select data-action-email="${esc(m.email)}" onclick="event.stopPropagation()"
                            class="text-xs border border-slate-300 rounded px-2 py-1 bg-white focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500">
                      <option value="">Actions ▾</option>
                      <option value="resend">✉ Resend sign-in link</option>
                      <option value="reset"${m.superAdmin ? ' disabled' : ''}>🔑 Reset password</option>
                      <option value="delete"${m.superAdmin ? ' disabled' : ''}>🗑 Delete member</option>
                    </select>
                    <span class="text-slate-400 text-xs select-none" aria-hidden="true">▾</span>
                  </div>
                </summary>
                <form data-edit-form data-email="${esc(m.email)}" class="px-4 pb-4 pt-1 grid sm:grid-cols-2 gap-3 bg-slate-50 border-t border-slate-100">
                  <p class="sm:col-span-2 text-[11px] text-slate-500">
                    <span class="uppercase tracking-widest font-semibold text-slate-600">Email</span>
                    <span class="ml-2 font-mono text-slate-700 break-all">${esc(m.email)}</span>
                  </p>
                  <label class="block sm:col-span-2">
                    <span class="text-[11px] uppercase tracking-widest text-brand-700 font-semibold">Name</span>
                    <input type="text" name="name" value="${esc(m.name || "")}" required
                           class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
                  </label>
                  <label class="block sm:col-span-2">
                    <span class="text-[11px] uppercase tracking-widest text-brand-700 font-semibold">Affiliation</span>
                    <input type="text" name="affiliation" value="${esc(m.affiliation || "")}"
                           class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
                  </label>
                  <label class="block">
                    <span class="text-[11px] uppercase tracking-widest text-brand-700 font-semibold">Country</span>
                    <select name="country" class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500">
                      ${countryOptionsFor(m.country)}
                    </select>
                  </label>
                  <label class="block">
                    <span class="text-[11px] uppercase tracking-widest text-brand-700 font-semibold">Role</span>
                    <select name="role" class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500">
                      ${roleOptionsFor(m.role)}
                    </select>
                  </label>
                  <div class="sm:col-span-2 flex items-center gap-3">
                    <button type="submit" class="inline-flex items-center gap-2 bg-brand-700 hover:bg-brand-800 text-white font-semibold px-3 py-1.5 rounded text-xs transition">
                      Save changes
                    </button>
                    <button type="button" data-cancel-edit class="text-xs font-semibold text-slate-500 hover:text-rose-600 hover:underline">
                      Cancel
                    </button>
                    <p data-edit-msg class="text-xs"></p>
                  </div>
                </form>
              </details>
            </li>
          `;
        }).join("");
      };

      const loadMembers = async () => {
        try {
          const r = await fetch(`${WORKER_URL}/api/admin/members`, { credentials: "include" });
          if (!r.ok) return;
          const data = await r.json();
          renderMembers(data.members || []);
        } catch {}
      };

      // Row-level change events:
      //   · admin checkbox toggles      → patch admin flag
      //   · Actions ▾ dropdown          → resend invite / reset pwd / delete
      // (Status select is gone; "removed" soft-flag is replaced by hard
      // delete via the Actions dropdown.)
      memberRows.addEventListener("change", async (e) => {
        const t = e.target;
        if (!(t instanceof HTMLElement)) return;

        // 1. admin flag toggle
        if (t instanceof HTMLInputElement && t.dataset.adminEmail) {
          const body = { email: t.dataset.adminEmail, admin: t.checked };
          const r = await fetch(`${WORKER_URL}/api/admin/members`, {
            method: "POST", credentials: "include",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(body),
          });
          if (!r.ok) {
            const d = await r.json().catch(() => ({}));
            alert(d.error || "Couldn't update.");
            loadMembers(); // revert UI
          }
          return;
        }

        // 2. Actions ▾ dropdown
        if (t instanceof HTMLSelectElement && t.dataset.actionEmail) {
          const action = t.value;
          const email  = t.dataset.actionEmail;
          // Reset the dropdown straight away so the user can re-pick the
          // same action again later (otherwise the selected option sticks
          // and re-picking does nothing).
          t.value = "";
          if (!action) return;

          t.disabled = true;
          try {
            if (action === "resend") {
              if (!confirm(`Send a fresh magic-link to ${email}?`)) return;
              const r = await fetch(`${WORKER_URL}/api/admin/members/resend-invite`, {
                method: "POST", credentials: "include",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ email }),
              });
              const d = await r.json().catch(() => ({}));
              if (r.ok && d.ok) alert(`Sent; magic-link is on its way to ${email}.`);
              else alert((d.error || "Couldn't send invite.") + " (HTTP " + r.status + ")");
              return;
            }

            if (action === "reset") {
              if (!confirm(`Clear ${email}'s password?\n\nThey'll need to sign in via magic-link and set a new one. (No effect if they never set one.)`)) return;
              const r = await fetch(`${WORKER_URL}/api/admin/members/reset-password`, {
                method: "POST", credentials: "include",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ email }),
              });
              const d = await r.json().catch(() => ({}));
              if (r.ok && d.ok) {
                alert(d.alreadyCleared ? `${email} already had no password; nothing to reset.` : `Password cleared for ${email}.`);
                loadMembers();
              } else {
                alert((d.error || "Couldn't reset password.") + " (HTTP " + r.status + ")");
              }
              return;
            }

            if (action === "delete") {
              if (!confirm(`Permanently remove ${email} from AsPEN members?\n\nThis can't be undone. Studies / template drafts they created stay, but they lose all access.`)) return;
              const r = await fetch(`${WORKER_URL}/api/admin/members/delete`, {
                method: "POST", credentials: "include",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ email }),
              });
              const d = await r.json().catch(() => ({}));
              if (r.ok && d.ok) loadMembers();
              else alert((d.error || "Couldn't delete member.") + " (HTTP " + r.status + ")");
              return;
            }
          } catch (err) {
            alert("Network error: " + String((err && err.message) || err));
          } finally {
            t.disabled = false;
          }
        }
      });

      // Per-row Edit form: name / affiliation / country / role inline
      // patch on any member. Worker accepts partial updates so we only
      // send what the form contains (admin flag + status are still
      // changed via the always-visible row controls above).
      memberRows.addEventListener("submit", async (e) => {
        const f = e.target;
        if (!(f instanceof HTMLFormElement) || !f.dataset.email) return;
        e.preventDefault();
        const data = new FormData(f);
        const body = {
          email:       f.dataset.email,
          name:        String(data.get("name") || "").trim(),
          affiliation: String(data.get("affiliation") || "").trim(),
          country:     String(data.get("country") || "").trim().toUpperCase(),
          role:        String(data.get("role") || "").trim(),
        };
        if (!body.name) {
          const msg = f.querySelector("[data-edit-msg]");
          if (msg) { msg.textContent = "Name required."; msg.className = "text-xs text-rose-700"; }
          return;
        }
        const btn = f.querySelector("button[type='submit']");
        btn.disabled = true;
        const msg = f.querySelector("[data-edit-msg]");
        if (msg) { msg.textContent = "Saving…"; msg.className = "text-xs text-slate-500 italic"; }
        try {
          const r = await fetch(`${WORKER_URL}/api/admin/members`, {
            method: "POST", credentials: "include",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(body),
          });
          const d = await r.json().catch(() => ({}));
          if (r.ok && d.ok) {
            if (msg) { msg.textContent = "Saved."; msg.className = "text-xs text-brand-700"; }
            // Reload to reflect new sort position + summary text.
            setTimeout(loadMembers, 350);
          } else {
            if (msg) { msg.textContent = (d.error || "Couldn't save") + " (HTTP " + r.status + ")"; msg.className = "text-xs text-rose-700"; }
          }
        } catch (err) {
          if (msg) { msg.textContent = "Network error: " + String((err && err.message) || err); msg.className = "text-xs text-rose-700"; }
        } finally {
          btn.disabled = false;
        }
      });

      // Cancel-edit collapses the row's details.
      memberRows.addEventListener("click", (e) => {
        const t = e.target;
        if (!(t instanceof HTMLElement)) return;
        if (t.hasAttribute("data-cancel-edit")) {
          const det = t.closest("details");
          if (det) det.open = false;
        }
      });

      const memberForm = document.querySelector("[data-member-form]");
      const memberMsg = memberForm?.querySelector("[data-member-msg]");
      const setMemberMsg = (msg, isError = false) => {
        if (!memberMsg) return;
        memberMsg.textContent = msg;
        memberMsg.classList.remove("hidden");
        memberMsg.classList.toggle("text-rose-700", isError);
      };
      memberForm?.addEventListener("submit", async (e) => {
        e.preventDefault();
        const data = new FormData(memberForm);
        const body = {
          email: String(data.get("email") || ""),
          name: String(data.get("name") || ""),
          affiliation: String(data.get("affiliation") || ""),
          country: String(data.get("country") || "").toUpperCase(),
          role: String(data.get("role") || ""),
          status: String(data.get("status") || "active"),
          admin: data.get("admin") === "on",
        };
        const btn = memberForm.querySelector("button[type='submit']");
        btn.disabled = true;
        setMemberMsg("Saving…");
        const r = await fetch(`${WORKER_URL}/api/admin/members`, {
          method: "POST", credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(body),
        });
        const d = await r.json().catch(() => ({}));
        if (r.ok && d.ok) {
          setMemberMsg("Added.");
          memberForm.reset();
          loadMembers();
        } else {
          setMemberMsg(d.error || "Failed.", true);
        }
        btn.disabled = false;
      });

      // ── Boot ──
      (async () => {
        try {
          const meR = await fetch(`${WORKER_URL}/api/me`, { credentials: "include" });
          if (!meR.ok) return setState("signed-out");
          const me = await meR.json();
          if (!me?.member?.isAdmin) return setState("forbidden");
          setState("ready");
          if (me.member.isSuperAdmin) {
            document.querySelectorAll("[data-superadmin-only]").forEach(el => el.classList.remove("hidden"));
          }
          loadUploads();
          loadDeleteRequests();
          if (me.member.isSuperAdmin) { loadStudies(); loadProposals(); }
          loadMembers();
        } catch { setState("signed-out"); }
      })();
    })();
  </script>
</BaseLayout>
