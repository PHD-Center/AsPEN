---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import { WORKER_URL } from "../../data/site-config";
import pubsRaw from "../../data/publications.json";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

type Pub = (typeof pubsRaw)[number];
const pubsByPmid: Record<string, {
  title: string;
  authors: string;
  journal: string;
  year: number;
  doi?: string;
  pmcid?: string;
  fulltext?: string;
  tags?: string[];
}> = {};
for (const p of pubsRaw as Pub[]) {
  if (!p.pmid) continue;
  pubsByPmid[p.pmid] = {
    title: p.title,
    authors: p.authors,
    journal: p.journal,
    year: p.year,
    doi: p.doi,
    pmcid: (p as { pmcid?: string }).pmcid,
    fulltext: (p as { fulltext?: string }).fulltext,
    tags: (p as { tags?: string[] }).tags,
  };
}

const EMOJIS = ["👍", "🤔", "📌", "⭐"];
---

<BaseLayout
  title="Reading group — AsPEN members"
  description="AsPEN paper-of-the-month picks: react, take notes, discuss."
>
  <PageHeader
    eyebrow="Members → Reading group"
    title="AsPEN reading group"
    description="Featured papers with chair commentary. React, jot down your own take, or join the discussion."
  />

  <section class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-10 space-y-10">
    <div class="flex items-center justify-between gap-3 flex-wrap text-sm">
      <a class="text-brand-700 hover:underline font-semibold" href={`${base}/members/`}>← Members area</a>
      <a class="text-brand-700 hover:underline font-semibold" href={`${base}/members/reading/notes`}>My reading notes →</a>
    </div>

    <div data-state="loading" class="text-sm text-slate-600 italic">Loading…</div>
    <div data-state="signed-out" class="hidden border border-slate-200 rounded-lg p-6 bg-slate-50">
      <p class="text-sm text-slate-700">You're not signed in. <a class="text-brand-700 hover:underline font-semibold" href={`${base}/members/login`}>Sign in →</a></p>
    </div>
    <div data-state="error" class="hidden border border-rose-300 bg-rose-50 rounded-lg p-6">
      <p class="text-sm text-rose-800" data-error-msg></p>
    </div>

    <div data-state="ready" class="hidden space-y-8">
      <!-- ── Suggest a paper (open to all members) ───────────── -->
      <details class="border border-slate-200 rounded-lg bg-white">
        <summary class="cursor-pointer select-none px-4 py-3 text-sm font-semibold text-brand-700 hover:bg-brand-50/40 rounded-lg">
          💡 Suggest a paper for the reading group
        </summary>
        <form data-suggest-form class="p-4 space-y-3 border-t border-slate-100">
          <p class="text-xs text-slate-500 leading-relaxed">
            Recommend an AsPEN-relevant paper for the AsPEN office to consider as a future pick. Goes to the chair's queue — no obligation to publish.
          </p>
          <label class="block">
            <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Paper title</span>
            <input type="text" name="title" required maxlength="500"
                   placeholder="e.g. Antipsychotic drugs and risk of falls and fractures"
                   class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
          </label>
          <label class="block">
            <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Why this paper?</span>
            <textarea name="reason" required rows="3" maxlength="1500"
                      placeholder="One paragraph: what it's about and why it matters for AsPEN members."
                      class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500"></textarea>
          </label>
          <label class="block">
            <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">PDF (optional)</span>
            <input type="file" name="file" accept=".pdf"
                   class="mt-1 block w-full text-xs file:mr-3 file:py-1.5 file:px-3 file:rounded file:border-0 file:text-xs file:font-semibold file:bg-brand-50 file:text-brand-700 hover:file:bg-brand-100" />
            <span class="block mt-1 text-[11px] text-slate-500">Attach the author-accepted manuscript or open-access PDF. Goes through the chair's review queue; if the paper becomes a pick, the file is downloadable from its card.</span>
          </label>
          <button type="submit" class="inline-flex items-center gap-2 bg-brand-700 hover:bg-brand-800 text-white font-semibold px-4 py-2 rounded text-sm transition disabled:opacity-60">
            Send suggestion
          </button>
          <p data-suggest-msg class="hidden text-sm bg-slate-50 border border-slate-200 rounded p-3" role="status" aria-live="polite"></p>
        </form>
      </details>

      <div data-empty class="hidden border border-slate-200 rounded-lg p-6 bg-slate-50">
        <p class="text-sm text-slate-700">No reading-group picks yet. The AsPEN office adds new picks here. Suggest one above — could be yours!</p>
      </div>

      <div data-picks class="space-y-6"></div>
    </div>
  </section>

  <script is:inline define:vars={{ WORKER_URL, BASE: base, pubsByPmid, EMOJIS }}>
    (() => {
      const setState = (name) => {
        document.querySelectorAll("[data-state]").forEach((el) => {
          el.classList.toggle("hidden", el.dataset.state !== name);
        });
      };
      const setError = (msg) => {
        document.querySelector("[data-error-msg]").textContent = msg;
        setState("error");
      };

      if (!WORKER_URL) return setError("Members area isn't enabled yet.");

      const esc = (s) => String(s ?? "").replace(/[&<>"']/g, (c) => ({
        "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;",
      }[c]));
      const fmtDate = (iso) => {
        try { return new Date(iso).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" }); }
        catch { return iso; }
      };
      const fmtRel = (iso) => {
        try {
          const diffMs = Date.now() - new Date(iso).getTime();
          const m = Math.floor(diffMs / 60000);
          if (m < 1) return "just now";
          if (m < 60) return m + " min ago";
          const h = Math.floor(m / 60);
          if (h < 24) return h + " h ago";
          const d = Math.floor(h / 24);
          if (d < 7) return d + " d ago";
          return new Date(iso).toLocaleDateString("en-US", { month: "short", day: "numeric" });
        } catch { return iso; }
      };

      let me = { email: "", name: "", isAdmin: false };
      let totalPicks = 0;     // populated by refresh() — used to compute issue numbers

      const renderPick = (pick, indexFromTop) => {
        // Issue numbering: latest pick is the highest number. Picks come in
        // newest-first, so issue = totalPicks - indexFromTop.
        const issueNum = totalPicks - indexFromTop;
        const isFeatured = indexFromTop === 0;

        const paper = pubsByPmid[pick.pmid];
        const fullTextLink = paper?.pmcid
          ? `https://pmc.ncbi.nlm.nih.gov/articles/${paper.pmcid}/`
          : paper?.fulltext;
        const tags = (paper?.tags || []).slice(0, 4);

        const reactions = pick.reactions || {};
        const reactionCounts = {};
        for (const emoji of EMOJIS) reactionCounts[emoji] = 0;
        let myReactions = new Set();
        for (const [email, emojis] of Object.entries(reactions)) {
          for (const e of emojis) {
            if (EMOJIS.includes(e)) reactionCounts[e]++;
            if (email.toLowerCase() === me.email.toLowerCase()) myReactions.add(e);
          }
        }

        const takes = pick.takes || {};
        const myTake = takes[me.email] || takes[me.email.toLowerCase()] || { text: "", share: false };
        const publicTakes = Object.entries(takes)
          .filter(([email, t]) => t.share && email.toLowerCase() !== me.email.toLowerCase());

        const comments = pick.comments || [];

        const reactionsHtml = EMOJIS.map((e) => {
          const isOn = myReactions.has(e);
          const count = reactionCounts[e];
          return `
            <button type="button" data-react data-pmid="${esc(pick.pmid)}" data-emoji="${esc(e)}"
                    class="inline-flex items-center gap-1 px-3 py-1.5 rounded-full border text-sm transition ${isOn ? "border-brand-500 bg-brand-50 text-brand-700" : "border-slate-200 bg-white text-slate-600 hover:border-slate-400"}">
              <span>${esc(e)}</span>
              ${count > 0 ? `<span class="text-[11px] tabular-nums font-semibold">${count}</span>` : ""}
            </button>
          `;
        }).join("");

        // Split commentary at first paragraph — first paragraph becomes a
        // pull-quote lede with drop-cap; the rest renders as normal body.
        const commentary = (pick.commentary || "").trim();
        const splitIdx = commentary.indexOf("\n\n");
        const lede = splitIdx > 0 ? commentary.slice(0, splitIdx).trim() : commentary;
        const restCommentary = splitIdx > 0 ? commentary.slice(splitIdx + 2).trim() : "";

        const tagsHtml = tags.length > 0
          ? `<div class="flex flex-wrap gap-1.5 mt-3">${tags.map((t) => `
              <span class="text-[10px] uppercase tracking-wider font-semibold text-brand-700 bg-brand-50 border border-brand-100 rounded-full px-2 py-0.5">${esc(t)}</span>
            `).join("")}</div>`
          : "";

        return `
          <article data-pick-pmid="${esc(pick.pmid)}"
                   class="bg-white border ${isFeatured ? "border-brand-500 shadow-lg" : "border-slate-200 shadow-sm"} rounded-3xl overflow-hidden">

            <!-- ── Magazine masthead ─────────────────────────────── -->
            <header class="px-6 sm:px-10 pt-8 pb-6 border-b border-slate-100 ${isFeatured ? "bg-gradient-to-br from-brand-50/60 to-white" : ""}">
              <div class="flex items-baseline justify-between gap-4 flex-wrap">
                <p class="text-[10px] uppercase tracking-[0.2em] font-bold text-brand-700">
                  ${isFeatured ? "Latest issue" : "Issue"} · No. ${issueNum}
                </p>
                <p class="text-[10px] uppercase tracking-widest text-slate-500 font-semibold">${esc(fmtDate(pick.pickedAt))}</p>
              </div>
              <h2 class="mt-4 font-serif text-2xl sm:text-3xl lg:text-4xl font-bold text-slate-900 leading-tight tracking-tight">
                ${esc(pick.headline)}
              </h2>
              ${tagsHtml}
            </header>

            <!-- ── Article body: 2-column on desktop (lede on left, paper rail on right) ─ -->
            <div class="grid gap-8 px-6 sm:px-10 py-8 lg:grid-cols-[1fr,18rem]">

              <!-- Editor's commentary -->
              <div class="space-y-4">
                ${lede ? `
                  <p class="font-serif text-lg sm:text-xl text-slate-800 leading-relaxed first-letter:font-bold first-letter:text-5xl first-letter:font-serif first-letter:text-brand-700 first-letter:float-left first-letter:mr-2 first-letter:mt-1 first-letter:leading-none whitespace-pre-line">${esc(lede)}</p>
                ` : ""}
                ${restCommentary ? `
                  <p class="text-[15px] text-slate-700 leading-relaxed whitespace-pre-line">${esc(restCommentary)}</p>
                ` : ""}
                ${!lede && !restCommentary ? `<p class="text-sm text-slate-400 italic">No editor's note for this issue.</p>` : ""}
              </div>

              <!-- Paper-of-issue side rail -->
              <aside class="lg:border-l lg:border-slate-100 lg:pl-8">
                <p class="text-[10px] uppercase tracking-[0.2em] text-brand-700 font-bold">The paper</p>
                ${paper ? `
                  <p class="mt-2 font-serif font-semibold text-slate-900 leading-snug text-[15px]">${esc(paper.title)}</p>
                  <p class="text-xs text-slate-600 mt-2 leading-relaxed">${esc(paper.authors)}</p>
                  <p class="text-xs text-slate-500 mt-1 italic">${esc(paper.journal)} · ${paper.year}</p>
                  <div class="mt-4 flex flex-col gap-2 text-xs">
                    ${fullTextLink ? `<a href="${esc(fullTextLink)}" target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-1.5 bg-brand-700 text-white font-semibold hover:bg-brand-800 px-3 py-2 rounded transition">📄 Open full text</a>` : ""}
                    ${paper.doi ? `<a class="text-brand-700 hover:underline truncate" target="_blank" rel="noopener" href="https://doi.org/${esc(paper.doi)}">DOI: ${esc(paper.doi)}</a>` : ""}
                    <a class="text-brand-700 hover:underline" target="_blank" rel="noopener" href="https://pubmed.ncbi.nlm.nih.gov/${esc(pick.pmid)}/">PubMed: ${esc(pick.pmid)}</a>
                  </div>
                ` : `
                  <p class="mt-2 text-sm text-slate-500 italic">Paper (PMID ${esc(pick.pmid)}) — bibliographic info not yet in publications.json.</p>
                `}
              </aside>

            </div>

            <!-- ── Engagement bar ─────────────────────────────────── -->
            <div class="px-6 sm:px-10 pb-8 space-y-6">

              <!-- Member-contributed PDF (per pick) -->
              <div class="pt-3 border-t border-slate-100">
                <p class="text-[10px] uppercase tracking-widest text-brand-600 font-semibold">Paper PDF</p>
                ${pick.paperPdf ? `
                  <div class="mt-2 flex flex-wrap items-center gap-2 text-xs">
                    <button type="button" data-download-paper data-path="${esc(pick.paperPdf)}"
                            class="inline-flex items-center gap-1 bg-brand-700 hover:bg-brand-800 text-white font-semibold px-3 py-1.5 rounded transition">
                      📄 Download PDF (members only)
                    </button>
                    ${me.isAdmin
                      ? `<button type="button" data-admin-delete-paper data-path="${esc(pick.paperPdf)}"
                            class="inline-flex items-center gap-1 text-rose-700 border border-rose-300 hover:bg-rose-50 font-semibold px-3 py-1.5 rounded transition">
                          Delete
                        </button>`
                      : `<button type="button" data-request-delete-paper data-path="${esc(pick.paperPdf)}"
                            class="inline-flex items-center gap-1 text-rose-700 border border-rose-300 hover:bg-rose-50 font-semibold px-3 py-1.5 rounded transition">
                          Request delete
                        </button>`}
                  </div>
                ` : `
                  <details class="mt-2">
                    <summary class="cursor-pointer text-xs text-brand-700 font-semibold hover:underline">📎 Contribute the PDF</summary>
                    <form data-paper-upload-form data-pmid="${esc(pick.pmid)}" class="mt-2 space-y-2">
                      <p class="text-[11px] text-slate-500 leading-relaxed">
                        Upload the author-accepted manuscript or open-access PDF. Goes through the chair's review queue; once approved, every member can download it from here.
                      </p>
                      <input type="file" name="file" required accept=".pdf"
                             class="block w-full text-xs file:mr-3 file:py-1.5 file:px-3 file:rounded file:border-0 file:text-xs file:font-semibold file:bg-brand-50 file:text-brand-700 hover:file:bg-brand-100" />
                      <textarea name="description" rows="2" maxlength="500"
                                placeholder="Optional: where it's from, any notes for the reviewer."
                                class="w-full border border-slate-300 rounded px-3 py-2 text-xs focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500"></textarea>
                      <div class="flex items-center justify-between gap-3 flex-wrap">
                        <button type="submit" class="text-xs font-semibold bg-brand-700 hover:bg-brand-800 text-white px-3 py-1.5 rounded transition disabled:opacity-60">
                          Submit for review
                        </button>
                        <p data-paper-upload-msg class="hidden text-xs"></p>
                      </div>
                    </form>
                  </details>
                `}
              </div>

              <!-- Reactions -->
              <div class="pt-3 border-t border-slate-100 flex flex-wrap items-center gap-2">
                <span class="text-[10px] uppercase tracking-widest text-brand-600 font-semibold mr-1">React</span>
                ${reactionsHtml}
              </div>

              <!-- My take -->
              <details class="pt-3 border-t border-slate-100" ${myTake.text ? "open" : ""}>
                <summary class="cursor-pointer text-[10px] uppercase tracking-widest text-brand-600 font-semibold hover:text-brand-700">
                  ${myTake.text ? "My take · saved" : "Jot a quick take (private by default)"}
                </summary>
                <form data-take-form data-pmid="${esc(pick.pmid)}" class="mt-3 space-y-2">
                  <textarea name="text" rows="2" maxlength="2000" placeholder="1-2 lines: what would you take from this for your own research?"
                            class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500">${esc(myTake.text)}</textarea>
                  <div class="flex items-center justify-between gap-3 flex-wrap">
                    <label class="inline-flex items-center gap-2 text-xs text-slate-600 cursor-pointer">
                      <input type="checkbox" name="share" ${myTake.share ? "checked" : ""}
                             class="rounded border-slate-400 text-brand-700 focus:ring-brand-500" />
                      Share with other members
                    </label>
                    <button type="submit" class="text-xs font-semibold bg-brand-700 hover:bg-brand-800 text-white px-3 py-1.5 rounded transition">Save take</button>
                  </div>
                  <p data-take-msg class="hidden text-xs"></p>
                </form>
              </details>

              <!-- Shared takes from other members -->
              ${publicTakes.length > 0 ? `
                <div class="pt-3 border-t border-slate-100">
                  <p class="text-[10px] uppercase tracking-widest text-brand-600 font-semibold mb-2">Other members' takes</p>
                  <div class="space-y-2">
                    ${publicTakes.map(([email, t]) => `
                      <div class="bg-brand-50/40 border border-brand-100 rounded p-2">
                        <p class="text-xs text-slate-700 leading-relaxed whitespace-pre-line">${esc(t.text)}</p>
                        <p class="text-[10px] text-slate-500 mt-1">— ${esc(email)} · ${esc(fmtRel(t.updatedAt))}</p>
                      </div>
                    `).join("")}
                  </div>
                </div>
              ` : ""}

              <!-- Comments -->
              <details class="pt-3 border-t border-slate-100" ${comments.length > 0 ? "open" : ""}>
                <summary class="cursor-pointer text-[10px] uppercase tracking-widest text-brand-600 font-semibold hover:text-brand-700">
                  Discuss · ${comments.length}
                </summary>
                <div class="mt-3 space-y-2">
                  ${comments.length > 0 ? comments.map((c) => `
                    <div class="border border-slate-200 rounded p-3 bg-white">
                      <p class="text-sm text-slate-800 leading-relaxed whitespace-pre-line">${esc(c.body)}</p>
                      <p class="text-[10px] text-slate-500 mt-1">${esc(c.name || c.author)} · ${esc(fmtRel(c.postedAt))}</p>
                    </div>
                  `).join("") : `<p class="text-xs text-slate-500 italic">No comments yet — start the discussion.</p>`}
                </div>
                <form data-comment-form data-pmid="${esc(pick.pmid)}" class="mt-3 space-y-2">
                  <textarea name="body" required rows="2" maxlength="3000"
                            placeholder="Add a thought…"
                            class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500"></textarea>
                  <div class="flex justify-end">
                    <button type="submit" class="text-xs font-semibold bg-brand-700 hover:bg-brand-800 text-white px-3 py-1.5 rounded transition">Post</button>
                  </div>
                  <p data-comment-msg class="hidden text-xs"></p>
                </form>
              </details>
            </div>
          </article>
        `;
      };

      const root = document.querySelector("[data-picks]");
      const emptyEl = document.querySelector("[data-empty]");

      const refresh = async () => {
        try {
          const meR = await fetch(`${WORKER_URL}/api/me`, { credentials: "include" });
          if (!meR.ok) return setState("signed-out");
          const meData = await meR.json();
          me = {
            email: (meData?.member?.email || "").toLowerCase(),
            name: meData?.member?.name || "",
            isAdmin: Boolean(meData?.member?.isAdmin),
          };

          const r = await fetch(`${WORKER_URL}/api/reading`, { credentials: "include" });
          if (r.status === 401) return setState("signed-out");
          if (!r.ok) return setError("Couldn't load the reading group (" + r.status + ").");
          const data = await r.json();
          const picks = (data && data.picks) || [];
          setState("ready");
          if (picks.length === 0) {
            emptyEl.classList.remove("hidden");
            root.innerHTML = "";
          } else {
            emptyEl.classList.add("hidden");
            totalPicks = picks.length;
            root.innerHTML = picks.map((p, i) => renderPick(p, i)).join("");
          }
        } catch {
          setError("Couldn't reach the auth service.");
        }
      };

      // ── Delegated event handlers ──

      // React click
      root?.addEventListener("click", async (e) => {
        const t = e.target?.closest?.("[data-react]");
        if (!t) return;
        const pmid = t.dataset.pmid;
        const emoji = t.dataset.emoji;
        t.disabled = true;
        try {
          await fetch(`${WORKER_URL}/api/reading/react`, {
            method: "POST", credentials: "include",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ pmid, emoji }),
          });
          await refresh();
        } finally { t.disabled = false; }
      });

      // Take submit
      root?.addEventListener("submit", async (e) => {
        const form = e.target;
        if (!form.matches?.("[data-take-form]")) return;
        e.preventDefault();
        const pmid = form.dataset.pmid;
        const data = new FormData(form);
        const text = String(data.get("text") || "");
        const share = data.get("share") === "on";
        const msgEl = form.querySelector("[data-take-msg]");
        msgEl.textContent = "Saving…"; msgEl.classList.remove("hidden");
        const r = await fetch(`${WORKER_URL}/api/reading/take`, {
          method: "POST", credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ pmid, text, share }),
        });
        const d = await r.json().catch(() => ({}));
        if (r.ok && d.ok) {
          msgEl.textContent = text ? "Saved." : "Removed.";
          setTimeout(refresh, 400);
        } else {
          msgEl.textContent = d.error || "Failed.";
          msgEl.classList.add("text-rose-700");
        }
      });

      // Comment submit
      root?.addEventListener("submit", async (e) => {
        const form = e.target;
        if (!form.matches?.("[data-comment-form]")) return;
        e.preventDefault();
        const pmid = form.dataset.pmid;
        const body = String(new FormData(form).get("body") || "").trim();
        if (!body) return;
        const msgEl = form.querySelector("[data-comment-msg]");
        msgEl.textContent = "Posting…"; msgEl.classList.remove("hidden");
        const r = await fetch(`${WORKER_URL}/api/reading/comment`, {
          method: "POST", credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ pmid, body }),
        });
        const d = await r.json().catch(() => ({}));
        if (r.ok && d.ok) {
          form.reset();
          msgEl.classList.add("hidden");
          setTimeout(refresh, 400);
        } else {
          msgEl.textContent = d.error || "Failed.";
          msgEl.classList.add("text-rose-700");
        }
      });

      // Download paper PDF (member-contributed) — fetch private blob → save as file.
      // Path is always under papers/, so /api/content/<path> is the right endpoint.
      root?.addEventListener("click", async (e) => {
        const btn = e.target?.closest?.("[data-download-paper]");
        if (!btn) return;
        const path = btn.dataset.path;
        btn.disabled = true;
        try {
          const r = await fetch(`${WORKER_URL}/api/content/${path}`, { credentials: "include" });
          if (!r.ok) return alert("Couldn't download (" + r.status + ").");
          const blob = await r.blob();
          const url = URL.createObjectURL(blob);
          const a = document.createElement("a");
          a.href = url;
          a.download = path.split("/").pop() || "paper.pdf";
          document.body.appendChild(a);
          a.click();
          a.remove();
          URL.revokeObjectURL(url);
        } finally { btn.disabled = false; }
      });

      // Admin: delete the contributed PDF
      root?.addEventListener("click", async (e) => {
        const btn = e.target?.closest?.("[data-admin-delete-paper]");
        if (!btn) return;
        const path = btn.dataset.path;
        if (!confirm(`Delete ${path}? This cannot be undone.`)) return;
        btn.disabled = true;
        const r = await fetch(`${WORKER_URL}/api/admin/delete-file`, {
          method: "POST", credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ path }),
        });
        const d = await r.json().catch(() => ({}));
        if (r.ok && d.ok) {
          setTimeout(refresh, 400);
        } else {
          alert(d.error || "Delete failed.");
          btn.disabled = false;
        }
      });

      // Member: request delete of the contributed PDF
      root?.addEventListener("click", async (e) => {
        const btn = e.target?.closest?.("[data-request-delete-paper]");
        if (!btn) return;
        const path = btn.dataset.path;
        const reason = prompt(`Request delete of ${path}? Briefly say why (the chair will see this):`);
        if (!reason || !reason.trim()) return;
        btn.disabled = true;
        const r = await fetch(`${WORKER_URL}/api/request-delete`, {
          method: "POST", credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ path, reason: reason.trim() }),
        });
        const d = await r.json().catch(() => ({}));
        if (r.ok && d.ok) {
          alert(d.deduped
            ? "You already requested delete for this — it's already in the chair's queue."
            : "Request sent. The chair will see this in the admin review queue.");
        } else {
          alert(d.error || "Couldn't send request.");
        }
        btn.disabled = false;
      });

      // Paper PDF upload (per pick — goes to review queue, lands at papers/pmid-{pmid}.pdf on approve)
      root?.addEventListener("submit", async (e) => {
        const form = e.target;
        if (!form.matches?.("[data-paper-upload-form]")) return;
        e.preventDefault();
        const pmid = form.dataset.pmid;
        const fd = new FormData(form);
        const file = fd.get("file");
        if (!(file instanceof File) || !file.name) return;
        const description = String(fd.get("description") || "");

        const out = new FormData();
        out.append("file", file);
        out.append("category", "reading");
        out.append("pmid", pmid);
        if (description) out.append("description", description);

        const msgEl = form.querySelector("[data-paper-upload-msg]");
        const btn = form.querySelector("button[type='submit']");
        btn.disabled = true;
        msgEl.textContent = "Uploading…"; msgEl.classList.remove("hidden", "text-rose-700");
        const r = await fetch(`${WORKER_URL}/api/upload`, {
          method: "POST", credentials: "include", body: out,
        });
        const d = await r.json().catch(() => ({}));
        if (r.ok && d.ok) {
          msgEl.textContent = "Sent. The chair will review and approve it.";
          form.reset();
        } else {
          msgEl.textContent = d.error || "Upload failed.";
          msgEl.classList.add("text-rose-700");
        }
        btn.disabled = false;
      });

      // Suggest a paper
      const suggestForm = document.querySelector("[data-suggest-form]");
      const suggestMsg = suggestForm?.querySelector("[data-suggest-msg]");
      const setSuggestMsg = (msg, isError = false) => {
        suggestMsg.textContent = msg;
        suggestMsg.classList.remove("hidden");
        suggestMsg.classList.toggle("text-rose-700", isError);
      };
      suggestForm?.addEventListener("submit", async (e) => {
        e.preventDefault();
        const data = new FormData(suggestForm);
        const title = String(data.get("title") || "").trim();
        const reason = String(data.get("reason") || "").trim();
        const file = data.get("file");
        const hasFile = file instanceof File && file.name && file.size > 0;

        const btn = suggestForm.querySelector("button[type='submit']");
        btn.disabled = true;
        setSuggestMsg("Sending…");

        // 1) Post the suggestion (JSON) — receive a suggestion id back.
        const r = await fetch(`${WORKER_URL}/api/reading/suggest`, {
          method: "POST", credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ title, reason }),
        });
        const d = await r.json().catch(() => ({}));
        if (!(r.ok && d.ok)) {
          setSuggestMsg(d.error || "Couldn't send.", true);
          btn.disabled = false;
          return;
        }
        const suggestionId = d.id;

        // 2) If a PDF was attached, send it to the upload queue tagged
        //    with the suggestion id. The chair will resolve the
        //    destination pmid when approving.
        if (hasFile && suggestionId) {
          setSuggestMsg("Suggestion sent. Uploading PDF…");
          const up = new FormData();
          up.append("file", file);
          up.append("category", "reading");
          up.append("suggestionId", suggestionId);
          if (reason) up.append("description", reason.slice(0, 500));
          const u = await fetch(`${WORKER_URL}/api/upload`, {
            method: "POST", credentials: "include", body: up,
          });
          const ud = await u.json().catch(() => ({}));
          if (!(u.ok && ud.ok)) {
            setSuggestMsg("Suggestion sent, but PDF upload failed: " + (ud.error || u.status), true);
            btn.disabled = false;
            return;
          }
          setSuggestMsg(d.deduped
            ? "You've already suggested this — PDF added to the queue."
            : "Suggestion + PDF sent. Both go to the chair's review queue.");
        } else {
          setSuggestMsg(d.deduped
            ? "You've already suggested this — it's already in the queue."
            : "Sent. Thanks — the chair will see this in the admin queue.");
        }
        suggestForm.reset();
        btn.disabled = false;
      });

      refresh();
    })();
  </script>
</BaseLayout>
