---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import { WORKER_URL } from "../../data/site-config";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const workerConfigured = WORKER_URL.length > 0;
---

<BaseLayout
  title="Members sign-in — AsPEN"
  description="Sign in to the AsPEN members area with an email magic-link."
>
  <PageHeader
    eyebrow="Members"
    title="Sign in"
    description="Members enter their email; a one-time link arrives in their inbox within a minute."
  />

  <section class="mx-auto max-w-xl px-4 sm:px-6 lg:px-8 py-12">
    {!workerConfigured && (
      <div class="mb-6 p-4 border border-amber-300 bg-amber-50 rounded-lg text-sm text-amber-900">
        <strong>Login is not yet configured.</strong> The auth worker
        URL hasn't been added to <code>src/data/site-config.ts</code>.
        Once it's set, this form will be live.
      </div>
    )}

    <form
      data-login-form
      class="border border-slate-200 rounded-2xl bg-white p-6 shadow-sm space-y-4"
    >
      <label class="block">
        <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Email</span>
        <input
          type="email"
          name="email"
          required
          autocomplete="email"
          placeholder="you@institution.edu"
          class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500"
        />
      </label>
      <button
        type="submit"
        class="w-full inline-flex items-center justify-center gap-2 bg-brand-700 hover:bg-brand-800 text-white font-semibold px-5 py-3 rounded-lg transition disabled:opacity-60 disabled:cursor-not-allowed"
      >
        Send me a sign-in link
      </button>
      <p
        data-status
        class="hidden text-sm leading-relaxed text-slate-700 bg-slate-50 border border-slate-200 rounded p-3"
        role="status"
        aria-live="polite"
      ></p>
    </form>

    <p class="mt-6 text-sm text-slate-600">
      Not a member yet? <a class="text-brand-700 hover:underline font-semibold" href={`${base}/membership/`}>Apply for membership</a>.
    </p>
  </section>

  <script is:inline define:vars={{ WORKER_URL, workerConfigured }}>
    (() => {
      const form = document.querySelector("[data-login-form]");
      const status = form?.querySelector("[data-status]");
      const button = form?.querySelector("button[type='submit']");
      if (!form || !status || !button) return;

      const show = (msg, isError = false) => {
        status.textContent = msg;
        status.classList.remove("hidden");
        status.classList.toggle("text-rose-700", isError);
        status.classList.toggle("border-rose-200", isError);
        status.classList.toggle("bg-rose-50", isError);
      };

      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        if (!workerConfigured) {
          show("Login isn't enabled yet — the worker URL hasn't been set.", true);
          return;
        }
        const data = new FormData(form);
        const email = String(data.get("email") || "").trim();
        if (!email) return;
        button.disabled = true;
        show("Sending…");
        try {
          const r = await fetch(`${WORKER_URL}/api/request-login`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ email }),
            credentials: "include",
          });
          if (!r.ok) throw new Error(String(r.status));
          show(
            "If that email is on the member list, a sign-in link is on its way — check your inbox in the next minute. The link is valid for 15 minutes.",
          );
          form.reset();
        } catch (err) {
          show("Couldn't reach the sign-in service — please try again in a moment.", true);
        } finally {
          button.disabled = false;
        }
      });
    })();
  </script>
</BaseLayout>
