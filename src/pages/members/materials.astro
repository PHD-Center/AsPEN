---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import { WORKER_URL } from "../../data/site-config";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<BaseLayout
  title="Working materials — AsPEN members"
  description="Study protocols, slides, analysis code shared within the AsPEN community."
>
  <PageHeader
    eyebrow="Members → Working materials"
    title="Protocols, slides, code"
    description="Internal materials shared by AsPEN study leads."
  />

  <section class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-10 space-y-6">
    <p class="text-sm">
      <a class="text-brand-700 hover:underline font-semibold" href={`${base}/members/`}>← Members area</a>
    </p>

    <div data-state="loading" class="text-sm text-slate-600 italic">
      Loading materials…
    </div>

    <div data-state="signed-out" class="hidden border border-slate-200 rounded-lg p-6 bg-slate-50">
      <p class="text-sm text-slate-700">
        You're not signed in. <a class="text-brand-700 hover:underline font-semibold" href={`${base}/members/login`}>Sign in →</a>
      </p>
    </div>

    <div data-state="empty" class="hidden border border-slate-200 rounded-lg p-6 bg-slate-50">
      <p class="text-sm text-slate-700">
        No materials yet. AsPEN study leads upload protocols, slide decks and analysis code as the working library grows.
      </p>
    </div>

    <div data-state="error" class="hidden border border-rose-300 bg-rose-50 rounded-lg p-6">
      <p class="text-sm text-rose-800" data-error-msg></p>
    </div>

    <div data-state="ready" class="hidden space-y-6">
      <!-- ── Upload (members can submit; admin must approve) ── -->
      <details data-upload-wrap class="hidden border border-slate-200 rounded-lg bg-white">
        <summary class="cursor-pointer select-none px-4 py-3 text-sm font-semibold text-brand-700 hover:bg-brand-50/40 rounded-lg">
          ＋ Contribute materials
        </summary>
        <form data-upload-form class="p-4 space-y-3 border-t border-slate-100">
          <p class="text-xs text-slate-500 leading-relaxed">
            Upload a protocol, slide deck, code archive, or other working material. Submissions go to a review queue.
          </p>
          <label class="block">
            <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">File</span>
            <input type="file" name="file" required class="mt-1 block w-full text-sm text-slate-700 file:mr-3 file:py-1.5 file:px-3 file:rounded file:border-0 file:text-xs file:font-semibold file:bg-brand-100 file:text-brand-700 hover:file:bg-brand-200" />
          </label>
          <label class="block">
            <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Subfolder</span>
            <select name="subfolder" class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500">
              <option value="protocols">Protocols</option>
              <option value="slides">Slides</option>
              <option value="code">Code</option>
              <option value="other">Other</option>
            </select>
          </label>
          <label class="block">
            <span class="text-xs uppercase tracking-widest text-brand-700 font-semibold">Description (optional)</span>
            <textarea name="description" rows="2" placeholder="e.g. PSSA protocol v3 for antipsychotic study"
                      class="mt-1 w-full border border-slate-300 rounded px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500"></textarea>
          </label>
          <button type="submit" class="inline-flex items-center gap-2 bg-brand-700 hover:bg-brand-800 text-white font-semibold px-4 py-2 rounded text-sm transition disabled:opacity-60">
            Submit for review
          </button>
          <p data-upload-msg class="hidden text-sm bg-slate-50 border border-slate-200 rounded p-3" role="status" aria-live="polite"></p>
        </form>
      </details>

      <div data-folders class="space-y-6"></div>
    </div>
  </section>

  <script is:inline define:vars={{ WORKER_URL, BASE: base }}>
    (() => {
      const setState = (name) => {
        document.querySelectorAll("[data-state]").forEach((el) => {
          el.classList.toggle("hidden", el.dataset.state !== name);
        });
      };
      const setError = (msg) => {
        document.querySelector("[data-error-msg]").textContent = msg;
        setState("error");
      };

      if (!WORKER_URL) {
        setError("Members area isn't enabled yet — the auth worker URL hasn't been set.");
        return;
      }

      const esc = (s) => String(s ?? "").replace(/[&<>"']/g, (c) => ({
        "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;",
      }[c]));

      const fmtSize = (n) => {
        if (!n) return "";
        if (n < 1024) return n + " B";
        if (n < 1024 * 1024) return (n / 1024).toFixed(1) + " KB";
        return (n / (1024 * 1024)).toFixed(1) + " MB";
      };

      const prettyFolder = (name) => {
        // protocols → Protocols, slides → Slides, code → Code
        return name.charAt(0).toUpperCase() + name.slice(1);
      };

      const downloadFile = async (path) => {
        try {
          const r = await fetch(`${WORKER_URL}/api/content/${path}`, { credentials: "include" });
          if (!r.ok) return alert("Couldn't download: " + r.status);
          const blob = await r.blob();
          const href = URL.createObjectURL(blob);
          const a = document.createElement("a");
          a.href = href;
          a.download = path.split("/").pop() || "file";
          document.body.appendChild(a);
          a.click();
          document.body.removeChild(a);
          setTimeout(() => URL.revokeObjectURL(href), 1000);
        } catch {
          alert("Download failed.");
        }
      };

      let isAdmin = false;

      const refresh = async () => {
        try {
          const meR = await fetch(`${WORKER_URL}/api/me`, { credentials: "include" });
          if (!meR.ok) return setState("signed-out");
          const meData = await meR.json();
          isAdmin = Boolean(meData?.member?.isAdmin);

          // Show the upload form for logged-in members
          document.querySelector("[data-upload-wrap]")?.classList.remove("hidden");

          const listR = await fetch(`${WORKER_URL}/api/list/materials`, { credentials: "include" });
          if (listR.status === 401) return setState("signed-out");
          if (!listR.ok) return setError("Couldn't load materials (" + listR.status + ").");

          const data = await listR.json();
          const files = (data && data.files) || [];
          if (files.length === 0) {
            document.querySelector("[data-folders]").innerHTML =
              '<p class="text-sm text-slate-500 italic text-center py-6 border border-slate-200 rounded-lg bg-white">No materials yet. Be the first to contribute one above.</p>';
            return setState("ready");
          }

          // Group by top-level subfolder under materials/ (e.g. materials/protocols/x.pdf → "protocols")
          // Items not in a subfolder go under "Other".
          const groups = {};
          for (const f of files) {
            const rel = f.path.replace(/^materials\//, "");
            const parts = rel.split("/");
            const folder = parts.length > 1 ? parts[0] : "Other";
            (groups[folder] ??= []).push(f);
          }
          // Sort folder keys alphabetically; files inside sorted by filename
          const folderNames = Object.keys(groups).sort();
          for (const k of folderNames) {
            groups[k].sort((a, b) => a.path.localeCompare(b.path));
          }

          const root = document.querySelector("[data-folders]");
          root.innerHTML = folderNames.map((folder) => `
            <div>
              <h3 class="text-xs uppercase tracking-widest text-brand-600 font-semibold mb-2">${esc(prettyFolder(folder))} · ${groups[folder].length}</h3>
              <ul class="divide-y divide-slate-200 border border-slate-200 rounded-lg bg-white">
                ${groups[folder].map((f) => {
                  const filename = f.path.split("/").pop();
                  const sub = f.path.replace(/^materials\//, "").replace(/\/[^/]*$/, "");
                  const sizeLabel = fmtSize(f.size);
                  return `
                    <li class="px-4 py-3 hover:bg-slate-50 flex items-center justify-between gap-3">
                      <div class="min-w-0 flex-1">
                        <p class="text-sm text-slate-800 truncate" title="${esc(filename)}">${esc(filename)}</p>
                        ${sub && sub !== folder ? `<p class="text-[10px] text-slate-500 truncate">${esc(sub)}/</p>` : ""}
                      </div>
                      <span class="flex items-center gap-3 shrink-0">
                        ${sizeLabel ? `<span class="text-xs text-slate-500 tabular-nums">${esc(sizeLabel)}</span>` : ""}
                        <button type="button" data-download="${esc(f.path)}" class="text-xs font-semibold text-brand-700 hover:underline">Download</button>
                        ${isAdmin
                          ? `<button type="button" data-admin-delete="${esc(f.path)}" class="text-xs font-semibold text-slate-500 hover:text-rose-600 hover:underline">Delete</button>`
                          : `<button type="button" data-request-delete="${esc(f.path)}" class="text-xs font-semibold text-slate-500 hover:text-rose-600 hover:underline">Request delete</button>`}
                      </span>
                    </li>
                  `;
                }).join("")}
              </ul>
            </div>
          `).join("");

          root.addEventListener("click", async (e) => {
            const t = e.target;
            if (!(t instanceof HTMLElement)) return;

            if (t.dataset.download) {
              downloadFile(t.dataset.download);
              return;
            }

            // Admin: direct delete after confirm
            if (t.dataset.adminDelete) {
              const path = t.dataset.adminDelete;
              const filename = path.split("/").pop();
              if (!confirm(`Delete "${filename}"?\n\nThis removes the file from the library and is irreversible.`)) return;
              t.disabled = true;
              const r = await fetch(`${WORKER_URL}/api/admin/delete-file`, {
                method: "POST", credentials: "include",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ path }),
              });
              const d = await r.json().catch(() => ({}));
              if (r.ok && d.ok) {
                refresh();
              } else {
                alert(d.error || "Couldn't delete.");
                t.disabled = false;
              }
              return;
            }

            // Member: request delete (prompt for reason)
            if (t.dataset.requestDelete) {
              const path = t.dataset.requestDelete;
              const filename = path.split("/").pop();
              const reason = prompt(`Request to delete "${filename}".\n\nWhy should this be removed? (Admin will see this.)`);
              if (!reason || !reason.trim()) return;
              t.disabled = true;
              const r = await fetch(`${WORKER_URL}/api/request-delete`, {
                method: "POST", credentials: "include",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ path, reason: reason.trim() }),
              });
              const d = await r.json().catch(() => ({}));
              if (r.ok && d.ok) {
                t.textContent = d.deduped ? "Already requested" : "Request sent ✓";
                t.classList.add("text-emerald-700");
                setTimeout(() => { t.textContent = "Request delete"; t.classList.remove("text-emerald-700"); t.disabled = false; }, 3000);
              } else {
                alert(d.error || "Couldn't send request.");
                t.disabled = false;
              }
              return;
            }
          });

          setState("ready");
        } catch (e) {
          setError("Couldn't reach the auth service.");
        }
      };

      // Upload form
      const uploadForm = document.querySelector("[data-upload-form]");
      const uploadMsg  = uploadForm?.querySelector("[data-upload-msg]");
      const setUploadMsg = (msg, isError = false) => {
        if (!uploadMsg) return;
        uploadMsg.textContent = msg;
        uploadMsg.classList.remove("hidden");
        uploadMsg.classList.toggle("text-rose-700", isError);
        uploadMsg.classList.toggle("border-rose-200", isError);
        uploadMsg.classList.toggle("bg-rose-50", isError);
      };
      uploadForm?.addEventListener("submit", async (e) => {
        e.preventDefault();
        const data = new FormData(uploadForm);
        data.set("category", "materials");
        const btn = uploadForm.querySelector("button[type='submit']");
        btn.disabled = true;
        setUploadMsg("Uploading…");
        try {
          const r = await fetch(`${WORKER_URL}/api/upload`, {
            method: "POST",
            body: data,
            credentials: "include",
          });
          const j = await r.json().catch(() => ({}));
          if (r.ok && j.ok) {
            setUploadMsg("Submitted. The AsPEN office will review and add it shortly.");
            uploadForm.reset();
          } else {
            setUploadMsg(j.error || "Upload failed.", true);
          }
        } catch {
          setUploadMsg("Couldn't reach the auth service.", true);
        } finally {
          btn.disabled = false;
        }
      });

      refresh();
    })();
  </script>
</BaseLayout>
