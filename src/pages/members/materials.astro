---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import { WORKER_URL } from "../../data/site-config";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<BaseLayout
  title="Working materials — AsPEN members"
  description="Study protocols, slides, analysis code shared within the AsPEN community."
>
  <PageHeader
    eyebrow="Members → Working materials"
    title="Protocols, slides, code"
    description="Internal materials shared by AsPEN study leads."
  />

  <section class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-10 space-y-6">
    <p class="text-sm">
      <a class="text-brand-700 hover:underline font-semibold" href={`${base}/members/`}>← Members area</a>
    </p>

    <div data-state="loading" class="text-sm text-slate-600 italic">
      Loading materials…
    </div>

    <div data-state="signed-out" class="hidden border border-slate-200 rounded-lg p-6 bg-slate-50">
      <p class="text-sm text-slate-700">
        You're not signed in. <a class="text-brand-700 hover:underline font-semibold" href={`${base}/members/login`}>Sign in →</a>
      </p>
    </div>

    <div data-state="empty" class="hidden border border-slate-200 rounded-lg p-6 bg-slate-50">
      <p class="text-sm text-slate-700">
        No materials yet. AsPEN study leads upload protocols, slide decks and analysis code as the working library grows.
      </p>
    </div>

    <div data-state="error" class="hidden border border-rose-300 bg-rose-50 rounded-lg p-6">
      <p class="text-sm text-rose-800" data-error-msg></p>
    </div>

    <div data-state="ready" class="hidden space-y-6" data-folders></div>
  </section>

  <script is:inline define:vars={{ WORKER_URL, BASE: base }}>
    (() => {
      const setState = (name) => {
        document.querySelectorAll("[data-state]").forEach((el) => {
          el.classList.toggle("hidden", el.dataset.state !== name);
        });
      };
      const setError = (msg) => {
        document.querySelector("[data-error-msg]").textContent = msg;
        setState("error");
      };

      if (!WORKER_URL) {
        setError("Members area isn't enabled yet — the auth worker URL hasn't been set.");
        return;
      }

      const esc = (s) => String(s ?? "").replace(/[&<>"']/g, (c) => ({
        "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;",
      }[c]));

      const fmtSize = (n) => {
        if (!n) return "";
        if (n < 1024) return n + " B";
        if (n < 1024 * 1024) return (n / 1024).toFixed(1) + " KB";
        return (n / (1024 * 1024)).toFixed(1) + " MB";
      };

      const prettyFolder = (name) => {
        // protocols → Protocols, slides → Slides, code → Code
        return name.charAt(0).toUpperCase() + name.slice(1);
      };

      const downloadFile = async (path) => {
        try {
          const r = await fetch(`${WORKER_URL}/api/content/${path}`, { credentials: "include" });
          if (!r.ok) return alert("Couldn't download: " + r.status);
          const blob = await r.blob();
          const href = URL.createObjectURL(blob);
          const a = document.createElement("a");
          a.href = href;
          a.download = path.split("/").pop() || "file";
          document.body.appendChild(a);
          a.click();
          document.body.removeChild(a);
          setTimeout(() => URL.revokeObjectURL(href), 1000);
        } catch {
          alert("Download failed.");
        }
      };

      const refresh = async () => {
        try {
          const meR = await fetch(`${WORKER_URL}/api/me`, { credentials: "include" });
          if (!meR.ok) return setState("signed-out");

          const listR = await fetch(`${WORKER_URL}/api/list/materials`, { credentials: "include" });
          if (listR.status === 401) return setState("signed-out");
          if (!listR.ok) return setError("Couldn't load materials (" + listR.status + ").");

          const data = await listR.json();
          const files = (data && data.files) || [];
          if (files.length === 0) return setState("empty");

          // Group by top-level subfolder under materials/ (e.g. materials/protocols/x.pdf → "protocols")
          // Items not in a subfolder go under "Other".
          const groups = {};
          for (const f of files) {
            const rel = f.path.replace(/^materials\//, "");
            const parts = rel.split("/");
            const folder = parts.length > 1 ? parts[0] : "Other";
            (groups[folder] ??= []).push(f);
          }
          // Sort folder keys alphabetically; files inside sorted by filename
          const folderNames = Object.keys(groups).sort();
          for (const k of folderNames) {
            groups[k].sort((a, b) => a.path.localeCompare(b.path));
          }

          const root = document.querySelector("[data-folders]");
          root.innerHTML = folderNames.map((folder) => `
            <div>
              <h3 class="text-xs uppercase tracking-widest text-brand-600 font-semibold mb-2">${esc(prettyFolder(folder))} · ${groups[folder].length}</h3>
              <ul class="divide-y divide-slate-200 border border-slate-200 rounded-lg bg-white">
                ${groups[folder].map((f) => {
                  const filename = f.path.split("/").pop();
                  const sub = f.path.replace(/^materials\//, "").replace(/\/[^/]*$/, "");
                  const sizeLabel = fmtSize(f.size);
                  return `
                    <li class="px-4 py-3 hover:bg-slate-50 flex items-center justify-between gap-3">
                      <div class="min-w-0 flex-1">
                        <p class="text-sm text-slate-800 truncate" title="${esc(filename)}">${esc(filename)}</p>
                        ${sub && sub !== folder ? `<p class="text-[10px] text-slate-500 truncate">${esc(sub)}/</p>` : ""}
                      </div>
                      <span class="flex items-center gap-3 shrink-0">
                        ${sizeLabel ? `<span class="text-xs text-slate-500 tabular-nums">${esc(sizeLabel)}</span>` : ""}
                        <button type="button" data-download="${esc(f.path)}" class="text-xs font-semibold text-brand-700 hover:underline">Download</button>
                      </span>
                    </li>
                  `;
                }).join("")}
              </ul>
            </div>
          `).join("");

          root.addEventListener("click", (e) => {
            const t = e.target;
            if (t instanceof HTMLElement && t.dataset.download) {
              downloadFile(t.dataset.download);
            }
          });

          setState("ready");
        } catch (e) {
          setError("Couldn't reach the auth service.");
        }
      };

      refresh();
    })();
  </script>
</BaseLayout>
