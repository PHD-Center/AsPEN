---
// Redirect: /propose/ was merged into /contact/#propose on 2026-05-25.
// Kept as a redirect shim so any external links / bookmarks still resolve.
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const dest = `${base}/contact/#propose`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="refresh" content={`0; url=${dest}`} />
    <link rel="canonical" href={dest} />
    <title>Redirecting to Contact — AsPEN</title>
  </head>
  <body>
    <p>This page moved. Redirecting to <a href={dest}>Contact → Propose a study</a>…</p>
    <script is:inline define:vars={{ dest }}>
      window.location.replace(dest);
    </script>
  </body>
</html>
