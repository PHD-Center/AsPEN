---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHeader from "../../../components/PageHeader.astro";
import PublicationCard from "../../../components/PublicationCard.astro";
import { getCollection } from "astro:content";
import pubsRaw from "../../../data/publications.json";

export async function getStaticPaths() {
  const items = await getCollection("spotlight");
  return items.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const fallback = `${base}/images/AsPenLogo.png`;
const img = entry.data.image ? `${base}/images/${entry.data.image}` : fallback;
const isFallback = !entry.data.image;
const d = entry.data.date;
const dateStr = d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });

// Resolve referenced PMIDs against publications.json so the citations
// render identically to /publications/.
type Pub = (typeof pubsRaw)[number];
const pubByPmid = new Map<string, Pub>((pubsRaw as Pub[]).filter((p) => p.pmid).map((p) => [p.pmid!, p]));
const referencedPmids = entry.data.references ?? [];
const references = referencedPmids
  .map((pmid) => pubByPmid.get(pmid))
  .filter((p): p is Pub => Boolean(p));
---

<BaseLayout title={`${entry.data.title} — Spotlight`} description={`Spotlight feature: ${entry.data.title}`}>
  <PageHeader
    eyebrow="Activities → Spotlight"
    title={entry.data.title}
    description={dateStr}
  />

  <article class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-10">
    <div class={`mb-10 aspect-[16/7] overflow-hidden rounded-xl border border-slate-200 ${isFallback ? "bg-brand-50 flex items-center justify-center p-6" : "bg-brand-50/60"}`}>
      <img
        src={img}
        alt=""
        class={isFallback ? "max-h-full w-auto opacity-80" : "w-full h-full object-cover"}
        style={isFallback ? "max-height: min(100%, 240px)" : undefined}
      />
    </div>

    <div class="article-prose">
      <Content />
    </div>

    {references.length > 0 && (
      <section class="mt-12 border-t border-slate-200 pt-6">
        <h2 class="text-xs uppercase tracking-widest text-brand-600 font-semibold mb-3">References</h2>
        <ul class="divide-y divide-slate-100 border border-slate-200 rounded-lg bg-white">
          {references.map((p) => <PublicationCard pub={p} />)}
        </ul>
      </section>
    )}

    <p class="mt-12">
      <a href={`${base}/activities/spotlight/`} class="text-brand-600 hover:underline">← Back to all Spotlight features</a>
    </p>
  </article>
</BaseLayout>
