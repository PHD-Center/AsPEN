---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import { getCollection } from "astro:content";

const activities = (await getCollection("activities")).sort(
  (a, b) => (a.data.order ?? 0) - (b.data.order ?? 0)
);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<BaseLayout title="AsPEN studies" description="Multi-country pharmacoepidemiologic studies conducted across AsPEN sites.">
  <PageHeader
    eyebrow="Activities → AsPEN studies"
    title="AsPEN studies"
    description="A growing portfolio of multi-country studies. Each study applies a common protocol locally at participating sites, then meta-analyses results."
  />

  <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12 grid gap-6 md:grid-cols-2">
    {activities.map((entry) => (
      <a
        href={`${base}/activities/studies/${entry.slug}/`}
        class="group block border border-slate-200 rounded-lg p-6 bg-white hover:shadow-md hover:border-brand-300 transition"
      >
        <p class="text-xs uppercase tracking-wide text-brand-600 font-semibold">{entry.data.year}</p>
        <h2 class="mt-1 text-xl font-bold text-slate-900 group-hover:text-brand-700 leading-snug">{entry.data.title}</h2>
        {entry.data.summary && (
          <p class="mt-3 text-sm text-slate-600 leading-relaxed">{entry.data.summary}</p>
        )}
        <div class="mt-4 flex flex-wrap items-center gap-3 text-xs">
          {entry.data.sites && entry.data.sites.length > 0 && (
            <span class="text-slate-500">{entry.data.sites.length} sites</span>
          )}
          {entry.data.methods && entry.data.methods.length > 0 && (
            <span class="text-slate-500">{entry.data.methods.length} methods</span>
          )}
          <span class="ml-auto text-brand-700 font-semibold group-hover:underline">Read more →</span>
        </div>
      </a>
    ))}
  </section>
</BaseLayout>
