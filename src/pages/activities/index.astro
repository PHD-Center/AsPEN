---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<BaseLayout title="Activities — AsPEN" description="AsPEN multi-national studies and Spotlight features.">
  <PageHeader
    eyebrow="Activities"
    title="Activities"
    description="Two streams of work: the AsPEN studies portfolio and Spotlight, where we highlight notable contributions from the network."
  />

  <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12 grid gap-6 md:grid-cols-2">
    <a href={`${base}/activities/aspen-studies/`} class="block group border border-slate-200 rounded-lg p-8 hover:border-brand-500 hover:shadow-md transition">
      <p class="text-xs uppercase tracking-widest text-brand-600 font-semibold">Stream 1</p>
      <h2 class="mt-2 text-2xl font-bold text-slate-900 group-hover:text-brand-700">AsPEN studies</h2>
      <p class="mt-3 text-slate-600">Multi-country pharmacoepidemiologic studies using common protocols applied locally to each site's data. Includes PSSA studies and the SCAN project.</p>
      <span class="inline-block mt-4 text-brand-600 font-semibold">View studies →</span>
    </a>
    <a href={`${base}/activities/spotlight/`} class="block group border border-slate-200 rounded-lg p-8 hover:border-brand-500 hover:shadow-md transition">
      <p class="text-xs uppercase tracking-widest text-brand-600 font-semibold">Stream 2</p>
      <h2 class="mt-2 text-2xl font-bold text-slate-900 group-hover:text-brand-700">Spotlight</h2>
      <p class="mt-3 text-slate-600">Short features highlighting an AsPEN-affiliated study, dataset, or methodologic contribution from the network.</p>
      <span class="inline-block mt-4 text-brand-600 font-semibold">View spotlights →</span>
    </a>
  </section>
</BaseLayout>
