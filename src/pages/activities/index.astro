---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<BaseLayout title="Activities — AsPEN" description="Spotlight features from across the AsPEN network.">
  <PageHeader
    eyebrow="Activities"
    title="Activities"
    description="Short features highlighting an AsPEN-affiliated study, dataset, or methodologic contribution from the network."
  />

  <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12">
    <a href={`${base}/activities/spotlight/`} class="block group border border-slate-200 rounded-lg p-8 hover:border-brand-500 hover:shadow-md transition max-w-2xl">
      <p class="text-xs uppercase tracking-widest text-brand-600 font-semibold">Spotlight</p>
      <h2 class="mt-2 text-2xl font-bold text-slate-900 group-hover:text-brand-700">Network spotlights</h2>
      <p class="mt-3 text-slate-600">Short features on AsPEN-affiliated studies, datasets, and methodologic contributions.</p>
      <span class="inline-block mt-4 text-brand-600 font-semibold">View spotlights →</span>
    </a>
  </section>
</BaseLayout>
